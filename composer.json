{
    "name": "islamwiki/islamwiki",
    "description": "A comprehensive Islamic knowledge platform built with modern PHP and Islamic design principles",
    "type": "project",
    "version": "0.0.50",
    "license": "AGPL-3.0-only",
    "keywords": [
        "islamic",
        "knowledge",
        "quran",
        "hadith",
        "islamic-sciences",
        "php",
        "framework"
    ],
    "authors": [
        {
            "name": "IslamWiki Team",
            "email": "dev@islam.wiki"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "guzzlehttp/psr7": "^2.7",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-server-handler": "^1.0",
        "twig/twig": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "erusev/parsedown": "^1.7",
        "phpdocumentor/graphviz": "^2.0",
        "phpdocumentor/phpdocumentor": "^3.4",
        "phpdocumentor/reflection-docblock": "^5.3",
        "phpdocumentor/type-resolver": "^1.7",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "IslamWiki\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
