{
    "name": "islamwiki/islamwiki",
    "description": "A comprehensive Islamic knowledge platform built with modern PHP and Islamic design principles",
    "type": "project",
    "version": "0.0.54",
    "license": "AGPL-3.0-only",
    "keywords": [
        "islamic",
        "knowledge",
        "quran",
        "hadith",
        "islamic-sciences",
        "php",
        "framework"
    ],
    "authors": [
        {
            "name": "IslamWiki Team",
            "email": "dev@islam.wiki"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "psr/log": "^1.1",
        "guzzlehttp/psr7": "^2.7",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0",
        "psr/http-server-handler": "^1.0",
        "guzzlehttp/guzzle": "^7.9",
        "twig/twig": "^3.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "erusev/parsedown": "^1.7"
    },
    "autoload": {
        "psr-4": {
            "IslamWiki\\": "src/",
            "IslamWiki\\Extensions\\": "extensions/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
