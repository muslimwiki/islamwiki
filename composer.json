{
    "name": "islamwiki/islamwiki",
    "description": "IslamWiki - Authentic Islamic Knowledge Platform",
    "type": "project",
    "version": "0.0.2.1",
    "license": "AGPL-3.0",
    "keywords": [
        "islamic",
        "wiki",
        "knowledge",
        "platform",
        "quran",
        "hadith",
        "islamic-sciences"
    ],
    "authors": [
        {
            "name": "IslamWiki Development Team",
            "email": "team@islamwiki.com",
            "homepage": "https://islamwiki.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "twig/twig": "^3.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "IslamWiki\\Core\\": "src/Core/",
            "IslamWiki\\Extensions\\": "extensions/",
            "IslamWiki\\Skins\\": "skins/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IslamWiki\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "stan": "phpstan analyse src",
        "organize": "php scripts/organize_project.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
