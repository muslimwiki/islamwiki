{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
        <!-- Page Header -->
        <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900">Discussion: {{ page.title }}</h1>
                    <p class="text-gray-600 mt-2">Talk page for {{ page.title }}</p>
                </div>
                <div class="flex space-x-3">
                    <a href="{{ page.url }}" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                        View Page
                    </a>
                    <a href="{{ page.url }}/edit" class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                        Edit Page
                    </a>
                </div>
            </div>
        </div>

        <!-- Discussion Thread -->
        {% if discussion %}
            <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
                <div class="flex items-start space-x-4">
                    <div class="flex-shrink-0">
                        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                            </svg>
                        </div>
                    </div>
                    
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center space-x-2 mb-2">
                            <span class="text-sm font-medium text-gray-900">{{ discussion.username }}</span>
                            {% if discussion.role %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    {{ discussion.role }}
                                </span>
                            {% endif %}
                            <span class="text-sm text-gray-500">{{ discussion.created_at|date('M j, Y g:i A') }}</span>
                        </div>
                        
                        <div class="prose max-w-none">
                            {{ discussion.content|raw }}
                        </div>
                        
                        <div class="mt-4 flex items-center space-x-4 text-sm text-gray-500">
                            <span class="italic">{{ discussion.signature|raw }}</span>
                            {% if discussion.edit_count > 0 %}
                                <span>(edited {{ discussion.edit_count }} time{{ discussion.edit_count > 1 ? 's' : '' }})</span>
                            {% endif %}
                        </div>
                        
                        <div class="mt-4 flex items-center space-x-2">
                            <button onclick="showReplyForm({{ discussion.id }})" class="text-sm text-green-600 hover:text-green-700 font-medium">
                                Reply
                            </button>
                            {% if user and (user.id == discussion.user_id or user.role in ['admin', 'editor']) %}
                                <a href="/discussion/{{ page.slug }}/edit/{{ discussion.id }}" class="text-sm text-blue-600 hover:text-blue-700 font-medium">
                                    Edit
                                </a>
                                <button onclick="deleteDiscussion({{ discussion.id }})" class="text-sm text-red-600 hover:text-red-700 font-medium">
                                    Delete
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        <!-- Replies -->
        {% if replies|length > 0 %}
            <div class="space-y-4">
                {% for reply in replies %}
                    <div class="bg-white rounded-lg shadow p-6 ml-8">
                        <div class="flex items-start space-x-4">
                            <div class="flex-shrink-0">
                                <div class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center">
                                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                    </svg>
                                </div>
                            </div>
                            
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center space-x-2 mb-2">
                                    <span class="text-sm font-medium text-gray-900">{{ reply.username }}</span>
                                    {% if reply.role %}
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                            {{ reply.role }}
                                        </span>
                                    {% endif %}
                                    <span class="text-sm text-gray-500">{{ reply.created_at|date('M j, Y g:i A') }}</span>
                                </div>
                                
                                <div class="prose max-w-none">
                                    {{ reply.content|raw }}
                                </div>
                                
                                <div class="mt-4 flex items-center space-x-4 text-sm text-gray-500">
                                    <span class="italic">{{ reply.signature|raw }}</span>
                                    {% if reply.edit_count > 0 %}
                                        <span>(edited {{ reply.edit_count }} time{{ reply.edit_count > 1 ? 's' : '' }})</span>
                                    {% endif %}
                                </div>
                                
                                <div class="mt-4 flex items-center space-x-2">
                                    <button onclick="showReplyForm({{ reply.id }})" class="text-sm text-green-600 hover:text-green-700 font-medium">
                                        Reply
                                    </button>
                                    {% if user and (user.id == reply.user_id or user.role in ['admin', 'editor']) %}
                                        <a href="/discussion/{{ page.slug }}/edit/{{ reply.id }}" class="text-sm text-blue-600 hover:text-blue-700 font-medium">
                                            Edit
                                        </a>
                                        <button onclick="deleteDiscussion({{ reply.id }})" class="text-sm text-red-600 hover:text-red-700 font-medium">
                                            Delete
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <!-- Reply Form -->
        <div id="reply-form" class="hidden bg-white rounded-lg shadow-lg p-6 mt-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Add Reply</h3>
            <form action="/discussion/{{ page.slug }}" method="POST" class="space-y-4">
                <input type="hidden" id="parent-id" name="parent_id" value="">
                
                <div>
                    <label for="content" class="block text-sm font-medium text-gray-700 mb-2">Your Reply</label>
                    <textarea id="content" name="content" rows="6" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-500" placeholder="Write your reply here..." required></textarea>
                    <p class="text-sm text-gray-500 mt-1">You can use basic formatting and links.</p>
                </div>
                
                <div class="flex justify-end space-x-3">
                    <button type="button" onclick="hideReplyForm()" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                        Cancel
                    </button>
                    <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                        Post Reply
                    </button>
                </div>
            </form>
        </div>

        <!-- Start Discussion Button -->
        {% if not discussion %}
            <div class="text-center py-8">
                <p class="text-gray-500 mb-4">No discussion has been started for this page yet.</p>
                <button onclick="showReplyForm(0)" class="px-6 py-3 bg-green-600 text-white rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                    Start Discussion
                </button>
            </div>
        {% endif %}
    </div>
</div>

<script>
function showReplyForm(parentId) {
    document.getElementById('parent-id').value = parentId;
    document.getElementById('reply-form').classList.remove('hidden');
    document.getElementById('content').focus();
    
    // Scroll to form
    document.getElementById('reply-form').scrollIntoView({ behavior: 'smooth' });
}

function hideReplyForm() {
    document.getElementById('reply-form').classList.add('hidden');
    document.getElementById('content').value = '';
    document.getElementById('parent-id').value = '';
}

function deleteDiscussion(discussionId) {
    if (confirm('Are you sure you want to delete this discussion? This action cannot be undone.')) {
        fetch(`/discussion/{{ page.slug }}/${discussionId}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to delete discussion');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred');
        });
    }
}
</script>
{% endblock %} 