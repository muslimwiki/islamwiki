{% extends 'layouts/app.twig' %}

{% block title %}{{ pageTitle }} - Wiki - IslamWiki{% endblock %}

{% block content %}
<div class="wiki-page-not-found-container">
    <div class="container mx-auto px-4 py-6">
        <!-- Page Header -->
        <div class="wiki-page-header mb-6">
            <div class="page-title-section">
                <h1 class="wiki-page-title">{{ pageTitle }}</h1>
                <p class="wiki-page-subtitle">From IslamWiki</p>
            </div>
            
            <!-- Action Buttons -->
            <div class="page-action-buttons">
                <a href="/wiki/create?title={{ pageName }}" class="btn btn-primary">
                    <span class="btn-icon">✏️</span>
                    Create
                </a>
                <a href="/wiki/{{ pageName }}/discussion" class="btn btn-secondary">
                    <span class="btn-icon">💬</span>
                    Discussion
                </a>
                <button class="btn btn-secondary" onclick="showPageOptions()">
                    <span class="btn-icon">⋯</span>
                </button>
            </div>
        </div>

        <!-- Page Not Found Message -->
        <div class="page-not-found-message">
            <div class="message-content">
                <p class="message-text">
                    There is currently no text in this page. You can 
                    <a href="/search?q={{ pageName }}&type=wiki">search for this page title in other pages</a>, 
                    <a href="/wiki/{{ pageName }}/history">search the related logs</a>, or 
                    <a href="/wiki/create?title={{ pageName }}" class="create-link">create this page</a>.
                </p>
            </div>
        </div>

        <!-- Quick Create Section -->
        <div class="quick-create-section">
            <div class="quick-create-header">
                <h3>Create "{{ pageTitle }}"</h3>
                <p>Start writing this page now</p>
            </div>
            
            <div class="quick-create-form">
                <form method="POST" action="/wiki/create">
                    <!-- CSRF Token -->
                    <input type="hidden" name="_token" value="{{ csrf_token() }}">
                    <input type="hidden" name="title" value="{{ pageTitle }}">
                    <input type="hidden" name="slug" value="{{ pageName }}">
                    
                    <!-- Quick Category Selection -->
                    <div class="form-group">
                        <label for="quick-category" class="form-label">Category</label>
                        <select id="quick-category" name="category_id" class="form-select" required>
                            <option value="">Select a category</option>
                            <option value="1">Quranic Studies</option>
                            <option value="2">Hadith Studies</option>
                            <option value="3">Islamic History</option>
                            <option value="4">Fiqh & Jurisprudence</option>
                            <option value="5">Islamic Practices</option>
                            <option value="6">Islamic Sciences</option>
                        </select>
                    </div>
                    
                    <!-- Quick Summary -->
                    <div class="form-group">
                        <label for="quick-summary" class="form-label">Brief Summary</label>
                        <textarea id="quick-summary" 
                                  name="summary" 
                                  class="form-textarea" 
                                  rows="2"
                                  placeholder="Brief description of what this page will cover"
                                  required></textarea>
                    </div>
                    
                    <!-- Content Editor with Toolbar -->
                    <div class="form-group">
                        <label for="quick-content" class="form-label">Page Content</label>
                        
                        <!-- Formatting Toolbar -->
                        <div class="formatting-toolbar">
                            <div class="toolbar-group">
                                <button type="button" class="toolbar-btn" data-format="bold" title="Bold (Ctrl+B)">
                                    <strong>B</strong>
                                </button>
                                <button type="button" class="toolbar-btn" data-format="italic" title="Italic (Ctrl+I)">
                                    <em>I</em>
                                </button>
                                <button type="button" class="toolbar-btn" data-format="heading" title="Heading">
                                    <strong>H</strong>
                                </button>
                            </div>
                            
                            <div class="toolbar-group">
                                <button type="button" class="toolbar-btn" data-format="list" title="Bullet List">
                                    • List
                                </button>
                                <button type="button" class="toolbar-btn" data-format="link" title="Insert Link">
                                    🔗
                                </button>
                                <button type="button" class="toolbar-btn" data-format="image" title="Insert Image">
                                    🖼️
                                </button>
                            </div>
                        </div>
                        
                        <!-- Content Editor -->
                        <textarea id="quick-content" 
                                  name="content" 
                                  class="form-textarea content-editor" 
                                  rows="15"
                                  placeholder="Write your page content here. Use the toolbar above for formatting."
                                  required></textarea>
                    </div>
                    
                    <!-- Form Actions -->
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <span class="btn-icon">📝</span>
                            Save Page
                        </button>
                        <a href="/wiki" class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<script>
// Formatting Toolbar Functionality
document.addEventListener('DOMContentLoaded', function() {
    const toolbar = document.querySelector('.formatting-toolbar');
    const contentEditor = document.getElementById('quick-content');
    
    if (!toolbar || !contentEditor) return;
    
    // Toolbar button click handlers
    toolbar.addEventListener('click', function(e) {
        if (e.target.classList.contains('toolbar-btn')) {
            e.preventDefault();
            const format = e.target.dataset.format;
            applyFormat(format);
        }
    });
    
    // Apply formatting based on button type
    function applyFormat(format) {
        const start = contentEditor.selectionStart;
        const end = contentEditor.selectionEnd;
        const selectedText = contentEditor.value.substring(start, end);
        let replacement = '';
        
        switch(format) {
            case 'bold':
                replacement = `**${selectedText}**`;
                break;
            case 'italic':
                replacement = `*${selectedText}*`;
                break;
            case 'heading':
                replacement = `# ${selectedText}`;
                break;
            case 'list':
                replacement = `- ${selectedText}`;
                break;
            case 'link':
                replacement = `[${selectedText}](url)`;
                break;
            case 'image':
                replacement = `![${selectedText}](image-url)`;
                break;
        }
        
        // Replace selected text
        contentEditor.value = contentEditor.value.substring(0, start) + replacement + contentEditor.value.substring(end);
        
        // Restore focus and selection
        contentEditor.focus();
        contentEditor.setSelectionRange(start, start + replacement.length);
    }
    
    // Auto-resize textarea
    contentEditor.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 400) + 'px';
    });
});

// Page options function
function showPageOptions() {
    // Implement page options menu
    alert('Page options menu - to be implemented');
}
</script>
{% endblock %} 