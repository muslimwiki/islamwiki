{% extends 'layouts/app.twig' %}

{# Read query parameters directly to ensure they're always available #}
{% set title = title|default('New Page') %}
{% set namespace = namespace|default('') %}
{% set content = content|default('') %}
{% set isNew = isNew|default(true) %}
{% set canEdit = canEdit|default(true) %}
{% set canDelete = canDelete|default(false) %}
{% set canLock = canLock|default(false) %}
{% set user = user|default(null) %}
{% set locale = locale|default('en') %}

{% block title %}Creating {{ title }} - IslamWiki{% endblock %}

{% block content %}
<div class="wiki-creation-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="section-container">
            <h1 class="page-title">
                Creating {{ title }}
            </h1>
            <p class="page-subtitle">
                From IslamWiki
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <div class="section-container">
        <!-- Instructions -->
        <div class="instructions-box">
            <div class="instructions-content">
                <div class="instructions-icon">
                    <i class="fas fa-info-circle"></i>
                </div>
                <div class="instructions-text">
                    <p>
                        You have followed a link to a page that does not exist yet. To create the page, start typing in the box below using <strong>Enhanced Markdown with Wiki Extensions</strong>. If you are here by mistake, click your browser's <strong>back</strong> button.
                    </p>
                </div>
            </div>
        </div>

        <!-- Create Form -->
        <div class="create-form-container">
            <form method="POST" action="/create" class="create-form">
                <input type="hidden" name="_token" value="">
                <input type="hidden" name="title" value="{{ title }}">
                <input type="hidden" name="namespace" value="{{ namespace }}">
                <input type="hidden" name="comment" value="Created page">
                <input type="hidden" name="content_format" value="markdown">

                <!-- Content Format Information -->
                <div class="format-selection">
                    <div class="format-info">
                        <div class="format-icon">
                            <i class="fas fa-markdown"></i>
                        </div>
                        <div class="format-details">
                            <h3>Enhanced Markdown with Wiki Extensions</h3>
                            <p>IslamWiki uses <strong>Markdown</strong> with powerful wiki extensions for internal links, templates, categories, and Islamic content features.</p>
                        </div>
                    </div>
                </div>

                <!-- Enhanced Markdown Toolbar -->
                <div class="formatting-toolbar" id="markdown-toolbar">
                    <!-- Top Row -->
                    <div class="toolbar-row">
                        <div class="toolbar-section">
                            <!-- Basic Markdown Formatting -->
                            <button type="button" class="toolbar-btn" data-action="bold" title="Bold">
                                <strong>B</strong>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="italic" title="Italic">
                                <em>I</em>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="heading" title="Heading">
                                <i class="fas fa-heading"></i>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="link" title="Insert Link">
                                <i class="fas fa-link"></i>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="image" title="Insert Image">
                                <i class="fas fa-image"></i>
                            </button>
                            <div class="toolbar-separator"></div>
                            <button type="button" class="toolbar-btn" data-action="list" title="List">
                                <i class="fas fa-list"></i>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="code" title="Code">
                                <i class="fas fa-code"></i>
                            </button>
                        </div>

                        <div class="toolbar-section">
                            <!-- Wiki Extensions Dropdown -->
                            <div class="toolbar-dropdown">
                                <button type="button" class="dropdown-btn" data-dropdown="wiki-extensions">
                                    Wiki Extensions <i class="fas fa-chevron-down"></i>
                                </button>
                                <div class="dropdown-content" id="wiki-extensions-dropdown">
                                    <div class="dropdown-section">
                                        <h4>Internal Links</h4>
                                        <button type="button" data-action="internal-link">[[Page Name]]</button>
                                        <button type="button" data-action="internal-link-display">[[Page|Display]]</button>
                                        <button type="button" data-action="category">[Category:Name]</button>
                                    </div>
                                    <div class="dropdown-section">
                                        <h4>Templates</h4>
                                        <button type="button" data-action="template">&#123;&#123;Template&#125;&#125;</button>
                                        <button type="button" data-action="infobox">&#123;&#123;Infobox&#125;&#125;</button>
                                        <button type="button" data-action="reference">&#123;&#123;Reference&#125;&#125;</button>
                                    </div>
                                    <div class="dropdown-section">
                                        <h4>References</h4>
                                        <button type="button" data-action="ref">Reference</button>
                                        <button type="button" data-action="ref-named">Named Reference</button>
                                    </div>
                                </div>
                            </div>

                            <!-- Islamic Content Extensions -->
                            <div class="toolbar-dropdown">
                                <button type="button" class="dropdown-btn" data-dropdown="islamic">
                                    Islamic Content <i class="fas fa-chevron-down"></i>
                                </button>
                                <div class="dropdown-content" id="islamic-dropdown">
                                    <div class="dropdown-section">
                                        <h4>Quran</h4>
                                        <button type="button" data-action="quran-template">&#123;&#123;Quran|surah=1|ayah=1-7&#125;&#125;</button>
                                        <button type="button" data-action="quran-verse">Quran Verse</button>
                                        <button type="button" data-action="quran-chapter">Quran Chapter</button>
                                    </div>
                                    <div class="dropdown-section">
                                        <h4>Hadith</h4>
                                        <button type="button" data-action="hadith-template">&#123;&#123;Hadith|book=Bukhari|number=1&#125;&#125;</button>
                                        <button type="button" data-action="hadith-chain">Hadith Chain</button>
                                        <button type="button" data-action="hadith-grade">Hadith Grade</button>
                                    </div>
                                    <div class="dropdown-section">
                                        <h4>Islamic Content</h4>
                                        <button type="button" data-action="scholar-template">&#123;&#123;Scholar|name=Ibn Sina&#125;&#125;</button>
                                        <button type="button" data-action="fatwa-template">&#123;&#123;Fatwa|scholar=Name&#125;&#125;</button>
                                        <button type="button" data-action="prayer-times">&#123;&#123;PrayerTimes&#125;&#125;</button>
                                    </div>
                                </div>
                            </div>

                            <!-- Special Characters -->
                            <div class="toolbar-dropdown">
                                <button type="button" class="dropdown-btn" data-dropdown="special">
                                    Special characters <i class="fas fa-chevron-down"></i>
                                </button>
                                <div class="dropdown-content" id="special-dropdown">
                                    <div class="special-chars-grid">
                                        <div class="char-category">
                                            <h4>Latin</h4>
                                            <div class="char-grid">
                                                <button type="button" data-char="Á">Á</button>
                                                <button type="button" data-char="á">á</button>
                                                <button type="button" data-char="À">À</button>
                                                <button type="button" data-char="à">à</button>
                                                <button type="button" data-char="Â">Â</button>
                                                <button type="button" data-char="â">â</button>
                                                <button type="button" data-char="Ä">Ä</button>
                                                <button type="button" data-char="ä">ä</button>
                                                <button type="button" data-char="Ã">Ã</button>
                                                <button type="button" data-char="ã">ã</button>
                                            </div>
                                        </div>
                                        <div class="char-category">
                                            <h4>Symbols</h4>
                                            <div class="char-grid">
                                                <button type="button" data-char="©">©</button>
                                                <button type="button" data-char="®">®</button>
                                                <button type="button" data-char="™">™</button>
                                                <button type="button" data-char="±">±</button>
                                                <button type="button" data-char="×">×</button>
                                                <button type="button" data-char="÷">÷</button>
                                                <button type="button" data-char="≤">≤</button>
                                                <button type="button" data-char="≥">≥</button>
                                                <button type="button" data-char="≠">≠</button>
                                                <button type="button" data-char="≈">≈</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Help -->
                            <div class="toolbar-dropdown">
                                <button type="button" class="dropdown-btn" data-dropdown="help">
                                    Help <i class="fas fa-chevron-down"></i>
                                </button>
                                <div class="dropdown-content" id="help-dropdown">
                                    <div class="help-content">
                                        <h4>Enhanced Markdown Examples</h4>
                                        <div class="help-example">
                                            <strong>Bold:</strong> <code>**text**</code>
                                        </div>
                                        <div class="help-example">
                                            <strong>Italic:</strong> <code>*text*</code>
                                        </div>
                                        <div class="help-example">
                                            <strong>Heading:</strong> <code># Heading</code>
                                        </div>
                                        <div class="help-example">
                                            <strong>List:</strong> <code>- Item</code>
                                        </div>
                                        <div class="help-example">
                                            <strong>Internal Link:</strong> <code>[[Page Name]]</code>
                                        </div>
                                        <div class="help-example">
                                            <strong>Template:</strong> <code>&#123;&#123;Template|param=value&#125;&#125;</code>
                                        </div>
                                        <div class="help-example">
                                            <strong>Quran:</strong> <code>&#123;&#123;Quran|surah=1|ayah=1-7&#125;&#125;</code>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="toolbar-section">
                            <!-- Insert Dropdown -->
                            <div class="toolbar-dropdown">
                                <button type="button" class="dropdown-btn" data-dropdown="insert">
                                    Insert <i class="fas fa-chevron-down"></i>
                                </button>
                                <div class="dropdown-content" id="insert-dropdown">
                                    <button type="button" data-action="gallery">Picture Gallery</button>
                                    <button type="button" data-action="table">Table</button>
                                    <button type="button" data-action="redirect">Redirect</button>
                                </div>
                            </div>

                            <!-- Search and Replace -->
                            <button type="button" class="toolbar-btn" data-action="search" title="Search and Replace">
                                <i class="fas fa-search"></i>
                            </button>

                            <!-- Preview Toggle -->
                            <button type="button" class="toolbar-btn preview-btn" data-action="preview" title="Toggle Preview">
                                <i class="fas fa-eye"></i> Preview
                            </button>

                            <!-- Three Dots Menu -->
                            <div class="toolbar-dropdown">
                                <button type="button" class="dropdown-btn" data-dropdown="more-options">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <div class="dropdown-content" id="more-options-dropdown">
                                    <button type="button" data-action="protect">Protect</button>
                                    <button type="button" data-action="watch">Watch</button>
                                    <button type="button" data-action="tools">Tools</button>
                                    <button type="button" data-action="what-links">What Links Here</button>
                                    <button type="button" data-action="page-info">Page Information</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Row -->
                    <div class="toolbar-row">
                        <div class="toolbar-section">
                            <!-- Additional Formatting -->
                            <button type="button" class="toolbar-btn" data-action="indent-left" title="Decrease Indent">
                                <i class="fas fa-outdent"></i>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="indent-right" title="Increase Indent">
                                <i class="fas fa-indent"></i>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="superscript" title="Superscript">
                                <i class="fas fa-superscript"></i>
                            </button>
                            <button type="button" class="toolbar-btn" data-action="subscript" title="Subscript">
                                <i class="fas fa-subscript"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Content Editor with Preview Toggle -->
                <div class="editor-container">
                    <div class="editor-section">
                        <label for="content" class="form-label">
                            Page Content
                        </label>
                        <textarea id="content"
                                  name="content"
                                  rows="25"
                                  required
                                  class="form-textarea"
                                  placeholder="Enter your page content using Enhanced Markdown with wiki extensions...">{{ content }}</textarea>
                    </div>

                    <!-- Preview Section (Hidden by default) -->
                    <div class="preview-section" id="preview-section" style="display: none;">
                        <div class="preview-header">
                            <h4>Live Preview</h4>
                            <button type="button" class="close-preview" data-action="close-preview">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div class="preview-content" id="preview-content">
                            <!-- Preview content will be rendered here -->
                        </div>
                    </div>
                </div>

                <!-- Summary -->
                <div class="form-group">
                    <label for="summary" class="form-label">
                        Summary
                    </label>
                    <textarea id="summary"
                              name="summary"
                              rows="3"
                              class="form-textarea summary-textarea"
                              placeholder="Brief description of your changes..."></textarea>
                </div>

                <!-- Watch Page -->
                <div class="form-group checkbox-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="watch" value="1" class="form-checkbox">
                        <span class="checkbox-text">Watch this page</span>
                    </label>
                </div>

                <!-- Contribution Notice -->
                <div class="contribution-notice">
                    <p>
                        Please note that all contributions to IslamWiki are considered to be released under the GNU Affero General Public License v3.0 (AGPL-3.0). If you do not want your writing to be edited and redistributed, then do not submit it here. You are also promising us that you wrote this yourself, or copied it from a public domain or similar free resource. Do not submit copyrighted work without permission!
                    </p>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="button"
                            onclick="window.history.back()"
                            class="btn btn-secondary">
                        Cancel
                    </button>
                    <button type="button"
                            class="btn btn-secondary"
                            id="show-preview-btn">
                        Show preview
                    </button>
                    <button type="button"
                            class="btn btn-secondary">
                        Show changes
                    </button>
                    <button type="button"
                            class="btn btn-secondary">
                        Save draft
                    </button>
                    <button type="submit"
                            class="btn btn-primary">
                        Save page
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<script src="/assets/js/enhanced-markdown-toolbar.js"></script>
{% endblock %} 