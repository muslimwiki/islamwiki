{% extends "layouts/app.twig" %}

{% block title %}Community - IslamWiki{% endblock %}

{% block content %}
<div class="main-content-wrapper">
    <div class="main-content">
        <div class="community-header">
            <h1>🌍 Islamic Community</h1>
            <p>Connect with fellow Muslims, share knowledge, and grow together in faith.</p>
        </div>
        
        <div class="community-sections">
            <div class="community-section">
                <h2>👥 Community Features</h2>
                <div class="feature-grid">
                    <div class="feature-card">
                        <i class="fas fa-users"></i>
                        <h3>User Profiles</h3>
                        <p>Create your profile and connect with other community members.</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-comments"></i>
                        <h3>Discussions</h3>
                        <p>Participate in meaningful discussions about Islamic topics.</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-share-alt"></i>
                        <h3>Knowledge Sharing</h3>
                        <p>Share your knowledge and learn from others.</p>
                    </div>
                </div>
            </div>
            
            <div class="community-section">
                <h2>📚 Learning Together</h2>
                <p>Join study groups, participate in online courses, and engage in collaborative learning experiences.</p>
            </div>
            
            <div class="community-section">
                <h2>🤝 Get Involved</h2>
                <p>This community section is under development. Check back soon for more features!</p>
            </div>
        </div>
    </div>
</div>
{% endblock %} 