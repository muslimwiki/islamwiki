{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block body_class %}profile-edit-page{% endblock %}

{% block content %}
<div class="profile-edit-container">
    <div class="container">
        <!-- Edit Profile Header -->
        <div class="edit-header">
            <h1 class="edit-title">✏️ Edit Profile</h1>
            <p class="edit-subtitle">Update your personal information and preferences</p>
        </div>

        <!-- Edit Profile Form -->
        <div class="edit-form">
            <form id="editProfileForm" method="POST" action="/profile">
                <div class="form-sections">
                    <!-- Personal Information Section -->
                    <div class="form-section">
                        <h2 class="section-title">👤 Personal Information</h2>
                        
                        <div class="form-group">
                            <label class="form-label">Display Name</label>
                            <input type="text" class="form-control" name="display_name" 
                                   value="{{ user.display_name ?? '' }}" 
                                   placeholder="Enter your display name">
                            <small class="form-help">This name will be shown on your profile</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" name="email" 
                                   value="{{ user.email ?? '' }}" 
                                   placeholder="Enter your email address">
                            <small class="form-help">Your email address for notifications</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" name="bio" rows="4" 
                                      placeholder="Tell others about yourself...">{{ user.bio ?? '' }}</textarea>
                            <small class="form-help">A short description about yourself (max 500 characters)</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Location</label>
                            <input type="text" class="form-control" name="location" 
                                   value="{{ user.location ?? '' }}" 
                                   placeholder="City, Country">
                            <small class="form-help">Optional: Share your general location</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Website</label>
                            <input type="url" class="form-control" name="website" 
                                   value="{{ user.website ?? '' }}" 
                                   placeholder="https://your-website.com">
                            <small class="form-help">Optional: Link to your personal website</small>
                        </div>
                    </div>

                    <!-- Appearance Settings Section -->
                    <div class="form-section">
                        <h2 class="section-title">🎨 Appearance Settings</h2>
                        
                        <div class="form-group">
                            <label class="form-label">Active Skin</label>
                            <select class="form-control" name="skin">
                                <option value="Bismillah" {% if userSettings.skin == 'Bismillah' %}selected{% endif %}>Bismillah</option>
                                <option value="Muslim" {% if userSettings.skin == 'Muslim' %}selected{% endif %}>Muslim</option>
                            </select>
                            <small class="form-help">Choose the visual theme for your experience</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Theme</label>
                            <select class="form-control" name="theme">
                                <option value="light" {% if userSettings.theme == 'light' %}selected{% endif %}>Light</option>
                                <option value="dark" {% if userSettings.theme == 'dark' %}selected{% endif %}>Dark</option>
                                <option value="auto" {% if userSettings.theme == 'auto' %}selected{% endif %}>Auto</option>
                            </select>
                            <small class="form-help">Choose your preferred color scheme</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Language</label>
                            <select class="form-control" name="language">
                                <option value="en" {% if userSettings.language == 'en' %}selected{% endif %}>English</option>
                                <option value="ar" {% if userSettings.language == 'ar' %}selected{% endif %}>العربية</option>
                                <option value="ur" {% if userSettings.language == 'ur' %}selected{% endif %}>اردو</option>
                                <option value="tr" {% if userSettings.language == 'tr' %}selected{% endif %}>Türkçe</option>
                            </select>
                            <small class="form-help">Choose your preferred language</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Timezone</label>
                            <select class="form-control" name="timezone">
                                <option value="UTC" {% if userSettings.timezone == 'UTC' %}selected{% endif %}>UTC</option>
                                <option value="America/New_York" {% if userSettings.timezone == 'America/New_York' %}selected{% endif %}>Eastern Time</option>
                                <option value="America/Los_Angeles" {% if userSettings.timezone == 'America/Los_Angeles' %}selected{% endif %}>Pacific Time</option>
                                <option value="Europe/London" {% if userSettings.timezone == 'Europe/London' %}selected{% endif %}>London</option>
                                <option value="Europe/Paris" {% if userSettings.timezone == 'Europe/Paris' %}selected{% endif %}>Paris</option>
                                <option value="Asia/Dubai" {% if userSettings.timezone == 'Asia/Dubai' %}selected{% endif %}>Dubai</option>
                                <option value="Asia/Karachi" {% if userSettings.timezone == 'Asia/Karachi' %}selected{% endif %}>Karachi</option>
                                <option value="Asia/Istanbul" {% if userSettings.timezone == 'Asia/Istanbul' %}selected{% endif %}>Istanbul</option>
                            </select>
                            <small class="form-help">Choose your timezone for accurate timestamps</small>
                        </div>
                    </div>

                    <!-- Privacy Settings Section -->
                    <div class="form-section">
                        <h2 class="section-title">🔒 Privacy Settings</h2>
                        
                        <div class="form-group">
                            <label class="form-label">Profile Visibility</label>
                            <select class="form-control" name="privacy_level">
                                <option value="public" {% if userSettings.privacy_level == 'public' %}selected{% endif %}>Public</option>
                                <option value="registered" {% if userSettings.privacy_level == 'registered' %}selected{% endif %}>Registered Users Only</option>
                                <option value="private" {% if userSettings.privacy_level == 'private' %}selected{% endif %}>Private</option>
                            </select>
                            <small class="form-help">Control who can view your profile</small>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">Notification Frequency</label>
                            <select class="form-control" name="notifications">
                                <option value="immediate" {% if userSettings.notifications == 'immediate' %}selected{% endif %}>Immediate</option>
                                <option value="hourly" {% if userSettings.notifications == 'hourly' %}selected{% endif %}>Hourly Digest</option>
                                <option value="daily" {% if userSettings.notifications == 'daily' %}selected{% endif %}>Daily Digest</option>
                                <option value="weekly" {% if userSettings.notifications == 'weekly' %}selected{% endif %}>Weekly Digest</option>
                                <option value="never" {% if userSettings.notifications == 'never' %}selected{% endif %}>Never</option>
                            </select>
                            <small class="form-help">How often you want to receive notifications</small>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <span>💾</span>
                        Save Changes
                    </button>
                    <a href="/profile" class="btn btn-secondary">
                        <span>❌</span>
                        Cancel
                    </a>
                    <a href="/settings" class="btn btn-outline">
                        <span>⚙️</span>
                        Advanced Settings
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('editProfileForm');
    
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        const data = Object.fromEntries(formData);
        
        try {
            const response = await fetch('/profile', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]')?.content || ''
                },
                body: JSON.stringify(data)
            });
            
            const result = await response.json();
            
            if (result.success) {
                showNotification('Profile updated successfully!', 'success');
                setTimeout(() => {
                    window.location.href = '/profile';
                }, 1500);
            } else {
                showNotification(result.message || 'Failed to update profile', 'error');
            }
        } catch (error) {
            showNotification('An error occurred while updating profile', 'error');
        }
    });
    
    function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.className = `notification notification-${type}`;
        notification.textContent = message;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.remove();
        }, 5000);
    }
});
</script>
{% endblock %}
