{% extends 'layouts/app.twig' %}

{% block title %}{{ templateName }} - Template - IslamWiki{% endblock %}

{% block content %}
<div class="template-page-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="section-container">
            <div class="template-header">
                <h1 class="page-title">
                    <i class="fas fa-file-code"></i>
                    Template:{{ templateName }}
                </h1>
                <div class="template-actions">
                    <a href="/wiki/Template:{{ templateName }}/edit" class="btn btn-primary">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                    <a href="/wiki/Special:Templates" class="btn btn-secondary">
                        <i class="fas fa-list"></i> All Templates
                    </a>
                </div>
            </div>
            <p class="page-subtitle">
                Template page for {{ templateName }}
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <div class="section-container">
        <!-- Template Information -->
        <div class="template-info-box">
            <div class="template-info-content">
                <div class="template-info-icon">
                    <i class="fas fa-info-circle"></i>
                </div>
                <div class="template-info-text">
                    <p>
                        This is a <strong>template</strong> that can be used in other wiki pages. 
                        Templates are stored as namespace pages and can be modified by users.
                    </p>
                    <p>
                        <strong>Usage:</strong> <code>&#123;&#123;{{ templateName }}&#125;&#125;</code>
                    </p>
                </div>
            </div>
        </div>

        <!-- Template Content -->
        <div class="template-content-section">
            <div class="template-content-header">
                <h2>Template Content</h2>
                <div class="template-content-actions">
                    <button type="button" class="btn btn-outline-secondary" id="copy-template-btn">
                        <i class="fas fa-copy"></i> Copy
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="preview-template-btn">
                        <i class="fas fa-eye"></i> Preview
                    </button>
                </div>
            </div>
            
            <div class="template-content-display">
                <pre class="template-code" id="template-code">{{ templateContent }}</pre>
            </div>
        </div>

        <!-- Template Preview -->
        <div class="template-preview-section" id="template-preview-section" style="display: none;">
            <div class="template-preview-header">
                <h3>Template Preview</h3>
                <button type="button" class="btn btn-outline-secondary" id="close-preview-btn">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
            <div class="template-preview-content" id="template-preview-content">
                <!-- Preview content will be rendered here -->
            </div>
        </div>

        <!-- Template Usage Examples -->
        <div class="template-usage-section">
            <h2>Usage Examples</h2>
            
            <div class="usage-example">
                <h3>Basic Usage</h3>
                <div class="code-example">
                    <code>&#123;&#123;{{ templateName }}&#125;&#125;</code>
                </div>
                <p>Use this template in any wiki page by adding the above code.</p>
            </div>
            
            {% if templateContent contains '{{{' %}
            <div class="usage-example">
                <h3>With Parameters</h3>
                <div class="code-example">
                    <code>&#123;&#123;{{ templateName }}|param1|param2|named=value&#125;&#125;</code>
                </div>
                <p>This template accepts parameters. Check the template content above for available parameters.</p>
            </div>
            {% endif %}
        </div>

        <!-- Template Metadata -->
        {% if metadata %}
        <div class="template-metadata-section">
            <h2>Template Information</h2>
            <div class="metadata-grid">
                {% if metadata.created_at %}
                <div class="metadata-item">
                    <span class="metadata-label">Created:</span>
                    <span class="metadata-value">{{ metadata.created_at|date('F j, Y') }}</span>
                </div>
                {% endif %}
                
                {% if metadata.updated_at %}
                <div class="metadata-item">
                    <span class="metadata-label">Last Modified:</span>
                    <span class="metadata-value">{{ metadata.updated_at|date('F j, Y') }}</span>
                </div>
                {% endif %}
                
                {% if metadata.creator_id %}
                <div class="metadata-item">
                    <span class="metadata-label">Creator:</span>
                    <span class="metadata-value">User ID: {{ metadata.creator_id }}</span>
                </div>
                {% endif %}
                
                {% if metadata.last_editor_id %}
                <div class="metadata-item">
                    <span class="metadata-label">Last Editor:</span>
                    <span class="metadata-value">User ID: {{ metadata.last_editor_id }}</span>
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <!-- Related Templates -->
        <div class="related-templates-section">
            <h2>Related Templates</h2>
            <div class="related-templates-list">
                <a href="/wiki/Special:Templates" class="related-template-link">
                    <i class="fas fa-th-list"></i> View All Templates
                </a>
                <a href="/wiki/Template:Infobox" class="related-template-link">
                    <i class="fas fa-table"></i> Infobox Template
                </a>
                <a href="/wiki/Template:Stub" class="related-template-link">
                    <i class="fas fa-exclamation-triangle"></i> Stub Template
                </a>
            </div>
        </div>
    </div>
</div>


<script>
document.addEventListener('DOMContentLoaded', function() {
    // Copy template button
    const copyBtn = document.getElementById('copy-template-btn');
    const templateCode = document.getElementById('template-code');
    
    copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(templateCode.textContent).then(function() {
            copyBtn.innerHTML = '<i class="fas fa-check"></i> Copied!';
            setTimeout(function() {
                copyBtn.innerHTML = '<i class="fas fa-copy"></i> Copy';
            }, 2000);
        });
    });
    
    // Preview template button
    const previewBtn = document.getElementById('preview-template-btn');
    const previewSection = document.getElementById('template-preview-section');
    const previewContent = document.getElementById('template-preview-content');
    const closePreviewBtn = document.getElementById('close-preview-btn');
    
    previewBtn.addEventListener('click', function() {
        // For now, just show the raw HTML content
        // In a full implementation, this would process the template with sample parameters
        previewContent.innerHTML = templateCode.textContent;
        previewSection.style.display = 'block';
        previewBtn.style.display = 'none';
    });
    
    closePreviewBtn.addEventListener('click', function() {
        previewSection.style.display = 'none';
        previewBtn.style.display = 'inline-flex';
    });
});
</script>
{% endblock %} 