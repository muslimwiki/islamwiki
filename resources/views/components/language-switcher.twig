<div class="language-switcher" data-current-language="{{ current_language() }}">
    <div class="language-current">
        <span class="language-flag">
            {% if current_language() == 'ar' %}🇸🇦
            {% elseif current_language() == 'ur' %}🇵🇰
            {% elseif current_language() == 'tr' %}🇹🇷
            {% elseif current_language() == 'id' %}🇮🇩
            {% elseif current_language() == 'ms' %}🇲🇾
            {% elseif current_language() == 'fa' %}🇮🇷
            {% elseif current_language() == 'he' %}🇮🇱
            {% else %}🇺🇸{% endif %}
        </span>
        <span class="language-name">
            {% if current_language() == 'ar' %}العربية
            {% elseif current_language() == 'ur' %}اردو
            {% elseif current_language() == 'tr' %}Türkçe
            {% elseif current_language() == 'id' %}Bahasa Indonesia
            {% elseif current_language() == 'ms' %}Bahasa Melayu
            {% elseif current_language() == 'fa' %}فارسی
            {% elseif current_language() == 'he' %}עברית
            {% else %}English{% endif %}
        </span>
        <span class="language-arrow">▼</span>
    </div>
    
    <div class="language-dropdown">
        <a href="{{ lang_url('') }}" class="language-option" data-language="en">
            <span class="language-flag">🇺🇸</span>
            <span class="language-name">English</span>
        </a>
        <a href="{{ lang_url('') }}" class="language-option" data-language="ar">
            <span class="language-flag">🇸🇦</span>
            <span class="language-name">العربية</span>
        </a>
        <a href="{{ lang_url('') }}" class="language-option" data-language="ur">
            <span class="language-flag">🇵🇰</span>
            <span class="language-name">اردو</span>
        </a>
        <a href="{{ lang_url('') }}" class="language-option" data-language="tr">
            <span class="language-flag">🇹🇷</span>
            <span class="language-name">Türkçe</span>
        </a>
        <a href="{{ lang_url('') }}" class="language-option" data-language="id">
            <span class="language-flag">🇮🇩</span>
            <span class="language-name">Bahasa Indonesia</span>
        </a>
        <a href="{{ lang_url('') }}" class="language-option" data-language="ms">
            <span class="language-flag">🇲🇾</span>
            <span class="language-name">Bahasa Melayu</span>
        </a>
        <a href="{{ lang_url('') }}" class="language-option" data-language="fa">
            <span class="language-flag">🇮🇷</span>
            <span class="language-name">فارسی</span>
        </a>
        <a href="{{ lang_url('') }}" class="language-option" data-language="he">
            <span class="language-flag">🇮🇱</span>
            <span class="language-name">עברית</span>
        </a>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const languageSwitcher = document.querySelector('.language-switcher');
    const languageCurrent = languageSwitcher.querySelector('.language-current');
    const languageDropdown = languageSwitcher.querySelector('.language-dropdown');
    const languageOptions = languageSwitcher.querySelectorAll('.language-option');
    
    // Toggle dropdown
    languageCurrent.addEventListener('click', function() {
        languageDropdown.classList.toggle('show');
    });
    
    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
        if (!languageSwitcher.contains(event.target)) {
            languageDropdown.classList.remove('show');
        }
    });
    
    // Handle language switching
    languageOptions.forEach(option => {
        option.addEventListener('click', function(event) {
            event.preventDefault();
            
            const targetLanguage = this.dataset.language;
            const currentPath = window.location.pathname;
            
            // Remove current language prefix if it exists
            let pathWithoutLanguage = currentPath;
            const currentLanguage = languageSwitcher.dataset.currentLanguage;
            
            if (currentLanguage !== 'en' && currentPath.startsWith('/' + currentLanguage + '/')) {
                pathWithoutLanguage = currentPath.substring(currentLanguage.length + 1);
            }
            
            // Generate new URL
            let newUrl;
            if (targetLanguage === 'en') {
                newUrl = pathWithoutLanguage || '/';
            } else {
                newUrl = '/' + targetLanguage + (pathWithoutLanguage || '');
            }
            
            // Navigate to new URL
            window.location.href = newUrl;
        });
    });
});
</script>

