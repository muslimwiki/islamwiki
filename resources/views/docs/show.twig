{% extends 'layouts/app.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="docs-layout" style="display:flex; gap: 24px;">
  <aside class="docs-sidebar" style="flex: 0 0 420px; max-width: 420px;">
    <div class="card">
      <div class="card-header"><h2 class="card-title">Documentation</h2></div>
      <div class="card-body">
        <input type="text" id="docs-search" class="input" placeholder="Search docs..." oninput="filterDocsTree(this.value)">
        <ul id="docs-tree" class="docs-tree" style="margin-top:12px; list-style:none; padding-left:0;">
          {% macro render_node(node, current) %}
            {% if node.type == 'dir' %}
              {% if node.name %}
                <li class="tree-dir" data-name="{{ node.name|lower }}">
                  <button class="tree-toggle" aria-expanded="{{ node.open ? 'true' : 'false' }}" data-path="{{ node.path }}">{{ node.open ? '▼' : '▶' }}</button>
                  <a href="/docs/{{ node.path }}">📁 {{ node.name }}</a>
                  <ul class="tree-children" style="list-style:none; margin-left: 1rem; display: {{ node.open ? 'block' : 'none' }};">
                    {% for child in node.children %}
                      {{ _self.render_node(child, current) }}
                    {% endfor %}
                  </ul>
                </li>
              {% else %}
                {# synthetic root: render children only #}
                {% for child in node.children %}
                  {{ _self.render_node(child, current) }}
                {% endfor %}
              {% endif %}
            {% else %}
              <li class="tree-file" data-name="{{ node.name|lower }}">
                <a href="/docs/{{ node.path }}" class="{{ current == node.path ? 'active' : '' }}">📄 {{ node.name }}</a>
              </li>
            {% endif %}
          {% endmacro %}
          {{ _self.render_node({ type: 'dir', path: '', name: '', children: tree, open: true }, current) }}
        </ul>
      </div>
    </div>
  </aside>

  <section class="docs-content" style="flex: 1; min-width:0;">
    <article class="card">
      <div class="card-body">
        <div class="docs-toolbar" style="display:flex; justify-content:flex-end; gap:12px; margin-bottom:12px;">
          <label style="display:flex; align-items:center; gap:6px; font-size: 0.9rem;">
            <input id="toggle-ascii-tree" type="checkbox" /> ASCII tree
          </label>
        </div>
        <div class="markdown-body">
          {{ content|raw }}
        </div>
      </div>
    </article>
  </section>
</div>

<script>
function filterDocsTree(q) {
  const term = (q||'').toLowerCase().trim();
  document.querySelectorAll('#docs-tree li').forEach(li => {
    const name = li.getAttribute('data-name') || '';
    li.style.display = !term || name.includes(term) ? '' : 'none';
  });
}

// Toggle hide/show directories
document.addEventListener('click', function(e) {
  const toggle = e.target.closest('.tree-toggle');
  if (!toggle) return;
  e.preventDefault();
  const li = toggle.closest('.tree-dir');
  const children = li.querySelector(':scope > .tree-children');
  const expanded = toggle.getAttribute('aria-expanded') === 'true';
  toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
  toggle.textContent = expanded ? '▶' : '▼';
  children.style.display = expanded ? 'none' : 'block';
});

// Helpers
function looksLikeTree(text) {
  return text && (text.includes('├──') || text.includes('└──') || text.includes('│'));
}

// Add copy buttons and per-block ASCII toggles where relevant
function enhanceCodeBlocks() {
  document.querySelectorAll('.markdown-body pre').forEach(pre => {
    if (pre.dataset.enhanced) return;
    pre.dataset.enhanced = '1';
    pre.style.position = 'relative';

    const code = pre.querySelector('code');
    const isTree = code && (code.classList.contains('lang-tree') || code.classList.contains('language-tree') || looksLikeTree(code.textContent));

    // Copy button
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.style.position = 'absolute';
    btn.style.right = isTree ? '60px' : '8px';
    btn.style.top = '8px';
    btn.style.padding = '4px 8px';
    btn.style.fontSize = '12px';
    btn.style.cursor = 'pointer';
    btn.addEventListener('click', () => {
      const c = pre.querySelector('code');
      const text = c ? c.textContent : pre.textContent;
      navigator.clipboard.writeText(text || '').then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = 'Copy'), 1200);
      });
    });
    pre.appendChild(btn);

    // ASCII toggle for tree-like blocks
    if (isTree) {
      const asciiBtn = document.createElement('button');
      asciiBtn.className = 'ascii-btn';
      asciiBtn.textContent = 'ASCII';
      asciiBtn.style.position = 'absolute';
      asciiBtn.style.right = '8px';
      asciiBtn.style.top = '8px';
      asciiBtn.style.padding = '4px 8px';
      asciiBtn.style.fontSize = '12px';
      asciiBtn.style.cursor = 'pointer';

      const c = code;
      c.dataset.treeOriginal = c.textContent;
      let ascii = c.textContent
        .replaceAll('├──', '+--')
        .replaceAll('└──', '`--')
        .replaceAll('│',  '|')
        .replaceAll('─',  '-')
        .replace(/\u00A0/g, ' ');
      c.dataset.treeAscii = ascii;
      c.dataset.treeAsciiOn = '0';

      asciiBtn.addEventListener('click', () => {
        const on = c.dataset.treeAsciiOn === '1';
        if (on) {
          c.textContent = c.dataset.treeOriginal || c.textContent;
          c.dataset.treeAsciiOn = '0';
          asciiBtn.textContent = 'ASCII';
        } else {
          c.textContent = c.dataset.treeAscii || c.textContent;
          c.dataset.treeAsciiOn = '1';
          asciiBtn.textContent = 'Unicode';
        }
      });
      pre.appendChild(asciiBtn);
    }
  });
}

enhanceCodeBlocks();

// Normalize ordered lists numbering across separated blocks
function normalizeOrderedLists() {
  const container = document.querySelector('.markdown-body');
  if (!container) return;
  const ols = Array.from(container.querySelectorAll('ol.md-list'));
  let running = 0;
  let prev = null;
  const isReset = (el) => el && (/^H[1-6]$/.test(el.tagName) || el.tagName === 'HR' || el.tagName === 'PRE' || el.tagName === 'BLOCKQUOTE');
  ols.forEach((ol) => {
    // reset if there's a reset element between previous list and this one
    if (prev) {
      let s = prev.nextElementSibling;
      let resetFound = false;
      while (s && s !== ol) {
        if (isReset(s)) { resetFound = true; break; }
        s = s.nextElementSibling;
      }
      if (resetFound) running = 0;
    }
    const items = ol.querySelectorAll(':scope > li').length;
    const start = running + 1;
    if (start !== 1) ol.setAttribute('start', String(start));
    running += items;
    prev = ol;
  });
}

normalizeOrderedLists();

// If an unordered list follows an ordered list, nest it under the last item
function nestFollowingUnorderedLists() {
  const container = document.querySelector('.markdown-body');
  if (!container) return;
  let el = container.firstElementChild;
  while (el) {
    if (el.tagName === 'UL' && el.classList.contains('md-list')) {
      const prev = el.previousElementSibling;
      if (prev && prev.tagName === 'OL' && prev.classList.contains('md-list')) {
        const lastLi = prev.querySelector(':scope > li:last-child');
        if (lastLi) {
          lastLi.appendChild(el);
          // adjust pointer since el is now child of lastLi
          el = lastLi; // continue traversal
        }
      }
    }
    el = el.nextElementSibling || (el.parentElement === container ? null : el.parentElement.nextElementSibling);
  }
}

nestFollowingUnorderedLists();

// Remove global toggle wiring since we now offer per-block toggles
</script>
{% endblock %}


