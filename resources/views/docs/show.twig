{% extends 'layouts/app.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body_class %}docs-page{% endblock %}

{% block content %}
<div class="docs-layout">
    <!-- Docs Sidebar -->
    <div class="docs-sidebar">
        <div class="docs-sidebar-header">
            <h2 class="docs-sidebar-title">
                <span>📚</span>
                Documentation
            </h2>
        </div>
        <div class="docs-sidebar-content">
            <!-- Docs Search -->
            <div class="docs-search">
                <input type="text" class="docs-search-input" placeholder="Search documentation..." id="docs-search">
            </div>
            
            <!-- Docs Navigation -->
            <nav class="docs-nav">
                <div class="docs-nav-section">
                    <h3 class="docs-nav-section-title">Getting Started</h3>
                    <ul class="docs-nav-list">
                        <li class="docs-nav-item">
                            <a href="/docs/introduction" class="docs-nav-link">Introduction</a>
                        </li>
                        <li class="docs-nav-item">
                            <a href="/docs/installation" class="docs-nav-link">Installation</a>
                        </li>
                        <li class="docs-nav-item">
                            <a href="/docs/quick-start" class="docs-nav-link">Quick Start</a>
                        </li>
                    </ul>
                </div>
                
                <div class="docs-nav-section">
                    <h3 class="docs-nav-section-title">Core Features</h3>
                    <ul class="docs-nav-list">
                        <li class="docs-nav-item">
                            <a href="/docs/authentication" class="docs-nav-link">Authentication</a>
                        </li>
                        <li class="docs-nav-item">
                            <a href="/docs/database" class="docs-nav-link">Database</a>
                        </li>
                        <li class="docs-nav-item">
                            <a href="/docs/routing" class="docs-nav-link">Routing</a>
                        </li>
                        <li class="docs-nav-item">
                            <a href="/docs/views" class="docs-nav-link">Views & Templates</a>
                        </li>
                    </ul>
                </div>
                
                <div class="docs-nav-section">
                    <h3 class="docs-nav-section-title">Advanced</h3>
                    <ul class="docs-nav-list">
                        <li class="docs-nav-item">
                            <a href="/docs/extensions" class="docs-nav-link">Extensions</a>
                        </li>
                        <li class="docs-nav-item">
                            <a href="/docs/skins" class="docs-nav-link">Skins & Themes</a>
                        </li>
                        <li class="docs-nav-item">
                            <a href="/docs/api" class="docs-nav-link">API Reference</a>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
    </div>

    <!-- Docs Main Content -->
    <div class="docs-main">
        <!-- Docs Header -->
        <div class="docs-header">
            <h1 class="docs-title">{{ title }}</h1>
            {% if subtitle %}
            <p class="docs-subtitle">{{ subtitle }}</p>
            {% endif %}
            
            <div class="docs-meta">
                <div class="docs-meta-item">
                    <span class="docs-meta-icon">📅</span>
                    <span>Last updated: {{ "now"|date("M j, Y") }}</span>
                </div>
                <div class="docs-meta-item">
                    <span class="docs-meta-icon">👁️</span>
                    <span>Reading time: 5 min</span>
                </div>
                <div class="docs-meta-item">
                    <span class="docs-meta-icon">🏷️</span>
                    <span>Category: {{ category|default('General') }}</span>
                </div>
            </div>
        </div>

        <!-- Docs Breadcrumbs -->
        <div class="docs-breadcrumbs">
            <nav aria-label="Breadcrumb">
                <ol class="breadcrumb-list">
                    <li class="breadcrumb-item">
                        <a href="/docs" class="breadcrumb-link">Documentation</a>
                    </li>
                    {% if category %}
                    <li class="breadcrumb-item">
                        <a href="/docs/{{ category|lower }}" class="breadcrumb-link">{{ category }}</a>
                    </li>
                    {% endif %}
                    <li class="breadcrumb-item">
                        <span class="breadcrumb-current">{{ title }}</span>
                    </li>
                </ol>
            </nav>
        </div>

        <!-- Docs Content -->
        <div class="docs-content">
            <div class="markdown-body">
                {{ content|raw }}
            </div>
        </div>

        <!-- Docs Footer -->
        <div class="docs-footer">
            <div class="docs-footer-content">
                <nav class="docs-footer-nav">
                    {% if prev_page %}
                    <a href="{{ prev_page.url }}" class="docs-footer-link">← {{ prev_page.title }}</a>
                    {% endif %}
                    {% if next_page %}
                    <a href="{{ next_page.url }}" class="docs-footer-link">{{ next_page.title }} →</a>
                    {% endif %}
                </nav>
                <div class="docs-footer-info">
                    <span>📚 IslamWiki Documentation</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Search Functionality -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('docs-search');
    const navLinks = document.querySelectorAll('.docs-nav-link');
    
    searchInput.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        
        navLinks.forEach(link => {
            const text = link.textContent.toLowerCase();
            if (text.includes(searchTerm)) {
                link.style.display = 'block';
            } else {
                link.style.display = 'none';
            }
        });
    });
});
</script>
{% endblock %}


