{% extends "layouts/dashboard.twig" %}

{% block title %}User Dashboard - {{ parent() }}{% endblock %}

{% block content %}
<div class="user-dashboard-container">
    <!-- Welcome Hero Section -->
    <div class="welcome-hero">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">🌟 Your Learning Dashboard</h1>
                <p class="hero-subtitle">Track your progress and discover new Islamic knowledge</p>

            </div>
            <div class="hero-actions">
                <button class="btn-hero btn-hero-primary" onclick="startLearning()">
                    <span class="btn-icon">🚀</span>
                    Start Learning
                </button>
                <button class="btn-hero btn-hero-secondary" onclick="exploreContent()">
                    <span class="btn-icon">🔍</span>
                    Explore Content
                </button>
            </div>
        </div>
        <div class="hero-decoration">
            <div class="islamic-pattern"></div>
        </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="quick-stats-row">
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">📚</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.total_pages|default(0) }}</div>
                <div class="stat-label">Articles Read</div>
                <div class="stat-change positive">+3 this week</div>
            </div>
        </div>
        
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">✏️</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.total_edits|default(0) }}</div>
                <div class="stat-label">Contributions</div>
                <div class="stat-change positive">+1 today</div>
            </div>
        </div>
        
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">⭐</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.recent_activity|default(0) }}</div>
                <div class="stat-label">Active Days</div>
                <div class="stat-change positive">+5 this month</div>
            </div>
        </div>
        
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">🎯</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.watchlist_count|default(0) }}</div>
                <div class="stat-label">Watchlist</div>
                <div class="stat-change neutral">Updated</div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Grid -->
    <div class="dashboard-main-grid">
        <!-- Left Column -->
        <div class="dashboard-column">
            <!-- Learning Progress Widget -->
            <div class="dashboard-widget learning-progress-widget">
                <div class="widget-header">
                    <h3 class="widget-title">📖 Learning Journey</h3>
                    <div class="widget-actions">
                        <button class="btn-icon-small" onclick="refreshProgress()">🔄</button>
                        <button class="btn-icon-small" onclick="viewFullProgress()">📊</button>
                    </div>
                </div>
                <div class="widget-content">
                    <div class="progress-overview">
                        <div class="progress-item">
                            <div class="progress-header">
                                <span class="progress-label">Quran Studies</span>
                                <span class="progress-percentage">65%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 65%"></div>
                            </div>
                            <div class="progress-stats">
                                <span class="progress-current">13 Juz</span>
                                <span class="progress-total">20 Juz</span>
                            </div>
                        </div>
                        
                        <div class="progress-item">
                            <div class="progress-header">
                                <span class="progress-label">Hadith Collection</span>
                                <span class="progress-percentage">42%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 42%"></div>
                            </div>
                            <div class="progress-stats">
                                <span class="progress-current">210 Hadith</span>
                                <span class="progress-total">500 Hadith</span>
                            </div>
                        </div>
                        
                        <div class="progress-item">
                            <div class="progress-header">
                                <span class="progress-label">Islamic Sciences</span>
                                <span class="progress-percentage">78%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 78%"></div>
                            </div>
                            <div class="progress-stats">
                                <span class="progress-current">7 Topics</span>
                                <span class="progress-total">9 Topics</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="learning-actions">
                        <button class="btn btn-primary btn-sm" onclick="continueLearning()">Continue Learning</button>
                        <button class="btn btn-secondary btn-sm" onclick="setGoals()">Set Goals</button>
                    </div>
                </div>
            </div>

            <!-- Recent Activity Widget -->
            <div class="dashboard-widget recent-activity-widget">
                <div class="widget-header">
                    <h3 class="widget-title">🕒 Recent Activity</h3>
                    <div class="widget-actions">
                        <button class="btn-icon-small" onclick="viewAllActivity()">📋</button>
                    </div>
                </div>
                <div class="widget-content">
                    <div class="activity-timeline">
                        {% if recentActivity|length > 0 %}
                            {% for activity in recentActivity[:5] %}
                            <div class="activity-item">
                                <div class="activity-icon">
                                    <span class="icon">📝</span>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-title">{{ activity.page_title|default('Article') }}</div>
                                    <div class="activity-description">{{ activity.change_summary|default('Updated content') }}</div>
                                    <div class="activity-meta">
                                        <span class="activity-time">{{ activity.time_ago|default('2 hours ago') }}</span>
                                        <span class="activity-type">{{ activity.activity_type|default('edit')|title }}</span>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <div class="no-activity">
                                <div class="no-activity-icon">🌟</div>
                                <div class="no-activity-text">No recent activity</div>
                                <div class="no-activity-subtext">Start exploring content to see your activity here</div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="dashboard-column">
            <!-- Quick Actions Widget -->
            <div class="dashboard-widget quick-actions-widget">
            <div class="widget-header">
                    <h3 class="widget-title">⚡ Quick Actions</h3>
                </div>
                <div class="widget-content">
                    <div class="quick-actions-grid">
                        <button class="quick-action-btn" onclick="searchQuran()">
                            <span class="action-icon">📖</span>
                            <span class="action-text">Search Quran</span>
                        </button>
                        <button class="quick-action-btn" onclick="browseHadith()">
                            <span class="action-icon">📜</span>
                            <span class="action-text">Browse Hadith</span>
                        </button>
                        <button class="quick-action-btn" onclick="exploreSciences()">
                            <span class="action-icon">🔬</span>
                            <span class="action-text">Islamic Sciences</span>
                        </button>
                        <button class="quick-action-btn" onclick="checkPrayerTimes()">
                            <span class="action-icon">🕌</span>
                            <span class="action-text">Prayer Times</span>
                        </button>
                        <button class="quick-action-btn" onclick="viewCalendar()">
                            <span class="action-icon">📅</span>
                            <span class="action-text">Islamic Calendar</span>
                        </button>
                        <button class="quick-action-btn" onclick="joinCommunity()">
                            <span class="action-icon">👥</span>
                            <span class="action-text">Community</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Personalized Recommendations Widget -->
            <div class="dashboard-widget recommendations-widget">
                <div class="widget-header">
                    <h3 class="widget-title">💡 Recommended for You</h3>
                    <div class="widget-actions">
                        <button class="btn-icon-small" onclick="refreshRecommendations()">🔄</button>
                    </div>
            </div>
            <div class="widget-content">
                    <div class="recommendations-list">
                        <div class="recommendation-item">
                            <div class="recommendation-icon">📚</div>
                            <div class="recommendation-content">
                                <div class="recommendation-title">Fiqh of Prayer</div>
                                <div class="recommendation-description">Complete guide to prayer rules and etiquette</div>
                                <div class="recommendation-meta">
                                    <span class="difficulty beginner">Beginner</span>
                                    <span class="duration">15 min read</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="recommendation-item">
                            <div class="recommendation-icon">🎯</div>
                            <div class="recommendation-content">
                                <div class="recommendation-title">Daily Dhikr Collection</div>
                                <div class="recommendation-description">Essential daily remembrance and supplications</div>
                                <div class="recommendation-meta">
                                    <span class="difficulty intermediate">Intermediate</span>
                                    <span class="duration">10 min read</span>
                                </div>
                        </div>
                    </div>
                        
                        <div class="recommendation-item">
                            <div class="recommendation-icon">🌟</div>
                            <div class="recommendation-content">
                                <div class="recommendation-title">Prophet's Character</div>
                                <div class="recommendation-description">Learn about the noble character of Prophet Muhammad ﷺ</div>
                                <div class="recommendation-meta">
                                    <span class="difficulty beginner">Beginner</span>
                                    <span class="duration">20 min read</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="recommendations-actions">
                        <button class="btn btn-primary btn-sm" onclick="viewAllRecommendations()">View All</button>
                        <button class="btn btn-secondary btn-sm" onclick="customizePreferences()">Customize</button>
                </div>
            </div>
        </div>

            <!-- Community Updates Widget -->
            <div class="dashboard-widget community-widget">
            <div class="widget-header">
                    <h3 class="widget-title">👥 Community Updates</h3>
                </div>
                <div class="widget-content">
                    <div class="community-updates">
                        <div class="update-item">
                            <div class="update-icon">🎉</div>
                            <div class="update-content">
                                <div class="update-text">New members joined this week</div>
                                <div class="update-meta">+12 members</div>
                            </div>
                        </div>
                        
                        <div class="update-item">
                            <div class="update-icon">📝</div>
                            <div class="update-content">
                                <div class="update-text">New articles published</div>
                                <div class="update-meta">+8 articles</div>
                            </div>
                        </div>
                        
                        <div class="update-item">
                            <div class="update-icon">💬</div>
                            <div class="update-content">
                                <div class="update-text">Active discussions</div>
                                <div class="update-meta">15 ongoing</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="community-actions">
                        <button class="btn btn-primary btn-sm" onclick="joinDiscussion()">Join Discussion</button>
                        <button class="btn btn-secondary btn-sm" onclick="viewCommunity()">View Community</button>
                    </div>
                </div>
                </div>
            </div>
        </div>

    <!-- Bottom Section -->
    <div class="dashboard-bottom-section">
        <!-- Daily Inspiration Widget -->
        <div class="dashboard-widget inspiration-widget">
            <div class="widget-header">
                <h3 class="widget-title">🌟 Daily Inspiration</h3>
                <div class="widget-actions">
                    <button class="btn-icon-small" onclick="refreshInspiration()">🔄</button>
                </div>
            </div>
            <div class="widget-content">
                <div class="inspiration-content">
                    <div class="inspiration-quote">
                        "The best of you are those who learn the Quran and teach it to others."
                    </div>
                    <div class="inspiration-source">
                        — Prophet Muhammad ﷺ
                    </div>
                    <div class="inspiration-actions">
                        <button class="btn btn-primary btn-sm" onclick="shareInspiration()">Share</button>
                        <button class="btn btn-secondary btn-sm" onclick="saveInspiration()">Save</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upcoming Events Widget -->
        <div class="dashboard-widget events-widget">
            <div class="widget-header">
                <h3 class="widget-title">📅 Upcoming Events</h3>
                <div class="widget-actions">
                    <button class="btn-icon-small" onclick="viewAllEvents()">📋</button>
                </div>
            </div>
            <div class="widget-content">
                <div class="events-list">
                    <div class="event-item">
                        <div class="event-date">
                            <div class="event-day">25</div>
                            <div class="event-month">Aug</div>
                        </div>
                        <div class="event-content">
                            <div class="event-title">Islamic Finance Workshop</div>
                            <div class="event-time">2:00 PM - 4:00 PM</div>
                            <div class="event-location">Online Event</div>
                        </div>
                        <button class="btn btn-primary btn-sm" onclick="joinEvent()">Join</button>
                    </div>
                    
                    <div class="event-item">
                        <div class="event-date">
                            <div class="event-day">28</div>
                            <div class="event-month">Aug</div>
                        </div>
                        <div class="event-content">
                            <div class="event-title">Quran Recitation Circle</div>
                            <div class="event-time">7:00 PM - 8:30 PM</div>
                            <div class="event-location">Local Mosque</div>
                        </div>
                        <button class="btn btn-secondary btn-sm" onclick="joinEvent()">Join</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom CSS for User Dashboard -->
<style>
.user-dashboard-container {
    padding: 0;
    max-width: 100%;
}

/* Welcome Hero Section */
.welcome-hero {
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 50%, #6ba53a 100%);
    border-radius: 20px;
    padding: 40px;
    margin-bottom: 30px;
    position: relative;
    overflow: hidden;
    color: white;
}

.hero-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 2;
}

.hero-text {
    flex: 1;
}

.hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: white !important;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4);
}

.hero-subtitle {
    font-size: 1.2rem;
    color: white !important;
    opacity: 0.95;
    margin-bottom: 25px;
    font-weight: 500;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
}



.hero-actions {
    display: flex;
    gap: 15px;
    flex-direction: column;
}

.btn-hero {
    padding: 15px 30px;
    border: none;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
    text-decoration: none;
}

.btn-hero-primary {
    background: #d4af37;
    color: #2d5016;
}

.btn-hero-primary:hover {
    background: #e6c44a;
    transform: translateY(-2px);
}

.btn-hero-secondary {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
}

.btn-hero-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
}

.hero-decoration {
    position: absolute;
    top: 0;
    right: 0;
    width: 300px;
    height: 100%;
    opacity: 0.1;
}

.islamic-pattern {
    width: 100%;
    height: 100%;
    background-image: 
        radial-gradient(circle at 20% 20%, #d4af37 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, #ffffff 0%, transparent 50%);
}

/* Quick Stats Row - Using Working Pattern from Main Dashboard */
.quick-stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin-bottom: 30px;
}

/* The stat-card styles are already defined in the main dashboard layout */

/* Main Dashboard Grid */
.dashboard-main-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 30px;
}

.dashboard-column {
    display: flex;
    flex-direction: column;
    gap: 25px;
}

/* Dashboard Widgets */
.dashboard-widget {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #f0f0f0;
    overflow: hidden;
    transition: all 0.3s ease;
}

.dashboard-widget:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
}

.widget-header {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    padding: 20px 25px;
    border-bottom: 1px solid #e9ecef;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.widget-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #2c3e50;
    margin: 0;
}

.widget-actions {
    display: flex;
    gap: 8px;
}

.btn-icon-small {
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 8px;
    background: rgba(45, 80, 22, 0.1);
    color: #2d5016;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.btn-icon-small:hover {
    background: rgba(45, 80, 22, 0.2);
    transform: scale(1.05);
}

.widget-content {
    padding: 25px;
}

/* Bottom Section */
.dashboard-bottom-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
}

/* Buttons */
.btn {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-primary {
    background: #2d5016;
    color: white;
}

.btn-primary:hover {
    background: #4a8029;
    transform: translateY(-1px);
}

.btn-secondary {
    background: #6c757d;
    color: white;
}

.btn-secondary:hover {
    background: #5a6268;
    transform: translateY(-1px);
}

.btn-sm {
    padding: 8px 16px;
    font-size: 0.9rem;
}

/* Progress Bars */
.progress-overview {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.progress-item {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid #e9ecef;
}

.progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
}

.progress-label {
    font-weight: 600;
    color: #2c3e50;
}

.progress-percentage {
    font-weight: 700;
    color: #2d5016;
    font-size: 1.1rem;
}

.progress-bar {
    height: 8px;
    background: #e9ecef;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 8px;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #2d5016, #4a8029);
    border-radius: 4px;
    transition: width 0.3s ease;
}

.progress-stats {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: #7f8c8d;
}

.learning-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
}

/* Activity Items */
.activity-timeline {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.activity-item {
    display: flex;
    gap: 15px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 10px;
    border: 1px solid #e9ecef;
}

.activity-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #2d5016, #4a8029);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
    flex-shrink: 0;
}

.activity-content {
    flex: 1;
}

.activity-title {
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 5px;
}

.activity-description {
    color: #7f8c8d;
    font-size: 0.9rem;
    margin-bottom: 8px;
}

.activity-meta {
    display: flex;
    gap: 15px;
    font-size: 0.8rem;
    color: #95a5a6;
}

.no-activity {
    text-align: center;
    padding: 40px 20px;
    color: #7f8c8d;
}

.no-activity-icon {
    font-size: 3rem;
    margin-bottom: 15px;
}

.no-activity-text {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
}

.no-activity-subtext {
    font-size: 0.9rem;
}

/* Quick Actions */
.quick-actions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
}

.quick-action-btn {
    background: #f8f9fa;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    padding: 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #2c3e50;
}

.quick-action-btn:hover {
    background: #2d5016;
    color: white;
    border-color: #2d5016;
    transform: translateY(-2px);
}

.action-icon {
    font-size: 2rem;
}

.action-text {
    font-weight: 600;
    font-size: 0.9rem;
    text-align: center;
}

/* Recommendations */
.recommendations-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.recommendation-item {
    display: flex;
    gap: 15px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 10px;
    border: 1px solid #e9ecef;
}

.recommendation-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #d4af37, #f1c40f);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
    flex-shrink: 0;
}

.recommendation-content {
    flex: 1;
}

.recommendation-title {
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 5px;
}

.recommendation-description {
    color: #7f8c8d;
    font-size: 0.9rem;
    margin-bottom: 8px;
    line-height: 1.4;
}

.recommendation-meta {
    display: flex;
    gap: 10px;
    align-items: center;
}

.difficulty {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
}

.difficulty.beginner {
    background: #d5f4e6;
    color: #27ae60;
}

.difficulty.intermediate {
    background: #fef9e7;
    color: #f39c12;
}

.difficulty.advanced {
