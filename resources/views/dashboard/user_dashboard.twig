{% extends "layouts/dashboard.twig" %}

{% block dashboard_title %}User Dashboard{% endblock %}

{% block dashboard_content %}
<div class="user-dashboard">
    <!-- User Main Content Area -->
    <div class="user-main-content">
        <!-- User Dashboard Header -->
        <div class="user-header">
            <h1>🌟 User Dashboard</h1>
            <p>Welcome to your personalized learning and contribution center</p>
            <div class="user-controls">
                <button class="btn btn-primary" onclick="refreshUserData()">🔄 Refresh</button>
                <button class="btn btn-secondary" onclick="viewProfile()">👤 View Profile</button>
                <button class="btn btn-success" onclick="startLearning()">📚 Start Learning</button>
            </div>
        </div>

        <!-- User Welcome Widget -->
        <div class="dashboard-widget widget-large">
            <div class="widget-header">
                <h3>👋 Welcome Back!</h3>
                <span class="widget-icon">🌟</span>
            </div>
            <div class="widget-content">
                <div class="user-welcome-stats">
                    <div class="welcome-stat">
                        <span class="welcome-value">0</span>
                        <span class="welcome-label">Learning Streak</span>
                    </div>
                    <div class="welcome-stat">
                        <span class="welcome-value">0</span>
                        <span class="welcome-label">Articles Read</span>
                    </div>
                    <div class="welcome-stat">
                        <span class="welcome-value">0</span>
                        <span class="welcome-label">Contributions</span>
                    </div>
                </div>
                <div class="user-motivation">
                    <div class="motivation-text">
                        <span class="motivation-label">Today's Goal:</span>
                        <span class="motivation-value">Read 3 articles</span>
                    </div>
                    <div class="motivation-progress">
                        <span class="progress-label">Progress:</span>
                        <span class="progress-value">0/3 completed</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Dashboard Grid -->
        <div class="user-grid">
            <!-- Learning Progress Widget -->
            <div class="dashboard-widget widget-medium">
                <div class="widget-header">
                    <h3>📚 Learning Progress</h3>
                    <span class="widget-icon">📖</span>
                </div>
                <div class="widget-content">
                    <div class="learning-stats">
                        <div class="learning-stat">
                            <span class="stat-number">0</span>
                            <span class="stat-text">Courses Started</span>
                        </div>
                        <div class="learning-stat">
                            <span class="stat-number">0</span>
                            <span class="stat-text">Lessons Completed</span>
                        </div>
                        <div class="learning-stat">
                            <span class="stat-number">0%</span>
                            <span class="stat-text">Overall Progress</span>
                        </div>
                    </div>
                    <div class="content-actions">
                        <button class="btn btn-primary btn-sm" onclick="continueLearning()">Continue Learning</button>
                        <button class="btn btn-secondary btn-sm" onclick="viewCourses()">Browse Courses</button>
                    </div>
                </div>
            </div>

            <!-- Recent Activity Widget -->
            <div class="dashboard-widget widget-medium">
                <div class="widget-header">
                    <h3>📝 Recent Activity</h3>
                    <span class="widget-icon">📋</span>
                </div>
                <div class="widget-content">
                    <div class="activity-list">
                        <div class="activity-item">
                            <span class="activity-icon">📖</span>
                            <span class="activity-text">No recent activity</span>
                        </div>
                    </div>
                    <div class="content-actions">
                        <button class="btn btn-primary btn-sm" onclick="viewActivity()">View All Activity</button>
                        <button class="btn btn-secondary btn-sm" onclick="startActivity()">Start New Activity</button>
                    </div>
                </div>
            </div>

            <!-- Community Widget -->
            <div class="dashboard-widget widget-medium">
                <div class="widget-header">
                    <h3>👥 Community</h3>
                    <span class="widget-icon">🤝</span>
                </div>
                <div class="widget-content">
                    <div class="community-stats">
                        <div class="community-stat">
                            <span class="stat-number">0</span>
                            <span class="stat-text">Forum Posts</span>
                        </div>
                        <div class="community-stat">
                            <span class="stat-number">0</span>
                            <span class="stat-text">Comments Made</span>
                        </div>
                        <div class="community-stat">
                            <span class="stat-number">0</span>
                            <span class="stat-text">Helpful Votes</span>
                        </div>
                    </div>
                    <div class="content-actions">
                        <button class="btn btn-primary btn-sm" onclick="joinDiscussion()">Join Discussion</button>
                        <button class="btn btn-secondary btn-sm" onclick="viewForums()">Browse Forums</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Quick Actions -->
        <div class="user-quick-actions">
            <h3>⚡ Quick Actions</h3>
            <div class="action-grid">
                <button class="action-btn" onclick="startReading()">
                    <span class="action-icon">📖</span>
                    <span class="action-text">Start Reading</span>
                </button>
                <button class="action-btn" onclick="joinCourse()">
                    <span class="action-icon">🎓</span>
                    <span class="action-text">Join Course</span>
                </button>
                <button class="action-btn" onclick="contributeArticle()">
                    <span class="action-icon">✏️</span>
                    <span class="action-text">Write Article</span>
                </button>
                <button class="action-btn" onclick="askQuestion()">
                    <span class="action-icon">❓</span>
                    <span class="action-text">Ask Question</span>
                </button>
                <button class="action-btn" onclick="viewProgress()">
                    <span class="action-icon">📊</span>
                    <span class="action-text">View Progress</span>
                </button>
                <button class="action-btn" onclick="connectCommunity()">
                    <span class="action-icon">🤝</span>
                    <span class="action-text">Connect</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
// User dashboard functions
function refreshUserData() {
    location.reload();
}

function viewProfile() {
    window.location.href = '/profile';
}

function startLearning() {
    window.location.href = '/courses';
}

function continueLearning() {
    window.location.href = '/learning';
}

function viewCourses() {
    window.location.href = '/courses';
}

function viewActivity() {
    window.location.href = '/activity';
}

function startActivity() {
    window.location.href = '/activity/new';
}

function joinDiscussion() {
    window.location.href = '/forums';
}

function viewForums() {
    window.location.href = '/forums';
}

function startReading() {
    window.location.href = '/articles';
}

function joinCourse() {
    window.location.href = '/courses';
}

function contributeArticle() {
    window.location.href = '/articles/create';
}

function askQuestion() {
    window.location.href = '/questions/ask';
}

function viewProgress() {
    window.location.href = '/progress';
}

function connectCommunity() {
    window.location.href = '/community';
}
</script>
{% endblock %} 