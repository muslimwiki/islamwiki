{% extends "layouts/dashboard.twig" %}

{% block dashboard_title %}User Dashboard{% endblock %}

{% block dashboard_content %}
<div class="user-dashboard-container">
    <!-- Welcome Hero Section -->
    <div class="welcome-hero">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">🌟 Your Learning Dashboard</h1>
                <p class="hero-subtitle">Track your progress and discover new Islamic knowledge</p>
            </div>
            <div class="hero-actions">
                <button class="btn-hero btn-hero-primary" onclick="startLearning()">
                    <span class="btn-icon">🚀</span>
                    Start Learning
                </button>
                <button class="btn-hero btn-hero-secondary" onclick="exploreContent()">
                    <span class="btn-icon">🔍</span>
                    Explore Content
                </button>
            </div>
        </div>
        <div class="hero-decoration">
            <div class="islamic-pattern"></div>
        </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="quick-stats-row">
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">📚</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.total_pages|default(0) }}</div>
                <div class="stat-label">Articles Read</div>
                <div class="stat-change positive">+3 this week</div>
            </div>
        </div>
        
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">✏️</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.total_edits|default(0) }}</div>
                <div class="stat-label">Contributions</div>
                <div class="stat-change positive">+1 today</div>
            </div>
        </div>
        
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">⭐</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.recent_activity|default(0) }}</div>
                <div class="stat-label">Active Days</div>
                <div class="stat-change positive">+5 this month</div>
            </div>
        </div>
        
        <div class="stat-card primary">
            <div class="stat-icon">
                <span class="stat-icon-text">🎯</span>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ userStats.watchlist_count|default(0) }}</div>
                <div class="stat-label">Watchlist</div>
                <div class="stat-change neutral">Updated</div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Grid -->
    <div class="dashboard-main-grid">
        <!-- Left Column -->
        <div class="dashboard-column">
            <!-- Learning Progress Widget -->
            <div class="dashboard-widget learning-progress-widget">
                <div class="widget-header">
                    <h3 class="widget-title">📖 Learning Journey</h3>
                    <div class="widget-actions">
                        <button class="btn-icon-small" onclick="refreshProgress()">🔄</button>
                        <button class="btn-icon-small" onclick="viewFullProgress()">📊</button>
                    </div>
                </div>
                <div class="widget-content">
                    <div class="progress-overview">
                        <div class="progress-item">
                            <div class="progress-header">
                                <span class="progress-label">Quran Studies</span>
                                <span class="progress-percentage">65%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 65%"></div>
                            </div>
                        </div>
                        
                        <div class="progress-item">
                            <div class="progress-header">
                                <span class="progress-label">Hadith Studies</span>
                                <span class="progress-percentage">42%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 42%"></div>
                            </div>
                        </div>
                        
                        <div class="progress-item">
                            <div class="progress-header">
                                <span class="progress-label">Islamic History</span>
                                <span class="progress-percentage">78%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 78%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function startLearning() {
    window.location.href = '/quran';
}

function exploreContent() {
    window.location.href = '/wiki';
}

function refreshProgress() {
    // Refresh progress data
    console.log('Refreshing progress...');
}

function viewFullProgress() {
    window.location.href = '/profile/progress';
}
</script>
{% endblock %} 