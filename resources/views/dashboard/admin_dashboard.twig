{% extends "layouts/dashboard.twig" %}

{% block dashboard_title %}Admin Dashboard{% endblock %}

{% block dashboard_content %}
<div class="admin-dashboard">
    <!-- Admin View (Default) -->
    <div id="admin-view" class="dashboard-view active">
        <!-- Admin Main Content Area -->
        <div class="admin-main-content">
            <!-- Admin Dashboard Header -->
            <div class="admin-header">
                <h1>🛡️ Admin Dashboard</h1>
                <p>System administration and monitoring for IslamWiki</p>
                <div class="admin-controls">
                    <button class="btn btn-primary" onclick="refreshAllWidgets()">🔄 Refresh All</button>
                    <button class="btn btn-secondary" onclick="exportDashboard('json')">📊 Export Data</button>
                    <button class="btn btn-warning" onclick="showSystemLogs()">📋 System Logs</button>
                </div>
            </div>

            <!-- System Overview Widget -->
            <div class="dashboard-widget widget-large">
                <div class="widget-header">
                    <h3>📊 System Overview</h3>
                    <span class="widget-icon">⚙️</span>
                </div>
                <div class="widget-content">
                    <div class="system-metrics">
                        <div class="metric">
                            <span class="metric-value">0</span>
                            <span class="metric-label">Total Users</span>
                        </div>
                        <div class="metric">
                            <span class="metric-value">0</span>
                            <span class="metric-label">Active Users</span>
                        </div>
                        <div class="metric">
                            <span class="metric-value">0</span>
                            <span class="metric-label">Total Articles</span>
                        </div>
                    </div>
                    <div class="system-health">
                        <div class="health-indicator excellent">
                            <span class="health-label">System Health:</span>
                            <span class="health-value">Excellent</span>
                        </div>
                        <div class="uptime-info">
                            <span class="uptime-label">Uptime:</span>
                            <span class="uptime-value">99.9%</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Admin Dashboard Grid -->
            <div class="admin-grid">
                <!-- User Management Widget -->
                <div class="dashboard-widget widget-medium">
                    <div class="widget-header">
                        <h3>👥 User Management</h3>
                        <span class="widget-icon">👤</span>
                    </div>
                    <div class="widget-content">
                        <div class="user-stats">
                            <div class="stat-item">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Total Users</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">0</span>
                                <span class="stat-text">New Users Today</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Active Users</span>
                            </div>
                        </div>
                        <div class="content-actions">
                            <button class="btn btn-primary btn-sm" onclick="manageUsers()">Manage Users</button>
                            <button class="btn btn-secondary btn-sm" onclick="viewUserReports()">View Reports</button>
                        </div>
                    </div>
                </div>

                <!-- Content Moderation Widget -->
                <div class="dashboard-widget widget-medium">
                    <div class="widget-header">
                        <h3>📝 Content Moderation</h3>
                        <span class="widget-icon">✏️</span>
                    </div>
                    <div class="widget-content">
                        <div class="moderation-stats">
                            <div class="stat-item">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Pending Reviews</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Flagged Content</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Today's Edits</span>
                            </div>
                        </div>
                        <div class="content-actions">
                            <button class="btn btn-primary btn-sm" onclick="reviewContent()">Review Content</button>
                            <button class="btn btn-secondary btn-sm" onclick="viewFlagged()">View Flagged</button>
                        </div>
                    </div>
                </div>

                <!-- Security Widget -->
                <div class="dashboard-widget widget-medium">
                    <div class="widget-header">
                        <h3>🔒 Security</h3>
                        <span class="widget-icon">🛡️</span>
                    </div>
                    <div class="widget-content">
                        <div class="security-status">
                            <div class="status-item">
                                <span class="status-label">Firewall:</span>
                                <span class="status-value active">Active</span>
                            </div>
                            <div class="status-item">
                                <span class="status-label">SSL:</span>
                                <span class="status-value active">Enabled</span>
                            </div>
                        </div>
                        <div class="security-actions">
                            <button class="btn btn-primary btn-sm" onclick="runSecurityScan()">Security Scan</button>
                            <button class="btn btn-secondary btn-sm" onclick="viewSecurityLogs()">View Logs</button>
                        </div>
                    </div>
                </div>

                <!-- Template Management Widget -->
                <div class="dashboard-widget widget-medium">
                    <div class="widget-header">
                        <h3>🔧 Template Management</h3>
                        <span class="widget-icon">📋</span>
                    </div>
                    <div class="widget-content">
                        <div class="template-stats">
                            <div class="stat-item">
                                <span class="stat-number">33</span>
                                <span class="stat-text">Total Templates</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">5</span>
                                <span class="stat-text">Template Types</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-number">9</span>
                                <span class="stat-text">Error Templates</span>
                            </div>
                        </div>
                        <div class="template-actions">
                            <a href="/templates" class="btn btn-primary btn-sm">Manage Templates</a>
                            <a href="/templates/error" class="btn btn-secondary btn-sm">Error Templates</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- User View (Hidden by default) -->
    <div id="user-view" class="dashboard-view">
        <!-- User Main Content Area -->
        <div class="user-main-content">
            <!-- User Dashboard Header -->
            <div class="user-header">
                <h1>🌟 User Dashboard</h1>
                <p>Welcome to your personalized learning and contribution center</p>
                <div class="user-controls">
                    <button class="btn btn-primary" onclick="refreshUserData()">🔄 Refresh</button>
                    <button class="btn btn-secondary" onclick="viewProfile()">👤 View Profile</button>
                    <button class="btn btn-success" onclick="startLearning()">📚 Start Learning</button>
                </div>
            </div>

            <!-- User Welcome Widget -->
            <div class="dashboard-widget widget-large">
                <div class="widget-header">
                    <h3>👋 Welcome Back!</h3>
                    <span class="widget-icon">🌟</span>
                </div>
                <div class="widget-content">
                    <div class="user-welcome-stats">
                        <div class="welcome-stat">
                            <span class="welcome-value">0</span>
                            <span class="welcome-label">Learning Streak</span>
                        </div>
                        <div class="welcome-stat">
                            <span class="welcome-value">0</span>
                            <span class="welcome-label">Articles Read</span>
                        </div>
                        <div class="welcome-stat">
                            <span class="welcome-value">0</span>
                            <span class="welcome-label">Contributions</span>
                        </div>
                    </div>
                    <div class="user-motivation">
                        <div class="motivation-text">
                            <span class="motivation-label">Today's Goal:</span>
                            <span class="motivation-value">Read 3 articles</span>
                        </div>
                        <div class="motivation-progress">
                            <span class="progress-label">Progress:</span>
                            <span class="progress-value">0/3 completed</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- User Dashboard Grid -->
            <div class="user-grid">
                <!-- Learning Progress Widget -->
                <div class="dashboard-widget widget-medium">
                    <div class="widget-header">
                        <h3>📚 Learning Progress</h3>
                        <span class="widget-icon">📖</span>
                    </div>
                    <div class="widget-content">
                        <div class="learning-stats">
                            <div class="learning-stat">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Courses Started</span>
                            </div>
                            <div class="learning-stat">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Lessons Completed</span>
                            </div>
                            <div class="learning-stat">
                                <span class="stat-number">0%</span>
                                <span class="stat-text">Overall Progress</span>
                            </div>
                        </div>
                        <div class="content-actions">
                            <button class="btn btn-primary btn-sm" onclick="continueLearning()">Continue Learning</button>
                            <button class="btn btn-secondary btn-sm" onclick="viewCourses()">Browse Courses</button>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity Widget -->
                <div class="dashboard-widget widget-medium">
                    <div class="widget-header">
                        <h3>�� Recent Activity</h3>
                        <span class="widget-icon">📋</span>
                    </div>
                    <div class="widget-content">
                        <div class="activity-list">
                            <div class="activity-item">
                                <span class="activity-icon">📖</span>
                                <span class="activity-text">No recent activity</span>
                            </div>
                        </div>
                        <div class="content-actions">
                            <button class="btn btn-primary btn-sm" onclick="viewActivity()">View All Activity</button>
                            <button class="btn btn-secondary btn-sm" onclick="startActivity()">Start New Activity</button>
                        </div>
                    </div>
                </div>

                <!-- Community Widget -->
                <div class="dashboard-widget widget-medium">
                    <div class="widget-header">
                        <h3>👥 Community</h3>
                        <span class="widget-icon">🤝</span>
                    </div>
                    <div class="widget-content">
                        <div class="community-stats">
                            <div class="community-stat">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Forum Posts</span>
                            </div>
                            <div class="community-stat">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Comments Made</span>
                            </div>
                            <div class="community-stat">
                                <span class="stat-number">0</span>
                                <span class="stat-text">Helpful Votes</span>
                            </div>
                        </div>
                        <div class="content-actions">
                            <button class="btn btn-primary btn-sm" onclick="joinDiscussion()">Join Discussion</button>
                            <button class="btn btn-secondary btn-sm" onclick="viewForums()">Browse Forums</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- User Quick Actions -->
            <div class="user-quick-actions">
                <h3>⚡ Quick Actions</h3>
                <div class="action-grid">
                    <button class="action-btn" onclick="startReading()">
                        <span class="action-icon">📖</span>
                        <span class="action-text">Start Reading</span>
                    </button>
                    <button class="action-btn" onclick="joinCourse()">
                        <span class="action-icon">🎓</span>
                        <span class="action-text">Join Course</span>
                    </button>
                    <button class="action-btn" onclick="contributeArticle()">
                        <span class="action-icon">✏️</span>
                        <span class="action-text">Write Article</span>
                    </button>
                    <button class="action-btn" onclick="askQuestion()">
                        <span class="action-icon">❓</span>
                        <span class="action-text">Ask Question</span>
                    </button>
                    <button class="action-btn" onclick="viewProgress()">
                        <span class="action-icon">📊</span>
                        <span class="action-text">View Progress</span>
                    </button>
                    <button class="action-btn" onclick="connectCommunity()">
                        <span class="action-icon">🤝</span>
                        <span class="action-text">Connect</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// View switching functionality
function switchView(viewMode) {
    // Hide all views
    document.querySelectorAll('.dashboard-view').forEach(view => {
        view.classList.remove('active');
    });
    
    // Show selected view
    document.getElementById(viewMode + '-view').classList.add('active');
    
    // Update toggle buttons
    document.querySelectorAll('.toggle-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    document.querySelector(`[data-view="${viewMode}"]`).classList.add('active');
    
    // Store preference in localStorage
    localStorage.setItem('adminDashboardView', viewMode);
}

// Load saved view preference
document.addEventListener('DOMContentLoaded', function() {
    const savedView = localStorage.getItem('adminDashboardView') || 'admin';
    switchView(savedView);
});

// Admin dashboard functions
function refreshAllWidgets() {
    location.reload();
}

function exportDashboard(format) {
    if (format === 'json') {
        alert('Dashboard data export feature coming soon!');
    }
}

function showSystemLogs() {
    alert('System logs viewer coming soon!');
}

function backupSystem() {
    alert('System backup feature coming soon!');
}

function clearCache() {
    alert('Cache clearing feature coming soon!');
}

function updateSystem() {
    alert('System update checker coming soon!');
}

function viewLogs() {
    window.location.href = '/admin/logs';
}

function manageUsers() {
    window.location.href = '/admin/users';
}

function viewUserReports() {
    window.location.href = '/admin/reports';
}

function reviewContent() {
    window.location.href = '/admin/moderation';
}

function viewFlagged() {
    window.location.href = '/admin/flagged';
}

function runSecurityScan() {
    alert('Security scan feature coming soon!');
}

function viewSecurityLogs() {
    window.location.href = '/admin/security/logs';
}

// User dashboard functions
function refreshUserData() {
    location.reload();
}

function viewProfile() {
    alert('Profile viewer coming soon!');
}

function startLearning() {
    alert('Learning system coming soon!');
}

function continueLearning() {
    alert('Continue learning feature coming soon!');
}

function viewCourses() {
    alert('Course browser coming soon!');
}

function viewActivity() {
    alert('Activity viewer coming soon!');
}

function startActivity() {
    alert('Start activity feature coming soon!');
}

function joinDiscussion() {
    alert('Discussion system coming soon!');
}

function viewForums() {
    alert('Forum browser coming soon!');
}

function startReading() {
    alert('Reading system coming soon!');
}

function joinCourse() {
    alert('Course joining feature coming soon!');
}

function contributeArticle() {
    alert('Article contribution system coming soon!');
}

function askQuestion() {
    alert('Question system coming soon!');
}

function viewProgress() {
    alert('Progress viewer coming soon!');
}

function connectCommunity() {
    alert('Community connection feature coming soon!');
}
</script>
{% endblock %}
