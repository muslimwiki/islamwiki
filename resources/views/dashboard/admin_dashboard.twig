{% extends "layouts/dashboard.twig" %}

{% block dashboard_title %}Admin Dashboard{% endblock %}

{% block dashboard_content %}
<div class="admin-dashboard">
    <!-- Admin Dashboard Header -->
    <div class="admin-header">
        <h1>🛡️ Admin Dashboard</h1>
        <p>System administration and monitoring for IslamWiki</p>
        <div class="admin-controls">
            <button class="btn btn-primary" onclick="refreshAllWidgets()">🔄 Refresh All</button>
            <button class="btn btn-secondary" onclick="exportDashboard('json')">📊 Export Data</button>
            <button class="btn btn-warning" onclick="showSystemLogs()">📋 System Logs</button>
        </div>
    </div>

    <!-- Admin Quick Actions -->
    <div class="admin-quick-actions">
        <h3>⚡ Quick Actions</h3>
        <div class="action-grid">
            <button class="action-btn" onclick="backupSystem()">
                <span class="action-icon">💾</span>
                <span class="action-text">Backup System</span>
            </button>
            <button class="action-btn" onclick="clearCache()">
                <span class="action-icon">🧹</span>
                <span class="action-text">Clear Cache</span>
            </button>
            <button class="action-btn" onclick="updateSystem()">
                <span class="action-icon">🔄</span>
                <span class="action-text">Check Updates</span>
            </button>
            <button class="action-btn" onclick="viewLogs()">
                <span class="action-icon">📋</span>
                <span class="action-text">View Logs</span>
            </button>
            <button class="action-btn" onclick="manageExtensions()">
                <span class="action-icon">🔌</span>
                <span class="action-text">Extensions</span>
            </button>
            <button class="action-btn" onclick="systemSettings()">
                <span class="action-icon">⚙️</span>
                <span class="action-text">Settings</span>
            </button>
        </div>
    </div>

    <!-- Admin Dashboard Grid -->
    <div class="admin-grid">
        <!-- System Overview Widget -->
        <div class="dashboard-widget widget-large">
            <div class="widget-header">
                <h3>📊 System Overview</h3>
                <span class="widget-icon">⚙️</span>
            </div>
            <div class="widget-content">
                <div class="system-metrics">
                    <div class="metric">
                        <span class="metric-value">0</span>
                        <span class="metric-label">Total Users</span>
                    </div>
                    <div class="metric">
                        <span class="metric-value">0</span>
                        <span class="metric-label">Active Users</span>
                    </div>
                    <div class="metric">
                        <span class="metric-value">0</span>
                        <span class="metric-label">Total Articles</span>
                    </div>
                </div>
                <div class="system-health">
                    <div class="health-indicator excellent">
                        <span class="health-label">System Health:</span>
                        <span class="health-value">Excellent</span>
                    </div>
                    <div class="uptime-info">
                        <span class="uptime-label">Uptime:</span>
                        <span class="uptime-value">99.9%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Management Widget -->
        <div class="dashboard-widget widget-medium">
            <div class="widget-header">
                <h3>👥 User Management</h3>
                <span class="widget-icon">👤</span>
            </div>
            <div class="widget-content">
                <div class="user-stats">
                    <div class="stat-item">
                        <span class="stat-number">0</span>
                        <span class="stat-text">Total Users</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">0</span>
                        <span class="stat-text">New Users Today</span>
                    </div>
                </div>
                <div class="user-actions">
                    <button class="btn btn-primary btn-sm" onclick="manageUsers()">Manage Users</button>
                    <button class="btn btn-secondary btn-sm" onclick="viewUserReports()">View Reports</button>
                </div>
            </div>
        </div>

        <!-- Content Management Widget -->
        <div class="dashboard-widget widget-medium">
            <div class="widget-header">
                <h3>📝 Content Management</h3>
                <span class="widget-icon">📄</span>
            </div>
            <div class="widget-content">
                <div class="content-stats">
                    <div class="stat-item">
                        <span class="stat-number">0</span>
                        <span class="stat-text">Total Articles</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">0</span>
                        <span class="stat-text">Pending Reviews</span>
                    </div>
                </div>
                <div class="content-actions">
                    <button class="btn btn-primary btn-sm" onclick="reviewContent()">Review Content</button>
                    <button class="btn btn-secondary btn-sm" onclick="viewFlagged()">View Flagged</button>
                </div>
            </div>
        </div>

        <!-- Security Widget -->
        <div class="dashboard-widget widget-medium">
            <div class="widget-header">
                <h3>🔒 Security</h3>
                <span class="widget-icon">🛡️</span>
            </div>
            <div class="widget-content">
                <div class="security-status">
                    <div class="status-item">
                        <span class="status-label">Firewall:</span>
                        <span class="status-value active">Active</span>
                    </div>
                    <div class="status-item">
                        <span class="status-label">SSL:</span>
                        <span class="status-value active">Enabled</span>
                    </div>
                </div>
                <div class="security-actions">
                    <button class="btn btn-primary btn-sm" onclick="runSecurityScan()">Security Scan</button>
                    <button class="btn btn-secondary btn-sm" onclick="viewSecurityLogs()">View Logs</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Admin dashboard functions
function refreshAllWidgets() {
    location.reload();
}

function exportDashboard(format) {
    if (format === 'json') {
        alert('Dashboard data export feature coming soon!');
    }
}

function showSystemLogs() {
    alert('System logs viewer coming soon!');
}

function manageUsers() {
    window.location.href = '/admin/users';
}

function viewUserReports() {
    window.location.href = '/admin/reports';
}

function reviewContent() {
    window.location.href = '/admin/moderation';
}

function viewFlagged() {
    window.location.href = '/admin/flagged';
}

function backupSystem() {
    alert('System backup feature coming soon!');
}

function clearCache() {
    alert('Cache clearing feature coming soon!');
}

function updateSystem() {
    alert('System update checker coming soon!');
}

function viewLogs() {
    window.location.href = '/admin/logs';
}

function manageExtensions() {
    window.location.href = '/admin/extensions';
}

function systemSettings() {
    window.location.href = '/admin/settings';
}

function runSecurityScan() {
    alert('Security scan feature coming soon!');
}

function viewSecurityLogs() {
    window.location.href = '/admin/security/logs';
}
</script>
{% endblock %} 