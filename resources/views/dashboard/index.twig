{% extends "layouts/app.twig" %}

{% block title %}Dashboard - IslamWiki{% endblock %}

{% block content %}
<!-- Dashboard Header -->
<div class="hero" style="background: linear-gradient(135deg, var(--success-color) 0%, #059669 100%);">
    <div class="hero-content">
        <h1>Welcome back, {{ user.username }}! 👋</h1>
        <p>Manage your contributions and explore Islamic knowledge</p>
    </div>
</div>

<!-- User Stats -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-number">0</div>
        <div class="stat-label">Pages Created</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">0</div>
        <div class="stat-label">Edits Made</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">0</div>
        <div class="stat-label">Pages Watched</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">Today</div>
        <div class="stat-label">Last Active</div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">🚀 Quick Actions</h2>
    </div>
    <div class="flex gap-4 flex-wrap">
        <a href="/pages/create" class="btn">✏️ Create New Page</a>
        <a href="/pages" class="btn btn-secondary">📚 Browse All Pages</a>
        <a href="/profile" class="btn btn-secondary">👤 Edit Profile</a>
        <a href="/contributing" class="btn btn-secondary">📖 Contributing Guide</a>
    </div>
</div>

<!-- Recent Activity -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">📈 Recent Activity</h2>
    </div>
    <div class="text-center" style="padding: 2rem;">
        <p style="color: var(--text-secondary);">No recent activity yet.</p>
        <p>Start contributing to see your activity here!</p>
        <a href="/pages/create" class="btn mt-4">Create Your First Page</a>
    </div>
</div>

<!-- Watched Pages -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">👀 Watched Pages</h2>
    </div>
    <div class="text-center" style="padding: 2rem;">
        <p style="color: var(--text-secondary);">You're not watching any pages yet.</p>
        <p>Watch pages to get notified of changes!</p>
        <a href="/pages" class="btn mt-4">Browse Pages</a>
    </div>
</div>

<!-- Your Contributions -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">🎯 Your Contributions</h2>
    </div>
    <div class="text-center" style="padding: 2rem;">
        <p style="color: var(--text-secondary);">No contributions yet.</p>
        <p>Start contributing to build your profile!</p>
        <div class="flex gap-4 justify-center mt-4">
            <a href="/pages/create" class="btn">Create Page</a>
            <a href="/pages" class="btn btn-secondary">Edit Existing</a>
        </div>
    </div>
</div>

<!-- Learning Resources -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">📚 Learning Resources</h2>
    </div>
    <div class="page-list">
        <div class="page-item">
            <h3><a href="/welcome">Welcome Guide</a></h3>
            <p class="page-excerpt">
                Learn how to use IslamWiki effectively and start contributing to the community.
            </p>
            <div class="page-meta">
                <small>🎯 Getting Started</small>
                <a href="/welcome" class="btn btn-small">Read Guide</a>
            </div>
        </div>
        
        <div class="page-item">
            <h3><a href="/contributing">Contributing Guidelines</a></h3>
            <p class="page-excerpt">
                Learn the best practices for contributing to IslamWiki and maintaining quality content.
            </p>
            <div class="page-meta">
                <small>📖 Guidelines</small>
                <a href="/contributing" class="btn btn-small">Read Guidelines</a>
            </div>
        </div>
        
        <div class="page-item">
            <h3><a href="/islamic-sciences">Islamic Sciences</a></h3>
            <p class="page-excerpt">
                Explore the rich tradition of Islamic scholarship and academic disciplines.
            </p>
            <div class="page-meta">
                <small>🔬 Academic</small>
                <a href="/islamic-sciences" class="btn btn-small">Explore Sciences</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
