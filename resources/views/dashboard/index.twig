{% extends "layouts/dashboard.twig" %}

{% block title %}IslamWiki Dashboard{% endblock %}

{% block content %}
<div class="dashboard-content">

    <!-- Key Statistics Row -->
    <div class="stats-row">
        <div class="stat-card primary">
            <div class="stat-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18,22A2,2 0 0,0 20,20V4C20,2.89 19.1,2 18,2H12V9L9.5,7.5L7,9V2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18Z"/>
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ stats.total_articles|default(2847) }}</div>
                <div class="stat-label">Total Articles</div>
                <div class="stat-change positive">+127 this month</div>
            </div>
        </div>

        <div class="stat-card primary">
            <div class="stat-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16 17V19H2V17S2 13 9 13 16 17 16 17M12.5 7.5A3.5 3.5 0 1 0 9 4A3.5 3.5 0 0 0 12.5 7.5Z"/>
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ stats.active_contributors|default(1247) }}</div>
                <div class="stat-label">Active Contributors</div>
                <div class="stat-change positive">+89 this week</div>
            </div>
        </div>

        <div class="stat-card primary">
            <div class="stat-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,12A7,7 0 0,1 12,19A7,7 0 0,1 5,12H7A5,5 0 0,0 12,17A5,5 0 0,0 17,12H19Z"/>
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ stats.verified_scholars|default(156) }}</div>
                <div class="stat-label">Verified Scholars</div>
                <div class="stat-change positive">+12 verified</div>
            </div>
        </div>

        <div class="stat-card primary">
            <div class="stat-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.87,15.07L10.33,12.56L10.36,12.53C12.1,10.59 13.34,8.36 14.07,6H17V4H10V2H8V4H1V6H12.17C11.5,7.92 10.44,9.75 9,11.35C8.07,10.32 7.3,9.19 6.69,8H4.69C5.42,9.63 6.42,11.17 7.67,12.56L2.58,17.58L4,19L9,14L12.11,17.11L12.87,15.07Z"/>
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ stats.languages|default(47) }}</div>
                <div class="stat-label">Languages</div>
                <div class="stat-change positive">+3 new languages</div>
            </div>
        </div>
    </div>

    <!-- Content Grid -->
    <div class="content-grid">
        <!-- Left Column -->
        <div class="content-column">
            <!-- Quick Actions -->
            <div class="content-card quick-actions">
                <div class="card-header">
                    <h3>Quick Actions</h3>
                    <span class="card-icon">⚡</span>
                </div>
                <div class="quick-actions-grid">
                    <a href="/wiki/create" class="action-btn">
                        <span class="action-icon">✍️</span>
                        <span class="action-text">Create Article</span>
                    </a>
                    <a href="/quran" class="action-btn">
                        <span class="action-icon">📖</span>
                        <span class="action-text">Browse Quran</span>
                    </a>
                    <a href="/hadith" class="action-btn">
                        <span class="action-icon">📜</span>
                        <span class="action-text">Search Hadith</span>
                    </a>
                    <a href="/contribute" class="action-btn">
                        <span class="action-icon">🤝</span>
                        <span class="action-text">Contribute</span>
                    </a>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="content-card recent-activity">
                <div class="card-header">
                    <h3>Recent Activity</h3>
                    <span class="card-icon">📊</span>
                </div>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-avatar">👤</div>
                        <div class="activity-content">
                            <div class="activity-text">New article published: "Islamic Ethics in Modern Times"</div>
                            <div class="activity-meta">by Ahmed Hassan • 2 hours ago</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-avatar">📚</div>
                        <div class="activity-content">
                            <div class="activity-text">Hadith collection updated with 15 new entries</div>
                            <div class="activity-meta">by Fatima Al-Zahra • 4 hours ago</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-avatar">🌍</div>
                        <div class="activity-content">
                            <div class="activity-text">New language support added: Turkish</div>
                            <div class="activity-meta">by Translation Team • 6 hours ago</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="content-column">
            <!-- Content Overview -->
            <div class="content-card content-overview">
                <div class="card-header">
                    <h3>Content Overview</h3>
                    <span class="card-icon">📊</span>
                </div>
                <div class="overview-grid">
                    <div class="overview-item">
                        <div class="overview-icon">📖</div>
                        <div class="overview-content">
                            <div class="overview-title">Quran & Tafsir</div>
                            <div class="overview-count">6,236 verses</div>
                            <div class="overview-progress">
                                <div class="progress-bar" style="width: 100%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="overview-item">
                        <div class="overview-icon">📚</div>
                        <div class="overview-content">
                            <div class="overview-title">Hadith Collections</div>
                            <div class="overview-count">12,847 hadith</div>
                            <div class="overview-progress">
                                <div class="progress-bar" style="width: 85%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="overview-item">
                        <div class="overview-icon">🕌</div>
                        <div class="overview-content">
                            <div class="overview-title">Islamic History</div>
                            <div class="overview-count">1,456 articles</div>
                            <div class="overview-progress">
                                <div class="progress-bar" style="width: 72%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="overview-item">
                        <div class="overview-icon">⚖️</div>
                        <div class="overview-content">
                            <div class="overview-title">Fiqh & Jurisprudence</div>
                            <div class="overview-count">3,289 rulings</div>
                            <div class="overview-progress">
                                <div class="progress-bar" style="width: 68%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- System Status -->
            <div class="content-card system-status">
                <div class="card-header">
                    <h3>System Status</h3>
                    <span class="card-icon">🔧</span>
                </div>
                <div class="status-list">
                    <div class="status-item">
                        <div class="status-indicator online"></div>
                        <div class="status-content">
                            <div class="status-name">Database</div>
                            <div class="status-detail">All systems operational</div>
                        </div>
                    </div>
                    <div class="status-item">
                        <div class="status-indicator online"></div>
                        <div class="status-content">
                            <div class="status-name">Search Engine</div>
                            <div class="status-detail">Indexing 99.8% complete</div>
                        </div>
                    </div>
                    <div class="status-item">
                        <div class="status-indicator online"></div>
                        <div class="status-content">
                            <div class="status-name">API Services</div>
                            <div class="status-detail">Response time: 45ms</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
