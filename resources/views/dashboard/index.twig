{% extends "layouts/app.twig" %}

{% block title %}Dashboard - IslamWiki{% endblock %}

{% block content %}
<div class="card">
    <h1>Dashboard</h1>
    <p>Welcome to your IslamWiki dashboard</p>
    
    <div style="margin: 20px 0;">
        <a href="/" class="btn">Back to Home</a>
    </div>
</div>

<!-- Interactive Dashboard Stats -->
<div class="card" x-data="{ 
    stats: {
        totalPages: 1234,
        userEdits: 42,
        watchlist: 12,
        recentActivity: []
    },
    loading: false,
    refreshStats() {
        this.loading = true;
        // Simulate API call
        setTimeout(() => {
            this.stats.totalPages = Math.floor(Math.random() * 2000) + 1000;
            this.stats.userEdits = Math.floor(Math.random() * 100) + 20;
            this.stats.watchlist = Math.floor(Math.random() * 20) + 5;
            this.loading = false;
        }, 1000);
    }
}">
    <h2>Statistics</h2>
    <button @click="refreshStats()" class="btn" :disabled="loading">
        <span x-show="!loading">Refresh Stats</span>
        <span x-show="loading">Loading...</span>
    </button>
    
    <div class="stats" style="display: flex; gap: 20px; margin: 20px 0;">
        <div class="stat-card" style="flex: 1; background: white; padding: 20px; border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <h3>Total Pages</h3>
            <p x-text="stats.totalPages"></p>
        </div>
        <div class="stat-card" style="flex: 1; background: white; padding: 20px; border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <h3>Your Edits</h3>
            <p x-text="stats.userEdits"></p>
        </div>
        <div class="stat-card" style="flex: 1; background: white; padding: 20px; border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <h3>Watchlist</h3>
            <p x-text="stats.watchlist"></p>
        </div>
    </div>
</div>

<!-- Recent Activity Section -->
<div class="card" x-data="{ 
    activities: [
        { type: 'edit', page: 'Quran', time: '2 hours ago', user: 'You' },
        { type: 'create', page: 'Hadith Collection', time: '1 day ago', user: 'You' },
        { type: 'edit', page: 'Islamic History', time: '3 days ago', user: 'Admin' }
    ],
    showActivity: true
}">
    <h2>Recent Activity</h2>
    <button @click="showActivity = !showActivity" class="btn btn-secondary">
        <span x-show="showActivity">Hide</span>
        <span x-show="!showActivity">Show</span> Activity
    </button>
    
    <div x-show="showActivity" x-transition style="margin-top: 20px;">
        <template x-for="activity in activities" :key="activity.page">
            <div style="padding: 10px; border-bottom: 1px solid #eee;">
                <strong x-text="activity.user"></strong> 
                <span x-text="activity.type === 'edit' ? 'edited' : 'created'"></span>
                <strong x-text="activity.page"></strong>
                <span x-text="activity.time" style="color: #666; font-size: 0.9em;"></span>
            </div>
        </template>
    </div>
</div>

<!-- Watchlist Section -->
<div class="card" x-data="{ 
    watchlist: [
        'Quran',
        'Hadith Collection', 
        'Islamic History',
        'Prayer Times',
        'Islamic Calendar'
    ],
    newPage: '',
    addToWatchlist() {
        if (this.newPage.trim()) {
            this.watchlist.push(this.newPage.trim());
            this.newPage = '';
        }
    },
    removeFromWatchlist(index) {
        this.watchlist.splice(index, 1);
    }
}">
    <h2>Your Watchlist</h2>
    
    <div style="margin: 20px 0;">
        <input type="text" x-model="newPage" placeholder="Add page to watchlist..." 
               @keyup.enter="addToWatchlist()"
               style="padding: 0.5rem; border: 1px solid #ccc; border-radius: 0.375rem; margin-right: 10px;">
        <button @click="addToWatchlist()" class="btn">Add</button>
    </div>
    
    <div style="margin: 20px 0;">
        <template x-for="(page, index) in watchlist" :key="index">
            <div style="padding: 10px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
                <span x-text="page"></span>
                <button @click="removeFromWatchlist(index)" 
                        style="background: #dc2626; color: white; border: none; padding: 0.25rem 0.5rem; border-radius: 0.25rem; cursor: pointer;">
                    Remove
                </button>
            </div>
        </template>
    </div>
</div>
{% endblock %}
