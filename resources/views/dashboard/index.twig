{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="home-three-column-layout full-width">
    <!-- Left Column: Quick Actions & User Stats (2/10) -->
    <div class="second-nav-column">
        <!-- User Stats -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📊 Your Stats</h2>
            </div>
            <div class="card-body">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">📄</div>
                        <div class="stat-content">
                            <div class="stat-number">{{ userStats.total_pages ?? 0 }}</div>
                            <div class="stat-label">Pages Created</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">✏️</div>
                        <div class="stat-content">
                            <div class="stat-number">{{ userStats.total_edits ?? 0 }}</div>
                            <div class="stat-label">Total Edits</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">👀</div>
                        <div class="stat-content">
                            <div class="stat-number">{{ userStats.watchlist_count ?? 0 }}</div>
                            <div class="stat-label">Pages Watched</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">⭐</div>
                        <div class="stat-content">
                            <div class="stat-number">{{ userStats.recent_activity ?? 0 }}</div>
                            <div class="stat-label">Contribution Score</div>
                        </div>
                    </div>
                </div>
                
                <!-- Contribution Actions -->
                <div class="contribution-actions">
                    <a href="/wiki/create" class="btn btn-primary">Create New Page</a>
                    <a href="/wiki" class="btn btn-outline">Edit Existing</a>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">🚀 Quick Actions</h2>
            </div>
            <div class="card-body">
                <div class="quick-actions-list">
                    <a href="/wiki/create" class="quick-action-item primary">
                        <span class="action-icon">✏️</span>
                        <span class="action-text">Create New Page</span>
                    </a>
                    <a href="/wiki" class="quick-action-item">
                        <span class="action-icon">📚</span>
                        <span class="action-text">Wiki</span>
                    </a>
                    <a href="/search" class="quick-action-item">
                        <span class="action-icon">🔍</span>
                        <span class="action-text">Search Content</span>
                    </a>
                    <a href="/profile" class="quick-action-item">
                        <span class="action-icon">👤</span>
                        <span class="action-text">Edit Profile</span>
                    </a>
                    <a href="/settings" class="quick-action-item">
                        <span class="action-icon">⚙️</span>
                        <span class="action-text">Settings</span>
                    </a>
                    <a href="/contributing" class="quick-action-item">
                        <span class="action-icon">📖</span>
                        <span class="action-text">Contributing Guide</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Middle Column: Main Content (6/10) -->
    <div class="main-content-column">
        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <div class="welcome-section">
                <div class="welcome-content">
                    <div class="welcome-text">
                        <h1 class="welcome-title">
                            {% if isLoggedIn %}
                                Welcome back, {{ user.username ?? 'User' }}! 👋
                            {% else %}
                                Welcome to IslamWiki! 🕌
                            {% endif %}
                        </h1>
                        <p class="welcome-subtitle">
                            {% if isLoggedIn %}
                                Manage your contributions and explore Islamic knowledge
                            {% else %}
                                Discover and contribute to Islamic knowledge
                            {% endif %}
                        </p>
                        <div class="welcome-meta">
                            <span class="meta-item">
                                <span class="meta-icon">🕒</span>
                                {{ currentTime }}
                            </span>
                            {% if isLoggedIn and userStats.member_since %}
                            <span class="meta-item">
                                <span class="meta-icon">📅</span>
                                Member since {{ userStats.member_since|date('M j, Y') }}
                            </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📈 Recent Activity</h2>
            </div>
            <div class="card-body">
                {% if recentActivity|length > 0 %}
                    <div class="activity-list">
                        {% for activity in recentActivity %}
                        <div class="activity-item">
                            <div class="activity-icon">
                                {% if activity.type == 'edit' %}✏️{% else %}📄{% endif %}
                            </div>
                            <div class="activity-content">
                                <div class="activity-title">
                                    <a href="/wiki/{{ activity.page_slug }}">{{ activity.page_title }}</a>
                                </div>
                                <div class="activity-meta">
                                    <span class="activity-type">{{ activity.action }}</span>
                                    <span class="activity-time">{{ activity.timestamp|date('M j, Y g:i A') }}</span>
                                </div>
                            </div>
                            <div class="activity-badge">
                                {% if activity.type == 'edit' %}
                                    <span class="badge badge-edit">Edit</span>
                                {% else %}
                                    <span class="badge badge-create">Create</span>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="activity-footer">
                        <a href="/profile" class="btn btn-outline">View All Activity</a>
                    </div>
                {% else %}
                    <div class="empty-state">
                        <div class="empty-icon">📊</div>
                        <h3>No recent activity yet</h3>
                        <p>Start contributing to see your activity here!</p>
                        <a href="/wiki/create" class="btn btn-primary">Create Your First Page</a>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Knowledge Graph (Bayan) -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">🧠 Knowledge Graph (Bayan)</h2>
            </div>
            <div class="card-body">
                {% if bayan.graph and bayan.graph.nodes|length > 0 %}
                <div class="bayan-mini-graph" style="width:100%; height:220px; border:1px solid var(--border-color); border-radius:8px; background:var(--background-color); margin-bottom:1rem; position:relative;">
                    <svg id="bayanGraphSvg" viewBox="0 0 600 200" preserveAspectRatio="xMidYMid meet" style="width:100%; height:100%;">
                        <!-- edges -->
                        {% for e in bayan.graph.edges %}
                        <line data-edge="{{ loop.index0 }}" stroke="var(--border-color)" stroke-width="1.5" x1="0" y1="0" x2="0" y2="0"></line>
                        {% endfor %}
                        <!-- nodes -->
                        {% for n in bayan.graph.nodes %}
                        <g data-node="{{ n.id }}">
                            <circle r="8" fill="{{ n.isHub ? '#3b82f6' : '#94a3b8' }}" stroke="#1f2937" stroke-width="1"></circle>
                            <text font-size="10" fill="var(--text-primary)" text-anchor="middle" dy="-12">{{ n.label|length > 18 ? n.label|slice(0,18) ~ '…' : n.label }}</text>
                        </g>
                        {% endfor %}
                    </svg>
                </div>
                {% endif %}
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">🧩</div>
                        <div class="stat-content">
                            <div class="stat-number">{{ (attribute(bayan.statistics, 'total_nodes') ?? (bayan.graph.nodes|length ?? 0)) }}</div>
                            <div class="stat-label">Nodes</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">🔗</div>
                        <div class="stat-content">
                            <div class="stat-number">{{ (attribute(bayan.statistics, 'total_edges') ?? (bayan.graph.edges|length ?? 0)) }}</div>
                            <div class="stat-label">Relationships</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">🏷️</div>
                        <div class="stat-content">
                            <div class="stat-number">{{ (attribute(bayan.statistics, 'node_types') ?? []) is iterable ? (attribute(bayan.statistics, 'node_types')|length) : ((bayan.node_types ?? [])|length) }}</div>
                            <div class="stat-label">Node Types</div>
                        </div>
                    </div>
                </div>
                <div style="margin-top:1rem;">
                    <h3 class="section-title">Top Hub Nodes</h3>
                    <ul>
                        {% for node in bayan.hub_nodes ?? [] %}
                            <li><a href="/bayan/node/{{ node.id }}">{{ node.title }}</a></li>
                        {% else %}
                            <li>No hub nodes found yet.</li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="dashboard-links" style="margin-top:1rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
                    <a class="dashboard-link" href="/bayan">Open Bayan</a>
                    <a class="dashboard-link" href="/bayan/create">Create Node</a>
                    <a class="dashboard-link" href="/bayan/search">Search</a>
                </div>
            </div>
        </div>

        <!-- Watched Pages -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">👀 Watched Pages</h2>
            </div>
            <div class="card-body">
                {% if watchlist|length > 0 %}
                    <div class="watchlist-list">
                        {% for page in watchlist %}
                        <div class="watchlist-item">
                            <div class="watchlist-icon">📖</div>
                            <div class="watchlist-content">
                                <div class="watchlist-title">
                                    <a href="/wiki/{{ page.slug }}">{{ page.title }}</a>
                                </div>
                                <div class="watchlist-meta">
                                    <span class="watchlist-date">Watched {{ page.watch_date|date('M j, Y') }}</span>
                                    <span class="watchlist-status">Active</span>
                                </div>
                            </div>
                            <div class="watchlist-actions">
                                <button class="btn btn-sm btn-outline" onclick="unwatchPage({{ page.id }})">
                                    <span>👁️</span>
                                    Unwatch
                                </button>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="watchlist-footer">
                        <a href="/wiki" class="btn btn-outline">View More Pages</a>
                    </div>
                {% else %}
                    <div class="empty-state">
                        <div class="empty-icon">👀</div>
                        <h3>You're not watching any pages yet</h3>
                        <p>Watch pages to get notified of changes!</p>
                        <a href="/wiki" class="btn btn-primary">View Pages</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Right Column: Learning Resources & Site Stats (2/10) -->
    <div class="sidebar-column">
        <!-- Learning Resources -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📚 Learning Resources</h2>
            </div>
            <div class="card-body">
                <div class="resources-list">
                    <a href="/welcome" class="resource-item">
                        <span class="resource-icon">🎯</span>
                        <div class="resource-content">
                            <h3>Welcome Guide</h3>
                            <p>Learn how to use IslamWiki effectively</p>
                        </div>
                    </a>
                    
                    <a href="/contributing" class="resource-item">
                        <span class="resource-icon">📖</span>
                        <div class="resource-content">
                            <h3>Contributing Guidelines</h3>
                            <p>Best practices for contributing</p>
                        </div>
                    </a>
                    
                    <a href="/islamic-sciences" class="resource-item">
                        <span class="resource-icon">🔬</span>
                        <div class="resource-content">
                            <h3>Islamic Sciences</h3>
                            <p>Explore Islamic scholarship</p>
                        </div>
                    </a>
                    
                    <a href="/quran" class="resource-item">
                        <span class="resource-icon">🕌</span>
                        <div class="resource-content">
                            <h3>Quran Studies</h3>
                            <p>Comprehensive Quranic resources</p>
                        </div>
                    </a>
                    
                    <a href="/hadith" class="resource-item">
                        <span class="resource-icon">📜</span>
                        <div class="resource-content">
                            <h3>Hadith Collection</h3>
                            <p>Authentic hadith collections</p>
                        </div>
                    </a>
                    
                    <a href="/prayer" class="resource-item">
                        <span class="resource-icon">🕐</span>
                        <div class="resource-content">
                            <h3>Prayer Times</h3>
                            <p>Prayer times and calendar</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <!-- Site Statistics -->
        {% if isLoggedIn %}
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📊 Site Statistics</h2>
            </div>
            <div class="card-body">
                <div class="site-stats-list">
                    <div class="site-stat-item">
                        <div class="site-stat-icon">📄</div>
                        <div class="site-stat-content">
                            <div class="site-stat-number">{{ siteStats.total_pages }}</div>
                            <div class="site-stat-label">Total Pages</div>
                        </div>
                    </div>
                    <div class="site-stat-item">
                        <div class="site-stat-icon">👥</div>
                        <div class="site-stat-content">
                            <div class="site-stat-number">{{ siteStats.total_users }}</div>
                            <div class="site-stat-label">Active Users</div>
                        </div>
                    </div>
                    <div class="site-stat-item">
                        <div class="site-stat-icon">✏️</div>
                        <div class="site-stat-content">
                            <div class="site-stat-number">{{ siteStats.total_edits }}</div>
                            <div class="site-stat-label">Total Edits</div>
                        </div>
                    </div>
                    <div class="site-stat-item">
                        <div class="site-stat-icon">📚</div>
                        <div class="site-stat-content">
                            <div class="site-stat-number">{{ siteStats.total_categories }}</div>
                            <div class="site-stat-label">Categories</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>

<style>
/* Dashboard Header */
.dashboard-header {
    margin-bottom: 2rem;
}

.welcome-section {
    text-align: center;
    padding: 2rem;
    background: var(--card-background);
    border-radius: 1rem;
    border: 1px solid var(--border-color);
}

.welcome-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.welcome-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 1rem;
}

.welcome-meta {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.meta-icon {
    font-size: 1rem;
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.stat-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.stat-card:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.stat-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.stat-content {
    flex: 1;
}

.stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
}

.stat-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 500;
}

/* Contribution Actions */
.contribution-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.contribution-actions .btn {
    flex: 1;
    min-width: 120px;
}

/* Quick Actions */
.quick-actions-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.quick-action-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--background-color);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.3s ease;
}

.quick-action-item:hover {
    border-color: var(--primary-color);
    background: var(--card-background);
    transform: translateY(-1px);
    text-decoration: none;
    color: var(--text-primary);
}

.quick-action-item.primary {
    background: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
}

.quick-action-item.primary:hover {
    background: var(--primary-hover);
    color: white;
}

.action-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
}

.action-text {
    font-weight: 500;
}

/* Activity List */
.activity-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.activity-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.activity-item:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.activity-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.activity-content {
    flex: 1;
}

.activity-title a {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
}

.activity-title a:hover {
    color: var(--primary-hover);
}

.activity-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
}

.activity-type {
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.activity-time {
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.activity-badge {
    flex-shrink: 0;
}

.badge {
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.8rem;
    font-weight: 500;
}

.badge-edit {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
}

.badge-create {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
}

/* Watchlist */
.watchlist-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.watchlist-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.watchlist-item:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.watchlist-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.watchlist-content {
    flex: 1;
}

.watchlist-title a {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
}

.watchlist-title a:hover {
    color: var(--primary-hover);
}

.watchlist-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
}

.watchlist-date {
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.watchlist-status {
    color: #22c55e;
    font-size: 0.8rem;
    font-weight: 500;
}

.watchlist-actions {
    flex-shrink: 0;
}

/* Resources */
.resources-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.resource-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.3s ease;
}

.resource-item:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--text-primary);
}

.resource-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.resource-content h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
}

.resource-content p {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin: 0;
}

/* Site Stats */
.site-stats-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.site-stat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
}

.site-stat-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.site-stat-content {
    flex: 1;
}

.site-stat-number {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
}

.site-stat-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

/* Empty States */
.empty-state {
    text-align: center;
    padding: 2rem;
}

.empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

.empty-state h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.empty-state p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
}

.empty-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

/* Responsive Design */
@media (max-width: 768px) {
    .stats-grid {
        grid-template-columns: 1fr;
    }
    
    .contribution-actions {
        flex-direction: column;
    }
    
    .welcome-title {
        font-size: 1.5rem;
    }
    
    .welcome-meta {
        flex-direction: column;
        gap: 0.5rem;
    }
}

@media (max-width: 480px) {
    .activity-meta {
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .watchlist-meta {
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .empty-actions {
        flex-direction: column;
    }
}
</style>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize dashboard functionality
    initializeDashboard();
});

function initializeDashboard() {
    // Add any dashboard-specific JavaScript here
    console.log('Dashboard initialized');
    try { initBayanMiniGraph(); } catch (e) { console.warn('Bayan mini-graph init failed', e); }
}

