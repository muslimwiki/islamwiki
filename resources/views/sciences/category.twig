{% extends "layouts/app.twig" %}

{% block title %}{{ category.title }} - Sciences - IslamWiki{% endblock %}

{% block content %}
<div class="sciences-container">
    <!-- Category Header -->
    <div class="sciences-header">
        <div class="sciences-header-content">
            <h1 class="sciences-title">{{ category.title }}</h1>
            <p class="sciences-description">{{ category.description }}</p>
        </div>
    </div>

    <!-- Category Content -->
    <div class="container mx-auto px-4 py-8">
        <div class="category-content">
            <div class="content-section">
                <h2 class="section-title">Overview</h2>
                <p class="content-text">{{ category.content }}</p>
            </div>

            <div class="topics-section">
                <h2 class="section-title">Key Topics</h2>
                <div class="topics-grid">
                    {% for topic in category.topics %}
                        <div class="topic-card">
                            <span class="topic-name">{{ topic }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="navigation-section">
                <a href="/sciences" class="back-button">
                    <span class="back-icon">←</span>
                    <span class="back-text">Back to Sciences</span>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
/* Sciences Category Styling */

.sciences-container {
    min-height: 100vh;
    background: linear-gradient(135deg, var(--background-color) 0%, rgba(79, 70, 229, 0.05) 100%);
}

.sciences-header {
    background: linear-gradient(135deg, var(--primary-color) 0%, #7c3aed 100%);
    color: white;
    padding: 3rem 0;
    text-align: center;
}

.sciences-header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
}

.sciences-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    color: white;
}

.sciences-description {
    font-size: 1.2rem;
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0.95;
    color: white;
}

.category-content {
    max-width: 1000px;
    margin: 0 auto;
}

.content-section {
    background: var(--card-background);
    border-radius: 1.5rem;
    padding: 2.5rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
}

.section-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 1.5rem 0;
}

.content-text {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1.1rem;
    margin: 0;
}

.topics-section {
    background: var(--card-background);
    border-radius: 1.5rem;
    padding: 2.5rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
}

.topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
}

.topic-card {
    background: var(--background-color);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 1rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
}

.topic-card:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.topic-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1rem;
}

.navigation-section {
    text-align: center;
    margin-top: 3rem;
}

.back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--primary-color) 0%, #7c3aed 100%);
    color: white;
    text-decoration: none;
    border-radius: 1rem;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 6px 20px rgba(79, 70, 229, 0.3);
}

.back-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(79, 70, 229, 0.4);
    color: white;
    text-decoration: none;
}

.back-icon {
    font-size: 1.2rem;
}

.back-text {
    font-size: 1.1rem;
}

/* Responsive Design */
@media (max-width: 768px) {
    .sciences-title {
        font-size: 2.5rem;
    }
    
    .sciences-description {
        font-size: 1rem;
    }
    
    .content-section,
    .topics-section {
        padding: 1.5rem;
    }
    
    .section-title {
        font-size: 1.5rem;
    }
    
    .topics-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}
