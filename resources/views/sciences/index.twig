{% extends "layouts/app.twig" %}

{% block title %}{{ title }} - IslamWiki{% endblock %}

{% block content %}
<div class="sciences-container">
    <!-- Sciences Header -->
    <div class="sciences-header">
        <div class="sciences-header-content">
            <h1 class="sciences-title">{{ title }}</h1>
            <p class="sciences-description">{{ description }}</p>
        </div>
    </div>

    <!-- Sciences Grid -->
    <div class="container mx-auto px-4 py-8">
        <div class="sciences-grid">
            {% for key, science in sciences %}
                <div class="science-card">
                    <div class="science-icon">{{ science.icon }}</div>
                    <div class="science-content">
                        <h3 class="science-title">
                            <a href="{{ science.url }}" class="science-link">{{ science.title }}</a>
                        </h3>
                        <p class="science-description">{{ science.description }}</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

{% endblock %}
