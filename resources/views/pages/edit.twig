{% extends 'layouts/app.twig' %}

{% block title %}{{ isNew ? 'Create' : 'Edit' }}: {{ title }} - IslamWiki{% endblock %}

{% block styles %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.css">
{% endblock %}

{% block content %}
    <div class="edit-container">
        <div class="edit-header">
            <h1 class="edit-title">
                {% if isNew %}
                    <span>✨ Create New Page</span>
                {% else %}
                    <span>✏️ Edit: {{ page.getAttribute('title') }}</span>
                {% endif %}
            </h1>
            <p class="edit-subtitle">
                {% if isNew %}
                    Create a new page to share knowledge with the community
                {% else %}
                    Make changes to this page and save your edits
                {% endif %}
            </p>
        </div>
        
        <div class="edit-content">
            {% set displaySlug = page.getAttribute('slug') %}
            {% if ':' in page.getAttribute('slug') %}
                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
            {% endif %}
            <form method="POST" action="{{ isNew ? (locale ? '/' ~ locale ~ '/wiki' : '/en/wiki') : (locale ? '/' ~ locale ~ '/wiki/' ~ displaySlug : '/en/wiki/' ~ displaySlug) }}">
                {% if not isNew %}
                    <input type="hidden" name="_method" value="PUT">
                {% endif %}
                
                <div class="form-section">
                    <div class="form-group">
                        <label for="title" class="form-label">📝 Page Title</label>
                        <input type="text" name="title" id="title" required
                               class="form-control {{ errors.title ? 'error' : '' }}"
                               value="{{ isNew ? title : page.getAttribute('title') }}" 
                               {{ not isNew and page.getAttribute('is_locked') ? 'readonly' : '' }}
                               placeholder="Enter page title...">
                        {% if errors.title %}
                            <div class="form-error">{{ errors.title }}</div>
                        {% endif %}
                    </div>
                    
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="namespace" class="form-label">📁 Namespace</label>
                            <select id="namespace" name="namespace" class="form-control">
                                <option value="">(Main)</option>
                                <option value="Help" {{ (isNew ? namespace : page.getAttribute('namespace')) == 'Help' ? 'selected' : '' }}>Help</option>
                                <option value="User" {{ (isNew ? namespace : page.getAttribute('namespace')) == 'User' ? 'selected' : '' }}>User</option>
                                <option value="Template" {{ (isNew ? namespace : page.getAttribute('namespace')) == 'Template' ? 'selected' : '' }}>Template</option>
                                <option value="Category" {{ (isNew ? namespace : page.getAttribute('namespace')) == 'Category' ? 'selected' : '' }}>Category</option>
                            </select>
                            <div class="form-help">Choose a namespace to organize your content</div>
                        </div>
                        
                        <div class="form-group">
                            <label for="content_format" class="form-label">📄 Format</label>
                            <select id="content_format" name="content_format" class="form-control">
                                <option value="markdown" {{ (isNew ? 'markdown' : page.getAttribute('content_format')) == 'markdown' ? 'selected' : '' }}>Markdown</option>
                                <option value="html" {{ (isNew ? 'markdown' : page.getAttribute('content_format')) == 'html' ? 'selected' : '' }}>HTML</option>
                                <option value="wikitext" {{ (isNew ? 'markdown' : page.getAttribute('content_format')) == 'wikitext' ? 'selected' : '' }}>WikiText</option>
                            </select>
                            <div class="form-help">Select the content format for your page</div>
                        </div>
                    </div>
                </div>
                
                <div class="form-section">
                    <div class="form-group">
                        <label for="content" class="form-label">📝 Content</label>
                        <div class="editor-wrapper">
                            <textarea id="content" name="content" rows="20" class="hidden">{{ isNew ? '' : page.getAttribute('content') }}</textarea>
                            <div id="editor"></div>
                        </div>
                        {% if errors.content %}
                            <div class="form-error">{{ errors.content }}</div>
                        {% endif %}
                    </div>
                </div>
                
                <div class="form-section">
                    <div class="form-group">
                        <label for="comment" class="form-label">💬 Edit Summary</label>
                        <input type="text" name="comment" id="comment" 
                               class="form-control"
                               placeholder="{% if isNew %}Describe what this page is about...{% else %}Briefly describe what you changed...{% endif %}">
                        <div class="form-help">
                            {% if isNew %}
                                Provide a brief description of what this page will contain
                            {% else %}
                                Help other editors understand your changes
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <div class="form-actions">
                    <a href="{{ isNew ? (locale ? '/' ~ locale : '/en') : (locale ? '/' ~ locale ~ '/wiki/' ~ displaySlug : '/en/wiki/' ~ displaySlug) }}" 
                       class="btn btn-secondary">
                        <span>❌</span>
                        Cancel
                    </a>
                    <button type="submit" 
                            class="btn btn-primary"
                            {{ not isNew and page.getAttribute('is_locked') ? 'disabled' : '' }}>
                        <span>💾</span>
                        {{ isNew ? 'Create Page' : 'Save Changes' }}
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    {% if not isNew %}
    <div class="page-tools">
        <div class="page-tools-header">
            <h3 class="page-tools-title">🔧 Page Tools</h3>
        </div>
        <div class="page-tools-content">
            <ul class="tools-list">
                <li class="tools-item">
                    {% set displaySlug = page.getAttribute('slug') %}
                    {% if ':' in page.getAttribute('slug') %}
                        {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                    {% endif %}
                    <a href="/wiki/{{ displaySlug }}/history" class="tools-link">
                        <span>📚</span>
                        View page history
                    </a>
                </li>
                {% if not page.isLocked and canLock %}
                <li class="tools-item">
                    <form action="/wiki/{{ page.slug }}/lock" method="POST" class="inline">
                        <button type="submit" class="tools-button">
                            <span>🔒</span>
                            Lock this page
                        </button>
                    </form>
                </li>
                {% endif %}
                {% if canDelete %}
                <li class="tools-item">
                    <form action="/wiki/{{ page.slug }}" method="POST" class="inline"
                          onsubmit="return confirm('Are you sure you want to delete this page? This cannot be undone.');">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="tools-button danger">
                            <span>🗑️</span>
                            Delete this page
                        </button>
                    </form>
                </li>
                {% endif %}
            </ul>
        </div>
    </div>
    {% endif %}
{% endblock %}

{% block scripts %}
    <script src="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const simplemde = new SimpleMDE({
                element: document.getElementById('content'),
                spellChecker: false,
                autofocus: true,
                placeholder: 'Enter your content here... Use Markdown formatting for rich text.',
                status: false,
                toolbar: [
                    'bold', 'italic', 'heading', '|',
                    'quote', 'unordered-list', 'ordered-list', '|',
                    'link', 'image', 'table', '|',
                    'preview', 'side-by-side', 'fullscreen', '|',
                    'guide'
                ],
                theme: 'default'
            });
            
            // Handle form submission with SimpleMDE content
            document.querySelector('form').addEventListener('submit', function(e) {
                document.getElementById('content').value = simplemde.value();
            });
            
            // Update preview when format changes
            document.getElementById('content_format').addEventListener('change', function() {
                console.log('Format changed to:', this.value);
            });
            
            // Add smooth animations
            const editContainer = document.querySelector('.edit-container');
            if (editContainer) {
                editContainer.style.opacity = '0';
                editContainer.style.transform = 'translateY(20px)';
                
                setTimeout(() => {
                    editContainer.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
                    editContainer.style.opacity = '1';
                    editContainer.style.transform = 'translateY(0)';
                }, 100);
            }
        });
    </script>
{% endblock %}
