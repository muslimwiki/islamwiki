{% extends "layouts/app.twig" %}

{% block title %}Welcome - IslamWiki{% endblock %}

{% block content %}
<div class="card">
        <h1>Welcome to IslamWiki</h1>
    <p>Your Islamic knowledge base and resource center</p>
    
    <div style="margin: 30px 0;">
        <a href="/dashboard" class="btn">Go to Dashboard</a>
    </div>
</div>

<!-- Alpine.js Interactive Example -->
<div class="card" x-data="{ 
    count: 0,
    message: 'Welcome to IslamWiki!',
    showAlert: false,
    alertMessage: '',
    alertType: 'info'
}">
    <h2>Interactive Demo</h2>
    <p>This demonstrates Alpine.js functionality:</p>
    
    <div style="margin: 20px 0;">
        <p><strong>Counter:</strong> <span x-text="count"></span></p>
        <button @click="count++" class="btn">Increment</button>
        <button @click="count--" class="btn btn-secondary">Decrement</button>
        <button @click="count = 0" class="btn btn-secondary">Reset</button>
    </div>
    
    <div style="margin: 20px 0;">
        <p><strong>Message:</strong> <span x-text="message"></span></p>
        <input type="text" x-model="message" placeholder="Type a message..." 
               style="padding: 0.5rem; border: 1px solid #ccc; border-radius: 0.375rem; margin-right: 10px;">
    </div>
    
    <div style="margin: 20px 0;">
        <button @click="alertType = 'success'; alertMessage = 'Success message!'; showAlert = true" 
                class="btn">Show Success Alert</button>
        <button @click="alertType = 'error'; alertMessage = 'Error message!'; showAlert = true" 
                class="btn btn-secondary">Show Error Alert</button>
        <button @click="alertType = 'info'; alertMessage = 'Info message!'; showAlert = true" 
                class="btn btn-secondary">Show Info Alert</button>
    </div>
    
    <!-- Alert Component -->
    <div x-show="showAlert" x-transition class="alert" 
         :class="{
             'alert-success': alertType === 'success',
             'alert-error': alertType === 'error',
             'alert-info': alertType === 'info'
         }">
        <span x-text="alertMessage"></span>
        <button @click="showAlert = false" style="float: right; background: none; border: none; font-size: 1.2em; cursor: pointer;">×</button>
    </div>
</div>

<div class="card">
    <h2>Features</h2>
    <ul>
        <li>Modern, responsive design</li>
        <li>Alpine.js for lightweight interactivity</li>
        <li>Twig templating for server-side rendering</li>
        <li>PSR-7 compatible HTTP handling</li>
        <li>Dependency injection container</li>
        <li>Comprehensive error handling and logging</li>
    </ul>
</div>
{% endblock %}
