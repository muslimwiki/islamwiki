{% extends "layouts/app.twig" %}

{% block title %}{{ title|default('Welcome to IslamWiki') }} - IslamWiki{% endblock %}

{% block styles %}
{% endblock %}

{% block content %}
<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">{{ title|default('Welcome to IslamWiki') }}</h1>
        
        <!-- Language Switcher -->
        {% if availableLanguages and availableLanguages|length > 1 %}
        <div class="language-switcher">
            <span class="language-switcher-label">Language:</span>
            {% for langCode, langName in availableLanguages %}
                {% if langCode == currentLanguage %}
                    <span class="language-option active">{{ langName }}</span>
                {% else %}
                    <a href="?lang={{ langCode }}" class="language-option">{{ langName }}</a>
                {% endif %}
            {% endfor %}
        </div>
        {% endif %}
        <div class="page-meta">
            {% if page.namespace %}
                <div class="page-meta-item">
                    <span class="page-meta-icon">📁</span>
                    <span>{{ page.namespace }}</span>
                </div>
            {% endif %}
            {# removed view counter per request #}
            <div class="page-meta-item">
                <span class="page-meta-icon">📅</span>
                <span>Last edited: {{ page.updated_at|date('M j, Y') }}</span>
            </div>
        </div>
    </div>

    <div class="page-content">
        {{ content|raw }}
    </div>

    <div class="page-actions">
        {% if canEdit %}
            {% set displaySlug = page.slug %}
            {% if ':' in page.slug %}
                {% set displaySlug = page.slug|split(':')|last %}
            {% endif %}
            <a href="/create?title={{ displaySlug }}" class="btn btn-primary">
                <span>✏️</span>
                Edit Page
            </a>
        {% endif %}
        
        {% if canDelete %}
            {% set displaySlug = page.slug %}
            {% if ':' in page.slug %}
                {% set displaySlug = page.slug|split(':')|last %}
            {% endif %}
            <a href="/wiki/{{ displaySlug }}/delete" class="btn btn-danger" 
               onclick="return confirm('Are you sure you want to delete this page?')">
                <span>🗑️</span>
                Delete Page
            </a>
        {% endif %}
        
        {% if canLock %}
            {% set displaySlug = page.slug %}
            {% if ':' in page.slug %}
                {% set displaySlug = page.slug|split(':')|last %}
            {% endif %}
            {% if page.is_locked %}
                <a href="/wiki/{{ displaySlug }}/unlock" class="btn btn-warning">
                    <span>🔓</span>
                    Unlock Page
                </a>
            {% else %}
                <a href="/wiki/{{ displaySlug }}/lock" class="btn btn-warning">
                    <span>🔒</span>
                    Lock Page
                </a>
            {% endif %}
        {% endif %}
        
        {% set displaySlug = page.slug %}
        {% if ':' in page.slug %}
            {% set displaySlug = page.slug|split(':')|last %}
        {% endif %}
        <a href="/wiki/{{ displaySlug }}/history" class="btn btn-secondary">
            <span>📚</span>
            View History
        </a>

        {# Watch/Unwatch #}
        <form id="watchForm" method="POST" action="/wiki/{{ displaySlug }}/watch" style="display:none;">
            <input type="hidden" name="_token" value="{{ csrf_token }}" />
        </form>
        <form id="unwatchForm" method="POST" action="/wiki/{{ displaySlug }}/unwatch" style="display:none;">
            <input type="hidden" name="_token" value="{{ csrf_token }}" />
        </form>
        {% if isWatched %}
            <a href="/wiki/{{ displaySlug }}/unwatch" class="btn btn-outline" title="Unwatch this page">
                <span>🚫</span>
                Unwatch
            </a>
        {% else %}
            <a href="/wiki/{{ displaySlug }}/watch" class="btn btn-outline" title="Watch this page">
                <span>👁️</span>
                Watch
            </a>
        {% endif %}
    </div>

    {% if latestRevision %}
    <div class="page-revision-info">
        <small>
            <span class="page-revision-icon">👤</span>
            Last edited by {{ latestRevision.author_name ?? 'Unknown' }} 
            on {{ latestRevision.created_at|date('M j, Y \a\t g:i A') }}
            {% if latestRevision.comment %}
                - {{ latestRevision.comment }}
            {% endif %}
        </small>
    </div>
    {% endif %}
</div>
{% endblock %} 