{% extends "layouts/app.twig" %}

{% block title %}{{ page.getAttribute('title') }} - IslamWiki{% endblock %}

{% block styles %}
<style>
    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
        background: var(--page-bg, #ffffff);
        border-radius: var(--page-radius, 1rem);
        box-shadow: 0 4px 6px -1px #0000001a;
        margin-bottom: 2rem;
    }
    
    .page-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid var(--page-border-light, #f3f4f6);
        position: relative;
    }
    
    .page-header::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 50%;
        transform: translateX(-50%);
        width: 100px;
        height: 2px;
        background: var(--page-accent, linear-gradient(135deg, #1E40AF 0%, #3B82F6 100%));
        border-radius: 1px;
    }
    
    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--page-text, #1f2937);
        margin: 0 0 1rem 0;
        line-height: 1.2;
    }
    
    .page-meta {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }
    
    .page-meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: var(--page-text-light, #6b7280);
        padding: 0.5rem 1rem;
        background: var(--page-bg-light, #f9fafb);
        border-radius: var(--page-radius-sm, 0.75rem);
        border: 1px solid var(--page-border-light, #f3f4f6);
    }
    
    .page-meta-icon {
        font-size: 1rem;
    }
    
    .page-content {
        text-align: left;
        line-height: 1.8;
        font-size: 1.1rem;
        color: var(--page-text, #1f2937);
        margin-bottom: 3rem;
    }
    
    .page-content h1,
    .page-content h2,
    .page-content h3,
    .page-content h4,
    .page-content h5,
    .page-content h6 {
        color: var(--page-text, #1f2937);
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }
    
    .page-content h1 {
        font-size: 2rem;
        border-bottom: 2px solid var(--page-border, #e5e7eb);
        padding-bottom: 0.5rem;
    }
    
    .page-content h2 {
        font-size: 1.75rem;
        border-bottom: 1px solid var(--page-border-light, #f3f4f6);
        padding-bottom: 0.25rem;
    }
    
    .page-content h3 {
        font-size: 1.5rem;
    }
    
    .page-content p {
        margin-bottom: 1.5rem;
    }
    
    .page-content ul,
    .page-content ol {
        margin-bottom: 1.5rem;
        padding-left: 2rem;
    }
    
    .page-content li {
        margin-bottom: 0.5rem;
    }
    
    .page-content blockquote {
        border-left: 4px solid var(--page-primary, #1E40AF);
        padding-left: 1.5rem;
        margin: 2rem 0;
        font-style: italic;
        color: var(--page-text-light, #6b7280);
    }
    
    .page-content code {
        background: var(--page-bg-light, #f9fafb);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.9rem;
    }
    
    .page-content pre {
        background: var(--page-bg-light, #f9fafb);
        padding: 1.5rem;
        border-radius: var(--page-radius-sm, 0.75rem);
        overflow-x: auto;
        margin: 2rem 0;
        border: 1px solid var(--page-border, #e5e7eb);
    }
    
    .page-content pre code {
        background: none;
        padding: 0;
    }
    
    .page-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        border-radius: var(--page-radius-sm, 0.75rem);
        overflow: hidden;
        box-shadow: 0 4px 6px -1px #0000001a;
    }
    
    .page-content th,
    .page-content td {
        padding: 1rem;
        text-align: left;
        border-bottom: 1px solid var(--page-border-light, #f3f4f6);
    }
    
    .page-content th {
        background: var(--page-bg-light, #f9fafb);
        font-weight: 600;
        color: var(--page-text, #1f2937);
    }
    
    .page-content tr:hover {
        background: var(--page-bg-light, #f9fafb);
    }
    
    .page-actions {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin: 3rem 0;
        padding: 2rem;
        background: var(--page-bg-light, #f9fafb);
        border-radius: var(--page-radius-sm, 0.75rem);
        border: 1px solid var(--page-border-light, #f3f4f6);
    }
    
    .page-actions .btn {
        min-width: 120px;
        justify-content: center;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        border: 1px solid var(--border-color);
        border-radius: 0.5rem;
        background: var(--background-color);
        color: var(--text-primary);
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .page-actions .btn:hover {
        border-color: var(--primary-color);
        background: var(--card-background);
        text-decoration: none;
        color: var(--text-primary);
    }

    .page-actions .btn-primary {
        background: var(--primary-color);
        color: #fff;
        border-color: var(--primary-color);
    }
    .page-actions .btn-primary:hover {
        background: var(--primary-hover);
        color: #fff;
    }
    .page-actions .btn-secondary {
        background: var(--card-background);
        color: var(--text-primary);
    }
    .page-actions .btn-outline {
        background: transparent;
        color: var(--text-primary);
    }
    
    .page-revision-info {
        text-align: center;
        margin-top: 2rem;
        padding: 1rem;
        background: var(--page-bg-light, #f9fafb);
        border-radius: var(--page-radius-sm, 0.75rem);
        border: 1px solid var(--page-border-light, #f3f4f6);
        color: var(--page-text-light, #6b7280);
        font-size: 0.9rem;
    }
    
    .page-revision-info small {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    
    .page-revision-icon {
        font-size: 1rem;
    }
    
    @media (max-width: 1200px) {
        .page-container {
            max-width: 95%;
            margin: 0 auto;
        }
    }
    
    @media (max-width: 768px) {
        .page-container {
            padding: 1rem;
            margin: 1rem;
            max-width: 95%;
        }
        
        .page-title {
            font-size: 2rem;
        }
        
        .page-meta {
            flex-direction: column;
            gap: 1rem;
        }
        
        .page-actions {
            flex-direction: column;
            align-items: center;
        }
        
        .page-actions .btn {
            width: 100%;
            max-width: 300px;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">{{ page.getAttribute('title') }}</h1>
        <div class="page-meta">
            {% if page.getAttribute('namespace') %}
                <div class="page-meta-item">
                    <span class="page-meta-icon">📁</span>
                    <span>{{ page.getAttribute('namespace') }}</span>
                </div>
            {% endif %}
            <div class="page-meta-item">
                <span class="page-meta-icon">👁️</span>
                <span>{{ page.getAttribute('view_count') }} views</span>
            </div>
            <div class="page-meta-item">
                <span class="page-meta-icon">📅</span>
                <span>Last edited: {{ page.getAttribute('updated_at')|date('M j, Y') }}</span>
            </div>
        </div>
    </div>

    <div class="page-content">
        {{ content|raw }}
    </div>

    <div class="page-actions">
        {% if canEdit %}
            {% set displaySlug = page.getAttribute('slug') %}
            {% if ':' in page.getAttribute('slug') %}
                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
            {% endif %}
            <a href="/wiki/{{ displaySlug }}/edit" class="btn btn-primary">
                <span>✏️</span>
                Edit Page
            </a>
        {% endif %}
        
        {% if canDelete %}
            {% set displaySlug = page.getAttribute('slug') %}
            {% if ':' in page.getAttribute('slug') %}
                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
            {% endif %}
            <a href="/wiki/{{ displaySlug }}/delete" class="btn btn-danger" 
               onclick="return confirm('Are you sure you want to delete this page?')">
                <span>🗑️</span>
                Delete Page
            </a>
        {% endif %}
        
        {% if canLock %}
            {% set displaySlug = page.getAttribute('slug') %}
            {% if ':' in page.getAttribute('slug') %}
                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
            {% endif %}
            {% if page.getAttribute('is_locked') %}
                <a href="/wiki/{{ displaySlug }}/unlock" class="btn btn-warning">
                    <span>🔓</span>
                    Unlock Page
                </a>
            {% else %}
                <a href="/wiki/{{ displaySlug }}/lock" class="btn btn-warning">
                    <span>🔒</span>
                    Lock Page
                </a>
            {% endif %}
        {% endif %}
        
        {% set displaySlug = page.getAttribute('slug') %}
        {% if ':' in page.getAttribute('slug') %}
            {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
        {% endif %}
        <a href="/wiki/{{ displaySlug }}/history" class="btn btn-secondary">
            <span>📚</span>
            View History
        </a>

        {# Watch/Unwatch #}
        <form id="watchForm" method="POST" action="/wiki/{{ displaySlug }}/watch" style="display:none;">
            <input type="hidden" name="_token" value="{{ csrf_token }}" />
        </form>
        <form id="unwatchForm" method="POST" action="/wiki/{{ displaySlug }}/unwatch" style="display:none;">
            <input type="hidden" name="_token" value="{{ csrf_token }}" />
        </form>
        {% if isWatched %}
            <a href="/wiki/{{ displaySlug }}/unwatch" class="btn btn-outline" title="Unwatch this page">
                <span>🚫</span>
                Unwatch
            </a>
        {% else %}
            <a href="/wiki/{{ displaySlug }}/watch" class="btn btn-outline" title="Watch this page">
                <span>👁️</span>
                Watch
            </a>
        {% endif %}
    </div>

    {% if latestRevision %}
    <div class="page-revision-info">
        <small>
            <span class="page-revision-icon">👤</span>
            Last edited by {{ latestRevision.author_name ?? 'Unknown' }} 
            on {{ latestRevision.created_at|date('M j, Y \a\t g:i A') }}
            {% if latestRevision.comment %}
                - {{ latestRevision.comment }}
            {% endif %}
        </small>
    </div>
    {% endif %}
</div>
{% endblock %} 