{% extends 'layouts/app.twig' %}

{% block title %}All Pages - IslamWiki{% endblock %}

{% block content %}
<div class="home-three-column-layout full-width">
    <!-- Left Column: Create New Content (2/10) -->
    <div class="second-nav-column">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">
                    {% if locale == 'ar' %}📝 إنشاء المحتوى{% else %}📝 Create Content{% endif %}
                </h2>
            </div>
            <div class="flex gap-4 flex-wrap">
                <a href="{{ lang_url('wiki/create') }}" class="btn">
                    {% if locale == 'ar' %}✏️ إنشاء صفحة جديدة{% else %}✏️ Create New Page{% endif %}
                </a>
                <a href="{{ lang_url('wiki/create?template=article') }}" class="btn btn-secondary">
                    {% if locale == 'ar' %}📄 قالب المقال{% else %}📄 Article Template{% endif %}
                </a>
                <a href="{{ lang_url('wiki/create?template=guide') }}" class="btn btn-secondary">
                    {% if locale == 'ar' %}📚 قالب الدليل{% else %}📚 Guide Template{% endif %}
                </a>
                <a href="{{ lang_url('wiki/create?template=reference') }}" class="btn btn-secondary">
                    {% if locale == 'ar' %}📖 قالب المرجع{% else %}📖 Reference Template{% endif %}
                </a>
            </div>
        </div>

        <!-- Stats Section -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">
                    {% if locale == 'ar' %}📊 إحصائيات الصفحات{% else %}📊 Page Statistics{% endif %}
                </h2>
            </div>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">📄</div>
                    <div class="stat-content">
                        <div class="stat-number">{{ pagination.total }}</div>
                        <div class="stat-label">
                            {% if locale == 'ar' %}إجمالي الصفحات{% else %}Total Pages{% endif %}
                        </div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">👥</div>
                    <div class="stat-content">
                        <div class="stat-number">{{ pages|length }}</div>
                        <div class="stat-label">
                            {% if locale == 'ar' %}المعروض{% else %}Showing{% endif %}
                        </div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">📊</div>
                    <div class="stat-content">
                        <div class="stat-number">{{ pagination.current_page }}</div>
                        <div class="stat-label">
                            {% if locale == 'ar' %}الصفحة الحالية{% else %}Current Page{% endif %}
                        </div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🔍</div>
                    <div class="stat-content">
                        <div class="stat-number">{{ filters.search ? 'Active' : 'None' }}</div>
                        <div class="stat-label">
                            {% if locale == 'ar' %}فلتر البحث{% else %}Search Filter{% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Middle Column: Main Content - Pages List (6/10) -->
    <div class="main-content-column">
        <!-- Hero Section -->
        <div class="hero">
            <div class="hero-content">
                {% if locale == 'ar' %}
                    <h1>📚 جميع الصفحات</h1>
                    <p>استكشف واكتشف جميع صفحات الموسوعة في النظام</p>
                {% else %}
                    <h1>📚 All Pages</h1>
                    <p>Explore and discover all wiki pages in the system</p>
                {% endif %}
            </div>
        </div>

        <!-- Pages List -->
        <div class="pages-list">
            {% if pages is empty %}
                <div class="card">
                    <div class="card-body">
                        <div class="empty-state">
                            <div class="empty-icon">📭</div>
                            <h3>No pages found</h3>
                            <p>No pages match your current filters. Try adjusting your search criteria or create a new page.</p>
                            <div class="empty-actions">
                                <a href="/wiki" class="btn btn-primary">
                                    <span>🔄</span> Clear Filters
                                </a>
                                <a href="/wiki/create" class="btn btn-outline">
                                    <span>📝</span> Create New Page
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="pages-grid">
                    {% for page in pages %}
                    {% set displaySlug = page.slug %}
                    {% if ':' in page.slug %}
                        {% set displaySlug = page.slug|split(':')|last %}
                    {% endif %}
                    <div class="page-card">
                        <div class="page-header">
                            <h3>
                                <a href="{{ lang_url('wiki/' ~ displaySlug) }}" class="page-title">
                                    <span class="page-icon">
                                        📄
                                    </span>
                                    {{ page.title }}
                                </a>
                            </h3>
                            <span class="page-namespace">{{ page.namespace|default('Main') }}</span>
                        </div>
                        
                        <div class="page-meta">
                            <div class="meta-item">
                                <span class="label">
                                    {% if locale == 'ar' %}📝 المراجعات:{% else %}📝 Revisions:{% endif %}
                                </span>
                                <span class="value">{{ page.revision_count|default(0) }}</span>
                            </div>
                            <div class="meta-item">
                                <span class="label">
                                    {% if locale == 'ar' %}🕒 محدث:{% else %}🕒 Updated:{% endif %}
                                </span>
                                <span class="value">{{ page.updated_at|default('Never')|date('M j, Y') }}</span>
                            </div>
                            <div class="meta-item">
                                <span class="label">
                                    {% if locale == 'ar' %}👤 المؤلف:{% else %}👤 Author:{% endif %}
                                </span>
                                <span class="value">{{ page.author|default('Unknown') }}</span>
                            </div>
                            <div class="meta-item">
                                <span class="label">
                                    {% if locale == 'ar' %}📊 المشاهدات:{% else %}📊 Views:{% endif %}
                                </span>
                                <span class="value">{{ page.view_count|default(0) }}</span>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Right Column: Filters & Actions (2/10) -->
    <div class="filters-column">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">🔍 Filters</h2>
            </div>
            <div class="card-body">
                <form method="GET" action="/wiki" class="filters-form">
                    <div class="filter-group">
                        <label class="form-label">Search Pages</label>
                        <input type="text" name="search" value="{{ filters.search|default('') }}" 
                               class="form-control" placeholder="Search page titles...">
                    </div>
                    
                    <div class="filter-group">
                        <label class="form-label">Namespace</label>
                        <select name="namespace" class="form-control">
                            <option value="">All Namespaces</option>
                            <option value="Main" {{ filters.namespace == 'Main' ? 'selected' : '' }}>Main</option>
                            <option value="User" {{ filters.namespace == 'User' ? 'selected' : '' }}>User</option>
                            <option value="Talk" {{ filters.namespace == 'Talk' ? 'selected' : '' }}>Talk</option>
                            <option value="Help" {{ filters.namespace == 'Help' ? 'selected' : '' }}>Help</option>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label class="form-label">Sort By</label>
                        <select name="sort" class="form-control">
                            <option value="title" {{ filters.sort == 'title' ? 'selected' : '' }}>Title</option>
                            <option value="updated_at" {{ filters.sort == 'updated_at' ? 'selected' : '' }}>Last Updated</option>
                            <option value="created_at" {{ filters.sort == 'created_at' ? 'selected' : '' }}>Created Date</option>
                            <option value="view_count" {{ filters.sort == 'view_count' ? 'selected' : '' }}>View Count</option>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label class="form-label">Order</label>
                        <select name="order" class="form-control">
                            <option value="asc" {{ filters.order == 'asc' ? 'selected' : '' }}>Ascending</option>
                            <option value="desc" {{ filters.order == 'desc' ? 'selected' : '' }}>Descending</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-full">Apply Filters</button>
                    <a href="/wiki" class="btn btn-outline w-full">Clear All</a>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %} 