{% extends "layouts/app.twig" %}

{% block title %}About - IslamWiki{% endblock %}

{% block content %}
<div class="home-three-column-layout full-width">
    <!-- Left Column: Get Involved (2/10) -->
    <div class="second-nav-column">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">🚀 Get Involved</h2>
            </div>
            <div class="card-body">
                <div class="involvement-content">
                    <p class="involvement-text">
                        Join our community of contributors and help us build the most comprehensive Islamic knowledge base. 
                        Whether you're a scholar, student, or enthusiast, there's a place for you in our community.
                    </p>
                    
                    <div class="involvement-actions">
                        {% if user %}
                            <a href="/wiki/create" class="btn btn-primary">
                                <span>📝</span> Create Your First Page
                            </a>
                            <a href="/dashboard" class="btn btn-outline">
                                <span>📊</span> Go to Dashboard
                            </a>
                            <a href="/community" class="btn btn-outline">
                                <span>👥</span> Join Community
                            </a>
                        {% else %}
                            <a href="/register" class="btn btn-primary">
                                <span>🌟</span> Join IslamWiki
                            </a>
                            <a href="/login" class="btn btn-outline">
                                <span>🔑</span> Sign In
                            </a>
                            <a href="/wiki" class="btn btn-outline">
                                <span>📚</span> Wiki
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Middle Column: Main Content (6/10) -->
    <div class="main-content-column">
        <!-- Hero Section -->
        <div class="hero">
            <div class="hero-content">
                <h1>🌟 About IslamWiki</h1>
                <p>Preserving and sharing Islamic knowledge for the global community</p>
                <div class="hero-actions">
                    <a href="/wiki/create" class="btn btn-outline">
                        <span>📝</span> Start Contributing
                    </a>
                    <a href="/wiki" class="btn btn-outline">
                        <span>📚</span> Wiki
                    </a>
                </div>
            </div>
        </div>

        <!-- Mission Section -->
        <div class="card">
            <div class="card-header">
                <h2>🎯 Our Mission</h2>
            </div>
            <div class="card-body">
                <div class="mission-content">
                    <p class="mission-text">
                        IslamWiki is a comprehensive platform dedicated to preserving and sharing Islamic knowledge. 
                        Our mission is to create the most extensive and accurate repository of Islamic studies, 
                        history, sciences, and cultural heritage, making this knowledge accessible to everyone 
                        regardless of their background or level of understanding.
                    </p>
                    <div class="mission-stats">
                        <div class="stat-item">
                            <div class="stat-number">📚</div>
                            <div class="stat-label">Islamic Studies</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">📜</div>
                            <div class="stat-label">Historical Records</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">🔬</div>
                            <div class="stat-label">Scientific Contributions</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">🤝</div>
                            <div class="stat-label">Community Driven</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- What We Offer Section -->
        <div class="features-section">
            <div class="card">
                <div class="card-header">
                    <h2>📖 What We Offer</h2>
                </div>
                <div class="card-body">
                    <div class="features-grid">
                        <div class="feature-card">
                            <div class="feature-icon">📚</div>
                            <h3>Islamic Studies</h3>
                            <p>Comprehensive articles on Quranic sciences, Hadith studies, Islamic law, theology, and philosophy. Explore the depths of Islamic scholarship and tradition.</p>
                            <div class="feature-tags">
                                <span class="tag">Quran</span>
                                <span class="tag">Hadith</span>
                                <span class="tag">Fiqh</span>
                            </div>
                        </div>
                        
                        <div class="feature-card">
                            <div class="feature-icon">📜</div>
                            <h3>Islamic History</h3>
                            <p>Detailed historical accounts from the time of Prophet Muhammad (ﷺ) to the modern era. Discover the rich tapestry of Islamic civilization and its contributions.</p>
                            <div class="feature-tags">
                                <span class="tag">History</span>
                                <span class="tag">Biography</span>
                                <span class="tag">Civilization</span>
                            </div>
                        </div>
                        
                        <div class="feature-card">
                            <div class="feature-icon">🔬</div>
                            <h3>Islamic Sciences</h3>
                            <p>Exploration of Islamic contributions to mathematics, astronomy, medicine, and other sciences. Learn about the golden age of Islamic scientific discovery.</p>
                            <div class="feature-tags">
                                <span class="tag">Science</span>
                                <span class="tag">Medicine</span>
                                <span class="tag">Astronomy</span>
                            </div>
                        </div>
                        
                        <div class="feature-card">
                            <div class="feature-icon">🤝</div>
                            <h3>Community Platform</h3>
                            <p>A collaborative environment where scholars, students, and enthusiasts can contribute, learn, and grow together in their understanding of Islam.</p>
                            <div class="feature-tags">
                                <span class="tag">Community</span>
                                <span class="tag">Collaboration</span>
                                <span class="tag">Learning</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Our Values Section -->
        <div class="values-section">
            <div class="card">
                <div class="card-header">
                    <h2>💎 Our Values</h2>
                </div>
                <div class="card-body">
                    <div class="values-grid">
                        <div class="value-item">
                            <div class="value-icon">📚</div>
                            <div class="value-content">
                                <h3>Accuracy & Authenticity</h3>
                                <p>We maintain the highest standards of accuracy, ensuring all content is well-researched and properly sourced from authentic Islamic sources.</p>
                            </div>
                        </div>
                        
                        <div class="value-item">
                            <div class="value-icon">🤝</div>
                            <div class="value-content">
                                <h3>Inclusivity & Respect</h3>
                                <p>We welcome contributors from all backgrounds and traditions, fostering an environment of mutual respect and understanding.</p>
                            </div>
                        </div>
                        
                        <div class="value-item">
                            <div class="value-icon">🌟</div>
                            <div class="value-content">
                                <h3>Open Access</h3>
                                <p>Knowledge should be freely accessible to all. We believe in making Islamic knowledge available to everyone without barriers.</p>
                            </div>
                        </div>
                        
                        <div class="value-item">
                            <div class="value-icon">🔬</div>
                            <div class="value-content">
                                <h3>Continuous Learning</h3>
                                <p>We embrace the spirit of lifelong learning, encouraging continuous improvement and expansion of our knowledge base.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Technology Section -->
        <div class="tech-section">
            <div class="card">
                <div class="card-header">
                    <h2>⚡ Our Technology</h2>
                </div>
                <div class="card-body">
                    <div class="tech-grid">
                        <div class="tech-item">
                            <div class="tech-icon">🔍</div>
                            <h3>Iqra Search Engine</h3>
                            <p>Advanced Islamic search engine with Arabic language support and semantic understanding.</p>
                        </div>
                        
                        <div class="tech-item">
                            <div class="tech-icon">🎨</div>
                            <h3>Bismillah Skin</h3>
                            <p>Beautiful, responsive design system that provides an optimal reading and editing experience.</p>
                        </div>
                        
                        <div class="tech-item">
                            <div class="tech-icon">⚡</div>
                            <h3>ZamZam Framework</h3>
                            <p>Lightweight JavaScript framework for dynamic interactions and enhanced user experience.</p>
                        </div>
                        
                        <div class="tech-item">
                            <div class="tech-icon">🧠</div>
                            <h3>Bayan Knowledge Graph</h3>
                            <p>Intelligent knowledge graph system that connects related concepts and provides deeper insights.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Contact Us (2/10) -->
    <div class="sidebar-column">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📞 Contact Us</h2>
            </div>
            <div class="card-body">
                <div class="contact-content">
                    <p>
                        Have questions, suggestions, or want to contribute? We'd love to hear from you! 
                        You can reach us through our community forums or by contributing directly to the platform.
                    </p>
                    
                    <div class="contact-methods">
                        <div class="contact-method">
                            <div class="contact-icon">💬</div>
                            <div class="contact-info">
                                <h3>Community Forums</h3>
                                <p>Join discussions and connect with other contributors</p>
                            </div>
                        </div>
                        
                        <div class="contact-method">
                            <div class="contact-icon">📧</div>
                            <div class="contact-info">
                                <h3>Direct Contribution</h3>
                                <p>Create and edit pages directly on the platform</p>
                            </div>
                        </div>
                        
                        <div class="contact-method">
                            <div class="contact-icon">📖</div>
                            <div class="contact-info">
                                <h3>Documentation</h3>
                                <p>Learn how to contribute effectively</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Mission Section */
.mission-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
}

.mission-text {
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--text-primary);
    margin-bottom: 2rem;
}

.mission-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
}

.stat-item {
    text-align: center;
    padding: 1rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.stat-item:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.stat-item .stat-number {
    font-size: 2rem;
    margin-bottom: 0.5rem;
}

.stat-item .stat-label {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
}

/* Features Section */
.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
}

.feature-card {
    background: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--primary-color), var(--primary-hover));
    opacity: 0;
    transition: opacity 0.3s ease;
}

.feature-card:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.feature-card:hover::before {
    opacity: 1;
}

.feature-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

.feature-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
}

.feature-card p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
}

.feature-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.tag {
    background: var(--background-color);
    color: var(--text-secondary);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.8rem;
    font-weight: 500;
}

/* Values Section */
.values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 1.5rem;
}

.value-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.value-item:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.value-icon {
    font-size: 2rem;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-background);
    border-radius: 50%;
}

.value-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.value-content p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
}

/* Technology Section */
.tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
}

.tech-item {
    text-align: center;
    padding: 1.5rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.tech-item:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.tech-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

.tech-item h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
}

.tech-item p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
}

/* Involvement Section */
.involvement-content {
    text-align: center;
}

.involvement-text {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: 2rem;
}

.involvement-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

/* Contact Section */
.contact-content {
    max-width: 800px;
    margin: 0 auto;
}

.contact-content > p {
    text-align: center;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: 2rem;
}

.contact-methods {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

.contact-method {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--background-color);
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.contact-method:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.contact-icon {
    font-size: 2rem;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-background);
    border-radius: 50%;
}

.contact-info h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
}

.contact-info p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin: 0;
}

/* Responsive Design */
@media (max-width: 768px) {
    .mission-stats {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .features-grid {
        grid-template-columns: 1fr;
    }
    
    .values-grid {
        grid-template-columns: 1fr;
    }
    
    .tech-grid {
        grid-template-columns: 1fr;
    }
    
    .contact-methods {
        grid-template-columns: 1fr;
    }
    
    .involvement-actions {
        flex-direction: column;
        align-items: center;
    }
    
    .hero h1 {
        font-size: 2rem;
    }
    
    .hero p {
        font-size: 1rem;
    }
}

@media (max-width: 480px) {
    .mission-stats {
        grid-template-columns: 1fr;
    }
    
    .value-item {
        flex-direction: column;
        text-align: center;
    }
    
    .contact-method {
        flex-direction: column;
        text-align: center;
    }
}
</style>
{% endblock %} 