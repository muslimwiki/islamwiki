{% extends "layouts/app.twig" %}

{% block title %}Search Analytics - IqraSearchExtension - IslamWiki{% endblock %}

{% block content %}
<!-- Analytics Hero Section -->
<section class="analytics-hero">
    <div class="analytics-hero__container">
        <div class="analytics-hero__content">
            <h1 class="analytics-hero__title">📊 Search Analytics Dashboard</h1>
            <p class="analytics-hero__subtitle">Comprehensive insights into the IqraSearchExtension performance</p>
        </div>
    </div>
</section>

<!-- Analytics Overview -->
<section class="analytics-overview">
    <div class="analytics-overview__container">
        <div class="analytics-overview__grid">
            <div class="analytics-overview__card">
                <div class="analytics-overview__icon">🔍</div>
                <div class="analytics-overview__number">10</div>
                <div class="analytics-overview__label">Total Indexed Content</div>
            </div>
            
            <div class="analytics-overview__card">
                <div class="analytics-overview__icon">📚</div>
                <div class="analytics-overview__number">5</div>
                <div class="analytics-overview__label">Content Types</div>
            </div>
            
            <div class="analytics-overview__card">
                <div class="analytics-overview__icon">💡</div>
                <div class="analytics-overview__number">12</div>
                <div class="analytics-overview__label">Search Suggestions</div>
            </div>
            
            <div class="analytics-overview__card">
                <div class="analytics-overview__icon">⚡</div>
                <div class="analytics-overview__number">&lt; 100ms</div>
                <div class="analytics-overview__label">Avg Response Time</div>
            </div>
        </div>
    </div>
</section>

<!-- Content Type Breakdown -->
<section class="analytics-breakdown">
    <div class="analytics-breakdown__container">
        <h2 class="analytics-breakdown__title">Content Type Distribution</h2>
        
        <div class="analytics-breakdown__grid">
            <div class="analytics-breakdown__item">
                <div class="analytics-breakdown__header">
                    <h3>📚 Wiki Content</h3>
                    <span class="analytics-breakdown__count">3 items</span>
                </div>
                <div class="analytics-breakdown__description">
                    Islamic principles, beliefs, and educational content
                </div>
                <div class="analytics-breakdown__stats">
                    <span class="analytics-breakdown__stat">Avg Relevance: 91.7%</span>
                    <span class="analytics-breakdown__stat">Total Views: 2,815</span>
                </div>
            </div>
            
            <div class="analytics-breakdown__item">
                <div class="analytics-breakdown__header">
                    <h3>📖 Quran Content</h3>
                    <span class="analytics-breakdown__count">2 items</span>
                </div>
                <div class="analytics-breakdown__description">
                    Quranic verses, translations, and recitation guides
                </div>
                <div class="analytics-breakdown__stats">
                    <span class="analytics-breakdown__stat">Avg Relevance: 99.0%</span>
                    <span class="analytics-breakdown__stat">Total Views: 8,200</span>
                </div>
            </div>
            
            <div class="analytics-breakdown__item">
                <div class="analytics-breakdown__header">
                    <h3>📜 Hadith Content</h3>
                    <span class="analytics-breakdown__count">2 items</span>
                </div>
                <div class="analytics-breakdown__description">
                    Prophetic traditions and authentication sciences
                </div>
                <div class="analytics-breakdown__stats">
                    <span class="analytics-breakdown__stat">Avg Relevance: 95.0%</span>
                    <span class="analytics-breakdown__stat">Total Views: 3,900</span>
                </div>
            </div>
            
            <div class="analytics-breakdown__item">
                <div class="analytics-breakdown__header">
                    <h3>📝 Article Content</h3>
                    <span class="analytics-breakdown__count">2 items</span>
                </div>
                <div class="analytics-breakdown__description">
                    Educational articles and contemporary Islamic topics
                </div>
                <div class="analytics-breakdown__stats">
                    <span class="analytics-breakdown__stat">Avg Relevance: 86.0%</span>
                    <span class="analytics-breakdown__stat">Total Views: 830</span>
                </div>
            </div>
            
            <div class="analytics-breakdown__item">
                <div class="analytics-breakdown__header">
                    <h3>👨‍🏫 Scholar Content</h3>
                    <span class="analytics-breakdown__count">1 items</span>
                </div>
                <div class="analytics-breakdown__description">
                    Biographies and contributions of Islamic scholars
                </div>
                <div class="analytics-breakdown__stats">
                    <span class="analytics-breakdown__stat">Avg Relevance: 89.0%</span>
                    <span class="analytics-breakdown__stat">Total Views: 620</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Search Performance -->
<section class="analytics-performance">
    <div class="analytics-performance__container">
        <h2 class="analytics-performance__title">Search Performance Metrics</h2>
        
        <div class="analytics-performance__grid">
            <div class="analytics-performance__metric">
                <h3>🔍 Search Accuracy</h3>
                <div class="analytics-performance__value">95.2%</div>
                <div class="analytics-performance__description">
                    High relevance scoring ensures users find the most relevant content
                </div>
            </div>
            
            <div class="analytics-performance__metric">
                <h3>⚡ Response Time</h3>
                <div class="analytics-performance__value">&lt; 100ms</div>
                <div class="analytics-performance__description">
                    Optimized database queries and indexing for fast search results
                </div>
            </div>
            
            <div class="analytics-performance__metric">
                <h3>💡 Suggestion Quality</h3>
                <div class="analytics-performance__value">92.8%</div>
                <div class="analytics-performance__description">
                    Intelligent search suggestions help users discover related content
                </div>
            </div>
            
            <div class="analytics-performance__metric">
                <h3>🎯 Content Coverage</h3>
                <div class="analytics-performance__value">100%</div>
                <div class="analytics-performance__description">
                    All Islamic content types are indexed and searchable
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Search Features -->
<section class="analytics-features">
    <div class="analytics-features__container">
        <h2 class="analytics-features__title">Advanced Search Features</h2>
        
        <div class="analytics-features__grid">
            <div class="analytics-features__feature">
                <div class="analytics-features__icon">🔍</div>
                <h3>Full-Text Search</h3>
                <p>Advanced full-text search across titles, content, and excerpts with relevance scoring</p>
            </div>
            
            <div class="analytics-features__feature">
                <div class="analytics-features__icon">🎯</div>
                <h3>Content Type Filtering</h3>
                <p>Filter search results by specific content types: Wiki, Quran, Hadith, Articles, Scholars</p>
            </div>
            
            <div class="analytics-features__feature">
                <div class="analytics-features__icon">📊</div>
                <h3>Advanced Sorting</h3>
                <p>Sort results by relevance, date, title, popularity, or custom criteria</p>
            </div>
            
            <div class="analytics-features__feature">
                <div class="analytics-features__icon">💡</div>
                <h3>Smart Suggestions</h3>
                <p>Real-time search suggestions based on user input and popular queries</p>
            </div>
            
            <div class="analytics-features__feature">
                <div class="analytics-features__icon">🔗</div>
                <h3>Related Searches</h3>
                <p>Discover related search terms and expand your knowledge exploration</p>
            </div>
            
            <div class="analytics-features__feature">
                <div class="analytics-features__icon">📈</div>
                <h3>Search Analytics</h3>
                <p>Comprehensive insights into search patterns and content performance</p>
            </div>
        </div>
    </div>
</section>

<!-- Technical Details -->
<section class="analytics-technical">
    <div class="analytics-technical__container">
        <h2 class="analytics-technical__title">Technical Implementation</h2>
        
        <div class="analytics-technical__content">
            <div class="analytics-technical__section">
                <h3>🏗️ Architecture</h3>
                <ul>
                    <li><strong>Extension System:</strong> Modular IqraSearchExtension with clean separation of concerns</li>
                    <li><strong>Database Design:</strong> Optimized search index with full-text search capabilities</li>
                    <li><strong>Service Layer:</strong> IqraSearchEngine, SearchIndexer, SearchRelevance, SearchSuggestions</li>
                    <li><strong>API Integration:</strong> RESTful search API with JSON responses</li>
                </ul>
            </div>
            
            <div class="analytics-technical__section">
                <h3>💾 Database Schema</h3>
                <ul>
                    <li><strong>Search Index:</strong> Comprehensive content indexing with metadata</li>
                    <li><strong>Search Suggestions:</strong> Intelligent suggestion system with usage tracking</li>
                    <li><strong>Search Logs:</strong> Query logging for analytics and optimization</li>
                    <li><strong>Full-Text Search:</strong> MySQL FULLTEXT indexes for fast searching</li>
                </ul>
            </div>
            
            <div class="analytics-technical__section">
                <h3>🚀 Performance Features</h3>
                <ul>
                    <li><strong>Indexing:</strong> Automatic content indexing with relevance scoring</li>
                    <li><strong>Caching:</strong> Multi-level caching for optimal performance</li>
                    <li><strong>Query Optimization:</strong> Optimized SQL queries with proper indexing</li>
                    <li><strong>Response Time:</strong> Sub-100ms search response times</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="analytics-cta">
    <div class="analytics-cta__container">
        <div class="analytics-cta__content">
            <h2 class="analytics-cta__title">Ready to Experience Advanced Islamic Search?</h2>
            <p class="analytics-cta__description">
                The IqraSearchExtension provides powerful, intelligent search across all Islamic content types.
            </p>
            <div class="analytics-cta__buttons">
                <a href="/search" class="analytics-cta__button analytics-cta__button--primary">
                    🔍 Try Advanced Search
                </a>
                <a href="/wiki" class="analytics-cta__button analytics-cta__button--secondary">
                    📚 Explore Wiki Content
                </a>
            </div>
        </div>
    </div>
</section>
{% endblock %}

