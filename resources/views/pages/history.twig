{% extends 'layouts/app.twig' %}

{% block title %}History: {{ page.getAttribute('title') }} - IslamWiki{% endblock %}

{% block styles %}
<style>
/* History Page Styles - Using Safa CSS approach */
.history-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%);
    padding: 2rem 0;
}

.history-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
}

.history-header {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    margin-bottom: 2rem;
    overflow: hidden;
}

.history-header-content {
    padding: 2rem;
}

.history-header-main {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.history-title-section {
    margin-bottom: 1rem;
}

.history-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 0.5rem;
}

.history-subtitle {
    color: #6b7280;
}

.history-actions {
    display: flex;
    justify-content: flex-end;
}

.history-back-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 8px;
    background: #4f46e5;
    color: white;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background-color 0.2s;
}

.history-back-btn:hover {
    background: #4338ca;
}

.history-stats {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    margin-bottom: 1.5rem;
    overflow: hidden;
}

.history-stats-content {
    padding: 1.5rem;
}

.history-stats-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.history-stats-info {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.history-stats-item {
    display: flex;
    align-items: center;
}

.history-stats-icon {
    width: 14px;
    height: 14px;
    margin-right: 8px;
    color: #4f46e5;
}

.history-stats-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: #111827;
}

.history-stats-meta {
    font-size: 0.875rem;
    color: #6b7280;
}

/* Icon sizing - SMALL ICONS */
.history-icon {
    width: 10px !important;
    height: 10px !important;
    min-width: 10px !important;
    min-height: 10px !important;
    max-width: 10px !important;
    max-height: 10px !important;
    margin-right: 8px;
    color: #9ca3af;
}

.history-stats-icon {
    width: 14px !important;
    height: 14px !important;
    min-width: 14px !important;
    min-height: 14px !important;
    max-width: 14px !important;
    max-height: 14px !important;
    margin-right: 8px;
    color: #4f46e5;
}

/* Revision List Styles */
.history-revisions {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    overflow: hidden;
}

.history-revisions-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid #e5e7eb;
}

.history-revisions-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
}

.history-revisions-list {
    list-style: none;
}

.history-revision-item {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid #f3f4f6;
    transition: background-color 0.15s;
}

.history-revision-item:hover {
    background-color: #f9fafb;
}

.history-revision-current {
    background-color: #eef2ff;
}

.history-revision-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.history-revision-main {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.history-revision-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.history-revision-badges {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.history-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
}

.history-badge-current {
    background-color: #dcfce7;
    color: #166534;
}

.history-badge-revision {
    background-color: #f3f4f6;
    color: #1f2937;
}

.history-badge-minor {
    background-color: #dbeafe;
    color: #1e40af;
}

.history-badge-icon {
    width: 12px !important;
    height: 12px !important;
    margin-right: 4px;
}

.history-revision-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.history-action-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
}

.history-action-revert {
    color: #a16207;
    background-color: #fef3c7;
}

.history-action-revert:hover {
    background-color: #fde68a;
}

.history-revision-comment {
    font-size: 0.875rem;
    font-weight: 500;
    color: #111827;
    margin-bottom: 0.5rem;
}
</style>
{% endblock %}

{% block content %}
    <div class="history-page">
        <div class="history-container">
            <!-- Header Section -->
            <div class="history-header">
                <div class="history-header-content">
                    <div class="history-header-main">
                        <div class="history-title-section">
                            <h1 class="history-title">History: {{ page.getAttribute('title') }}</h1>
                            <p class="history-subtitle">
                                Viewing revision history for this page
                            </p>
                        </div>
                        <div class="history-actions">
                            {% set displaySlug = page.getAttribute('slug') %}
                            {% if ':' in page.getAttribute('slug') %}
                                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                            {% endif %}
                            <a href="/wiki/{{ displaySlug }}" class="history-back-btn">
                                ← Back to page
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        
            <!-- Revision Stats -->
            <div class="history-stats">
                <div class="history-stats-content">
                    <div class="history-stats-main">
                        <div class="history-stats-info">
                            <div class="history-stats-item">
                                <svg class="history-stats-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                                <span class="history-stats-text">{{ revisions|length }} revisions</span>
                            </div>
                        </div>
                        <div class="history-stats-meta">
                            Showing all revisions
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Revision List -->
            <div class="history-revisions">
                <div class="history-revisions-header">
                    <h3 class="history-revisions-title">Revision History</h3>
                </div>
                <ul class="history-revisions-list">
                    {% for revision in revisions %}
                    <li class="history-revision-item {% if loop.first %}history-revision-current{% endif %}">
                        <div class="history-revision-content">
                            <div class="history-revision-main">
                                <div class="history-revision-info">
                                    <div class="history-revision-badges">
                                        {% if loop.first %}
                                            <span class="history-badge history-badge-current">
                                                <svg class="history-badge-icon" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                                </svg>
                                                Current
                                            </span>
                                        {% else %}
                                            <span class="history-badge history-badge-revision">
                                                Revision {{ loop.index }}
                                            </span>
                                        {% endif %}
                                        {% if revision.getAttribute('is_minor_edit') %}
                                            <span class="history-badge history-badge-minor">
                                                Minor edit
                                            </span>
                                        {% endif %}
                                    </div>
                                    <div class="history-revision-actions">
                                        {% if not loop.first %}
                                            {% set displaySlug = page.getAttribute('slug') %}
                                            {% if ':' in page.getAttribute('slug') %}
                                                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                                            {% endif %}
                                            <a href="/wiki/{{ displaySlug }}/revert/{{ revision.getAttribute('id') }}" 
                                               class="history-action-btn history-action-revert"
                                               onclick="return confirm('Are you sure you want to revert to this revision?');">
                                                Revert
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                                <p class="history-revision-comment">
                                    {{ revision.getAttribute('comment') ?: 'No edit comment' }}
                                </p>
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center space-x-6">
                                            <div class="flex items-center text-sm text-gray-500">
                                                <svg class="history-icon" style="width: 10px !important; height: 10px !important; min-width: 10px !important; min-height: 10px !important; max-width: 10px !important; max-height: 10px !important; margin-right: 8px; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                </svg>
                                                <span>Anonymous</span>
                                            </div>
                                            <div class="flex items-center text-sm text-gray-500">
                                                <svg class="history-icon" style="width: 10px !important; height: 10px !important; min-width: 10px !important; min-height: 10px !important; max-width: 10px !important; max-height: 10px !important; margin-right: 8px; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                                </svg>
                                                <time datetime="{{ revision.getAttribute('created_at')|date('c') }}" title="{{ revision.getAttribute('created_at')|date('F j, Y H:i:s') }}">
                                                    {{ revision.getAttribute('created_at')|date('M j, Y g:i A') }}
                                                </time>
                                            </div>
                                        </div>
                                        <div class="flex items-center space-x-3">
                                            {% set displaySlug = page.getAttribute('slug') %}
                                            {% if ':' in page.getAttribute('slug') %}
                                                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                                            {% endif %}
                                            <a href="/wiki/{{ displaySlug }}?rev={{ revision.getAttribute('id') }}" 
                                               class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                                                View
                                            </a>
                                            {% if not loop.first %}
                                                <a href="/wiki/{{ displaySlug }}/diff/{{ revision.getAttribute('id') }}/{{ revisions[loop.index - 1].getAttribute('id') }}" 
                                                   class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-blue-700 bg-blue-100 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200">
                                                    Compare
                                                </a>
                                            {% endif %}
                                        </div>
                                    </div>
                        </div>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
    
            <!-- Page Information -->
            <div class="bg-white rounded-xl shadow-lg overflow-hidden mt-8">
                <div class="px-6 py-4 sm:px-8 border-b border-gray-200">
                    <h3 class="text-lg font-semibold text-gray-900">Page Information</h3>
                </div>
                <div class="px-6 py-6 sm:px-8">
                    <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Page Title</dt>
                            <dd class="text-sm text-gray-900 font-medium">{{ page.getAttribute('title') }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Page ID</dt>
                            <dd class="text-sm text-gray-900">{{ page.getAttribute('id') }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Created</dt>
                            <dd class="text-sm text-gray-900">
                                <time datetime="{{ page.getAttribute('created_at')|date('c') }}">
                                    {{ page.getAttribute('created_at')|date('F j, Y H:i:s') }}
                                </time>
                                <span class="text-gray-500">by Anonymous</span>
                            </dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Last modified</dt>
                            <dd class="text-sm text-gray-900">
                                <time datetime="{{ page.getAttribute('updated_at')|date('c') }}">
                                    {{ page.getAttribute('updated_at')|date('F j, Y H:i:s') }}
                                </time>
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Add any interactive elements for the history page
            const compareCheckboxes = document.querySelectorAll('.compare-checkbox');
            const compareButton = document.getElementById('compare-selected');
            
            function updateCompareButton() {
                const checked = document.querySelectorAll('.compare-checkbox:checked');
                compareButton.disabled = checked.length !== 2;
                
                if (checked.length === 2) {
                    const [first, second] = checked;
                    {% set displaySlug = page.getAttribute('slug') %}
                    {% if ':' in page.getAttribute('slug') %}
                        {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                    {% endif %}
                    compareButton.href = `/wiki/{{ displaySlug }}/diff/${first.value}/${second.value}`;
                }
            }
            
            compareCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', updateCompareButton);
            });
            
            updateCompareButton();
        });
    </script>
{% endblock %}
