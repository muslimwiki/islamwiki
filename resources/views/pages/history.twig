{% extends 'layouts/app.twig' %}

{% block title %}History: {{ page.getAttribute('title') }} - IslamWiki{% endblock %}

{% block styles %}
{% endblock %}

{% block content %}
    <div class="history-page">
        <div class="history-container">
            <!-- Header Section -->
            <div class="history-header">
                <div class="history-header-content">
                    <div class="history-header-main">
                        <div class="history-title-section">
                            <h1 class="history-title">History: {{ page.getAttribute('title') }}</h1>
                            <p class="history-subtitle">
                                Viewing revision history for this page
                            </p>
                        </div>
                        <div class="history-actions">
                            {% set displaySlug = page.getAttribute('slug') %}
                            {% if ':' in page.getAttribute('slug') %}
                                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                            {% endif %}
                            <a href="/wiki/{{ displaySlug }}" class="history-back-btn">
                                ← Back to page
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        
            <!-- Revision Stats -->
            <div class="history-stats">
                <div class="history-stats-content">
                    <div class="history-stats-main">
                        <div class="history-stats-info">
                            <div class="history-stats-item">
                                <svg class="history-stats-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                                <span class="history-stats-text">{{ revisions|length }} revisions</span>
                            </div>
                        </div>
                        <div class="history-stats-meta">
                            Showing all revisions
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Revision List -->
            <div class="history-revisions">
                <div class="history-revisions-header">
                    <h3 class="history-revisions-title">Revision History</h3>
                </div>
                <ul class="history-revisions-list">
                    {% for revision in revisions %}
                    <li class="history-revision-item {% if loop.first %}history-revision-current{% endif %}">
                        <div class="history-revision-content">
                            <div class="history-revision-main">
                                <div class="history-revision-info">
                                    <div class="history-revision-badges">
                                        {% if loop.first %}
                                            <span class="history-badge history-badge-current">
                                                <svg class="history-badge-icon" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                                </svg>
                                                Current
                                            </span>
                                        {% else %}
                                            <span class="history-badge history-badge-revision">
                                                Revision {{ loop.index }}
                                            </span>
                                        {% endif %}
                                        {% if revision.getAttribute('is_minor_edit') %}
                                            <span class="history-badge history-badge-minor">
                                                Minor edit
                                            </span>
                                        {% endif %}
                                    </div>
                                    <div class="history-revision-actions">
                                        {% if not loop.first %}
                                            {% set displaySlug = page.getAttribute('slug') %}
                                            {% if ':' in page.getAttribute('slug') %}
                                                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                                            {% endif %}
                                            <a href="/wiki/{{ displaySlug }}/revert/{{ revision.getAttribute('id') }}" 
                                               class="history-action-btn history-action-revert"
                                               onclick="return confirm('Are you sure you want to revert to this revision?');">
                                                Revert
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                                <p class="history-revision-comment">
                                    {{ revision.getAttribute('comment') ?: 'No edit comment' }}
                                </p>
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center space-x-6">
                                            <div class="flex items-center text-sm text-gray-500">
                                                <svg class="history-icon" style="width: 10px !important; height: 10px !important; min-width: 10px !important; min-height: 10px !important; max-width: 10px !important; max-height: 10px !important; margin-right: 8px; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                </svg>
                                                <span>Anonymous</span>
                                            </div>
                                            <div class="flex items-center text-sm text-gray-500">
                                                <svg class="history-icon" style="width: 10px !important; height: 10px !important; min-width: 10px !important; min-height: 10px !important; max-width: 10px !important; max-height: 10px !important; margin-right: 8px; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                                </svg>
                                                <time datetime="{{ revision.getAttribute('created_at')|date('c') }}" title="{{ revision.getAttribute('created_at')|date('F j, Y H:i:s') }}">
                                                    {{ revision.getAttribute('created_at')|date('M j, Y g:i A') }}
                                                </time>
                                            </div>
                                        </div>
                                        <div class="flex items-center space-x-3">
                                            {% set displaySlug = page.getAttribute('slug') %}
                                            {% if ':' in page.getAttribute('slug') %}
                                                {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                                            {% endif %}
                                            <a href="/wiki/{{ displaySlug }}?rev={{ revision.getAttribute('id') }}" 
                                               class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                                                View
                                            </a>
                                            {% if not loop.first %}
                                                <a href="/wiki/{{ displaySlug }}/diff/{{ revision.getAttribute('id') }}/{{ revisions[loop.index - 1].getAttribute('id') }}" 
                                                   class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-blue-700 bg-blue-100 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200">
                                                    Compare
                                                </a>
                                            {% endif %}
                                        </div>
                                    </div>
                        </div>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
    
            <!-- Page Information -->
            <div class="bg-white rounded-xl shadow-lg overflow-hidden mt-8">
                <div class="px-6 py-4 sm:px-8 border-b border-gray-200">
                    <h3 class="text-lg font-semibold text-gray-900">Page Information</h3>
                </div>
                <div class="px-6 py-6 sm:px-8">
                    <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Page Title</dt>
                            <dd class="text-sm text-gray-900 font-medium">{{ page.getAttribute('title') }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Page ID</dt>
                            <dd class="text-sm text-gray-900">{{ page.getAttribute('id') }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Created</dt>
                            <dd class="text-sm text-gray-900">
                                <time datetime="{{ page.getAttribute('created_at')|date('c') }}">
                                    {{ page.getAttribute('created_at')|date('F j, Y H:i:s') }}
                                </time>
                                <span class="text-gray-500">by Anonymous</span>
                            </dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500 mb-1">Last modified</dt>
                            <dd class="text-sm text-gray-900">
                                <time datetime="{{ page.getAttribute('updated_at')|date('c') }}">
                                    {{ page.getAttribute('updated_at')|date('F j, Y H:i:s') }}
                                </time>
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Add any interactive elements for the history page
            const compareCheckboxes = document.querySelectorAll('.compare-checkbox');
            const compareButton = document.getElementById('compare-selected');
            
            function updateCompareButton() {
                const checked = document.querySelectorAll('.compare-checkbox:checked');
                compareButton.disabled = checked.length !== 2;
                
                if (checked.length === 2) {
                    const [first, second] = checked;
                    {% set displaySlug = page.getAttribute('slug') %}
                    {% if ':' in page.getAttribute('slug') %}
                        {% set displaySlug = page.getAttribute('slug')|split(':')|last %}
                    {% endif %}
                    compareButton.href = `/wiki/{{ displaySlug }}/diff/${first.value}/${second.value}`;
                }
            }
            
            compareCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', updateCompareButton);
            });
            
            updateCompareButton();
        });
    </script>
{% endblock %}
