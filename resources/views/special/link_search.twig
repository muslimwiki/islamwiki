{% extends 'layouts/app.twig' %}
{% set full_width = true %}
{% block content %}
  <section class="special-hero"><div class="special-hero-inner">
    <h1 class="special-title">External links search</h1>
    <form method="GET" class="special-form">
      <input type="text" name="q" value="{{ q }}" placeholder="Search external links (e.g., example.com)" />
      <button type="submit">Search</button>
    </form>
  </div></section>
{% endblock %}

