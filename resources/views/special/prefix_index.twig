{% extends 'layouts/app.twig' %}
{% set full_width = true %}
{% block content %}
  <section class="special-hero"><div class="special-hero-inner">
    <h1 class="special-title">All pages with prefix</h1>
    <form method="GET" class="special-form">
      <input type="text" name="namespace" value="{{ namespace }}" placeholder="Namespace (optional)" />
      <input type="text" name="prefix" value="{{ prefix }}" placeholder="Prefix" />
      <button type="submit">Filter</button>
    </form>
  </div></section>
  <section class="ns-list">
    <div class="ns-card">
      {% if results|length == 0 %}
        <p class="ns-empty">No results.</p>
      {% else %}
        <ul class="ns-pages">
          {% for page in results %}
            {% set displaySlug = page.slug %}
            {% if ':' in page.slug %}
              {% set displaySlug = page.slug.split(':', 2)[1] %}
            {% endif %}
            <li><a href="/wiki/{{ displaySlug }}">{{ page.title }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </section>
  <style>
  .special-hero { padding: 2rem 1.5rem; background: var(--card-background); border-bottom: 1px solid var(--border-color); }
  .special-hero-inner { max-width: 1200px; margin: 0 auto; }
  .special-title { font-size: 1.75rem; margin: 0 0 1rem; }
  .special-form { display: flex; gap: .5rem; }
  .special-form input { padding: .5rem .6rem; border: 1px solid var(--border-color); border-radius: .35rem; }
  .special-form button { padding: .5rem .9rem; }
  .ns-list { max-width: 1200px; margin: 1.5rem auto; padding: 0 1.5rem; }
  .ns-card { background: var(--background-color); border: 1px solid var(--border-color); border-radius: .75rem; padding: 1rem 1.25rem; }
  .ns-empty { color: var(--text-secondary); }
  .ns-pages { list-style: none; margin: 0; padding: 0; display: grid; gap: .35rem; }
  .ns-pages a { color: var(--primary-color); text-decoration: none; }
  .ns-pages a:hover { color: var(--primary-hover); text-decoration: underline; }
  </style>
{% endblock %}


