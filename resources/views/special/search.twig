{% extends 'layouts/app.twig' %}
{% set full_width = true %}
{% block content %}
  <section class="special-hero"><div class="special-hero-inner">
    <h1 class="special-title">Search</h1>
    <form method="GET" action="/search" class="special-form">
      <input type="text" name="q" value="{{ q }}" placeholder="Search all pages" />
      <button type="submit">Search</button>
    </form>
  </div></section>
{% endblock %}

