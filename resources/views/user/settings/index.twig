<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="settings-container">
        <!-- Header -->
        <div class="settings-header">
            <h1>User Settings</h1>
            <p>Customize your IslamWiki experience and manage your preferences</p>
        </div>

        <!-- Navigation Tabs -->
        <div class="settings-tabs">
            <a href="{{ path('user.settings.index') }}" class="settings-tab {{ active_tab == 'general' ? 'active' : '' }}">
                🏠 General
            </a>
            <a href="{{ path('user.settings.profile') }}" class="settings-tab {{ active_tab == 'profile' ? 'active' : '' }}">
                👤 Profile
            </a>
            <a href="{{ path('user.settings.appearance') }}" class="settings-tab {{ active_tab == 'appearance' ? 'active' : '' }}">
                🎨 Appearance
            </a>
            <a href="{{ path('user.settings.notifications') }}" class="settings-tab {{ active_tab == 'notifications' ? 'active' : '' }}">
                🔔 Notifications
            </a>
            <a href="{{ path('user.settings.privacy') }}" class="settings-tab {{ active_tab == 'privacy' ? 'active' : '' }}">
                🔒 Privacy
            </a>
        </div>

        <!-- Main Content -->
        <div class="settings-content">
            <!-- Success/Error Messages -->
            {% if message %}
            <div class="success-message">
                ✅ {{ message }}
            </div>
            {% endif %}

            {% if error %}
            <div class="error-message">
                ⚠️ {{ error }}
            </div>
            {% endif %}

            <!-- Profile Summary -->
            <div class="profile-summary">
                <div class="profile-avatar">
                    {% if user.avatar_url %}
                    <img src="{{ user.avatar_url }}" alt="{{ user.display_name }}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                    {% else %}
                    {{ user.first_name[0] }}{{ user.last_name[0] }}
                    {% endif %}
                </div>
                <div class="profile-name">{{ user.display_name }}</div>
                <div class="profile-email">{{ user.email }}</div>
                <div class="profile-completion">
                    <div class="profile-completion-bar" style="width: {{ user.profile_completion }}%"></div>
                </div>
                <div class="completion-text">{{ user.profile_completion }}% Profile Complete</div>
            </div>

            <!-- General Settings -->
            <div class="settings-section">
                <h3>General Preferences</h3>
                <div class="settings-grid">
                    <div class="setting-card">
                        <h4>🌍 Language & Region</h4>
                        <p>Set your preferred language and regional settings</p>
                        <div class="setting-controls">
                            <a href="{{ path('user.settings.profile') }}" class="btn btn-primary">Configure</a>
                        </div>
                    </div>

                    <div class="setting-card">
                        <h4>⏰ Time Zone</h4>
                        <p>Set your local time zone for accurate time display</p>
                        <div class="setting-controls">
                            <a href="{{ path('user.settings.profile') }}" class="btn btn-primary">Configure</a>
                        </div>
                    </div>

                    <div class="setting-card">
                        <h4>📧 Email Preferences</h4>
                        <p>Manage your email notification settings</p>
                        <div class="setting-controls">
                            <a href="{{ path('user.settings.notifications') }}" class="btn btn-primary">Configure</a>
                        </div>
                    </div>

                    <div class="setting-card">
                        <h4>🔒 Privacy Settings</h4>
                        <p>Control your privacy and data sharing preferences</p>
                        <div class="setting-controls">
                            <a href="{{ path('user.settings.privacy') }}" class="btn btn-primary">Configure</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="settings-section">
                <h3>Quick Actions</h3>
                <div class="settings-grid">
                    <div class="setting-card">
                        <h4>📥 Export Data</h4>
                        <p>Download a copy of your personal data</p>
                        <div class="setting-controls">
                            <a href="{{ path('user.settings.export-data') }}" class="btn btn-secondary">Export</a>
                        </div>
                    </div>

                    <div class="setting-card">
                        <h4>🔑 Change Password</h4>
                        <p>Update your account password</p>
                        <div class="setting-controls">
                            <a href="{{ path('auth.profile') }}" class="btn btn-secondary">Change</a>
                        </div>
                    </div>

                    <div class="setting-card">
                        <h4>📱 Two-Factor Auth</h4>
                        <p>Enable additional security for your account</p>
                        <div class="setting-controls">
                            <span class="btn btn-secondary" style="opacity: 0.5; cursor: not-allowed;">Coming Soon</span>
                        </div>
                    </div>

                    <div class="setting-card">
                        <h4>🔄 Account Recovery</h4>
                        <p>Set up account recovery options</p>
                        <div class="setting-controls">
                            <span class="btn btn-secondary" style="opacity: 0.5; cursor: not-allowed;">Coming Soon</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="danger-zone">
                <h3>⚠️ Danger Zone</h3>
                <p>These actions cannot be undone. Please proceed with caution.</p>
                <div class="setting-controls">
                    <button onclick="showDeleteAccountModal()" class="btn btn-danger">🗑️ Delete Account</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Account Modal -->
    <div id="deleteAccountModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 2rem; border-radius: 15px; max-width: 500px; width: 90%;">
            <h3 style="color: #DC2626; margin-bottom: 1rem;">Delete Account</h3>
            <p style="margin-bottom: 1.5rem; color: #6B7280;">
                This action will permanently delete your account and all associated data. 
                This cannot be undone.
            </p>
            <form action="{{ path('user.settings.delete-account') }}" method="POST" style="margin-bottom: 1.5rem;">
                <div class="form-group">
                    <label for="confirmPassword">Enter your password to confirm:</label>
                    <input type="password" id="confirmPassword" name="password" required>
                </div>
                <input type="hidden" name="_token" value="{{ csrf_token() }}">
                <div class="setting-controls">
                    <button type="button" onclick="hideDeleteAccountModal()" class="btn btn-secondary">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete Account</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function showDeleteAccountModal() {
            document.getElementById('deleteAccountModal').style.display = 'block';
        }

        function hideDeleteAccountModal() {
            document.getElementById('deleteAccountModal').style.display = 'none';
        }

        // Close modal when clicking outside
        document.getElementById('deleteAccountModal').addEventListener('click', function(e) {
            if (e.target === this) {
                hideDeleteAccountModal();
            }
        });

        // Auto-hide success messages after 5 seconds
        setTimeout(function() {
            const successMessages = document.querySelectorAll('.success-message');
            successMessages.forEach(function(message) {
                message.style.opacity = '0';
                setTimeout(function() {
                    message.remove();
                }, 300);
            });
        }, 5000);
    </script>
</body>
</html> 