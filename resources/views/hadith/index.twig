{% extends 'layouts/app.twig' %}

{% block title %}Hadith Collections - IslamWiki{% endblock %}

{% block content %}
<div class="hadith-page">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">📚 Hadith Collections</h1>
        <p class="page-subtitle">Authenticated sayings and traditions of Prophet Muhammad (peace be upon him)</p>
    </div>

    <!-- Hadith Stats -->
    <div class="hadith-stats">
        <div class="stat-card">
            <div class="stat-icon">📚</div>
            <div class="stat-content">
                <div class="stat-number">12,847</div>
                <div class="stat-label">Total Hadith</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div class="stat-content">
                <div class="stat-number">8,234</div>
                <div class="stat-label">Sahih (Authentic)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📖</div>
            <div class="stat-content">
                <div class="stat-number">6</div>
                <div class="stat-label">Major Collections</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">👨‍🏫</div>
            <div class="stat-content">
                <div class="stat-number">47</div>
                <div class="stat-label">Scholars</div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="hadith-content-grid">
        <!-- Left Column: Collections List -->
        <div class="collections-section">
            <div class="section-card">
                <div class="card-header">
                    <h2>📚 Major Collections</h2>
                    <div class="search-box">
                        <input type="text" id="collection-search" placeholder="Search collections..." class="search-input">
                    </div>
                </div>
                
                <div class="collections-list">
                    <div class="collection-item" data-collection="bukhari">
                        <div class="collection-icon">📖</div>
                        <div class="collection-info">
                            <div class="collection-name">Sahih Bukhari</div>
                            <div class="collection-details">
                                <span>Imam Bukhari</span>
                                <span>7,563 hadith</span>
                            </div>
                            <div class="collection-description">The most authentic collection of hadith, compiled by Imam Muhammad ibn Ismail al-Bukhari.</div>
                            <div class="collection-meta">
                                <span class="hadith-count">7,563 hadith</span>
                                <span class="authenticity">Sahih</span>
                            </div>
                        </div>
                    </div>

                    <div class="collection-item" data-collection="muslim">
                        <div class="collection-icon">📚</div>
                        <div class="collection-info">
                            <div class="collection-name">Sahih Muslim</div>
                            <div class="collection-details">
                                <span>Imam Muslim</span>
                                <span>7,563 hadith</span>
                            </div>
                            <div class="collection-description">Second most authentic collection, compiled by Imam Muslim ibn al-Hajjaj.</div>
                            <div class="collection-meta">
                                <span class="hadith-count">7,563 hadith</span>
                                <span class="authenticity">Sahih</span>
                            </div>
                        </div>
                    </div>

                    <div class="collection-item" data-collection="abudawud">
                        <div class="collection-icon">📖</div>
                        <div class="collection-info">
                            <div class="collection-name">Sunan Abu Dawud</div>
                            <div class="collection-details">
                                <span>Imam Abu Dawud</span>
                                <span>5,274 hadith</span>
                            </div>
                            <div class="collection-description">Focuses on legal hadith, compiled by Imam Abu Dawud al-Sijistani.</div>
                            <div class="collection-meta">
                                <span class="hadith-count">5,274 hadith</span>
                                <span class="authenticity">Hasan</span>
                            </div>
                        </div>
                    </div>

                    <div class="collection-item" data-collection="tirmidhi">
                        <div class="collection-icon">📚</div>
                        <div class="collection-info">
                            <div class="collection-name">Jami' at-Tirmidhi</div>
                            <div class="collection-details">
                                <span>Imam Tirmidhi</span>
                                <span>3,956 hadith</span>
                            </div>
                            <div class="collection-description">Comprehensive collection with commentary, compiled by Imam Abu Isa at-Tirmidhi.</div>
                            <div class="collection-meta">
                                <span class="hadith-count">3,956 hadith</span>
                                <span class="authenticity">Hasan</span>
                            </div>
                        </div>
                    </div>

                    <div class="collection-item" data-collection="nasai">
                        <div class="collection-icon">📖</div>
                        <div class="collection-info">
                            <div class="collection-name">Sunan an-Nasai</div>
                            <div class="collection-details">
                                <span>Imam Nasai</span>
                                <span>5,662 hadith</span>
                            </div>
                            <div class="collection-description">Focuses on legal and ritual hadith, compiled by Imam Ahmad ibn Shu'ayb an-Nasai.</div>
                            <div class="collection-meta">
                                <span class="hadith-count">5,662 hadith</span>
                                <span class="authenticity">Hasan</span>
                            </div>
                        </div>
                    </div>

                    <div class="collection-item" data-collection="ibnmajah">
                        <div class="collection-icon">📚</div>
                        <div class="collection-info">
                            <div class="collection-name">Sunan Ibn Majah</div>
                            <div class="collection-details">
                                <span>Imam Ibn Majah</span>
                                <span>4,341 hadith</span>
                            </div>
                            <div class="collection-description">Comprehensive collection covering various topics, compiled by Imam Muhammad ibn Yazid ibn Majah.</div>
                            <div class="collection-meta">
                                <span class="hadith-count">4,341 hadith</span>
                                <span class="authenticity">Mixed</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Categories & Quick Actions -->
        <div class="sidebar-section">
            <!-- Categories -->
            <div class="section-card">
                <div class="card-header">
                    <h3>🏷️ Categories</h3>
                </div>
                <div class="categories-grid">
                    <div class="category-item" data-category="worship">
                        <div class="category-icon">🕌</div>
                        <div class="category-name">Worship (Ibadah)</div>
                        <div class="category-count">2,847</div>
                    </div>
                    <div class="category-item" data-category="morals">
                        <div class="category-icon">❤️</div>
                        <div class="category-name">Morals & Ethics</div>
                        <div class="category-count">1,923</div>
                    </div>
                    <div class="category-item" data-category="family">
                        <div class="category-icon">👨‍👩‍👧‍👦</div>
                        <div class="category-name">Family & Society</div>
                        <div class="category-count">1,456</div>
                    </div>
                    <div class="category-item" data-category="business">
                        <div class="category-icon">💰</div>
                        <div class="category-name">Business & Trade</div>
                        <div class="category-count">987</div>
                    </div>
                    <div class="category-item" data-category="politics">
                        <div class="category-icon">🏛️</div>
                        <div class="category-name">Politics & Governance</div>
                        <div class="category-count">756</div>
                    </div>
                    <div class="category-item" data-category="knowledge">
                        <div class="category-icon">🎓</div>
                        <div class="category-name">Knowledge & Education</div>
                        <div class="category-count">1,234</div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="section-card">
                <div class="card-header">
                    <h3>⚡ Quick Actions</h3>
                </div>
                <div class="quick-actions">
                    <a href="/hadith/search" class="action-btn">
                        <span class="action-icon">🔍</span>
                        Search Hadith
                    </a>
                    <a href="/hadith/random" class="action-btn">
                        <span class="action-icon">🎲</span>
                        Random Hadith
                    </a>
                    <a href="/hadith/study" class="action-btn">
                        <span class="action-icon">📚</span>
                        Study Guide
                    </a>
                    <a href="/hadith/contribute" class="action-btn">
                        <span class="action-icon">✍️</span>
                        Contribute
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block head %}
{% endblock %}

{% block scripts %}
<script>
    // Collection search functionality
    document.getElementById('collection-search')?.addEventListener('input', function(e) {
        const query = e.target.value.toLowerCase();
        const collectionItems = document.querySelectorAll('.collection-item');
        
        collectionItems.forEach(item => {
            const collectionName = item.querySelector('.collection-name').textContent.toLowerCase();
            const collector = item.querySelector('.collection-details').textContent.toLowerCase();
            
            if (collectionName.includes(query) || collector.includes(query)) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    });

    // Collection item click handlers
    document.querySelectorAll('.collection-item').forEach(item => {
        item.addEventListener('click', function() {
            const collection = this.dataset.collection;
            window.location.href = `/hadith/collection/${collection}`;
        });
    });

    // Category item click handlers
    document.querySelectorAll('.category-item').forEach(item => {
        item.addEventListener('click', function() {
            const categoryName = this.querySelector('.category-name').textContent;
            window.location.href = `/hadith/category/${categoryName.toLowerCase().replace(/\s+/g, '-')}`;
        });
    });
</script>
{% endblock %} 