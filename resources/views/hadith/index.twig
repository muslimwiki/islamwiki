{% extends 'layouts/app.twig' %}

{% block title %}Hadith Collections - IslamWiki{% endblock %}

{% block head %}
{% endblock %}

{% block content %}
<div class="hadith-index-container">
    <!-- Enhanced Page Header -->
    <div class="hadith-page-header">
        <div class="header-content">
            <svg class="header-icon" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h1 class="page-title">📚 Hadith Collections</h1>
            <p class="page-subtitle">
                Authenticated sayings and traditions of Prophet Muhammad (peace be upon him) 
                from the most reliable Islamic scholars and collections
            </p>
            <a href="/hadith/search" class="cta-btn-primary">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                </svg>
                Search Hadiths
            </a>
        </div>
    </div>

    <!-- Enhanced Hadith Statistics -->
    <div class="stats-section">
        <h2 class="stats-title">Database Statistics</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <svg class="stat-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div class="stat-number">12,847</div>
                <div class="stat-label">Total Hadith</div>
            </div>
            
            <div class="stat-card">
                <svg class="stat-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div class="stat-number">8,234</div>
                <div class="stat-label">Sahih (Authentic)</div>
            </div>
            
            <div class="stat-card">
                <svg class="stat-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                </svg>
                <div class="stat-number">6</div>
                <div class="stat-label">Major Collections</div>
            </div>
            
            <div class="stat-card">
                <svg class="stat-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"/>
                </svg>
                <div class="stat-number">47</div>
                <div class="stat-label">Scholars</div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="content-grid">
        <!-- Left Column - Collections -->
        <div class="collections-section">
            <div class="section-header">
                <svg class="section-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                </svg>
                <h2 class="section-title">Major Hadith Collections</h2>
            </div>
            
            <div class="collections-grid">
                {% if collections %}
                    {% for collection in collections %}
                    <div class="collection-card">
                        <div class="collection-header">
                            <div class="flex-1">
                                <h3 class="collection-name">{{ collection.name }}</h3>
                                {% if collection.arabic_name %}
                                <p class="collection-arabic">{{ collection.arabic_name }}</p>
                                {% endif %}
                            </div>
                            <div class="ml-4">
                                <span class="reliability-badge {{ collection.reliability_level|default('mixed') }}">
                                    {{ collection.reliability_level|default('Mixed')|title }}
                                </span>
                            </div>
                        </div>
                        
                        <div class="collection-details">
                            <div class="detail-item">
                                <span class="detail-label">Author:</span>
                                <span class="detail-value">{{ collection.author|default('Unknown') }}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Compiled:</span>
                                <span class="detail-value">{{ collection.year_compiled|default('?') }} AH</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Total Hadiths:</span>
                                <span class="detail-value">{{ collection.total_hadiths|default('0')|number_format }}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Status:</span>
                                <span class="detail-value">{{ collection.status|default('Active') }}</span>
                            </div>
                        </div>
                        
                        {% if collection.description %}
                        <p class="collection-description">{{ collection.description }}</p>
                        {% endif %}
                        
                        <div class="collection-actions">
                            <a href="/hadith/collection/{{ collection.id }}" class="btn-primary">
                                Browse Collection
                            </a>
                            <a href="/hadith/search?collection={{ collection.id }}" class="btn-secondary">
                                Search
                            </a>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <!-- Placeholder for when collections are loaded -->
                    <div class="loading-placeholder">
                        <svg class="loading-icon" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        <h3 class="loading-title">Loading Collections...</h3>
                        <p class="loading-description">Please wait while we load the hadith collections.</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Right Column - Sidebar -->
        <div class="space-y-6">
            <!-- Quick Search -->
            <div class="hadith-sidebar">
                <h3 class="sidebar-title">
                    <svg class="icon" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                    </svg>
                    Quick Search
                </h3>
                <form action="/hadith/search" method="GET" class="search-form">
                    <input type="text" name="q" 
                           placeholder="Search hadiths..." 
                           class="search-input">
                    <button type="submit" class="search-button">
                        Search
                    </button>
                </form>
            </div>

            <!-- Quick Links -->
            <div class="hadith-sidebar">
                <h3 class="sidebar-title">
                    <svg class="icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Quick Links
                </h3>
                <div class="quick-links">
                    <a href="/hadith/search" class="quick-link">
                        <svg class="quick-link-icon" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        <div class="quick-link-content">
                            <div class="quick-link-title">Search Hadiths</div>
                            <div class="quick-link-description">Find specific hadiths</div>
                        </div>
                    </a>
                    
                    <a href="/{{ locale }}/quran" class="quick-link">
                        <svg class="quick-link-icon" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <div class="quick-link-content">
                            <div class="quick-link-title">Quran & Tafsir</div>
                            <div class="quick-link-description">Explore related verses</div>
                        </div>
                    </a>
                    
                    <a href="/wiki" class="quick-link">
                        <svg class="quick-link-icon" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                        </svg>
                        <div class="quick-link-content">
                            <div class="quick-link-title">Wiki Articles</div>
                            <div class="quick-link-description">Learn more about Islam</div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- About Hadith -->
            <div class="hadith-sidebar">
                <h3 class="sidebar-title">
                    <svg class="icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    About Hadith
                </h3>
                <div class="about-section">
                    <div class="about-text">
                        <p>
                            Hadith are the recorded sayings, actions, and approvals of Prophet Muhammad (peace be upon him), 
                            serving as a primary source of Islamic law and guidance alongside the Quran.
                        </p>
                        <p>
                            Our database includes authentic hadiths from the six major collections recognized by Sunni Islam, 
                            carefully graded for authenticity and reliability.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action Section -->
    <div class="cta-section">
        <div class="cta-content">
            <h2 class="cta-title">Ready to Explore Authentic Hadiths?</h2>
            <p class="cta-description">
                Discover the wisdom and guidance of Prophet Muhammad (peace be upon him) 
                through our comprehensive collection of authenticated hadiths.
            </p>
            <div class="cta-buttons">
                <a href="/hadith/search" class="cta-btn-primary">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                    </svg>
                    Start Searching
                </a>
                <a href="/hadith/collection/1" class="cta-btn-secondary">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                    </svg>
                    Browse Collections
                </a>
            </div>
        </div>
    </div>
</div>

<script>
// Add smooth scrolling for anchor links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
        }
    });
});

// Add hover effects for collection cards
document.querySelectorAll('.collection-card').forEach(card => {
    card.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-4px)';
    });
    
    card.addEventListener('mouseleave', function() {
        this.style.transform = 'translateY(0)';
    });
});
</script>
{% endblock %} 