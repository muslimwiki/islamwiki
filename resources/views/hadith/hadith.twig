{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block head %}
<style>
/* Hadith Page Specific Styles with Beautiful Islamic Theme */
.hadith-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    background: linear-gradient(135deg, #f8f6f0 0%, #ffffff 100%);
    min-height: 100vh;
    position: relative;
}

.hadith-container::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="islamic-pattern" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="%232d5016" opacity="0.03"/><circle cx="25" cy="25" r="3" fill="%232d5016" opacity="0.02"/><circle cx="25" cy="25" r="5" fill="%232d5016" opacity="0.01"/></pattern></defs><rect width="100" height="100" fill="url(%23islamic-pattern)"/></svg>') repeat;
    pointer-events: none;
    z-index: -1;
}

/* Beautiful Islamic Page Header */
.hadith-page-header {
    text-align: center;
    margin: 2rem 0 3rem 0;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    border-radius: 1.5rem;
    color: white;
    box-shadow: 0 15px 40px rgba(45, 80, 22, 0.4);
    position: relative;
    overflow: hidden;
}

.hadith-page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="header-pattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="2" fill="rgba(255,255,255,0.1)"/><circle cx="50" cy="50" r="4" fill="rgba(255,255,255,0.05)"/><circle cx="50" cy="50" r="6" fill="rgba(255,255,255,0.03)"/></pattern></defs><rect width="100" height="100" fill="url(%23header-pattern)"/></svg>') repeat;
    opacity: 0.3;
}

.header-content {
    position: relative;
    z-index: 1;
}

.page-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
    font-family: 'Traditional Arabic', 'Amiri', 'Scheherazade', serif;
}

.page-subtitle {
    font-size: 1.25rem;
    opacity: 0.9;
    font-weight: 300;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
}

.hadith-number {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    padding: 0.5rem 1.5rem;
    border-radius: 2rem;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.3);
}

.authenticity-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    margin-left: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.3);
}

.authenticity-badge.sahih {
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
}

.authenticity-badge.hasan {
    background: rgba(59, 130, 246, 0.2);
    color: #3b82f6;
}

.authenticity-badge.daif {
    background: rgba(245, 158, 11, 0.2);
    color: #f59e0b;
}

/* Breadcrumb Navigation */
.breadcrumb-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    color: #6b7280;
}

.breadcrumb-nav a {
    color: #2d5016;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
}

.breadcrumb-nav a:hover {
    color: #4a8029;
}

.breadcrumb-separator {
    margin: 0 0.5rem;
    color: #9ca3af;
}

/* Content Sections */
.hadith-content-section {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e7eb;
}

.section-header {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f3f4f6;
}

.section-icon {
    width: 2rem;
    height: 2rem;
    margin-right: 1rem;
    color: #2d5016;
}

.section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0;
}

/* Arabic Text Styling */
.arabic-text-container {
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    border-radius: 0.75rem;
    padding: 2rem;
    border: 1px solid #bae6fd;
    margin-bottom: 1.5rem;
}

.arabic-text {
    font-family: 'Noto Naskh Arabic', 'Amiri', 'Scheherazade', serif;
    font-size: 1.75rem;
    line-height: 2.5rem;
    text-align: right;
    direction: rtl;
    color: #1e40af;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);
}

/* Translation Styling */
.translation-container {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-radius: 0.75rem;
    padding: 2rem;
    border: 1px solid #bbf7d0;
    margin-bottom: 1.5rem;
}

.translation-text {
    font-size: 1.125rem;
    line-height: 1.75rem;
    color: #166534;
    font-weight: 400;
}

/* No Data Message */
.no-data-message {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border: 1px solid #f59e0b;
    border-radius: 1rem;
    padding: 3rem 2rem;
    text-align: center;
    margin: 2rem 0;
}

.no-data-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1.5rem;
    color: #d97706;
}

.no-data-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #92400e;
    margin-bottom: 1rem;
}

.no-data-description {
    font-size: 1.125rem;
    color: #a16207;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.no-data-reasons {
    background: white;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    text-align: left;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
}

.no-data-reasons h4 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 1rem;
}

.no-data-reasons ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.no-data-reasons li {
    display: flex;
    align-items: flex-start;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    color: #6b7280;
}

.no-data-reasons .check-icon {
    width: 1rem;
    height: 1rem;
    color: #10b981;
    margin-right: 0.5rem;
    margin-top: 0.125rem;
    flex-shrink: 0;
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-primary {
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(45, 80, 22, 0.3);
}

.btn-secondary {
    background: white;
    color: #d97706;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
    border: 2px solid #f59e0b;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.btn-secondary:hover {
    background: #fef3c7;
    transform: translateY(-2px);
}

/* Sidebar */
.hadith-sidebar {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e7eb;
    margin-bottom: 2rem;
}

.sidebar-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1f2937;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.sidebar-title .icon {
    width: 1.25rem;
    height: 1.25rem;
    color: #2d5016;
}

.sidebar-content {
    font-size: 0.875rem;
    color: #6b7280;
}

.sidebar-item {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f3f4f6;
}

.sidebar-item:last-child {
    border-bottom: none;
}

.sidebar-label {
    color: #6b7280;
}

.sidebar-value {
    color: #1f2937;
    font-weight: 500;
}

/* Navigation Links */
.nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
    gap: 0.5rem;
}

.nav-link.primary {
    background: #2d5016;
    color: white;
}

.nav-link.primary:hover {
    background: #4a8029;
    transform: translateY(-1px);
}

.nav-link.secondary {
    background: #f3f4f6;
    color: #374151;
}

.nav-link.secondary:hover {
    background: #e5e7eb;
    transform: translateY(-1px);
}

/* Responsive Design */
@media (max-width: 768px) {
    .hadith-container {
        padding: 1rem;
    }
    
    .hadith-page-header {
        padding: 2rem 1rem;
        margin: 1rem 0 2rem 0;
    }
    
    .page-title {
        font-size: 2rem;
    }
    
    .hadith-number {
        font-size: 1.25rem;
        padding: 0.375rem 1rem;
    }
    
    .action-buttons {
        flex-direction: column;
        align-items: center;
    }
    
    .btn-primary, .btn-secondary {
        width: 100%;
        max-width: 300px;
        justify-content: center;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="hadith-container">
    <!-- Breadcrumb Navigation -->
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="/hadith">Hadith</a>
        <span class="breadcrumb-separator">→</span>
        <a href="/hadith/collection/{{ collection_id }}">{{ hadith.collection_name|default('Collection ' ~ collection_id) }}</a>
        <span class="breadcrumb-separator">→</span>
        <span>Hadith {{ hadith_number }}</span>
    </nav>

    <!-- Page Header -->
    <div class="hadith-page-header">
        <div class="header-content">
            <h1 class="page-title">{{ hadith.collection_name|default('Collection ' ~ collection_id) }}</h1>
            <div class="page-subtitle">Authentic Hadith from Islamic Scholars</div>
            <div class="hadith-number">Hadith {{ hadith_number }}</div>
            {% if hadith and hadith.authenticity_level %}
            <span class="authenticity-badge {{ hadith.authenticity_level }}">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {{ hadith.authenticity_level|title }}
            </span>
            {% endif %}
        </div>
    </div>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Column - Main Content -->
        <div class="lg:col-span-2">
            {% if not hadith or not hadith.arabic_text %}
            <!-- No Data Message -->
            <div class="no-data-message">
                <svg class="no-data-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
                <h3 class="no-data-title">Hadith Not Yet Available</h3>
                <p class="no-data-description">
                    The requested hadith <strong>{{ hadith.collection_name|default('Collection ' ~ collection_id) }} {{ hadith_number }}</strong> 
                    is not currently available in our database.
                </p>
                
                <div class="no-data-reasons">
                    <h4>Why is this happening?</h4>
                    <ul>
                        <li>
                            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            The hadith number may not exist in this collection
                        </li>
                        <li>
                            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            The hadith data hasn't been imported yet
                        </li>
                        <li>
                            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            We're working on expanding our hadith database
                        </li>
                    </ul>
                </div>
                
                <div class="action-buttons">
                    <a href="/hadith" class="btn-primary">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
                        </svg>
                        Browse Hadith Collections
                    </a>
                    <a href="/hadith/search" class="btn-secondary">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        Search Hadiths
                    </a>
                </div>
            </div>
            {% else %}
            <!-- Hadith Content - Ready for when data is imported -->
            {% if hadith.arabic_text %}
            <div class="hadith-content-section">
                <div class="section-header">
                    <svg class="section-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                    </svg>
                    <h2 class="section-title">Arabic Text</h2>
                </div>
                <div class="arabic-text-container">
                    <p class="arabic-text">{{ hadith.arabic_text }}</p>
                </div>
            </div>
            {% endif %}

            {% if hadith.english_text %}
            <div class="hadith-content-section">
                <div class="section-header">
                    <svg class="section-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <h2 class="section-title">English Translation</h2>
                </div>
                <div class="translation-container">
                    <p class="translation-text">{{ hadith.english_text }}</p>
                </div>
            </div>
            {% endif %}

            {% if hadith.translation %}
            <div class="hadith-content-section">
                <div class="section-header">
                    <svg class="section-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                    </svg>
                    <h2 class="section-title">Additional Translation</h2>
                </div>
                <div class="translation-container">
                    <p class="translation-text">{{ hadith.translation }}</p>
                </div>
            </div>
            {% endif %}

            {% if chain %}
            <div class="hadith-content-section">
                <div class="section-header">
                    <svg class="section-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"/>
                    </svg>
                    <h2 class="section-title">Chain of Narrators (Isnad)</h2>
                </div>
                <div class="space-y-4">
                    {% for narrator in chain %}
                    <div class="flex items-center p-4 bg-gray-50 rounded-lg border border-gray-200">
                        <div class="flex-shrink-0 w-10 h-10 bg-green-100 text-green-800 text-sm font-bold rounded-full flex items-center justify-center mr-4">
                            {{ narrator.position_in_chain }}
                        </div>
                        <div class="flex-1">
                            <div class="font-semibold text-gray-900">{{ narrator.name }}</div>
                            {% if narrator.arabic_name %}
                            <div class="text-gray-600 text-right" dir="rtl" style="font-family: 'Noto Naskh Arabic', serif;">
                                {{ narrator.arabic_name }}
                            </div>
                            {% endif %}
                            {% if narrator.birth_year or narrator.death_year %}
                            <div class="text-sm text-gray-500 mt-1">
                                ({{ narrator.birth_year|default('?') }} - {{ narrator.death_year|default('?') }})
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {% if commentary %}
            <div class="hadith-content-section">
                <div class="section-header">
                    <svg class="section-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <h2 class="section-title">Commentary</h2>
                </div>
                <div class="bg-blue-50 rounded-lg p-4 border border-blue-200">
                    <div class="mb-3">
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/>
                            </svg>
                            {{ commentary.commentator_name }}
                        </span>
                    </div>
                    <p class="text-gray-700 leading-relaxed">{{ commentary.commentary_text }}</p>
                </div>
            </div>
            {% endif %}
            {% endif %}
        </div>

        <!-- Right Column - Sidebar -->
        <div class="space-y-6">
            <!-- Collection Info -->
            <div class="hadith-sidebar">
                <h3 class="sidebar-title">
                    <svg class="icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Collection Information
                </h3>
                <div class="sidebar-content">
                    <div class="sidebar-item">
                        <span class="sidebar-label">Collection:</span>
                        <span class="sidebar-value">{{ hadith.collection_name|default('Collection ' ~ collection_id) }}</span>
                    </div>
                    <div class="sidebar-item">
                        <span class="sidebar-label">Hadith Number:</span>
                        <span class="sidebar-value">{{ hadith_number }}</span>
                    </div>
                    {% if hadith and hadith.narrator %}
                    <div class="sidebar-item">
                        <span class="sidebar-label">Primary Narrator:</span>
                        <span class="sidebar-value">{{ hadith.narrator }}</span>
                    </div>
                    {% endif %}
                    {% if hadith and hadith.topic %}
                    <div class="sidebar-item">
                        <span class="sidebar-label">Topic:</span>
                        <span class="sidebar-value">{{ hadith.topic }}</span>
                    </div>
                    {% endif %}
                    {% if hadith and hadith.book %}
                    <div class="sidebar-item">
                        <span class="sidebar-label">Book:</span>
                        <span class="sidebar-value">{{ hadith.book }}</span>
                    </div>
                    {% endif %}
                    {% if hadith and hadith.chapter %}
                    <div class="sidebar-item">
                        <span class="sidebar-label">Chapter:</span>
                        <span class="sidebar-value">{{ hadith.chapter }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Navigation -->
            <div class="hadith-sidebar">
                <h3 class="sidebar-title">
                    <svg class="icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M8.707 7.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l2-2a1 1 0 00-1.414-1.414L11 7.586V3a1 1 0 10-2 0v4.586l-.293-.293z"/>
                    </svg>
                    Navigation
                </h3>
                <div class="nav-links">
                    <a href="/hadith/collection/{{ collection_id }}" class="nav-link primary">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                        </svg>
                        Back to Collection
                    </a>
                    
                    <div class="flex space-x-2">
                        {% if hadith_number > 1 %}
                        <a href="/hadith/{{ collection_id }}/{{ hadith_number - 1 }}" class="nav-link secondary flex-1">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            Previous
                        </a>
                        {% endif %}
                        
                        <a href="/hadith/{{ collection_id }}/{{ hadith_number + 1 }}" class="nav-link secondary flex-1">
                            Next
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Related Content -->
            <div class="hadith-sidebar">
                <h3 class="sidebar-title">
                    <svg class="icon" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Related Content
                </h3>
                <div class="space-y-3">
                    <a href="/hadith/search?q={{ hadith.topic|default('') }}" class="flex items-center p-3 bg-green-50 rounded-lg hover:bg-green-100 transition-colors border border-green-200">
                        <svg class="w-5 h-5 text-green-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        <div>
                            <div class="font-medium text-gray-900">Similar Topics</div>
                            <div class="text-sm text-gray-600">Find related hadiths</div>
                        </div>
                    </a>
                    
                    <a href="/{{ locale }}/quran" class="flex items-center p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors border border-blue-200">
                        <svg class="w-5 h-5 text-blue-600 mr-3" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <div>
                            <div class="font-medium text-gray-900">Quran & Tafsir</div>
                            <div class="text-sm text-gray-600">Explore related verses</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Actions -->
    <div class="hadith-content-section mt-8">
        <div class="text-center">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Share This Hadith</h3>
            <p class="text-gray-600 mb-6">Help others discover this authentic hadith</p>
            <div class="flex flex-wrap gap-4 justify-center">
                <button onclick="copyToClipboard(window.location.href)" class="btn-primary">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M8 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z"/>
                        <path d="M6 3a2 2 0 00-2 2v11a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2 3 3 0 01-3 3H9a3 3 0 01-3-3z"/>
                    </svg>
                    Copy Link
                </button>
                <a href="/hadith/widget/{{ collection_id }}/{{ hadith_number }}" class="btn-primary">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                    </svg>
                    Embed Widget
                </a>
                <a href="/api/hadith/{{ hadith.id|default('') }}" class="btn-primary">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                    </svg>
                    API Data
                </a>
            </div>
        </div>
    </div>
</div>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(function() {
        // Show success message
        const button = event.target.closest('button');
        const originalText = button.innerHTML;
        button.innerHTML = `
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Copied!
        `;
        button.classList.add('bg-green-700');
        
        setTimeout(() => {
            button.innerHTML = originalText;
            button.classList.remove('bg-green-700');
        }, 2000);
    }, function(err) {
        console.error('Could not copy text: ', err);
        alert('Failed to copy link. Please copy manually.');
    });
}

// Add smooth scrolling for anchor links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
        }
    });
});
</script>
{% endblock %} 