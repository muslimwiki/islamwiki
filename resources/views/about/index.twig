{% extends "layouts/app.twig" %}

{% block title %}About - IslamWiki{% endblock %}

{% block content %}
<div class="main-content-wrapper">
    <div class="main-content">
        <div class="about-header">
            <h1>📖 About IslamWiki</h1>
            <p>Your trusted source for authentic Islamic knowledge and community.</p>
        </div>
        
        <div class="about-sections">
            <div class="about-section">
                <h2>🎯 Our Mission</h2>
                <p>IslamWiki is dedicated to providing accurate, reliable, and comprehensive Islamic knowledge to Muslims and researchers worldwide. We strive to create a platform that combines traditional Islamic scholarship with modern technology.</p>
            </div>
            
            <div class="about-section">
                <h2>🌟 What We Offer</h2>
                <div class="feature-grid">
                    <div class="feature-card">
                        <i class="fas fa-book-open"></i>
                        <h3>Islamic Knowledge</h3>
                        <p>Comprehensive articles on Islamic topics, history, and practices.</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-search"></i>
                        <h3>Advanced Search</h3>
                        <p>Find Islamic content quickly with our specialized search engine.</p>
                    </div>
                    <div class="feature-card">
                        <i class="fas fa-users"></i>
                        <h3>Community</h3>
                        <p>Connect with fellow Muslims and share knowledge.</p>
                    </div>
                </div>
            </div>
            
            <div class="about-section">
                <h2>🔒 Quality & Authenticity</h2>
                <p>All content on IslamWiki is carefully reviewed and sourced from reliable Islamic scholars and authentic sources. We maintain high standards of accuracy and authenticity in everything we publish.</p>
            </div>
            
            <div class="about-section">
                <h2>📱 Technology</h2>
                <p>Built with modern web technologies, IslamWiki provides a fast, secure, and accessible platform for Islamic knowledge. Our platform is designed to work seamlessly across all devices and browsers.</p>
            </div>
            
            <div class="about-section">
                <h2>🤝 Get Involved</h2>
                <p>This about section is under development. Check back soon for more information about our team, mission, and how you can contribute!</p>
            </div>
        </div>
    </div>
</div>
{% endblock %} 