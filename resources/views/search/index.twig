{% extends "layouts/app.twig" %}

{% block title %}Search - IslamWiki{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <!-- Search Header -->
    <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">🔍 Search IslamWiki</h1>
        <p class="text-lg text-gray-600">Search across Quran, Hadith, Calendar events, Prayer times, and Wiki pages</p>
    </div>

    <!-- Search Form -->
    <div class="max-w-4xl mx-auto mb-8">
        <form method="GET" action="/search" class="bg-white rounded-lg shadow-lg p-6">
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1">
                    <input type="text" 
                           name="q" 
                           value="{{ query }}" 
                           placeholder="Search for anything..."
                           class="w-full px-4 py-3 text-lg border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                           autocomplete="off"
                           id="search-input">
                </div>
                <div class="md:w-48">
                    <select name="type" class="w-full px-4 py-3 text-lg border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent">
                        {% for key, label in searchTypes %}
                            <option value="{{ key }}" {% if type == key %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <button type="submit" class="w-full md:w-auto px-8 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors">
                        Search
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Search Results -->
    {% if query %}
        <div class="max-w-6xl mx-auto">
            <!-- Results Header -->
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h2 class="text-2xl font-semibold text-gray-900">
                        {% if totalResults == 1 %}
                            1 result found
                        {% else %}
                            {{ totalResults }} results found
                        {% endif %}
                    </h2>
                    <p class="text-gray-600">for "{{ query }}"</p>
                </div>
                
                <!-- Search Statistics -->
                {% if searchStats %}
                    <div class="text-sm text-gray-500">
                        <span class="mr-4">📄 {{ searchStats.total_pages }} pages</span>
                        <span class="mr-4">📖 {{ searchStats.total_quran }} verses</span>
                        <span class="mr-4">📚 {{ searchStats.total_hadith }} hadith</span>
                        <span class="mr-4">📅 {{ searchStats.total_calendar }} events</span>
                        <span>🕌 {{ searchStats.total_prayer }} locations</span>
                    </div>
                {% endif %}
            </div>

            <!-- Results -->
            {% if results %}
                <div class="space-y-6">
                    {% for result in results %}
                        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
                            <!-- Result Type Badge -->
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center space-x-2">
                                    {% if result.type == 'page' %}
                                        <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs font-medium rounded">📄 Page</span>
                                    {% elseif result.type == 'quran' %}
                                        <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-medium rounded">📖 Quran</span>
                                    {% elseif result.type == 'hadith' %}
                                        <span class="px-2 py-1 bg-purple-100 text-purple-800 text-xs font-medium rounded">📚 Hadith</span>
                                    {% elseif result.type == 'calendar' %}
                                        <span class="px-2 py-1 bg-orange-100 text-orange-800 text-xs font-medium rounded">📅 Event</span>
                                    {% elseif result.type == 'prayer' %}
                                        <span class="px-2 py-1 bg-red-100 text-red-800 text-xs font-medium rounded">🕌 Prayer</span>
                                    {% endif %}
                                    
                                    {% if result.relevance %}
                                        <span class="text-xs text-gray-500">Relevance: {{ (result.relevance * 100) | round(1) }}%</span>
                                    {% endif %}
                                </div>
                                
                                <div class="text-sm text-gray-500">
                                    {% if result.updated_at %}
                                        {{ result.updated_at | date('M j, Y') }}
                                    {% elseif result.event_date %}
                                        {{ result.event_date | date('M j, Y') }}
                                    {% elseif result.prayer_date %}
                                        {{ result.prayer_date | date('M j, Y') }}
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Result Title -->
                            <h3 class="text-xl font-semibold text-gray-900 mb-2">
                                <a href="{{ result.url }}" class="hover:text-green-600 transition-colors">
                                    {{ result.title }}
                                </a>
                            </h3>

                            <!-- Result Details -->
                            {% if result.type == 'quran' %}
                                <div class="mb-3">
                                    <p class="text-sm text-gray-600 mb-2">
                                        <strong>Surah:</strong> {{ result.surah_name }} ({{ result.surah_id }}:{{ result.verse_number }})
                                    </p>
                                    {% if result.arabic_text %}
                                        <div class="text-right text-lg mb-2" dir="rtl">
                                            {{ result.arabic_text }}
                                        </div>
                                    {% endif %}
                                </div>
                            {% elseif result.type == 'hadith' %}
                                <div class="mb-3">
                                    <p class="text-sm text-gray-600 mb-2">
                                        <strong>Collection:</strong> {{ result.collection_name }} #{{ result.hadith_number }}
                                        {% if result.authenticity %}
                                            <span class="ml-2 px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded">
                                                {{ result.authenticity }}
                                            </span>
                                        {% endif %}
                                    </p>
                                    {% if result.narrator %}
                                        <p class="text-sm text-gray-600">
                                            <strong>Narrator:</strong> {{ result.narrator }}
                                        </p>
                                    {% endif %}
                                </div>
                            {% elseif result.type == 'calendar' %}
                                <div class="mb-3">
                                    <p class="text-sm text-gray-600">
                                        <strong>Date:</strong> {{ result.event_date | date('F j, Y') }}
                                        {% if result.hijri_date %}
                                            ({{ result.hijri_date }})
                                        {% endif %}
                                        {% if result.category_name %}
                                            <span class="ml-2">• {{ result.category_name }}</span>
                                        {% endif %}
                                    </p>
                                    {% if result.arabic_title %}
                                        <p class="text-right text-lg mb-2" dir="rtl">
                                            {{ result.arabic_title }}
                                        </p>
                                    {% endif %}
                                </div>
                            {% elseif result.type == 'prayer' %}
                                <div class="mb-3">
                                    <p class="text-sm text-gray-600">
                                        <strong>Location:</strong> {{ result.city }}, {{ result.country }}
                                        {% if result.location_name %}
                                            ({{ result.location_name }})
                                        {% endif %}
                                    </p>
                                    <div class="grid grid-cols-5 gap-2 text-xs mt-2">
                                        <div><strong>Fajr:</strong> {{ result.fajr }}</div>
                                        <div><strong>Dhuhr:</strong> {{ result.dhuhr }}</div>
                                        <div><strong>Asr:</strong> {{ result.asr }}</div>
                                        <div><strong>Maghrib:</strong> {{ result.maghrib }}</div>
                                        <div><strong>Isha:</strong> {{ result.isha }}</div>
                                    </div>
                                </div>
                            {% elseif result.type == 'page' %}
                                <div class="mb-3">
                                    {% if result.author %}
                                        <p class="text-sm text-gray-600">
                                            <strong>Author:</strong> {{ result.author }}
                                        </p>
                                    {% endif %}
                                </div>
                            {% endif %}

                            <!-- Excerpt -->
                            {% if result.excerpt %}
                                <div class="text-gray-700 leading-relaxed">
                                    {{ result.excerpt | raw }}
                                </div>
                            {% endif %}

                            <!-- Action Buttons -->
                            <div class="mt-4 flex space-x-2">
                                <a href="{{ result.url }}" class="px-4 py-2 bg-green-600 text-white text-sm font-medium rounded hover:bg-green-700 transition-colors">
                                    View Details
                                </a>
                                
                                {% if result.type == 'quran' %}
                                    <a href="/quran/widget/{{ result.surah_id }}/{{ result.verse_number }}" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded hover:bg-blue-700 transition-colors">
                                        Widget
                                    </a>
                                {% elseif result.type == 'hadith' %}
                                    <a href="/hadith/widget/{{ result.collection_id }}/{{ result.hadith_number }}" class="px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded hover:bg-purple-700 transition-colors">
                                        Widget
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <!-- Pagination -->
                {% if totalPages > 1 %}
                    <div class="mt-8 flex justify-center">
                        <nav class="flex space-x-2">
                            {% if currentPage > 1 %}
                                <a href="?q={{ query }}&type={{ type }}&page={{ currentPage - 1 }}" 
                                   class="px-3 py-2 bg-white border border-gray-300 text-gray-700 rounded hover:bg-gray-50">
                                    Previous
                                </a>
                            {% endif %}
                            
                            {% for page in range(1, totalPages) %}
                                {% if page == currentPage %}
                                    <span class="px-3 py-2 bg-green-600 text-white rounded">{{ page }}</span>
                                {% else %}
                                    <a href="?q={{ query }}&type={{ type }}&page={{ page }}" 
                                       class="px-3 py-2 bg-white border border-gray-300 text-gray-700 rounded hover:bg-gray-50">
                                        {{ page }}
                                    </a>
                                {% endif %}
                            {% endfor %}
                            
                            {% if currentPage < totalPages %}
                                <a href="?q={{ query }}&type={{ type }}&page={{ currentPage + 1 }}" 
                                   class="px-3 py-2 bg-white border border-gray-300 text-gray-700 rounded hover:bg-gray-50">
                                    Next
                                </a>
                            {% endif %}
                        </nav>
                    </div>
                {% endif %}
            {% else %}
                <!-- No Results -->
                <div class="text-center py-12">
                    <div class="text-6xl mb-4">🔍</div>
                    <h3 class="text-2xl font-semibold text-gray-900 mb-2">No results found</h3>
                    <p class="text-gray-600 mb-6">Try different keywords or search in a specific category</p>
                    <div class="flex justify-center space-x-4">
                        {% for key, label in searchTypes %}
                            <a href="?q={{ query }}&type={{ key }}" 
                               class="px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors">
                                {{ label }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    {% else %}
        <!-- Search Tips -->
        <div class="max-w-4xl mx-auto">
            <div class="bg-gray-50 rounded-lg p-8">
                <h3 class="text-2xl font-semibold text-gray-900 mb-6">Search Tips</h3>
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-3">📖 Quran Search</h4>
                        <ul class="text-sm text-gray-600 space-y-1">
                            <li>• Search by verse content or translation</li>
                            <li>• Use surah names or numbers</li>
                            <li>• Search for specific themes or topics</li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-3">📚 Hadith Search</h4>
                        <ul class="text-sm text-gray-600 space-y-1">
                            <li>• Search by hadith content or narrator</li>
                            <li>• Filter by collection (Bukhari, Muslim, etc.)</li>
                            <li>• Search by authenticity level</li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-3">📅 Calendar Search</h4>
                        <ul class="text-sm text-gray-600 space-y-1">
                            <li>• Search Islamic events and holidays</li>
                            <li>• Find events by date or description</li>
                            <li>• Browse upcoming events</li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-semibold text-gray-900 mb-3">🕌 Prayer Search</h4>
                        <ul class="text-sm text-gray-600 space-y-1">
                            <li>• Search prayer times by location</li>
                            <li>• Find cities or countries</li>
                            <li>• Get prayer time schedules</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<!-- Search Suggestions JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-input');
    let suggestionsTimeout;

    searchInput.addEventListener('input', function() {
        clearTimeout(suggestionsTimeout);
        const query = this.value.trim();
        
        if (query.length < 2) {
            hideSuggestions();
            return;
        }

        suggestionsTimeout = setTimeout(() => {
            fetchSuggestions(query);
        }, 300);
    });

    function fetchSuggestions(query) {
        fetch(`/api/search/suggestions?q=${encodeURIComponent(query)}`)
            .then(response => response.json())
            .then(data => {
                if (data.suggestions && data.suggestions.length > 0) {
                    showSuggestions(data.suggestions);
                } else {
                    hideSuggestions();
                }
            })
            .catch(error => {
                console.error('Error fetching suggestions:', error);
                hideSuggestions();
            });
    }

    function showSuggestions(suggestions) {
        let suggestionsDiv = document.getElementById('search-suggestions');
        if (!suggestionsDiv) {
            suggestionsDiv = document.createElement('div');
            suggestionsDiv.id = 'search-suggestions';
            suggestionsDiv.className = 'absolute z-50 w-full bg-white border border-gray-300 rounded-lg shadow-lg mt-1';
            searchInput.parentNode.style.position = 'relative';
            searchInput.parentNode.appendChild(suggestionsDiv);
        }

        suggestionsDiv.innerHTML = suggestions.map(suggestion => `
            <a href="${suggestion.url}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">
                <div class="flex items-center">
                    <span class="mr-2">
                        ${getTypeIcon(suggestion.type)}
                    </span>
                    <span>${suggestion.text}</span>
                </div>
            </a>
        `).join('');
    }

    function hideSuggestions() {
        const suggestionsDiv = document.getElementById('search-suggestions');
        if (suggestionsDiv) {
            suggestionsDiv.remove();
        }
    }

    function getTypeIcon(type) {
        const icons = {
            'page': '📄',
            'quran': '📖',
            'hadith': '📚',
            'calendar': '📅',
            'prayer': '🕌'
        };
        return icons[type] || '📄';
    }

    // Hide suggestions when clicking outside
    document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !document.getElementById('search-suggestions')?.contains(e.target)) {
            hideSuggestions();
        }
    });
});
</script>
{% endblock %} 