{% extends "layouts/app.twig" %}

{% block title %}Search - IslamWiki{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <!-- Search Header with Bismillah Styling -->
    <div class="text-center mb-8">
        <div class="search-header">
            <h1 class="search-title">🔍 Search IslamWiki</h1>
            <p class="search-subtitle">Search across Quran, Hadith, Calendar events, Prayer times, and Wiki pages</p>
        </div>
    </div>

    <!-- Enhanced Search Form with Bismillah Styling -->
    <div class="max-w-4xl mx-auto mb-8">
        <form method="GET" action="/search" class="search-form">
            <div class="search-form-content">
                <div class="search-input-group">
                    <input type="text" 
                           name="q" 
                           value="{{ query }}" 
                           placeholder="Search for anything..."
                           class="search-input"
                           autocomplete="off"
                           id="search-input">
                    <div class="search-input-icon">🔍</div>
                </div>
                <div class="search-type-selector">
                    <select name="type" class="search-select">
                        {% for key, label in searchTypes %}
                            <option value="{{ key }}" {% if type == key %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="search-button-container">
                    <button type="submit" class="search-button">
                        <span class="search-button-text">Search</span>
                        <span class="search-button-icon">→</span>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Search Results with Bismillah Styling -->
    {% if query %}
        <div class="search-results-container">
            <!-- Enhanced Results Header -->
            <div class="results-header">
                <div class="results-info">
                    <h2 class="results-title">
                        {% if totalResults == 1 %}
                            1 result found
                        {% else %}
                            {{ totalResults }} results found
                        {% endif %}
                    </h2>
                    <p class="results-query">for "{{ query }}"</p>
                </div>
                
                <!-- Enhanced Search Statistics -->
                {% if searchStats %}
                    <div class="search-statistics">
                        <div class="stat-item">
                            <span class="stat-icon">📄</span>
                            <span class="stat-number">{{ searchStats.total_pages }}</span>
                            <span class="stat-label">pages</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-icon">📖</span>
                            <span class="stat-number">{{ searchStats.total_quran }}</span>
                            <span class="stat-label">verses</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-icon">📚</span>
                            <span class="stat-number">{{ searchStats.total_hadith }}</span>
                            <span class="stat-label">hadith</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-icon">📅</span>
                            <span class="stat-number">{{ searchStats.total_calendar }}</span>
                            <span class="stat-label">events</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-icon">🕌</span>
                            <span class="stat-number">{{ searchStats.total_prayer }}</span>
                            <span class="stat-label">locations</span>
                        </div>
                    </div>
                {% endif %}
            </div>

            <!-- Enhanced Results -->
            {% if results %}
                <div class="results-grid">
                    {% for result in results %}
                        <div class="result-card">
                            <!-- Enhanced Result Type Badge -->
                            <div class="result-header">
                                <div class="result-badges">
                                    {% if result.type == 'page' %}
                                        <span class="result-badge result-badge-page">📄 Page</span>
                                    {% elseif result.type == 'quran' %}
                                        <span class="result-badge result-badge-quran">📖 Quran</span>
                                    {% elseif result.type == 'hadith' %}
                                        <span class="result-badge result-badge-hadith">📚 Hadith</span>
                                    {% elseif result.type == 'calendar' %}
                                        <span class="result-badge result-badge-calendar">📅 Event</span>
                                    {% elseif result.type == 'prayer' %}
                                        <span class="result-badge result-badge-prayer">🕌 Prayer</span>
                                    {% endif %}
                                    
                                    {% if result.relevance %}
                                        <span class="relevance-badge">Relevance: {{ (result.relevance * 100) | round(1) }}%</span>
                                    {% endif %}
                                </div>
                                
                                <div class="result-date">
                                    {% if result.updated_at %}
                                        {{ result.updated_at | date('M j, Y') }}
                                    {% elseif result.event_date %}
                                        {{ result.event_date | date('M j, Y') }}
                                    {% elseif result.prayer_date %}
                                        {{ result.prayer_date | date('M j, Y') }}
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Enhanced Result Title -->
                            <h3 class="result-title">
                                <a href="{{ result.url }}" class="result-link">
                                    {{ result.title }}
                                </a>
                            </h3>

                            <!-- Enhanced Result Details -->
                            {% if result.type == 'quran' %}
                                <div class="result-details">
                                    <p class="result-meta">
                                        <strong>Surah:</strong> {{ result.surah_name }} ({{ result.surah_id }}:{{ result.verse_number }})
                                    </p>
                                    {% if result.arabic_text %}
                                        <div class="arabic-text" dir="rtl">
                                            {{ result.arabic_text }}
                                        </div>
                                    {% endif %}
                                </div>
                            {% elseif result.type == 'hadith' %}
                                <div class="result-details">
                                    <p class="result-meta">
                                        <strong>Collection:</strong> {{ result.collection_name }} #{{ result.hadith_number }}
                                        {% if result.authenticity %}
                                            <span class="authenticity-badge">{{ result.authenticity }}</span>
                                        {% endif %}
                                    </p>
                                    {% if result.narrator %}
                                        <p class="result-meta">
                                            <strong>Narrator:</strong> {{ result.narrator }}
                                        </p>
                                    {% endif %}
                                </div>
                            {% elseif result.type == 'calendar' %}
                                <div class="result-details">
                                    <p class="result-meta">
                                        <strong>Date:</strong> {{ result.event_date | date('F j, Y') }}
                                        {% if result.hijri_date %}
                                            ({{ result.hijri_date }})
                                        {% endif %}
                                        {% if result.category_name %}
                                            <span class="category-badge">{{ result.category_name }}</span>
                                        {% endif %}
                                    </p>
                                </div>
                            {% elseif result.type == 'prayer' %}
                                <div class="result-details">
                                    <p class="result-meta">
                                        <strong>Location:</strong> {{ result.location_name }}
                                        {% if result.prayer_date %}
                                            <span class="date-badge">{{ result.prayer_date | date('M j, Y') }}</span>
                                        {% endif %}
                                    </p>
                                </div>
                            {% endif %}
                            
                            <!-- Enhanced Excerpt -->
                            {% if result.excerpt %}
                                <div class="result-excerpt">
                                    {{ result.excerpt | raw }}
                                </div>
                            {% endif %}
                            
                            <!-- Enhanced Action Buttons -->
                            <div class="result-actions">
                                <a href="{{ result.url }}" class="action-button action-button-primary">
                                    <span class="action-icon">👁️</span>
                                    <span class="action-text">View Details</span>
                                </a>
                                
                                {% if result.type == 'page' %}
                                    <a href="{{ result.url }}/edit" class="action-button action-button-secondary">
                                        <span class="action-icon">✏️</span>
                                        <span class="action-text">Edit</span>
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <!-- Enhanced Empty State -->
                <div class="empty-results">
                    <div class="empty-icon">🔍</div>
                    <h3 class="empty-title">No results found</h3>
                    <p class="empty-description">Try adjusting your search terms or browse our content categories.</p>
                    <div class="empty-actions">
                        <a href="/" class="action-button action-button-primary">Browse Home</a>
                        <a href="/wiki" class="action-button action-button-secondary">View All Pages</a>
                    </div>
                </div>
            {% endif %}
        </div>
    {% endif %}
</div>

<style>
/* Bismillah Search Styling */

/* Search Header */
.search-header {
    background: linear-gradient(135deg, var(--primary-color) 0%, #7c3aed 100%);
    color: white;
    padding: 3rem 2rem;
    border-radius: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
}

.search-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="1" fill="rgba(255,255,255,0.1)"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
    opacity: 0.3;
}

.search-title {
    font-size: 3rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    line-height: 1.2;
    position: relative;
    z-index: 1;
}

.search-subtitle {
    font-size: 1.2rem;
    margin: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
}

/* Search Form */
.search-form {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 2rem;
    transition: all 0.3s ease;
}

.search-form:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
}

.search-form-content {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
}

.search-input-group {
    flex: 1;
    position: relative;
    min-width: 300px;
}

.search-input {
    width: 100%;
    padding: 1rem 1rem 1rem 3rem;
    border: 2px solid var(--border-color);
    border-radius: 1rem;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    background: var(--card-background);
    color: var(--text-primary);
}

.search-input:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
}

.search-input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.2rem;
    color: var(--text-secondary);
}

.search-type-selector {
    min-width: 200px;
}

.search-select {
    width: 100%;
    padding: 1rem;
    border: 2px solid var(--border-color);
    border-radius: 1rem;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: var(--card-background);
    color: var(--text-primary);
}

.search-select:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
}

.search-button-container {
    flex-shrink: 0;
}

.search-button {
    background: linear-gradient(135deg, var(--primary-color) 0%, #7c3aed 100%);
    color: white;
    border: none;
    padding: 1rem 2rem;
    border-radius: 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 5px 15px rgba(79, 70, 229, 0.3);
}

.search-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(79, 70, 229, 0.4);
}

.search-button-icon {
    font-size: 1.2rem;
    transition: transform 0.3s ease;
}

.search-button:hover .search-button-icon {
    transform: translateX(3px);
}

/* Search Results Container */
.search-results-container {
    max-width: 1200px;
    margin: 0 auto;
}

/* Results Header */
.results-header {
    background: var(--card-background);
    border-radius: 1.5rem;
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
}

.results-info {
    flex: 1;
}

.results-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem 0;
}

.results-query {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin: 0;
}

/* Search Statistics */
.search-statistics {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
}

.stat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--background-color);
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.stat-item:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
}

.stat-icon {
    font-size: 1.2rem;
}

.stat-number {
    font-weight: 700;
    color: var(--primary-color);
    font-size: 1.1rem;
}

.stat-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
}

/* Results Grid */
.results-grid {
    display: grid;
    gap: 1.5rem;
}

/* Result Card */
.result-card {
    background: var(--card-background);
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.result-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--primary-color), #7c3aed);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.result-card:hover {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.result-card:hover::before {
    opacity: 1;
}

/* Result Header */
.result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
}

.result-badges {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

/* Result Badges */
.result-badge {
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.result-badge-page {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
}

.result-badge-quran {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
}

.result-badge-hadith {
    background: rgba(139, 92, 246, 0.1);
    color: #8b5cf6;
}

.result-badge-calendar {
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
}

.result-badge-prayer {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
}

.relevance-badge {
    background: var(--background-color);
    color: var(--text-secondary);
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
}

.result-date {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
}

/* Result Title */
.result-title {
    margin: 0 0 1rem 0;
}

.result-link {
    color: var(--primary-color);
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 700;
    transition: all 0.3s ease;
}

.result-link:hover {
    color: var(--primary-hover);
    text-decoration: none;
}

/* Result Details */
.result-details {
    margin-bottom: 1.5rem;
}

.result-meta {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
}

.arabic-text {
    font-size: 1.3rem;
    line-height: 2;
    margin: 1rem 0;
    color: var(--text-primary);
    text-align: right;
}

.authenticity-badge,
.category-badge,
.date-badge {
    background: var(--background-color);
    color: var(--text-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.8rem;
    font-weight: 500;
    margin-left: 0.5rem;
}

/* Result Excerpt */
.result-excerpt {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 1rem;
}

.result-excerpt mark {
    background: rgba(79, 70, 229, 0.2);
    color: var(--primary-color);
    padding: 0.1rem 0.2rem;
    border-radius: 0.25rem;
    font-weight: 600;
}

/* Result Actions */
.result-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.action-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    font-size: 0.95rem;
}

.action-button-primary {
    background: linear-gradient(135deg, var(--primary-color) 0%, #7c3aed 100%);
    color: white;
    box-shadow: 0 5px 15px rgba(79, 70, 229, 0.3);
}

.action-button-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(79, 70, 229, 0.4);
    color: white;
    text-decoration: none;
}

.action-button-secondary {
    background: transparent;
    color: var(--primary-color);
    border-color: var(--primary-color);
}

.action-button-secondary:hover {
    background: var(--primary-color);
    color: white;
    text-decoration: none;
    transform: translateY(-2px);
}

.action-icon {
    font-size: 1rem;
}

/* Empty Results */
.empty-results {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--card-background);
    border-radius: 1.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
}

.empty-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
    opacity: 0.5;
}

.empty-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 1rem 0;
}

.empty-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin: 0 0 2rem 0;
    line-height: 1.6;
}

.empty-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

/* Responsive Design */
@media (max-width: 768px) {
    .search-title {
        font-size: 2rem;
    }
    
    .search-form-content {
        flex-direction: column;
    }
    
    .search-input-group {
        min-width: auto;
        width: 100%;
    }
    
    .search-type-selector {
        min-width: auto;
        width: 100%;
    }
    
    .search-button {
        width: 100%;
        justify-content: center;
    }
    
    .results-header {
        flex-direction: column;
        text-align: center;
    }
    
    .search-statistics {
        justify-content: center;
    }
    
    .result-header {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .result-actions {
        flex-direction: column;
    }
    
    .action-button {
        justify-content: center;
    }
}
</style>
{% endblock %} 