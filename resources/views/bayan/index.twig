{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Bayan Knowledge Graph</h1>
        <p class="text-lg text-gray-600">Explore the interconnected world of Islamic knowledge</p>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="p-2 rounded-full bg-blue-100 text-blue-600">
                    <svg class="bayan-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Total Nodes</p>
                    <p class="text-2xl font-semibold text-gray-900">{{ statistics.total_nodes|default(0) }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="p-2 rounded-full bg-green-100 text-green-600">
                    <svg class="bayan-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Total Relationships</p>
                    <p class="text-2xl font-semibold text-gray-900">{{ statistics.total_relationships|default(0) }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="p-2 rounded-full bg-purple-100 text-purple-600">
                    <svg class="bayan-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Node Types</p>
                    <p class="text-2xl font-semibold text-gray-900">{{ statistics.node_types|length|default(0) }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="p-2 rounded-full bg-orange-100 text-orange-600">
                    <svg class="bayan-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Relationship Types</p>
                    <p class="text-2xl font-semibold text-gray-900">{{ statistics.relationship_types|length|default(0) }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Mini Graph Visualization (Hubs + Neighbors) -->
    {% if graph and graph.nodes|length > 0 %}
    <div class="bg-white rounded-lg shadow p-4 mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-2">Graph Overview</h2>
        <div class="bayan-mini-graph" style="width:100%; height:320px; border:1px solid var(--border-color); border-radius:8px; background:var(--background-color); position:relative;">
            <svg id="bayanGraphSvgPage" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid meet" style="width:100%; height:100%;">
                {% for e in graph.edges %}
                <line data-edge="{{ loop.index0 }}" stroke="var(--border-color)" stroke-width="1.5" x1="0" y1="0" x2="0" y2="0"></line>
                {% endfor %}
                {% for n in graph.nodes %}
                <g data-node="{{ n.id }}">
                    <circle r="9" fill="{{ n.isHub ? '#3b82f6' : '#94a3b8' }}" stroke="#1f2937" stroke-width="1"></circle>
                    <text font-size="10" fill="var(--text-primary)" text-anchor="middle" dy="-12">{{ n.label|length > 22 ? n.label|slice(0,22) ~ '…' : n.label }}</text>
                </g>
                {% endfor %}
            </svg>
        </div>
    </div>
    {% endif %}

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-4 mb-8">
        <a href="/bayan/search" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200">
            <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            Search Knowledge Graph
        </a>
        <a href="/bayan/create" class="bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200">
            <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Create New Node
        </a>
        <a href="/bayan/statistics" class="bg-purple-600 hover:bg-purple-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200">
            <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            View Statistics
        </a>
    </div>

    <!-- Hub Nodes -->
    {% if hub_nodes %}
    <div class="bg-white rounded-lg shadow mb-8">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-xl font-semibold text-gray-900">Most Connected Nodes</h2>
            <p class="text-sm text-gray-600">Nodes with the most relationships</p>
        </div>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for node in hub_nodes %}
                <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition duration-200">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <h3 class="font-medium text-gray-900 mb-1">
                                <a href="/bayan/node/{{ node.id }}" class="hover:text-blue-600">{{ node.title }}</a>
                            </h3>
                            <p class="text-sm text-gray-600 mb-2">{{ node.type|title }}</p>
                            <p class="text-xs text-gray-500">{{ node.content|slice(0, 100) }}{% if node.content|length > 100 %}...{% endif %}</p>
                        </div>
                        <div class="ml-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                {{ node.relationship_count }} connections
                            </span>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Recent Nodes -->
    {% if recent_nodes %}
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-xl font-semibold text-gray-900">Recent Nodes</h2>
            <p class="text-sm text-gray-600">Recently added to the knowledge graph</p>
        </div>
        <div class="p-6">
            <div class="space-y-4">
                {% for node in recent_nodes %}
                <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:shadow-md transition duration-200">
                    <div class="flex-1">
                        <h3 class="font-medium text-gray-900">
                            <a href="/bayan/node/{{ node.id }}" class="hover:text-blue-600">{{ node.title }}</a>
                        </h3>
                        <p class="text-sm text-gray-600">{{ node.type|title }}</p>
                        <p class="text-xs text-gray-500 mt-1">{{ node.content|slice(0, 150) }}{% if node.content|length > 150 %}...{% endif %}</p>
                    </div>
                    <div class="ml-4 text-right">
                        <p class="text-xs text-gray-500">{{ node.created_at|date('M j, Y') }}</p>
                        {% if node.relationship_count %}
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 mt-1">
                            {{ node.relationship_count }} connections
                        </span>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %} 

{% block styles %}
<style>
.bayan-icon { width: 16px; height: 16px; }
@media (min-width: 768px) { .bayan-icon { width: 18px; height: 18px; } }
</style>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  try { initBayanGraphPage(); } catch (e) { console.warn('bayan graph init failed', e); }
});

function initBayanGraphPage() {
  const svg = document.getElementById('bayanGraphSvgPage');
  if (!svg) return;
  const width = 800, height = 300;
  const nodes = Array.from(svg.querySelectorAll('g[data-node]'));
  const edges = Array.from(svg.querySelectorAll('line[data-edge]'));

  // Split hubs/others by fill color
  const nodeData = nodes.map(g => ({ id: parseInt(g.getAttribute('data-node'), 10), el: g }));
  const hubs = nodeData.filter(nd => (nd.el.querySelector('circle')?.getAttribute('fill') === '#3b82f6'));
  const others = nodeData.filter(nd => !hubs.includes(nd));

  // Place hubs across the top
  const hubCount = Math.max(1, hubs.length);
  hubs.forEach((nd, i) => {
    const x = ((i + 1) * (width / (hubCount + 1)));
    const y = 110;
    nd.el.setAttribute('transform', `translate(${x},${y})`);
  });

  // Place others in two arcs below
  const radius = 90;
  const step = (Math.PI) / Math.max(1, others.length);
  others.forEach((nd, i) => {
    const angle = i * step + Math.PI/6;
    const x = width/2 + Math.cos(angle) * (radius + (i % 2 === 0 ? 20 : 0));
    const y = 200 + Math.sin(angle) * 35;
    nd.el.setAttribute('transform', `translate(${x},${y})`);
  });

  // Build id -> position map
  const pos = new Map();
  [...hubs, ...others].forEach(nd => {
    const t = nd.el.getAttribute('transform');
    const m = /translate\(([^,]+),([^\)]+)\)/.exec(t || '');
    if (m) pos.set(nd.id, { x: parseFloat(m[1]), y: parseFloat(m[2]) });
  });

  // Draw edges between hubs and nearest others
  let idx = 0;
  hubs.forEach(h => {
    others.slice(idx, idx + 6).forEach(o => {
      const e = edges.shift();
      if (!e) return;
      const p1 = pos.get(h.id), p2 = pos.get(o.id);
      e.setAttribute('x1', String(p1.x));
      e.setAttribute('y1', String(p1.y));
      e.setAttribute('x2', String(p2.x));
      e.setAttribute('y2', String(p2.y));
      e.setAttribute('stroke', 'var(--border-color)');
    });
    idx += 6;
  });
}
</script>
{% endblock %}