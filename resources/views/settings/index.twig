{% extends "layouts/app.twig" %}

{% block title %}{{ __('settings.title') }}{% endblock %}

{% block content %}
<div class="settings-container">
    <div class="settings-header">
        <h1>{{ __('settings.title') }}</h1>
        <p>{{ __('settings.subtitle') }}</p>
    </div>
    <div class="settings-content">
        <!-- Language Settings Section -->
        <div class="settings-section">
            <h2>{{ __('settings.language.title') }}</h2>
            <p>{{ __('settings.language.description') }}</p>
            
            <div class="language-grid">
                {% for language in supported_languages %}
                <div class="language-option {% if language.code == current_language %}selected{% endif %}" 
                     data-language="{{ language.code }}">
                    <div class="language-flag">{{ language.flag }}</div>
                    <div class="language-name">{{ language.native_name }}</div>
                    <div class="language-english">{{ language.name }}</div>
                    {% if language.code == current_language %}
                        <div class="current-indicator">{{ __('settings.language.current') }}</div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>

                            <form id="language-form" method="POST" action="{{ current_language() == 'en' ? '/settings/language' : '/' ~ current_language() ~ '/settings/language' }}" class="settings-form">
                <input type="hidden" name="language" id="selected-language" value="{{ current_language }}">
                <button type="submit" class="btn btn-primary">{{ __('settings.language.update') }}</button>
            </form>
        </div>

        <!-- Skin Settings Section -->
        <div class="settings-section">
            <h2>{{ __('settings.theme.title') }}</h2>
            <p>{{ __('settings.theme.description') }}</p>
            
            <div class="skin-options">
                <div class="skin-option">
                    <input type="radio" name="skin" id="skin-bismillah" value="Bismillah" checked>
                    <label for="skin-bismillah">
                        <span class="skin-name">{{ __('settings.skins.bismillah.name') }}</span>
                        <span class="skin-description">{{ __('settings.skins.bismillah.description') }}</span>
                    </label>
                </div>
                
                <div class="skin-option">
                    <input type="radio" name="skin" id="skin-muslim" value="Muslim">
                    <label for="skin-muslim">
                        <span class="skin-name">{{ __('settings.skins.muslim.name') }}</span>
                        <span class="skin-description">{{ __('settings.skins.muslim.description') }}</span>
                    </label>
                </div>
            </div>

            <form id="skin-form" method="POST" action="/settings/skin" class="settings-form">
                <input type="hidden" name="skin" id="selected-skin" value="Bismillah">
                <button type="submit" class="btn btn-secondary">{{ __('settings.theme.update') }}</button>
            </form>
        </div>
    </div>
</div>


<script>
document.addEventListener('DOMContentLoaded', function() {
    // Language selection
    const languageOptions = document.querySelectorAll('.language-option');
    const selectedLanguageInput = document.getElementById('selected-language');
    
    languageOptions.forEach(option => {
        option.addEventListener('click', function() {
            // Remove selected class from all options
            languageOptions.forEach(opt => opt.classList.remove('selected'));
            
            // Add selected class to clicked option
            this.classList.add('selected');
            
            // Update hidden input
            const language = this.dataset.language;
            selectedLanguageInput.value = language;
        });
    });
    
    // Skin selection
    const skinOptions = document.querySelectorAll('input[name="skin"]');
    const selectedSkinInput = document.getElementById('selected-skin');
    
    skinOptions.forEach(option => {
        option.addEventListener('change', function() {
            selectedSkinInput.value = this.value;
        });
    });
    
    // Form submission feedback
    const languageForm = document.getElementById('language-form');
    const skinForm = document.getElementById('skin-form');
    
    languageForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.textContent;
        submitBtn.textContent = '{{ __('messages.info.loading') }}';
        submitBtn.disabled = true;
        
        // Submit form via AJAX
        const formData = new FormData(this);
        
        // Get the form action URL for the fetch request
        const formAction = this.action;
        
        fetch(formAction, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Show success message
                alert(data.message);
                // Redirect to locale-aware settings page if provided
                if (data.redirect_url) {
                    window.location.href = data.redirect_url;
                } else {
                    // Fallback: stay on settings page and refresh
                    window.location.reload();
                }
            } else {
                // Show error message
                alert(data.message);
                // Reset button
                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('{{ __('messages.error.server_error') }}');
            // Reset button
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
        });
    });
    
    skinForm.addEventListener('submit', function(e) {
        const submitBtn = this.querySelector('button[type="submit"]');
        submitBtn.textContent = '{{ __('messages.info.loading') }}';
        submitBtn.disabled = true;
    });
});
</script>
{% endblock %} 