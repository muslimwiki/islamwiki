{% extends "layouts/app.twig" %}

{% block title %}{{ __('settings.title') }}{% endblock %}

{% block content %}
<div class="settings-container">
    <div class="settings-header">
        <h1>{{ __('settings.title') }}</h1>
        <p>{{ __('settings.subtitle') }}</p>
    </div>
    <div class="settings-content">
        <!-- Language Settings Section -->
        <div class="settings-section">
            <h2>{{ __('settings.language.title') }}</h2>
            <p>{{ __('settings.language.description') }}</p>
            
            <div class="language-grid">
                {% for language in supported_languages %}
                <div class="language-option {% if language.code == current_language %}selected{% endif %}" 
                     data-language="{{ language.code }}">
                    <div class="language-flag">{{ language.flag }}</div>
                    <div class="language-name">{{ language.native_name }}</div>
                    <div class="language-english">{{ language.name }}</div>
                    {% if language.code == current_language %}
                        <div class="current-indicator">{{ __('settings.language.current') }}</div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>

                            <form id="language-form" method="POST" action="{{ current_language() == 'en' ? '/settings/language' : '/' ~ current_language() ~ '/settings/language' }}" class="settings-form">
                <input type="hidden" name="language" id="selected-language" value="{{ current_language }}">
                <button type="submit" class="btn btn-primary">{{ __('settings.language.update') }}</button>
            </form>
        </div>

        <!-- Skin Settings Section -->
        <div class="settings-section">
            <h2>{{ __('settings.theme.title') }}</h2>
            <p>{{ __('settings.theme.description') }}</p>
            
            <div class="skin-options">
                <div class="skin-option">
                    <input type="radio" name="skin" id="skin-bismillah" value="Bismillah" checked>
                    <label for="skin-bismillah">
                        <span class="skin-name">{{ __('settings.skins.bismillah.name') }}</span>
                        <span class="skin-description">{{ __('settings.skins.bismillah.description') }}</span>
                    </label>
                </div>
                
                <div class="skin-option">
                    <input type="radio" name="skin" id="skin-muslim" value="Muslim">
                    <label for="skin-muslim">
                        <span class="skin-name">{{ __('settings.skins.muslim.name') }}</span>
                        <span class="skin-description">{{ __('settings.skins.muslim.description') }}</span>
                    </label>
                </div>
            </div>

            <form id="skin-form" method="POST" action="/settings/skin" class="settings-form">
                <input type="hidden" name="skin" id="selected-skin" value="Bismillah">
                <button type="submit" class="btn btn-secondary">{{ __('settings.theme.update') }}</button>
            </form>
        </div>
    </div>
</div>

<style>
.settings-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
}

.settings-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 30px;
    background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
    color: white;
    border-radius: 15px;
}

.settings-header h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    font-weight: 300;
}

.settings-header p {
    font-size: 1.1rem;
    opacity: 0.9;
}

.settings-content {
    background: white;
    border-radius: 15px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    overflow: hidden;
}

.settings-section {
    padding: 40px;
    border-bottom: 1px solid #E5E7EB;
}

.settings-section:last-child {
    border-bottom: none;
}

.settings-section h2 {
    color: #374151;
    font-size: 1.5rem;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid #E5E7EB;
}

.settings-section p {
    color: #6B7280;
    margin-bottom: 20px;
    line-height: 1.6;
}

.language-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin: 20px 0;
}

.language-option {
    border: 2px solid #E5E7EB;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
}

.language-option:hover {
    border-color: #4F46E5;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(79, 70, 229, 0.15);
}

.language-option.selected {
    border-color: #4F46E5;
    background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
}

.language-option.selected::before {
    content: "✓";
    position: absolute;
    top: 10px;
    right: 15px;
    background: #4F46E5;
    color: white;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.language-flag {
    font-size: 2rem;
    margin-bottom: 10px;
}

.language-name {
    font-size: 1.2rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 5px;
}

.language-english {
    font-size: 0.9rem;
    color: #6B7280;
}

.current-indicator {
    position: absolute;
    top: 10px;
    left: 15px;
    background: #10B981;
    color: white;
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
}

.skin-options {
    margin: 20px 0;
}

.skin-option {
    display: flex;
    align-items: center;
    padding: 15px;
    border: 2px solid #E5E7EB;
    border-radius: 8px;
    margin-bottom: 15px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.skin-option:hover {
    border-color: #4F46E5;
    background: #F9FAFB;
}

.skin-option input[type="radio"] {
    margin-right: 15px;
    transform: scale(1.2);
}

.skin-option label {
    cursor: pointer;
    flex: 1;
}

.skin-name {
    display: block;
    font-weight: 600;
    color: #374151;
    margin-bottom: 5px;
}

.skin-description {
    display: block;
    font-size: 0.9rem;
    color: #6B7280;
}

.settings-form {
    margin-top: 20px;
}

.btn {
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
}

.btn-primary {
    background: #4F46E5;
    color: white;
}

.btn-primary:hover {
    background: #4338CA;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
}

.btn-secondary {
    background: #6B7280;
    color: white;
}

.btn-secondary:hover {
    background: #4B5563;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(107, 114, 128, 0.3);
}

/* RTL Support */
[dir="rtl"] .language-option.selected::before {
    right: auto;
    left: 15px;
}

[dir="rtl"] .current-indicator {
    left: auto;
    right: 15px;
}

[dir="rtl"] .skin-option input[type="radio"] {
    margin-right: 0;
    margin-left: 15px;
}

/* Responsive Design */
@media (max-width: 768px) {
    .settings-container {
        padding: 10px;
    }
    
    .settings-header {
        padding: 20px;
    }
    
    .settings-header h1 {
        font-size: 2rem;
    }
    
    .settings-section {
        padding: 20px;
    }
    
    .language-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Language selection
    const languageOptions = document.querySelectorAll('.language-option');
    const selectedLanguageInput = document.getElementById('selected-language');
    
    languageOptions.forEach(option => {
        option.addEventListener('click', function() {
            // Remove selected class from all options
            languageOptions.forEach(opt => opt.classList.remove('selected'));
            
            // Add selected class to clicked option
            this.classList.add('selected');
            
            // Update hidden input
            const language = this.dataset.language;
            selectedLanguageInput.value = language;
        });
    });
    
    // Skin selection
    const skinOptions = document.querySelectorAll('input[name="skin"]');
    const selectedSkinInput = document.getElementById('selected-skin');
    
    skinOptions.forEach(option => {
        option.addEventListener('change', function() {
            selectedSkinInput.value = this.value;
        });
    });
    
    // Form submission feedback
    const languageForm = document.getElementById('language-form');
    const skinForm = document.getElementById('skin-form');
    
    languageForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.textContent;
        submitBtn.textContent = '{{ __('messages.info.loading') }}';
        submitBtn.disabled = true;
        
        // Submit form via AJAX
        const formData = new FormData(this);
        
        // Get the form action URL for the fetch request
        const formAction = this.action;
        
        fetch(formAction, {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Show success message
                alert(data.message);
                // Redirect to locale-aware settings page if provided
                if (data.redirect_url) {
                    window.location.href = data.redirect_url;
                } else {
                    // Fallback: stay on settings page and refresh
                    window.location.reload();
                }
            } else {
                // Show error message
                alert(data.message);
                // Reset button
                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('{{ __('messages.error.server_error') }}');
            // Reset button
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
        });
    });
    
    skinForm.addEventListener('submit', function(e) {
        const submitBtn = this.querySelector('button[type="submit"]');
        submitBtn.textContent = '{{ __('messages.info.loading') }}';
        submitBtn.disabled = true;
    });
});
</script>
{% endblock %} 