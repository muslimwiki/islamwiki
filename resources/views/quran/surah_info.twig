{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block head %}
<!-- Quran-specific CSS -->
<link rel="stylesheet" href="/skins/Bismillah/css/quran.css?v={{ 'now'|date('U') }}">
<link rel="stylesheet" href="/skins/Bismillah/css/quran-extension.css?v={{ 'now'|date('U') }}">
{% endblock %}

{% block content %}
<div class="quran-section">
    <div class="max-w-3xl mx-auto">
        <h1 class="text-2xl font-semibold mb-2">Surah {{ info.surah_number }} Information</h1>
        <div class="bg-white rounded-lg shadow p-6">
            <div class="text-xl">{{ info.surah_name_arabic }} — {{ info.surah_name_english }}</div>
            <div class="text-gray-600 mb-4">{{ info.surah_name_translation }}</div>
            <div class="grid grid-cols-2 gap-4 text-sm mb-4">
                <div><strong>Revelation:</strong> {{ info.revelation_type }}</div>
                <div><strong>Ayahs:</strong> {{ info.ayah_count }}</div>
                <div><strong>Juz Start:</strong> {{ info.juz_start }}</div>
                <div><strong>Juz End:</strong> {{ info.juz_end }}</div>
            </div>
            <div class="prose max-w-none">
                {{ info.description }}
            </div>
            <div class="mt-4">
                <a href="/{{ locale }}/quran/surah/{{ info.surah_number }}" class="text-blue-600 hover:text-blue-700">Read Surah</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
