{% extends "layouts/app.twig" %}

{% block title %}Quran {{ chapter }}:{{ ayah_number }}{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto bg-yellow-50 border border-yellow-200 text-yellow-800 rounded p-4">
        <p>This view is deprecated. Please use <a class="underline text-blue-700" href="/quran/{{ chapter }}/{{ ayah_number }}">/quran/{{ chapter }}/{{ ayah_number }}</a>.</p>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function copyVerse() {
    const text = `Quran ${chapter}:${ayah_number} - ${verse.arabic_text}`;
    navigator.clipboard.writeText(text).then(() => {
        alert('Verse reference copied to clipboard!');
    });
}

function shareVerse() {
    const text = `Quran ${chapter}:${ayah_number} - ${verse.arabic_text}`;
    const url = window.location.href;
    
    if (navigator.share) {
        navigator.share({
            title: 'Quran Verse',
            text: text,
            url: url
        });
    } else {
        // Fallback for browsers that don't support Web Share API
        const shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;
        window.open(shareUrl, '_blank');
    }
}
</script>
{% endblock %}

{% block styles %}
<style>
    .font-arabic {
        font-family: 'Amiri', 'Scheherazade', serif;
    }
</style>
{% endblock %} 