{% extends "layouts/app.twig" %}

{% block title %}{{ title|default('Quran Ayah') }} - IslamWiki{% endblock %}

{% block styles %}
{{ parent() }}
<link rel="stylesheet" href="/skins/Bismillah/css/quran.css">
{% endblock %}

{% block content %}
<div class="quran-ayah-container">
    <!-- Navigation -->
    <div class="ayah-navigation">
        <a href="/quran/surah/{{ surah }}" class="nav-link">
            <i class="fas fa-arrow-left"></i> Back to Surah {{ surah }}
        </a>
        <div class="ayah-reference">
            <span class="surah-number">Surah {{ surah }}</span>
            <span class="separator">:</span>
            <span class="ayah-number">Ayah {{ ayah_number }}</span>
        </div>
    </div>

    {% if ayah %}
        <div class="ayah-content">
            <!-- Arabic Text Section -->
            <div class="ayah-arabic">
                <div class="arabic-text">{{ ayah.text_arabic|default('بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ') }}</div>
                <div class="ayah-number-arabic">{{ ayah.ayah_number|default(ayah_number) }}</div>
            </div>

            <div class="quran-ayah-section">
                <div class="quran-ayah-content">
                    <div class="quran-ayah-arabic">{{ ayah.text_arabic }}</div>
                    <div class="text-sm text-gray-500 text-center">الآية {{ ayah_number }}</div>
                </div>

                {% if ayah.translation_text %}
                    <div class="quran-ayah-translation">
                        <h3 class="text-lg font-semibold text-gray-800 mb-3">Translation</h3>
                        <div class="text-gray-700 leading-relaxed">{{ ayah.translation_text }}</div>
                        {% if ayah.translator %}
                            <div class="text-sm text-gray-500 mt-2">— {{ ayah.translator }}</div>
                        {% endif %}
                    </div>
                {% endif %}

                <div class="border-t border-gray-200 pt-6">
                    <div class="flex justify-between items-center">
                        <div>
                            {% if ayah_number > 1 %}
                                <a href="/quran/{{ surah }}/{{ ayah_number - 1 }}"
                                   class="text-green-600 hover:text-green-700 font-medium">
                                    ← Previous Ayah
                                </a>
                            {% endif %}
                        </div>
                        <div class="text-center">
                            {% if ayah_number < 6236 %}
                                <a href="/quran/{{ surah }}/{{ ayah_number + 1 }}"
                                   class="text-green-600 hover:text-green-700 font-medium">
                                    Next Ayah →
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="text-center py-12">
            <p class="text-gray-600">Ayah not found.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
