{% extends "layouts/app.twig" %}

{% block title %}{{ title|default('Quran Error') }}{% endblock %}

{% block content %}
<div class="max-w-3xl mx-auto py-10">
  <div class="bg-red-50 border border-red-200 text-red-800 rounded-md p-6">
    <h1 class="text-2xl font-semibold mb-2">Quran Error</h1>
    <p class="mb-4">{{ error|default('An unexpected error occurred while loading Quran content. Please try again later.') }}</p>
    <div class="mt-6">
      <a href="/quran" class="inline-block px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">Back to Quran</a>
    </div>
  </div>
</div>
{% endblock %}
