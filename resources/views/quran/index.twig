{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="quran-section">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="quran-header">
            <h1 class="quran-title">القرآن الكريم</h1>
            <h2 class="quran-subtitle">The Holy Quran</h2>
            <p class="quran-description">Explore the divine revelation with search, study, and reflection tools</p>
        </div>

        <!-- Statistics -->
        {% if stats %}
        <div class="quran-stats">
            <h3 class="text-xl font-semibold text-gray-800 mb-4">Quran Statistics</h3>
            <div class="quran-stats-grid">
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.total_chapters }}</span>
                    <div class="quran-stat-label">Chapters</div>
                </div>
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.total_verses }}</span>
                    <div class="quran-stat-label">Verses</div>
                </div>
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.max_chapter }}</span>
                    <div class="quran-stat-label">Last Chapter</div>
                </div>
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.max_verse }}</span>
                    <div class="quran-stat-label">Longest Chapter</div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Quick Actions -->
        <div class="grid md:grid-cols-2 gap-6 mb-8">
            <!-- Search -->
            <div class="quran-search-section">
                <h3 class="text-xl font-semibold text-gray-800 mb-4">Search Quran</h3>
                <form action="/quran/search" method="GET" class="quran-search-form">
                    <div>
                        <label for="search" class="block text-sm font-medium text-gray-700 mb-2">Search Query</label>
                        <input type="text" id="search" name="q" placeholder="Enter keywords to search..." 
                               class="quran-search-input">
                    </div>
                    <div>
                        <label for="language" class="block text-sm font-medium text-gray-700 mb-2">Language</label>
                        <select id="language" name="lang" class="quran-search-select">
                            <option value="en">English</option>
                            <option value="ar">Arabic</option>
                            <option value="ur">Urdu</option>
                            <option value="tr">Turkish</option>
                        </select>
                    </div>
                    <button type="submit" class="quran-search-btn">
                        Search Quran
                    </button>
                </form>
            </div>

            <!-- Quick Navigation -->
            <div class="quran-navigation">
                <h3 class="text-xl font-semibold text-gray-800 mb-4">Quick Navigation</h3>
                <div class="space-y-3">
                    <a href="/quran/chapter/1" class="quran-nav-item">
                        <div class="quran-nav-title">Al-Fatiha (The Opening)</div>
                        <div class="quran-nav-subtitle">Chapter 1 - 7 verses</div>
                    </a>
                    <a href="/quran/chapter/2" class="quran-nav-item">
                        <div class="quran-nav-title">Al-Baqarah (The Cow)</div>
                        <div class="quran-nav-subtitle">Chapter 2 - 286 verses</div>
                    </a>
                    <a href="/quran/chapter/36" class="quran-nav-item">
                        <div class="quran-nav-title">Ya-Sin</div>
                        <div class="quran-nav-subtitle">Chapter 36 - 83 verses</div>
                    </a>
                    <a href="/quran/chapter/55" class="quran-nav-item">
                        <div class="quran-nav-title">Ar-Rahman (The Beneficent)</div>
                        <div class="quran-nav-subtitle">Chapter 55 - 78 verses</div>
                    </a>
                </div>
            </div>
        </div>

        <!-- Random Verse -->
        {% if random_verse %}
        <div class="quran-verse-section">
            <div class="quran-verse-header">
                <h3 class="quran-verse-title">Verse of the Day</h3>
            </div>
            <div class="quran-verse-content">
                <div class="quran-verse-arabic">{{ random_verse.arabic_text }}</div>
                {% if random_verse.translation_text %}
                <div class="quran-verse-translation">
                    <div class="font-medium mb-2">Translation:</div>
                    <div class="italic">{{ random_verse.translation_text }}</div>
                </div>
                {% endif %}
            </div>
            <div class="quran-verse-meta">
                <a href="/quran/verse/{{ random_verse.chapter_number }}/{{ random_verse.verse_number }}" 
                   class="quran-verse-chapter">
                    Quran {{ random_verse.chapter_number }}:{{ random_verse.verse_number }}
                </a>
                {% if random_verse.translator_name %}
                <span class="quran-verse-number">- {{ random_verse.translator_name }}</span>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <!-- Features -->
        <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white rounded-lg shadow-md p-6 text-center">
                <div class="text-3xl mb-4">📖</div>
                <h3 class="text-lg font-semibold text-gray-800 mb-2">Study</h3>
                <p class="text-gray-600 text-sm">Read and study Quran verses with translations and interpretations</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-6 text-center">
                <div class="text-3xl mb-4">🔍</div>
                <h3 class="text-lg font-semibold text-gray-800 mb-2">Search</h3>
                <p class="text-gray-600 text-sm">Search through the entire Quran by keywords and topics</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-6 text-center">
                <div class="text-3xl mb-4">🎧</div>
                <h3 class="text-lg font-semibold text-gray-800 mb-2">Listen</h3>
                <p class="text-gray-600 text-sm">Listen to beautiful recitations of Quran verses</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<style>
    .font-arabic {
        font-family: 'Amiri', 'Scheherazade', serif;
    }
</style>
{% endblock %} 