{% extends 'layouts/app.twig' %}

{% block title %}Quran & Tafsir - IslamWiki{% endblock %}

{% block content %}
<div class="quran-page">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">📖 Quran & Tafsir</h1>
        <p class="page-subtitle">The Holy Quran with translations, commentary, and scholarly interpretations</p>
    </div>

    <!-- Quran Stats -->
    <div class="quran-stats">
        <div class="stat-card">
            <div class="stat-icon">📚</div>
            <div class="stat-content">
                <div class="stat-number">114</div>
                <div class="stat-label">Surahs</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📖</div>
            <div class="stat-content">
                <div class="stat-number">6,236</div>
                <div class="stat-label">Verses</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🌍</div>
            <div class="stat-content">
                <div class="stat-number">47</div>
                <div class="stat-label">Languages</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📝</div>
            <div class="stat-content">
                <div class="stat-number">9</div>
                <div class="stat-label">Translators</div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="quran-content-grid">
        <!-- Left Column: Surah List -->
        <div class="surah-list-section">
            <div class="section-card">
                <div class="card-header">
                    <h2>📚 All Surahs</h2>
                    <div class="search-box">
                        <input type="text" id="surah-search" placeholder="Search surahs..." class="search-input">
                    </div>
                </div>
                
                <div class="surah-list" id="surah-list">
                    {% for surah in surahs %}
                    <div class="surah-item" data-surah="{{ surah.number }}">
                        <div class="surah-number">{{ surah.number }}</div>
                        <div class="surah-info">
                            <div class="surah-name">{{ surah.name_arabic }}</div>
                            <div class="surah-details">
                                <span class="surah-name-english">{{ surah.name_english }}</span>
                                <span class="surah-verse-count">{{ surah.verse_count }} verses</span>
                            </div>
                        </div>
                        <div class="surah-type">{{ surah.revelation_type }}</div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Right Column: Featured Content -->
        <div class="featured-content-section">
            <!-- Random Ayah -->
            <div class="section-card">
                <div class="card-header">
                    <h3>🌟 Verse of the Day</h3>
                </div>
                <div class="random-ayah">
                    {% if random_ayah %}
                    <div class="arabic-text">
                        {{ random_ayah.arabic_text }}
                    </div>
                    <div class="translation">
                        "{{ random_ayah.translation }}"
                    </div>
                    <div class="ayah-meta">
                        <span class="surah-name">{{ random_ayah.surah_name }}</span>
                        <span class="ayah-number">Verse {{ random_ayah.ayah_number }}</span>
                    </div>
                    {% else %}
                    <div class="placeholder-text">
                        <div class="placeholder-icon">📖</div>
                        <p>Loading verse of the day...</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="section-card">
                <div class="card-header">
                    <h3>⚡ Quick Actions</h3>
                </div>
                <div class="quran-actions">
                    <a href="{{ lang_url('quran/search') }}" class="btn btn-primary">
                        <span class="btn-icon">🔍</span>
                        Search Quran
                    </a>
                    <a href="{{ lang_url('quran/1') }}" class="btn btn-secondary">
                        <span class="btn-icon">📖</span>
                        Read Surah Al-Fatiha
                    </a>
                    <a href="{{ lang_url('quran/juz/1') }}" class="btn btn-secondary">
                        <span class="btn-icon">📚</span>
                        Browse by Juz
                    </a>
                    <a href="{{ lang_url('quran/page/1') }}" class="btn btn-secondary">
                        <span class="btn-icon">📄</span>
                        Browse by Page
                    </a>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="section-card">
                <div class="card-header">
                    <h3>📊 Recent Activity</h3>
                </div>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-icon">👁️</div>
                        <div class="activity-content">
                            <div class="activity-text">Surah Al-Fatiha viewed</div>
                            <div class="activity-time">2 hours ago</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon">📖</div>
                        <div class="activity-content">
                            <div class="activity-text">Surah Al-Baqarah read</div>
                            <div class="activity-time">1 day ago</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block head %}
{% endblock %}

{% block scripts %}
<script>
    // Surah search functionality
    document.getElementById('surah-search')?.addEventListener('input', function(e) {
        const query = e.target.value.toLowerCase();
        const surahItems = document.querySelectorAll('.surah-item');
        
        surahItems.forEach(item => {
            const surahName = item.querySelector('.surah-name').textContent.toLowerCase();
            const surahNameEnglish = item.querySelector('.surah-name-english').textContent.toLowerCase();
            
            if (surahName.includes(query) || surahNameEnglish.includes(query)) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    });

    // Surah item click handlers
    document.querySelectorAll('.surah-item').forEach(item => {
        item.addEventListener('click', function() {
            const surahNumber = this.dataset.surah;
            window.location.href = `/quran/surah/${surahNumber}`;
        });
    });

    // Add hover effects
    document.querySelectorAll('.surah-item').forEach(item => {
        item.addEventListener('mouseenter', function() {
            this.style.transform = 'translateX(5px)';
        });
        
        item.addEventListener('mouseleave', function() {
            this.style.transform = 'translateX(0)';
        });
    });
</script>
{% endblock %} 