{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="quran-section">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="quran-header">
            <h1 class="quran-title">القرآن الكريم</h1>
            <h2 class="quran-subtitle">The Holy Quran</h2>
            <p class="quran-description">Explore the divine revelation with search, study, and reflection tools</p>
        </div>

        <!-- Controls -->
        <form method="get" class="quran-search-form">
            <label class="quran-language-selector">Translation</label>
            <select name="translator" class="quran-search-select" onchange="this.form.submit()">
                {% for t in translators %}
                    <option value="{{ t.translator|default(t.name) }}" {% if translator == (t.translator|default(t.name)) %}selected{% endif %}>
                        {{ t.name }} ({{ t.language|upper }})
                    </option>
                {% endfor %}
            </select>
            <input type="hidden" name="lang" value="{{ language|default('en') }}" />
        </form>

        <!-- Statistics -->
        {% if stats %}
        <div class="quran-stats">
            <h3>Quran Statistics</h3>
            <div class="quran-stats-grid">
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.total_chapters }}</span>
                    <div class="quran-stat-label">Surahs</div>
                </div>
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.total_ayahs }}</span>
                    <div class="quran-stat-label">Ayahs</div>
                </div>
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.max_chapter }}</span>
                    <div class="quran-stat-label">Last Surah</div>
                </div>
                <div class="quran-stat-item">
                    <span class="quran-stat-number">{{ stats.max_ayah }}</span>
                    <div class="quran-stat-label">Max Ayahs in Surah</div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Surah List -->
        {% if surahs %}
        <div class="quran-content-section">
            <h3 class="quran-section-title">Surahs</h3>
            <div class="quran-grid">
                {% for s in surahs %}
                <a href="/quran/surah/{{ s.surah_number }}" class="quran-nav-item">
                    <div class="quran-nav-title">
                        {{ s.surah_number }}. {{ s.name_english }} — {{ s.name_translation }}
                    </div>
                    <div class="quran-nav-subtitle">
                        {{ s.revelation_type }} • {{ s.verses_count }} ayahs
                    </div>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Juz Overview -->
        {% if juz_stats %}
        <div class="quran-content-section">
            <h3 class="quran-section-title">Juz (30 Parts)</h3>
            <div class="quran-grid">
                {% for j in juz_stats %}
                <a href="/quran/juz/{{ j.juz }}" class="quran-nav-item">
                    <div class="quran-nav-title">Juz {{ j.juz }}</div>
                    <div class="quran-nav-subtitle">{{ j.ayah_count }} ayahs</div>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Random Ayah -->
        {% if random_ayah %}
        <div class="quran-ayah-section">
            <div class="quran-ayah-header">
                <h3 class="quran-ayah-title">Ayah of the Day</h3>
            </div>
            <div class="quran-ayah-content">
                <div class="quran-ayah-arabic">{{ random_ayah.arabic_text }}</div>
                {% if random_ayah.translation_text %}
                <div class="quran-ayah-translation">
                    <div class="quran-translation-label">Translation:</div>
                    <div class="quran-translation-text">{{ random_ayah.translation_text }}</div>
                </div>
                {% endif %}
            </div>
            <div class="quran-ayah-meta">
                <a href="/quran/{{ random_ayah.chapter_number }}/{{ random_ayah.ayah_number }}" 
                   class="quran-ayah-chapter">
                    Quran {{ random_ayah.chapter_number }}:{{ random_ayah.ayah_number }}
                </a>
                {% if random_ayah.translator_name %}
                <span class="quran-ayah-number">- {{ random_ayah.translator_name }}</span>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <!-- Features -->
        <div class="quran-features">
            <div class="quran-feature-item">
                <div class="bismillah-quran-icon">📖</div>
                <h3 class="quran-feature-title">Study</h3>
                <p class="quran-feature-description">Read and study Quran ayahs with translations and interpretations</p>
            </div>
            <div class="quran-feature-item">
                <div class="bismillah-quran-icon">🔍</div>
                <h3 class="quran-feature-title">Search</h3>
                <p class="quran-feature-description">Search through the entire Quran by keywords and topics</p>
            </div>
            <div class="quran-feature-item">
                <div class="bismillah-quran-icon">🎧</div>
                <h3 class="quran-feature-title">Listen</h3>
                <p class="quran-feature-description">Listen to beautiful recitations of Quran ayahs</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<style>
    .font-arabic {
        font-family: 'Amiri', 'Scheherazade', serif;
    }
</style>
{% endblock %} 