{% extends "layouts/app.twig" %}

{% block title %}{{ surah_name ?? 'Surah' }} {{ surah }}:{{ ayah_number }} - Quran - IslamWiki{% endblock %}

{% block head %}
<!-- Quran-specific CSS -->
<link rel="stylesheet" href="/skins/Bismillah/css/quran.css?v={{ 'now'|date('U') }}">
<link rel="stylesheet" href="/skins/Bismillah/css/quran-extension.css?v={{ 'now'|date('U') }}">
{% endblock %}

{% block content %}
<div class="ayah-container">


    <!-- Beautiful Islamic Page Header -->
    <div class="quran-page-header">
        <div class="header-content">
            <h1 class="page-title">📖 القرآن الكريم</h1>
            <p class="page-subtitle">The Noble Quran</p>
            {% if surah == 1 and ayah_number == 1 %}
            <div class="bismillah-inline">
                <div class="bismillah-text-inline">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</div>
                <div class="bismillah-translation-inline">In the name of Allah, the Entirely Merciful, the Especially Merciful</div>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Enhanced Quran Breadcrumbs with Translation Selector -->
    <div class="quran-breadcrumbs">
        <div class="breadcrumb-container">
            <div class="breadcrumb-left">
                <a href="/" class="breadcrumb-link">🏠 Home</a>
                <span class="breadcrumb-separator">›</span>
                <a href="/{{ locale }}/quran" class="breadcrumb-link">📖 Quran</a>
                <span class="breadcrumb-separator">›</span>
                <a href="/{{ locale }}/quran/{{ surah }}" class="breadcrumb-link">📚 {{ surah_name ?? 'Surah ' ~ surah }}</a>
                <span class="breadcrumb-separator">›</span>
                <span class="breadcrumb-current">🎯 Ayah {{ ayah_number }}</span>
            </div>
            <div class="breadcrumb-center">
                <a href="/{{ locale }}/quran/search" class="breadcrumb-nav-link">🔍 Search</a>
                <a href="/{{ locale }}/quran/juz" class="breadcrumb-nav-link">📚 Juz</a>
                <a href="/{{ locale }}/quran" class="breadcrumb-nav-link">📖 Surah List</a>
            </div>
            <div class="breadcrumb-right">
                <form method="get" action="" class="translation-form-inline">
                    <label for="translator" class="translation-label">Translation:</label>
                    <select name="translator" id="translator" onchange="this.form.submit()" class="translation-dropdown-inline">
                        {% for trans in translators %}
                            <option value="{{ trans.translator|default(trans.name) }}" {% if (translator ?? 'Saheeh International') == (trans.translator|default(trans.name)) %}selected{% endif %}>
                                {{ trans.name|default(trans.translator) }}
                                {% if trans.language_name %}({{ trans.language_name }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>
                    <input type="hidden" name="surah" value="{{ surah }}">
                    <input type="hidden" name="ayah" value="{{ ayah_number }}">
                </form>
            </div>
        </div>
    </div>



    {% if ayah %}
        <div class="ayah-content">
            <!-- Header Row with Surah Name -->
            <div class="ayah-header-row">
                <div class="ayah-surah-name">
                    {{ surah_name ?? 'Surah' }} {{ surah }}:{{ ayah_number }}
                </div>
            </div>

            <!-- Arabic Text with Ayah Number -->
            <div class="ayah-arabic-container">
                <div style="display: flex; align-items: center; width: 100%; direction: rtl;">
                    <span style="text-align: right; flex-grow: 1;">
                        {{ ayah.text_arabic|raw }}
                    </span>
                    <span class="ayah-number-badge" style="margin-right: 10px; margin-left: 0; display: inline-flex; align-items: center; justify-content: center; font-family: 'Traditional Arabic', 'Amiri', 'Traditional Naskh', 'Scheherazade', 'KFGQPC Uthmanic Script HAFS', 'KFGQPC Uthman Taha Naskh', 'UthmanicHafs', 'UthmanicHafs1 Ver18', sans-serif;">
                        {{ ayah_number|replace({'0':'٠','1':'١','2':'٢','3':'٣','4':'٤','5':'٥','6':'٦','7':'٧','8':'٨','9':'٩'}) }}
                    </span>
                </div>
            </div>

            <!-- Translation -->
            {% if ayah.translation_text %}
                <div class="ayah-translation-container">
                    {{ ayah.translation_text|raw }}
                    {% if ayah.translator_name %}
                        <div class="translation-meta">
                            <span class="meta-separator">—</span>
                            <span class="translator-name">{{ ayah.translator_name }}</span>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            <!-- Navigation -->
            <div class="ayah-navigation">
                {% if prev_ayah %}
                    <a href="/{{ locale }}/quran/{{ surah }}/{{ prev_ayah.ayah_number }}?translator={{ translator|url_encode }}" class="nav-button prev">
                        Previous Ayah
                    </a>
                {% else %}
                    <span></span>
                {% endif %}
                
                {% if next_ayah %}
                    <a href="/{{ locale }}/quran/{{ surah }}/{{ next_ayah.ayah_number }}?translator={{ translator|url_encode }}" class="nav-button next">
                        Next Ayah
                    </a>
                {% else %}
                    <span></span>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="error-message">
            <div class="error-icon">⚠️</div>
            <h3>Sorry, the requested ayah could not be found.</h3>
            <p>Please check the surah and ayah numbers and try again.</p>
            <a href="/{{ locale }}/quran" class="error-action-btn">Return to Quran</a>
        </div>
    {% endif %}
    
    <!-- Quran Page Footer -->
    <div class="quran-page-footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>📚 Quran Resources</h4>
                <ul>
                    <li><a href="/{{ locale }}/quran/search">Search Quran</a></li>
                    <li><a href="/{{ locale }}/quran/juz">Juz Navigation</a></li>
                    <li><a href="/{{ locale }}/quran/surah">Surah List</a></li>
                    <li><a href="/{{ locale }}/quran/translations">Translations</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>🕌 Islamic Knowledge</h4>
                <ul>
                    <li><a href="/hadith">Hadith Collection</a></li>
                    <li><a href="/sciences">Islamic Sciences</a></li>
                    <li><a href="/salah">Prayer Times</a></li>
                    <li><a href="/calendar">Islamic Calendar</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>🔍 Quick Actions</h4>
                <ul>
                    <li><a href="/{{ locale }}/quran/{{ surah }}">Full Surah View</a></li>
                    <li><a href="/{{ locale }}/quran/{{ surah }}/{{ ayah_number|default(1) - 1 }}">Previous Ayah</a></li>
                    <li><a href="/{{ locale }}/quran/{{ surah }}/{{ ayah_number|default(1) + 1 }}">Next Ayah</a></li>
                    <li><a href="/{{ locale }}/quran">Quran Home</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>📖 Study Tools</h4>
                <ul>
                    <li><a href="/{{ locale }}/quran/bookmark">Bookmark Ayah</a></li>
                    <li><a href="/{{ locale }}/quran/notes">Personal Notes</a></li>
                    <li><a href="/{{ locale }}/quran/recitation">Audio Recitation</a></li>
                    <li><a href="/{{ locale }}/quran/tajweed">Tajweed Rules</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>📖 May Allah guide us to the straight path. آمين</p>
        </div>
    </div>
</div>
{% endblock %}
