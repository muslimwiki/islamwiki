{% extends "layouts/app.twig" %}

{% block title %}{{ surah_name ?? 'Surah' }} {{ surah }}:{{ ayah_number }} - Quran - IslamWiki{% endblock %}

{% block head %}
<!-- Quran-specific CSS -->
<link rel="stylesheet" href="/skins/Bismillah/css/quran.css?v={{ 'now'|date('U') }}">
<link rel="stylesheet" href="/skins/Bismillah/css/quran-extension.css?v={{ 'now'|date('U') }}">
<style>
/* Ayah Page Specific Styles with Beautiful Islamic Theme */
.ayah-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    background: linear-gradient(135deg, #f8f6f0 0%, #ffffff 100%);
    min-height: 100vh;
    position: relative;
}

.ayah-container::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="islamic-pattern" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="%232d5016" opacity="0.03"/><circle cx="25" cy="25" r="3" fill="%232d5016" opacity="0.02"/><circle cx="25" cy="25" r="5" fill="%232d5016" opacity="0.01"/></pattern></defs><rect width="100" height="100" fill="url(%23islamic-pattern)"/></svg>') repeat;
    pointer-events: none;
    z-index: -1;
}

/* Quran Navigation Bar */
.quran-nav-bar {
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    padding: 1rem 0;
    margin-bottom: 2rem;
    border-radius: 0.5rem;
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.3);
}

.quran-nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.quran-nav-left, .quran-nav-right {
    display: flex;
    gap: 1.5rem;
    align-items: center;
}

.quran-nav-link {
    color: white;
    text-decoration: none;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    transition: all 0.3s ease;
    border: 1px solid transparent;
}

.quran-nav-link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-1px);
    box-shadow: 0 2px 10px rgba(255, 255, 255, 0.2);
}

.quran-nav-link:active {
    transform: translateY(0);
    transition: all 0.1s ease;
}

/* Beautiful Islamic Page Header */
.quran-page-header {
    text-align: center;
    margin: 2rem 0 3rem 0;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    border-radius: 1.5rem;
    color: white;
    box-shadow: 0 15px 40px rgba(45, 80, 22, 0.4);
    position: relative;
    overflow: hidden;
}

.quran-page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="header-pattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="2" fill="rgba(255,255,255,0.1)"/><circle cx="50" cy="50" r="4" fill="rgba(255,255,255,0.05)"/><circle cx="50" cy="50" r="6" fill="rgba(255,255,255,0.03)"/></pattern></defs><rect width="100" height="100" fill="url(%23header-pattern)"/></svg>') repeat;
    opacity: 0.3;
}

.header-content {
    position: relative;
    z-index: 1;
}

.page-title {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
    font-family: 'Traditional Arabic', 'Amiri', 'Scheherazade', serif;
}

.page-subtitle {
    font-size: 1.25rem;
    opacity: 0.9;
    font-weight: 300;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
}

.quran-page-header:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 50px rgba(45, 80, 22, 0.5);
    transition: all 0.3s ease;
}

.quran-page-header:active {
    transform: translateY(0);
    box-shadow: 0 15px 40px rgba(45, 80, 22, 0.4);
    transition: all 0.1s ease;
}

.quran-page-header:hover .page-title {
    text-shadow: 4px 4px 8px rgba(0,0,0,0.4);
    transition: all 0.3s ease;
}

.quran-page-header:hover .page-subtitle {
    opacity: 1;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.4);
    transition: all 0.3s ease;
}

.quran-page-header:hover {
    background: linear-gradient(135deg, #4a8029 0%, #2d5016 100%);
    transition: all 0.3s ease;
}

.quran-page-header:hover {
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

.quran-page-header:hover {
    box-shadow: 0 20px 50px rgba(45, 80, 22, 0.5);
    transition: all 0.3s ease;
}

/* Beautiful Bismillah Styling */
.bismillah-display {
    text-align: center;
    margin: 2rem 0;
    padding: 2rem;
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    border-radius: 1rem;
    color: white;
    box-shadow: 0 10px 30px rgba(45, 80, 22, 0.3);
    position: relative;
    overflow: hidden;
}

.bismillah-display::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text x="50" y="50" font-family="serif" font-size="60" text-anchor="middle" fill="rgba(255,255,255,0.1)">☪</text></svg>') center/60px no-repeat;
    opacity: 0.1;
}

.bismillah-text {
    font-family: 'Traditional Arabic', 'Amiri', 'Scheherazade', serif;
    font-size: 2.5rem;
    line-height: 3rem;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
}

.bismillah-translation {
    font-size: 1.1rem;
    opacity: 0.9;
    font-style: italic;
}

.bismillah-display:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(45, 80, 22, 0.4);
    transition: all 0.3s ease;
}

.bismillah-display:active {
    transform: translateY(-1px);
    box-shadow: 0 10px 30px rgba(45, 80, 22, 0.3);
    transition: all 0.1s ease;
}

.bismillah-display:hover .bismillah-text {
    text-shadow: 3px 3px 6px rgba(0,0,0,0.4);
    transition: all 0.3s ease;
}

.bismillah-display:hover .bismillah-translation {
    opacity: 1;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    transition: all 0.3s ease;
}

.bismillah-display:hover {
    background: linear-gradient(135deg, #4a8029 0%, #2d5016 100%);
    transition: all 0.3s ease;
}

.bismillah-display:hover {
    transform: translateY(-3px);
    transition: all 0.3s ease;
}

.bismillah-display:hover {
    box-shadow: 0 15px 40px rgba(45, 80, 22, 0.4);
    transition: all 0.3s ease;
}



.ayah-breadcrumbs:hover {
    transform: translateY(-1px);
    transition: all 0.3s ease;
}

.ayah-breadcrumbs:hover {
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.15);
    transition: all 0.3s ease;
}

.ayah-breadcrumbs a {
    color: #2d5016;
    text-decoration: none;
    transition: color 0.3s ease;
    font-weight: 500;
}

.ayah-breadcrumbs a:hover {
    text-decoration: underline;
    color: #4a8029;
    transform: translateX(2px);
    transition: all 0.3s ease;
    text-shadow: 0 1px 2px rgba(45, 80, 22, 0.2);
}

.ayah-breadcrumbs a:active {
    color: #2d5016;
    transform: translateX(1px);
    transition: all 0.1s ease;
}

.ayah-breadcrumbs a:hover {
    text-shadow: 0 1px 2px rgba(45, 80, 22, 0.2);
    transition: all 0.3s ease;
}

.ayah-breadcrumbs a:hover {
    transform: translateX(2px);
    transition: all 0.3s ease;
}

.ayah-breadcrumbs a:hover {
    color: #4a8029;
    transition: all 0.3s ease;
}

.ayah-breadcrumbs .separator {
    margin: 0 0.5rem;
    color: #2d5016;
    font-weight: 600;
    opacity: 0.7;
}

.ayah-content {
    background: linear-gradient(135deg, #ffffff 0%, #f8f6f0 100%);
    border-radius: 1rem;
    box-shadow: 0 10px 30px rgba(45, 80, 22, 0.1);
    overflow: hidden;
    margin-bottom: 2rem;
    border: 2px solid rgba(45, 80, 22, 0.1);
    transition: all 0.3s ease;
}

.ayah-content:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(45, 80, 22, 0.15);
    border-color: rgba(45, 80, 22, 0.2);
}

.ayah-content:active {
    transform: translateY(0);
    box-shadow: 0 10px 30px rgba(45, 80, 22, 0.1);
    transition: all 0.1s ease;
}

.ayah-content:hover .ayah-surah-name {
    color: #4a8029;
    transition: all 0.3s ease;
}

.ayah-content:hover .ayah-number-badge {
    transform: scale(1.05);
    transition: all 0.3s ease;
}

.ayah-content:hover {
    background: linear-gradient(135deg, #ffffff 0%, #f0ede6 100%);
    transition: all 0.3s ease;
}

.ayah-content:hover {
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

.ayah-content:hover {
    box-shadow: 0 15px 40px rgba(45, 80, 22, 0.15);
    transition: all 0.3s ease;
}

.ayah-header-row {
    display: flex;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 2px solid #2d5016;
    background: linear-gradient(135deg, #f8f6f0 0%, #ffffff 100%);
    transition: all 0.3s ease;
}

.ayah-header-row:hover {
    background: linear-gradient(135deg, #f0ede6 0%, #f8f6f0 100%);
    transition: all 0.3s ease;
}

.ayah-header-row:active {
    background: linear-gradient(135deg, #f8f6f0 0%, #ffffff 100%);
    transition: all 0.1s ease;
}

.ayah-header-row:hover .ayah-surah-name {
    color: #4a8029;
    transition: all 0.3s ease;
}

.ayah-header-row:hover {
    background: linear-gradient(135deg, #e8e4d8 0%, #f0ede6 100%);
    transition: all 0.3s ease;
}

.ayah-header-row:hover {
    transform: translateY(-1px);
    transition: all 0.3s ease;
}

.ayah-surah-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: #2d5016;
    transition: all 0.3s ease;
}

.ayah-surah-name:hover {
    color: #4a8029;
    transform: scale(1.02);
    transition: all 0.3s ease;
}

.ayah-surah-name:active {
    color: #2d5016;
    transform: scale(1);
    transition: all 0.1s ease;
}

.ayah-surah-name:hover {
    text-shadow: 0 1px 2px rgba(45, 80, 22, 0.2);
    transition: all 0.3s ease;
}

.ayah-surah-name:hover {
    transform: scale(1.02);
    transition: all 0.3s ease;
}

.ayah-surah-name:hover {
    color: #4a8029;
    transition: all 0.3s ease;
}

.ayah-number-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    color: white;
    font-weight: 700;
    margin-left: 1rem;
    box-shadow: 0 4px 15px rgba(45, 80, 22, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
}

.ayah-number-badge:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(45, 80, 22, 0.6);
    border-color: rgba(255, 255, 255, 0.4);
}

.ayah-number-badge:active {
    transform: scale(1.05);
    box-shadow: 0 4px 15px rgba(45, 80, 22, 0.4);
    transition: all 0.1s ease;
}

.ayah-number-badge:hover {
    border-color: rgba(255, 255, 255, 0.6);
    transition: all 0.3s ease;
}

.ayah-number-badge:hover {
    transform: scale(1.1);
    transition: all 0.3s ease;
}

.ayah-number-badge:hover {
    box-shadow: 0 6px 20px rgba(45, 80, 22, 0.6);
    transition: all 0.3s ease;
}

.ayah-arabic-container {
    padding: 3rem 2rem;
    direction: rtl;
    text-align: right;
    font-size: 2rem;
    line-height: 3rem;
    color: #2d5016;
    font-family: 'Traditional Arabic', 'Amiri', 'Traditional Naskh', 'Scheherazade', 'KFGQPC Uthmanic Script HAFS', 'KFGQPC Uthman Taha Naskh', 'UthmanicHafs', 'UthmanicHafs1 Ver18', sans-serif;
    background: linear-gradient(135deg, #f8f6f0 0%, #ffffff 100%);
    border-radius: 0.5rem;
    margin: 1rem;
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.1);
    position: relative;
}

.ayah-arabic-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    border-radius: 0.5rem 0.5rem 0 0;
}

.ayah-arabic-container:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(45, 80, 22, 0.2);
    transition: all 0.3s ease;
}

.ayah-arabic-container:active {
    transform: translateY(0);
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.1);
    transition: all 0.1s ease;
}

.ayah-arabic-container:hover::before {
    height: 6px;
    transition: all 0.3s ease;
}

.ayah-arabic-container:hover {
    background: linear-gradient(135deg, #f0ede6 0%, #ffffff 100%);
    transition: all 0.3s ease;
}

.ayah-arabic-container:hover {
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

.ayah-translation-container {
    padding: 2rem;
    border-top: 2px solid #2d5016;
    font-size: 1.25rem;
    line-height: 1.8;
    color: #2d5016;
    background: linear-gradient(135deg, #ffffff 0%, #f8f6f0 100%);
    margin: 1rem;
    border-radius: 0.5rem;
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.1);
    transition: all 0.3s ease;
}

.ayah-translation-container:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(45, 80, 22, 0.2);
    transition: all 0.3s ease;
}

.ayah-translation-container:active {
    transform: translateY(0);
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.1);
    transition: all 0.1s ease;
}

.ayah-translation-container:hover .translation-meta {
    transform: translateY(-1px);
    transition: all 0.3s ease;
}

.ayah-translation-container:hover {
    background: linear-gradient(135deg, #f0ede6 0%, #ffffff 100%);
    transition: all 0.3s ease;
}

.ayah-translation-container:hover {
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

.ayah-navigation {
    display: flex;
    justify-content: space-between;
    padding: 2rem;
    border-top: 2px solid #2d5016;
    background: linear-gradient(135deg, #f8f6f0 0%, #ffffff 100%);
    margin: 1rem;
    border-radius: 0.5rem;
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.1);
    transition: all 0.3s ease;
}

.ayah-navigation:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(45, 80, 22, 0.15);
    transition: all 0.3s ease;
}

.ayah-navigation:active {
    transform: translateY(0);
    box-shadow: 0 4px 20px rgba(45, 80, 22, 0.1);
    transition: all 0.1s ease;
}

.ayah-navigation:hover .nav-button {
    transform: translateY(-1px);
    transition: all 0.3s ease;
}

.ayah-navigation:hover {
    background: linear-gradient(135deg, #f0ede6 0%, #f8f6f0 100%);
    transition: all 0.3s ease;
}

.ayah-navigation:hover {
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

/* Translation Meta Styling */
.translation-meta {
    margin-top: 1.5rem;
    padding: 1rem;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border: 1px solid #dee2e6;
    border-radius: 0.5rem;
    color: #495057;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
}

.translation-meta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(45, 80, 22, 0.4);
    transition: all 0.3s ease;
}

.translation-meta:active {
    transform: translateY(0);
    box-shadow: 0 4px 15px rgba(45, 80, 22, 0.3);
    transition: all 0.1s ease;
}

.translation-meta:hover .meta-separator {
    opacity: 1;
    transform: scale(1.1);
    transition: all 0.3s ease;
}

.translation-meta:hover .translator-name {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
}

.translation-meta:hover {
    background: linear-gradient(135deg, #e8f5e8 0%, #d4edda 100%);
    border-color: #2d5016;
    color: #2d5016;
    transition: all 0.3s ease;
}

.translation-meta:hover {
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

.translation-meta:hover {
    box-shadow: 0 8px 25px rgba(45, 80, 22, 0.4);
    transition: all 0.3s ease;
}

.meta-separator {
    font-size: 1.5rem;
    margin-right: 0.5rem;
    opacity: 0.6;
    color: #6c757d;
}

.translator-name {
    font-weight: 600;
    font-size: 1.1rem;
    color: inherit;
}

/* Error Message Styling */
.error-message {
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, #fef2f2 0%, #ffffff 100%);
    border-radius: 1rem;
    border: 2px solid #fecaca;
    box-shadow: 0 4px 20px rgba(239, 68, 68, 0.1);
}

.error-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
}

.error-message h3 {
    color: #dc2626;
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

.error-message p {
    color: #6b7280;
    margin-bottom: 2rem;
}

.error-action-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    color: white;
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(45, 80, 22, 0.3);
}

.error-action-btn:hover {
    background: linear-gradient(135deg, #4a8029 0%, #2d5016 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(45, 80, 22, 0.4);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
}

.error-action-btn:active {
    transform: translateY(0);
    box-shadow: 0 4px 15px rgba(45, 80, 22, 0.3);
    transition: all 0.1s ease;
}

/* Beautiful Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideInLeft {
    from {
        opacity: 0;
        transform: translateX(-30px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes slideInRight {
    from {
        opacity: 0;
        transform: translateX(30px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.quran-page-header {
    animation: fadeInUp 0.8s ease-out;
}

.bismillah-display {
    animation: slideInLeft 0.8s ease-out 0.2s both;
}

.ayah-content {
    animation: fadeInUp 0.8s ease-out 0.4s both;
}

.nav-button.prev {
    animation: slideInLeft 0.6s ease-out 0.6s both;
}

.nav-button.next {
    animation: slideInRight 0.6s ease-out 0.6s both;
}

/* Responsive Design */
@media (max-width: 768px) {
    .quran-nav-container {
        flex-direction: column;
        gap: 1rem;
        padding: 0 1rem;
    }
    
    .quran-nav-left, .quran-nav-right {
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
    }
    
    .quran-nav-link {
        font-size: 0.9rem;
        padding: 0.4rem 0.8rem;
    }
    
    .quran-nav-bar {
        padding: 0.8rem 0;
        margin-bottom: 1.5rem;
    }
    
    .quran-breadcrumbs {
        padding: 1rem;
        margin-bottom: 1.5rem;
    }
    
    .breadcrumb-container {
        gap: 0.5rem;
    }
    
    .breadcrumb-link {
        padding: 0.4rem 0.8rem;
        font-size: 0.9rem;
    }
    
    .breadcrumb-separator {
        font-size: 1rem;
    }
    
    .ayah-container {
        padding: 1rem;
    }
    
    .quran-page-header {
        padding: 2rem 1rem;
        margin: 1rem 0 2rem 0;
    }
    
    .page-title {
        font-size: 2rem;
    }
    
    .page-subtitle {
        font-size: 1rem;
    }
    
    .bismillah-display {
        padding: 1.5rem;
        margin: 1rem 0;
    }
    
    .bismillah-text {
        font-size: 2rem;
        line-height: 2.5rem;
    }
    
    .ayah-arabic-container {
        padding: 2rem 1rem;
        font-size: 1.5rem;
        line-height: 2.5rem;
    }
    
    .ayah-number-badge {
        width: 2.5rem;
        height: 2.5rem;
    }
    
    .nav-button {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
    }
    
    .translation-dropdown {
        max-width: 100%;
    }
}

.nav-button {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(45, 80, 22, 0.3);
    border: 2px solid transparent;
}

.nav-button:hover {
    background: linear-gradient(135deg, #4a8029 0%, #2d5016 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(45, 80, 22, 0.4);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
}

.nav-button:active {
    transform: translateY(0);
    box-shadow: 0 4px 15px rgba(45, 80, 22, 0.3);
    transition: all 0.1s ease;
}

.nav-button.prev::before {
    content: '☪ ←';
    margin-right: 0.5rem;
    font-size: 1.1rem;
}

.nav-button.next::after {
    content: '→ ☪';
    margin-left: 0.5rem;
    font-size: 1.1rem;
}


</style>
{% endblock %}

{% block content %}
<div class="ayah-container">


    <!-- Beautiful Islamic Page Header -->
    <div class="quran-page-header">
        <div class="header-content">
            <h1 class="page-title">📖 القرآن الكريم</h1>
            <p class="page-subtitle">The Noble Quran</p>
            {% if surah == 1 and ayah_number == 1 %}
            <div class="bismillah-inline">
                <div class="bismillah-text-inline">بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ</div>
                <div class="bismillah-translation-inline">In the name of Allah, the Entirely Merciful, the Especially Merciful</div>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Enhanced Quran Breadcrumbs with Translation Selector -->
    <div class="quran-breadcrumbs">
        <div class="breadcrumb-container">
            <div class="breadcrumb-left">
                <a href="/" class="breadcrumb-link">🏠 Home</a>
                <span class="breadcrumb-separator">›</span>
                <a href="/{{ locale }}/quran" class="breadcrumb-link">📖 Quran</a>
                <span class="breadcrumb-separator">›</span>
                <a href="/{{ locale }}/quran/{{ surah }}" class="breadcrumb-link">📚 {{ surah_name ?? 'Surah ' ~ surah }}</a>
                <span class="breadcrumb-separator">›</span>
                <span class="breadcrumb-current">🎯 Ayah {{ ayah_number }}</span>
            </div>
            <div class="breadcrumb-center">
                <a href="/{{ locale }}/quran/search" class="breadcrumb-nav-link">🔍 Search</a>
                <a href="/{{ locale }}/quran/juz" class="breadcrumb-nav-link">📚 Juz</a>
                <a href="/{{ locale }}/quran" class="breadcrumb-nav-link">📖 Surah List</a>
            </div>
            <div class="breadcrumb-right">
                <form method="get" action="" class="translation-form-inline">
                    <label for="translator" class="translation-label">Translation:</label>
                    <select name="translator" id="translator" onchange="this.form.submit()" class="translation-dropdown-inline">
                        {% for trans in translators %}
                            <option value="{{ trans.translator|default(trans.name) }}" {% if (translator ?? 'Saheeh International') == (trans.translator|default(trans.name)) %}selected{% endif %}>
                                {{ trans.name|default(trans.translator) }}
                                {% if trans.language_name %}({{ trans.language_name }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>
                    <input type="hidden" name="surah" value="{{ surah }}">
                    <input type="hidden" name="ayah" value="{{ ayah_number }}">
                </form>
            </div>
        </div>
    </div>



    {% if ayah %}
        <div class="ayah-content">
            <!-- Header Row with Surah Name -->
            <div class="ayah-header-row">
                <div class="ayah-surah-name">
                    {{ surah_name ?? 'Surah' }} {{ surah }}:{{ ayah_number }}
                </div>
            </div>

            <!-- Arabic Text with Ayah Number -->
            <div class="ayah-arabic-container">
                <div style="display: flex; align-items: center; width: 100%; direction: rtl;">
                    <span style="text-align: right; flex-grow: 1;">
                        {{ ayah.text_arabic|raw }}
                    </span>
                    <span class="ayah-number-badge" style="margin-right: 10px; margin-left: 0; display: inline-flex; align-items: center; justify-content: center; font-family: 'Traditional Arabic', 'Amiri', 'Traditional Naskh', 'Scheherazade', 'KFGQPC Uthmanic Script HAFS', 'KFGQPC Uthman Taha Naskh', 'UthmanicHafs', 'UthmanicHafs1 Ver18', sans-serif;">
                        {{ ayah_number|replace({'0':'٠','1':'١','2':'٢','3':'٣','4':'٤','5':'٥','6':'٦','7':'٧','8':'٨','9':'٩'}) }}
                    </span>
                </div>
            </div>

            <!-- Translation -->
            {% if ayah.translation_text %}
                <div class="ayah-translation-container">
                    {{ ayah.translation_text|raw }}
                    {% if ayah.translator_name %}
                        <div class="translation-meta">
                            <span class="meta-separator">—</span>
                            <span class="translator-name">{{ ayah.translator_name }}</span>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            <!-- Navigation -->
            <div class="ayah-navigation">
                {% if prev_ayah %}
                    <a href="/{{ locale }}/quran/{{ surah }}/{{ prev_ayah.ayah_number }}?translator={{ translator|url_encode }}" class="nav-button prev">
                        Previous Ayah
                    </a>
                {% else %}
                    <span></span>
                {% endif %}
                
                {% if next_ayah %}
                    <a href="/{{ locale }}/quran/{{ surah }}/{{ next_ayah.ayah_number }}?translator={{ translator|url_encode }}" class="nav-button next">
                        Next Ayah
                    </a>
                {% else %}
                    <span></span>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="error-message">
            <div class="error-icon">⚠️</div>
            <h3>Sorry, the requested ayah could not be found.</h3>
            <p>Please check the surah and ayah numbers and try again.</p>
            <a href="/{{ locale }}/quran" class="error-action-btn">Return to Quran</a>
        </div>
    {% endif %}
    
    <!-- Quran Page Footer -->
    <div class="quran-page-footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>📚 Quran Resources</h4>
                <ul>
                    <li><a href="/{{ locale }}/quran/search">Search Quran</a></li>
                    <li><a href="/{{ locale }}/quran/juz">Juz Navigation</a></li>
                    <li><a href="/{{ locale }}/quran/surah">Surah List</a></li>
                    <li><a href="/{{ locale }}/quran/translations">Translations</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>🕌 Islamic Knowledge</h4>
                <ul>
                    <li><a href="/hadith">Hadith Collection</a></li>
                    <li><a href="/sciences">Islamic Sciences</a></li>
                    <li><a href="/salah">Prayer Times</a></li>
                    <li><a href="/calendar">Islamic Calendar</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>🔍 Quick Actions</h4>
                <ul>
                    <li><a href="/{{ locale }}/quran/{{ surah }}">Full Surah View</a></li>
                    <li><a href="/{{ locale }}/quran/{{ surah }}/{{ ayah_number|default(1) - 1 }}">Previous Ayah</a></li>
                    <li><a href="/{{ locale }}/quran/{{ surah }}/{{ ayah_number|default(1) + 1 }}">Next Ayah</a></li>
                    <li><a href="/{{ locale }}/quran">Quran Home</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>📖 Study Tools</h4>
                <ul>
                    <li><a href="/{{ locale }}/quran/bookmark">Bookmark Ayah</a></li>
                    <li><a href="/{{ locale }}/quran/notes">Personal Notes</a></li>
                    <li><a href="/{{ locale }}/quran/recitation">Audio Recitation</a></li>
                    <li><a href="/{{ locale }}/quran/tajweed">Tajweed Rules</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>📖 May Allah guide us to the straight path. آمين</p>
        </div>
    </div>
</div>
{% endblock %}
