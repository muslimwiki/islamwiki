<!-- Quran Widget - Ayah {{ chapter }}:{{ ayah_number }} -->
{% if is_widget %}
<div class="p-4 bg-white rounded-lg shadow">
    <div class="text-sm text-gray-500 mb-1">Quran {{ chapter }}:{{ ayah_number }}</div>
    <div class="text-lg font-arabic text-gray-800 leading-relaxed">{{ ayah.arabic_text }}</div>
{% if ayah.translation_text %}
<div class="text-sm text-gray-700 mb-3 italic">{{ ayah.translation_text }}</div>
{% endif %}
    <div>
        <a href="/{{ locale }}/quran/{{ chapter }}/{{ ayah_number }}" target="_blank" class="text-green-600 hover:text-green-700">
            View Ayah →
        </a>
    </div>
</div>
{% else %}
<div class="quran-ayah-section">
    <div class="quran-ayah-header">
        <h2 class="text-xl font-bold text-gray-900">Quran {{ chapter }}:{{ ayah_number }}</h2>
    </div>
    <div class="quran-ayah-content">
        <div class="text-2xl font-arabic text-gray-800 leading-relaxed">{{ ayah.arabic_text }}</div>
    </div>
    {% if ayah.translation_text %}
    <div class="text-gray-700 mb-4 italic">{{ ayah.translation_text }}</div>
    {% endif %}
    <div>
        <a href="/{{ locale }}/quran/{{ chapter }}/{{ ayah_number }}" class="text-green-600 hover:text-green-700 font-medium">
            View Ayah
        </a>
    </div>
</div>
{% endif %}

<style>
    .font-arabic {
        font-family: 'Amiri', 'Scheherazade', serif;
    }
    
    .quran-widget {
        max-width: 400px;
        margin: 0 auto;
    }
</style> 