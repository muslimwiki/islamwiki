<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}IslamWiki - Authentic Islamic Knowledge{% endblock %}</title>
    <meta name="description" content="{% block description %}The comprehensive Islamic knowledge repository. Explore Quran, Hadith, Islamic history, scholars, and authentic religious guidance for the global Muslim community.{% endblock %}">
    
    <!-- Safa CSS Framework -->
    <link rel="stylesheet" href="/assets/css/safa.css">
    
    <!-- Bismillah Skin CSS -->
    <link rel="stylesheet" href="/skins/Bismillah/css/bismillah.css">
    
    <style>
        /* Additional layout-specific styles that complement the skin */
        .main-content {
            min-height: calc(100vh - 200px);
            padding: 40px 20px;
        }

        .content-container {
            max-width: 1200px;
            margin: 0 auto;
        }
    </style>

    {% block head %}{% endblock %}
</head>
<body>
    <!-- Top Bar with Islamic Info -->
    <div class="bismillah-top-bar">
        <div class="bismillah-top-bar-content">
            <div class="bismillah-islamic-info">
                <div class="bismillah-prayer-info">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
                    </svg>
                    Next Prayer: Asr - 3:45 PM
                </div>
                <div class="bismillah-date-info">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2Z"/>
                    </svg>
                    15 Rabi' al-Awwal 1446 | September 18, 2024
                </div>
            </div>
            <div class="bismillah-user-actions">
                {% if user %}
                    <div class="user-dropdown">
                        <button class="bismillah-user-menu user-dropdown-toggle">
                            <span>👤 {{ user.name|default('User') }}</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M7,10L12,15L17,10H7Z"/>
                            </svg>
                        </button>
                        <div class="user-dropdown-menu">
                            <a href="/dashboard" class="dropdown-item">📊 Dashboard</a>
                            <a href="/profile" class="dropdown-item">👤 Profile</a>
                            <a href="/settings" class="dropdown-item">⚙️ Settings</a>
                            <a href="/auth/logout" class="dropdown-item">🚪 Logout</a>
                        </div>
                    </div>
                {% else %}
                    <a href="/auth/login" class="bismillah-user-menu">🔑 Login</a>
                    <a href="/auth/register" class="bismillah-user-menu">📝 Join</a>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Main Bar with Logo and Search -->
    <div class="bismillah-main-bar">
        <div class="bismillah-main-bar-content">
            <a href="/" class="bismillah-site-logo">
                <div class="bismillah-logo-icon">☪</div>
                <div class="bismillah-logo-text">
                    <div class="bismillah-site-name">IslamWiki</div>
                    <div class="bismillah-site-tagline">Authentic Islamic Knowledge</div>
                </div>
            </a>

            <div class="bismillah-main-search">
                <form action="/iqra-search" method="GET" class="bismillah-search-form">
                    <input type="text" name="q" class="bismillah-search-input" placeholder="Search Quran, Hadith, Scholars, Articles..." value="{{ search_query|default('') }}">
                    <button type="submit" class="bismillah-search-btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                        </svg>
                    </button>
                </form>
            </div>

            <div class="bismillah-header-actions">
                <button class="bismillah-lang-toggle" id="langToggle" data-lang="en" onclick="toggleLanguage()">
                    <span class="lang-icon">🌐</span>
                    <span class="lang-text">العربية</span>
                </button>
                <a href="/contribute" class="bismillah-contribute-btn">Contribute</a>
            </div>
        </div>
    </div>

    <!-- Main Navigation -->
    <nav class="bismillah-main-nav">
        <div class="bismillah-nav-content">
            <ul class="bismillah-nav-menu">
                <li class="bismillah-nav-item">
                    <a href="/" class="bismillah-nav-link {{ current_page == 'home' ? 'active' : '' }}">
                        <svg class="bismillah-nav-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
                        </svg>
                        Home
                    </a>
                </li>
                
                <li class="bismillah-nav-item has-dropdown">
                    <a href="/quran" class="bismillah-nav-link {{ current_page == 'quran' ? 'active' : '' }}">
                        <svg class="bismillah-nav-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18,22A2,2 0 0,0 20,20V4C20,2.89 19.1,2 18,2H12V9L9.5,7.5L7,9V2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18Z"/>
                        </svg>
                        Quran & Tafsir
                    </a>
                    <div class="nav-dropdown">
                        <a href="/quran/arabic" class="dropdown-item">
                            <span class="dropdown-icon">📖</span>Arabic Text
                        </a>
                        <a href="/quran/translations" class="dropdown-item">
                            <span class="dropdown-icon">🌍</span>Translations
                        </a>
                        <a href="/quran/tafsir" class="dropdown-item">
                            <span class="dropdown-icon">📚</span>Tafsir & Commentary
                        </a>
                        <a href="/quran/recitations" class="dropdown-item">
                            <span class="dropdown-icon">🎵</span>Recitations
                        </a>
                        <a href="/quran/topics" class="dropdown-item">
                            <span class="dropdown-icon">🔍</span>Topical Study
                        </a>
                    </div>
                </li>

                <li class="bismillah-nav-item has-dropdown">
                    <a href="/hadith" class="bismillah-nav-link {{ current_page == 'hadith' ? 'active' : '' }}">
                        <svg class="bismillah-nav-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2Z"/>
                        </svg>
                        Hadith Collections
                    </a>
                    <div class="nav-dropdown">
                        <a href="/hadith/bukhari" class="dropdown-item">
                            <span class="dropdown-icon">📖</span>Sahih Bukhari
                        </a>
                        <a href="/hadith/muslim" class="dropdown-item">
                            <span class="dropdown-icon">📚</span>Sahih Muslim
                        </a>
                        <a href="/hadith/abudawud" class="dropdown-item">
                            <span class="dropdown-icon">📖</span>Abu Dawud
                        </a>
                        <a href="/hadith/tirmidhi" class="dropdown-item">
                            <span class="dropdown-icon">📚</span>Tirmidhi
                        </a>
                        <a href="/hadith/nasai" class="dropdown-item">
                            <span class="dropdown-icon">📖</span>Nasai
                        </a>
                    </div>
                </li>

                <li class="bismillah-nav-item has-dropdown">
                    <a href="/wiki" class="bismillah-nav-link {{ current_page == 'wiki' ? 'active' : '' }}">
                        <svg class="bismillah-nav-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3C12.55,3 13,3.45 13,4C13,4.55 12.55,5 12,5C11.45,5 11,4.55 11,4C11,3.45 11.45,3 12,3M7,7H17V5H19V5H7V7Z"/>
                        </svg>
                        Wiki
                    </a>
                    <div class="nav-dropdown">
                        <a href="/wiki/articles" class="dropdown-item">
                            <span class="dropdown-icon">📄</span>Articles
                        </a>
                        <a href="/wiki/guides" class="dropdown-item">
                            <span class="dropdown-icon">📚</span>Guides & Tutorials
                        </a>
                        <a href="/wiki/references" class="dropdown-item">
                            <span class="dropdown-icon">📖</span>References
                        </a>
                        <a href="/wiki/categories" class="dropdown-item">
                            <span class="dropdown-icon">🏷️</span>Categories
                        </a>
                        <a href="/wiki/create" class="dropdown-item">
                            <span class="dropdown-icon">✍️</span>Create New Page
                        </a>
                    </div>
                </li>

                <li class="bismillah-nav-item has-dropdown">
                    <a href="/sciences" class="bismillah-nav-link {{ current_page == 'sciences' ? 'active' : '' }}">
                        <svg class="bismillah-nav-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12,3L1,9L12,15L21,10.09V17H23V9M5,13.18V17.18L12,21L19,17.18V13.18L12,17L5,13.18Z"/>
                        </svg>
                        Islamic Sciences
                    </a>
                    <div class="nav-dropdown">
                        <a href="/sciences/fiqh" class="dropdown-item">
                            <span class="dropdown-icon">⚖️</span>Fiqh (Islamic Jurisprudence)
                        </a>
                        <a href="/sciences/aqeedah" class="dropdown-item">
                            <span class="dropdown-icon">🧠</span>Aqeedah (Theology)
                        </a>
                        <a href="/sciences/seerah" class="dropdown-item">
                            <span class="dropdown-icon">📜</span>Seerah (Prophetic Biography)
                        </a>
                        <a href="/sciences/history" class="dropdown-item">
                            <span class="dropdown-icon">🏛️</span>Islamic History
                        </a>
                        <a href="/sciences/arabic" class="dropdown-item">
                            <span class="dropdown-icon">🔤</span>Arabic Language
                        </a>
                    </div>
                </li>

                <li class="bismillah-nav-item has-dropdown">
                    <a href="/community" class="bismillah-nav-link {{ current_page == 'community' ? 'active' : '' }}">
                        <svg class="bismillah-nav-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M16,4C16,4 15,4 14,6C14,6 14,8 16,10C16,10 18,10 20,8C20,8 20,6 18,4C18,4 16,4 16,4M20,12C20,12 18,12 16,14C16,14 16,16 18,18C18,18 20,18 22,16C22,16 22,14 20,12M6,8C6,8 4,8 2,10C2,10 2,12 4,14C4,14 6,14 8,12C8,12 8,10 6,8M6,16C6,16 4,16 2,18C2,18 2,20 4,22C4,22 6,22 8,20C8,20 8,18 6,16M12,8C12,8 10,8 8,10C8,10 8,12 10,14C10,14 12,14 14,12C14,12 14,10 12,8M12,16C12,16 10,16 8,18C8,18 8,20 10,22C10,22 12,22 14,20C14,20 14,18 12,16Z"/>
                        </svg>
                        Community
                    </a>
                    <div class="nav-dropdown">
                        <a href="/community/forums" class="dropdown-item">
                            <span class="dropdown-icon">💬</span>Forums & Discussions
                        </a>
                        <a href="/community/events" class="dropdown-item">
                            <span class="dropdown-icon">📅</span>Events & Gatherings
                        </a>
                        <a href="/community/scholars" class="dropdown-item">
                            <span class="dropdown-icon">👨‍🏫</span>Scholars Directory
                        </a>
                        <a href="/community/study-groups" class="dropdown-item">
                            <span class="dropdown-icon">👥</span>Study Groups
                        </a>
                        <a href="/community/contribute" class="dropdown-item">
                            <span class="dropdown-icon">✍️</span>Contribute Content
                        </a>
                    </div>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        <div class="content-container">
            {% block content %}{% endblock %}
        </div>
    </main>

    <!-- Footer -->
    <footer class="bismillah-legacy-footer">
        <div class="bismillah-legacy-footer-content">
            <div class="bismillah-legacy-footer-section">
                <h3>About IslamWiki</h3>
                <p>Dedicated to preserving and sharing authentic Islamic knowledge for the global Muslim community.</p>
                <a href="/about">Learn More</a>
            </div>
            <div class="bismillah-legacy-footer-section">
                <h3>Quick Links</h3>
                <ul class="bismillah-legacy-footer-links">
                    <li><a href="/quran">Quran & Tafsir</a></li>
                    <li><a href="/hadith">Hadith Collections</a></li>
                    <li><a href="/wiki">Wiki Articles</a></li>
                    <li><a href="/community">Community</a></li>
                </ul>
            </div>
            <div class="bismillah-legacy-footer-section">
                <h3>Support</h3>
                <ul class="bismillah-legacy-footer-links">
                    <li><a href="/contact">Contact Us</a></li>
                    <li><a href="/help">Help Center</a></li>
                    <li><a href="/contribute">Contribute</a></li>
                </ul>
            </div>
        </div>
    </footer>

    <!-- Copyright -->
    <div class="bismillah-copyright">
        <div class="bismillah-copyright-content">
            <p>&copy; 2024 IslamWiki. All rights reserved.</p>
        </div>
    </div>

    <!-- JavaScript -->
    <script src="/assets/js/zamzam.js"></script>
    <script>
        // Language and RTL toggle functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize language from localStorage or default to English
            const currentLang = localStorage.getItem('islamwiki_lang') || 'en';
            setLanguage(currentLang);
        });

        function toggleLanguage() {
            const currentLang = document.getElementById('langToggle').getAttribute('data-lang');
            const newLang = currentLang === 'en' ? 'ar' : 'en';
            setLanguage(newLang);
        }

        function setLanguage(lang) {
            const langToggle = document.getElementById('langToggle');
            const langIcon = langToggle.querySelector('.lang-icon');
            const langText = langToggle.querySelector('.lang-text');
            const htmlElement = document.documentElement;
            
            // Update button state
            langToggle.setAttribute('data-lang', lang);
            
            if (lang === 'ar') {
                // Arabic - RTL
                langIcon.textContent = '🇺🇸';
                langText.textContent = 'English';
                htmlElement.setAttribute('dir', 'rtl');
                htmlElement.setAttribute('lang', 'ar');
                document.body.classList.add('rtl');
                document.body.classList.remove('ltr');
            } else {
                // English - LTR
                langIcon.textContent = '🌐';
                langText.textContent = 'العربية';
                htmlElement.setAttribute('dir', 'ltr');
                htmlElement.setAttribute('lang', 'en');
                document.body.classList.add('ltr');
                document.body.classList.remove('rtl');
            }
            
            // Store preference in localStorage
            localStorage.setItem('islamwiki_lang', lang);
        }
    </script>

    {% block scripts %}{% endblock %}
</body>
</html> 