    <!-- Language Toggle Script -->
    <script>
        // Language toggle functionality
        function toggleLanguage() {
            const currentLang = document.documentElement.lang;
            const newLang = currentLang === 'en' ? 'ar' : 'en';
            setLanguage(newLang);
        }

        function setLanguage(lang) {
            document.documentElement.lang = lang;
            localStorage.setItem('preferred-language', lang);
            
            // Update language toggle button text
            const langToggle = document.getElementById('langToggle');
            if (langToggle) {
                langToggle.textContent = lang === 'en' ? 'العربية' : 'English';
            }
        }

        // Dropdown functionality for mobile/touch devices
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM loaded, checking dropdowns...');
            
            const navItems = document.querySelectorAll('.bismillah-nav-item.has-dropdown');
            console.log('Found nav items with dropdowns:', navItems.length);
            
            // Debug: check if hover events are working
            const allNavLinks = document.querySelectorAll('.bismillah-nav-link');
            console.log('Found nav links:', allNavLinks.length);
            
            allNavLinks.forEach((link, index) => {
                console.log(`Nav link ${index + 1}:`, link.textContent.trim());
                
                // Test hover events
                link.addEventListener('mouseenter', function() {
                    console.log(`Mouse entered nav link: ${this.textContent.trim()}`);
                    this.style.border = '2px solid green';
                });
                
                link.addEventListener('mouseleave', function() {
                    console.log(`Mouse left nav link: ${this.textContent.trim()}`);
                    this.style.border = '1px solid transparent';
                });
                
                // Test click events
                link.addEventListener('click', function(e) {
                    console.log(`Clicked nav link: ${this.textContent.trim()}`);
                });
            });
            
            // Debug: check dropdown items
            const allDropdownItems = document.querySelectorAll('.dropdown-item');
            console.log('Found dropdown items:', allDropdownItems.length);
            
            allDropdownItems.forEach((item, index) => {
                console.log(`Dropdown item ${index + 1}:`, item.textContent.trim());
                
                // Test hover events on dropdown items
                item.addEventListener('mouseenter', function() {
                    console.log(`Mouse entered dropdown item: ${this.textContent.trim()}`);
                    this.style.background = '#e8f5e8';
                });
                
                item.addEventListener('mouseleave', function() {
                    console.log(`Mouse left dropdown item: ${this.textContent.trim()}`);
                    this.style.background = 'white';
                });
                
                // Test click events on dropdown items
                item.addEventListener('click', function(e) {
                    console.log(`Clicked dropdown item: ${this.textContent.trim()}`);
                    // Allow navigation for actual links
                    if (this.href) {
                        console.log(`Navigating to: ${this.href}`);
                        // Uncomment the next line to allow actual navigation
                        // window.location.href = this.href;
                    }
                });
                
                // Ensure dropdown items are clickable
                item.style.pointerEvents = 'auto';
                item.style.cursor = 'pointer';
            });
            
            navItems.forEach((item, index) => {
                const link = item.querySelector('.bismillah-nav-link');
                const dropdown = item.querySelector('.nav-dropdown');
                
                console.log(`Nav item ${index + 1}:`, {
                    hasLink: !!link,
                    hasDropdown: !!dropdown,
                    dropdownDisplay: dropdown ? dropdown.style.display : 'N/A',
                    dropdownOpacity: dropdown ? dropdown.style.opacity : 'N/A'
                });
                
                // Add click event for mobile/touch devices
                if (link && dropdown) {
                    link.addEventListener('click', function(e) {
                        if (window.innerWidth <= 768) {
                            e.preventDefault();
                            const isVisible = dropdown.style.opacity === '1';
                            dropdown.style.opacity = isVisible ? '0' : '1';
                            dropdown.style.visibility = isVisible ? 'hidden' : 'visible';
                            dropdown.style.transform = isVisible ? 'translateY(-10px)' : 'translateY(0)';
                            console.log(`Toggled dropdown ${index + 1} to:`, isVisible ? 'hidden' : 'visible');
                        }
                    });
                }
                
                // Close dropdown when clicking outside
                document.addEventListener('click', function(e) {
                    if (!item.contains(e.target)) {
                        if (dropdown) {
                            dropdown.style.opacity = '0';
                            dropdown.style.visibility = 'hidden';
                            dropdown.style.transform = 'translateY(-10px)';
                        }
                    }
                });
            });
            
            // Initialize language from localStorage
            const savedLang = localStorage.getItem('preferred-language');
            if (savedLang) {
                setLanguage(savedLang);
            }
        });
    </script>
    
