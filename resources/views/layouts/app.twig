<!DOCTYPE html>
<html lang="{{ current_language|default('en') }}" dir="{{ current_language|default('en') in ['ar', 'ur', 'fa', 'he'] ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="">
    <title>{% block title %}{{ title|default('IslamWiki') }}{% endblock %}</title>
    
    <!-- Google Fonts for Islamic Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Bismillah Skin CSS - Beautiful Islamic Theme -->
    <link rel="stylesheet" href="/skins/Bismillah/css/bismillah.css?v={{ 'now'|date('U') }}">
    
    <!-- Additional Skin CSS (if specified) -->
    {% if skin_css_url %}
        <link rel="stylesheet" href="{{ skin_css_url }}?v={{ 'now'|date('U') }}">
    {% endif %}
</head>
<body class="bismillah-body">
    <!-- Header -->
    <header class="bismillah-header">
        <!-- Header Top Bar - Salah Time & Login -->
        <div class="bismillah-header-top">
            <div class="bismillah-header-content">
                <div class="bismillah-header-left">
                    <div class="bismillah-salah-info">
                        <div class="next-salah">
                            <span class="salah-icon">🕌</span>
                            <span class="salah-text">Next: Asr 3:45 PM</span>
                        </div>
                        <div class="current-time">
                            <span class="time-icon">🕐</span>
                            <span class="time-text">{{ 'now'|date('g:i A') }}</span>
                        </div>
                        <div class="current-date">
                            <span class="date-icon">📅</span>
                            <span class="date-text">{{ 'now'|date('l, F j, Y') }}</span>
                        </div>
                    </div>
                </div>
                
                <div class="bismillah-header-right">
                    <div class="bismillah-header-actions">
                        {% if user %}
                            <div class="user-dropdown">
                                <button class="bismillah-user-menu user-dropdown-toggle">
                                    <span>👤 {{ user.username }}</span>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M7,10L12,15L17,10H7Z"/>
                                    </svg>
                                </button>
                                <div class="user-dropdown-menu">
                                    <a href="/dashboard" class="dropdown-item">📊 Dashboard</a>
                                    <a href="/profile" class="dropdown-item">👤 Profile</a>
                                    <a href="/settings" class="dropdown-item">⚙️ Settings</a>
                                    <div class="dropdown-divider"></div>
                                    <form action="/auth/logout" method="POST" class="dropdown-form">
                                        <button type="submit" class="dropdown-item logout-item">🚪 Logout</button>
                                    </form>
                                </div>
                            </div>
                        {% else %}
                            <a href="/auth/login" class="bismillah-login-btn">Login</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Main Header - Logo, Search & Language -->
        <div class="bismillah-header-secondary">
            <div class="bismillah-header-container">
                <div class="bismillah-header-left">
                    <a href="/" class="bismillah-logo-link" aria-label="Go to IslamWiki Homepage" title="Go to Homepage">
                        <div class="bismillah-logo">
                            <div class="bismillah-logo-icon" aria-hidden="true">☪</div>
                            <div class="logo-text">
                                <div class="site-name">IslamWiki</div>
                                <div class="site-tagline">Authentic Islamic Knowledge</div>
                            </div>
                        </div>
                    </a>
                </div>
                
                <div class="bismillah-header-center">
                    <form class="search-form" action="/search" method="GET">
                        <div class="search-input-wrapper">
                            <input type="text" name="q" placeholder="Search Islamic knowledge..." class="search-input">
                            <button type="submit" class="search-btn">🔍</button>
                        </div>
                    </form>
                </div>
                
                <div class="bismillah-header-right">
                    <div class="bismillah-language-selector">
                        <div class="bismillah-lang-toggle" data-lang="en">
                            <span class="lang-text">EN</span>
                        </div>
                        <div class="bismillah-lang-toggle" data-lang="ar">
                            <span class="lang-text">عربي</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Navigation -->
        <nav class="bismillah-secondary-nav">
            <div class="bismillah-nav-content">
                <ul class="bismillah-nav-menu">
                    <li class="bismillah-nav-item">
                        <a href="/" class="bismillah-nav-link">
                            <span class="bismillah-nav-icon">🏠</span>
                            Home
                        </a>
                    </li>
                    <li class="bismillah-nav-item has-dropdown">
                        <a href="/quran" class="bismillah-nav-link">
                            <span class="bismillah-nav-icon">📖</span>
                            Quran
                        </a>
                        <div class="nav-dropdown">
                            <a href="/quran/read" class="dropdown-item">Read Quran</a>
                            <a href="/quran/translations" class="dropdown-item">Translations</a>
                            <a href="/quran/tafsir" class="dropdown-item">Tafsir</a>
                            <a href="/quran/recitation" class="dropdown-item">Recitation</a>
                        </div>
                    </li>
                    <li class="bismillah-nav-item has-dropdown">
                        <a href="/hadith" class="bismillah-nav-link">
                            <span class="bismillah-nav-icon">📚</span>
                            Hadith
                        </a>
                        <div class="nav-dropdown">
                            <a href="/hadith/collections" class="dropdown-item">Collections</a>
                            <a href="/hadith/search" class="dropdown-item">Search Hadith</a>
                            <a href="/hadith/authenticity" class="dropdown-item">Authenticity</a>
                        </div>
                    </li>
                    <li class="bismillah-nav-item has-dropdown">
                        <a href="/articles" class="bismillah-nav-link">
                            <span class="bismillah-nav-icon">📝</span>
                            Articles
                        </a>
                        <div class="nav-dropdown">
                            <a href="/articles/islamic-history" class="dropdown-item">Islamic History</a>
                            <a href="/articles/fiqh" class="dropdown-item">Fiqh</a>
                            <a href="/articles/aqeedah" class="dropdown-item">Aqeedah</a>
                            <a href="/articles/tasawwuf" class="dropdown-item">Tasawwuf</a>
                        </div>
                    </li>
                    <li class="bismillah-nav-item">
                        <a href="/salah" class="bismillah-nav-link">
                            <span class="bismillah-nav-icon">🕌</span>
                            Salah Times
                        </a>
                    </li>
                    <li class="bismillah-nav-item">
                        <a href="/calendar" class="bismillah-nav-link">
                            <span class="bismillah-nav-icon">📅</span>
                            Islamic Calendar
                        </a>
                    </li>
                    <li class="bismillah-nav-item">
                        <a href="/community" class="bismillah-nav-link">
                            <span class="bismillah-nav-icon">👥</span>
                            Community
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="main-content">
        {% block content %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bismillah-footer">
        <div class="bismillah-footer-content">
            <div class="bismillah-footer-section">
                <h3>About IslamWiki</h3>
                <p>Your trusted source for authentic Islamic knowledge, verified by scholars and accessible to the global Muslim community.</p>
            </div>
            <div class="bismillah-footer-section">
                <h3>Quick Links</h3>
                <ul class="bismillah-footer-links">
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/contact">Contact</a></li>
                    <li><a href="/privacy">Privacy Policy</a></li>
                    <li><a href="/terms">Terms of Service</a></li>
                </ul>
            </div>
            <div class="bismillah-footer-section">
                <h3>Connect</h3>
                <ul class="bismillah-footer-links">
                    <li><a href="/community">Community Forum</a></li>
                    <li><a href="/newsletter">Newsletter</a></li>
                    <li><a href="/social">Social Media</a></li>
                    <li><a href="/support">Support</a></li>
                </ul>
            </div>
        </div>
        <div class="bismillah-footer-bottom">
            <div class="bismillah-footer-content">
                <p>&copy; 2025 IslamWiki. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="/skins/Bismillah/js/bismillah.js?v={{ 'now'|date('U') }}"></script>
    <script src="/assets/js/marwa.js?v={{ 'now'|date('U') }}"></script>
    
    {% block scripts %}{% endblock %}
</body>
</html> 