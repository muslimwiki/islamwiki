<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="">
    <title>{% block title %}{{ title|default('IslamWiki') }}{% endblock %}</title>
    
    <!-- Google Fonts for Islamic Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Safa CSS Framework - Commented out to prevent purple theme override -->
    <!-- <link rel="stylesheet" href="/assets/css/safa.css?v={{ 'now'|date('U') }}"> -->
    
    <!-- Bismillah Skin CSS - Always load for main site structure -->
    <link rel="stylesheet" href="/skins/Bismillah/css/bismillah.css?v={{ 'now'|date('U') }}">
    
    <!-- Additional Skin CSS (if specified) -->
    {% if skin_css_url %}
        <link rel="stylesheet" href="{{ skin_css_url }}?v={{ 'now'|date('U') }}">
    {% endif %}
    
    <!-- Ensure Bismillah header styles are loaded -->
    <style>
        /* Override Safa CSS purple colors with Bismillah green theme */
        :root {
            --primary-color: #2d5016 !important;
            --secondary-color: #4a8029 !important;
            --accent-color: #d4af37 !important;
            --link-color: #2d5016 !important;
        }
        
        /* Force all primary colors to use Islamic green */
        *[class*="primary"], *[class*="btn-primary"], *[class*="bg-primary"] {
            background-color: #2d5016 !important;
            border-color: #2d5016 !important;
        }
        
        *[class*="text-primary"] {
            color: #2d5016 !important;
        }
        
        /* Override any purple colors */
        *[class*="purple"], *[class*="btn-purple"], *[class*="bg-purple"] {
            background-color: #2d5016 !important;
            border-color: #2d5016 !important;
        }
        
        *[class*="text-purple"] {
            color: #2d5016 !important;
        }
        
        /* Force dropdown functionality to work */
        .nav-dropdown {
            position: absolute !important;
            top: 100% !important;
            left: 0 !important;
            background: white !important;
            border: 1px solid #ddd !important;
            border-radius: 8px !important;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
            min-width: 200px !important;
            z-index: 99999 !important;
            opacity: 0 !important;
            visibility: hidden !important;
            transform: translateY(-10px) !important;
            transition: all 0.3s ease !important;
            border-top: 3px solid #d4af37 !important;
            display: block !important;
            /* Fix overflow and positioning issues */
            overflow: visible !important;
            clip: auto !important;
            height: auto !important;
            max-height: none !important;
            min-height: 100px !important;
            margin-top: 5px !important;
        }
        
        /* Show dropdowns only on hover */
        .bismillah-nav-item:hover .nav-dropdown {
            opacity: 1 !important;
            visibility: visible !important;
            transform: translateY(0) !important;
        }
        
        /* Fix navigation container overflow */
        .bismillah-main-nav {
            overflow: visible !important;
        }
        
        .bismillah-nav-content {
            overflow: visible !important;
        }
        
        .bismillah-nav-menu {
            overflow: visible !important;
        }
        
        .bismillah-nav-item {
            overflow: visible !important;
            position: relative !important;
            z-index: 1000 !important;
            display: inline-block !important;
        }
        
        .bismillah-nav-item.has-dropdown {
            overflow: visible !important;
            position: relative !important;
        }
        
        /* Ensure navigation links have proper hover areas */
        .bismillah-nav-link {
            position: relative !important;
            z-index: 1001 !important;
            display: block !important;
            padding: 8px 12px !important;
            color: white !important;
            text-decoration: none !important;
            background: transparent !important;
            /* Ensure links are clickable */
            pointer-events: auto !important;
            cursor: pointer !important;
        }
        
        .bismillah-nav-link:hover {
            background: rgba(255, 255, 255, 0.1) !important;
            color: white !important;
        }
        
        /* Debug: make sure nav items are clickable */
        .bismillah-nav-item {
            cursor: pointer !important;
            margin: 0 4px !important;
            position: relative !important;
            z-index: 1000 !important;
        }
        
        .bismillah-nav-item:hover {
            background: rgba(255, 255, 255, 0.05) !important;
        }
        
        /* Reduce spacing in navigation menu */
        .bismillah-nav-menu {
            gap: 8px !important;
            justify-content: center !important;
        }
        
        /* Ensure dropdowns don't block navigation links */
        .nav-dropdown {
            /* Remove pointer-events blocking */
        }
        
        .bismillah-nav-item:hover .nav-dropdown {
            /* Remove pointer-events blocking */
        }
        
        /* Fix any parent container clipping */
        body, html {
            overflow-x: visible !important;
        }
        
        .bismillah-header, .bismillah-main-nav {
            overflow: visible !important;
            clip: auto !important;
        }
        
        /* Basic styling for navigation items */
        .bismillah-nav-link {
            display: block !important;
            padding: 12px 16px !important;
            color: white !important;
            text-decoration: none !important;
            background: transparent !important;
        }
        
        .bismillah-nav-link:hover {
            background: rgba(255, 255, 255, 0.1) !important;
        }
        
        /* Ensure dropdown items are visible and clickable */
        .dropdown-item {
            display: block !important;
            padding: 12px 16px !important;
            color: #333 !important;
            text-decoration: none !important;
            border-bottom: 1px solid #eee !important;
            background: white !important;
            transition: all 0.3s ease !important;
            /* Make sure dropdown items are clickable */
            cursor: pointer !important;
            position: relative !important;
            z-index: 100000 !important;
            /* Ensure clicks work */
            pointer-events: auto !important;
        }
        
        .dropdown-item:hover {
            background: #f8f9fa !important;
            color: #2d5016 !important;
            padding-left: 24px !important;
            /* Debug: make hover visible */
            border-left: 3px solid #d4af37 !important;
        }
        
        .dropdown-item:last-child {
            border-bottom: none !important;
        }
        
        /* Ensure dropdown items don't block hover */
        .dropdown-item * {
            pointer-events: auto !important;
        }
        
        /* Make sure dropdown container allows interaction */
        .nav-dropdown {
            pointer-events: auto !important;
        }
        
        .nav-dropdown * {
            pointer-events: auto !important;
        }
        
        /* Override any pointer-events blocking */
        .bismillah-nav-item:hover .nav-dropdown,
        .bismillah-nav-item:hover .nav-dropdown * {
            pointer-events: auto !important;
        }
        
        /* Dropdown arrow indicator */
        .bismillah-nav-item.has-dropdown .bismillah-nav-link::after {
            content: '▼' !important;
            font-size: 12px !important;
            margin-left: 8px !important;
            opacity: 0.7 !important;
            transition: all 0.3s ease !important;
        }
        
        .bismillah-nav-item.has-dropdown:hover .bismillah-nav-link::after {
            transform: rotate(180deg) !important;
            opacity: 1 !important;
        }
        
        /* Right-aligned dropdowns */
        .bismillah-nav-item:nth-last-child(-n+3) .nav-dropdown,
        .bismillah-nav-item:nth-last-child(-n+2) .nav-dropdown,
        .bismillah-nav-item:last-child .nav-dropdown {
            left: auto !important;
            right: 0 !important;
        }
        
        /* Fallback styles for Bismillah header if CSS fails to load */
        .bismillah-header {
            background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%);
            color: white;
            box-shadow: 0 4px 20px rgba(45, 80, 22, 0.3);
        }
        
        .bismillah-header-top {
            padding: 1rem 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .bismillah-header-left, .bismillah-header-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .bismillah-header-secondary {
            background: rgba(255, 255, 255, 0.1);
            padding: 0.5rem 0;
        }
        
        .bismillah-secondary-nav {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .bismillah-logo {
            color: white;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        /* Force footer styling to work */
        .bismillah-footer {
            background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%) !important;
            color: white !important;
            padding: 3rem 0 2rem 0 !important;
            margin-top: auto !important;
            box-shadow: 0 -4px 20px rgba(45, 80, 22, 0.2) !important;
        }
        
        .bismillah-footer-content {
            width: 100% !important;
            max-width: none !important;
            margin: 0 !important;
            padding: 0 2rem !important;
            display: grid !important;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)) !important;
            gap: 3rem !important;
        }
        
        .bismillah-footer-section h3 {
            color: white !important;
            font-size: 1.25rem !important;
            font-weight: 600 !important;
            margin-bottom: 1.5rem !important;
            position: relative !important;
        }
        
        .bismillah-footer-section h3::after {
            content: '' !important;
            position: absolute !important;
            bottom: -8px !important;
            left: 0 !important;
            width: 40px !important;
            height: 3px !important;
            background: #d4af37 !important;
            border-radius: 2px !important;
        }
        
        .bismillah-footer-section p {
            color: rgba(255, 255, 255, 0.9) !important;
            line-height: 1.6 !important;
            margin-bottom: 1.5rem !important;
        }
        
        .bismillah-footer-section a {
            color: #d4af37 !important;
            text-decoration: none !important;
            transition: all 0.3s ease !important;
            display: inline-block !important;
            margin-bottom: 0.5rem !important;
        }
        
        .bismillah-footer-section a:hover {
            color: white !important;
            transform: translateX(5px) !important;
        }
        
        .bismillah-footer-links {
            list-style: none !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        
        .bismillah-footer-links li {
            margin-bottom: 0.5rem !important;
        }
        
        .bismillah-footer-links a {
            color: rgba(255, 255, 255, 0.8) !important;
            text-decoration: none !important;
            transition: all 0.3s ease !important;
            display: inline-block !important;
        }
        
        .bismillah-footer-links a:hover {
            color: #d4af37 !important;
            transform: translateX(5px) !important;
        }
        
        /* Copyright Section */
        .bismillah-copyright {
            background: #1a3a0f !important;
            color: rgba(255, 255, 255, 0.8) !important;
            padding: 1.5rem 0 !important;
            text-align: center !important;
            border-top: 1px solid rgba(255, 255, 255, 0.1) !important;
        }
        
        .bismillah-copyright-content {
            width: 100% !important;
            max-width: none !important;
            margin: 0 !important;
            padding: 0 2rem !important;
        }
        
        .bismillah-copyright p {
            margin: 0 !important;
            font-size: 0.9rem !important;
            color: rgba(255, 255, 255, 0.7) !important;
        }
        
        /* Force authentication pages to use green theme */
        .login-page, .register-page {
            background: linear-gradient(135deg, #f8faf5 0%, #ffffff 100%) !important;
        }
        
        .login-container, .register-container {
            background: white !important;
            border: 1px solid rgba(45, 80, 22, 0.1) !important;
            box-shadow: 0 10px 25px rgba(45, 80, 22, 0.15) !important;
        }
        
        .login-header, .register-header {
            background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%) !important;
            color: white !important;
        }
        
        .login-title, .register-title {
            color: white !important;
        }
        
        .login-subtitle, .register-subtitle {
            color: rgba(255, 255, 255, 0.9) !important;
        }
        
        .form-control:focus {
            border-color: #2d5016 !important;
            box-shadow: 0 0 0 3px rgba(45, 80, 22, 0.1) !important;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #2d5016 0%, #4a8029 100%) !important;
            color: white !important;
            border: none !important;
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #1a3a0f 0%, #2d5016 100%) !important;
            transform: translateY(-2px) !important;
        }
        
        .link {
            color: #2d5016 !important;
        }
        
        .link:hover {
            color: #1a3a0f !important;
        }
        
        .signup-link a {
            color: #2d5016 !important;
        }
        
        .signup-link a:hover {
            color: #1a3a0f !important;
        }
        
        .nav-link {
            color: white;
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            transition: all 0.3s ease;
        }
        
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }
        
        .nav-link.active {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }
        
        .bismillah-header-container {
            width: 100%;
            max-width: none;
            margin: 0;
            padding: 0 1.5rem;
        }
        
        .bismillah-search {
            width: 100%;
            max-width: 500px;
            margin: 0 auto;
        }
        
        .search-form {
            display: flex;
            position: relative;
        }
        
        .search-input-wrapper {
            position: relative;
            width: 100%;
        }
        
        .search-input {
            width: 100%;
            padding: 0.75rem 3rem 0.75rem 1rem;
            border: none;
            border-radius: 0.5rem;
            background: rgba(255, 255, 255, 0.9);
            color: #2d5016;
            font-size: 0.9rem;
        }
        
        .search-input:focus {
            outline: none;
            background: white;
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
        }
        
        .search-button {
            position: absolute;
            right: 0.5rem;
            top: 50%;
            transform: translateY(-50%);
            background: #2d5016;
            border: none;
            border-radius: 0.375rem;
            padding: 0.5rem;
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .search-button:hover {
            background: #4a8029;
            transform: translateY(-50%) scale(1.05);
        }
        
        .search-icon {
            width: 1.25rem;
            height: 1.25rem;
        }
        
        .bismillah-user-menu {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .user-button {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 0.5rem;
            padding: 0.5rem 1rem;
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .user-button:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.3);
        }
        
        .auth-buttons {
            display: flex;
            gap: 0.5rem;
        }
        
        .btn {
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
        }
        
        .btn-outline {
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
            background: transparent;
        }
        
        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.5);
        }
        
        .btn-primary {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        
        .btn-primary:hover {
            background: rgba(255, 255, 255, 0.3);
            border-color: rgba(255, 255, 255, 0.5);
        }
        
        /* Mobile responsive design */
        @media (max-width: 768px) {
            .bismillah-header-container {
                padding: 0 1rem;
            }
            
            .bismillah-header-top {
                flex-direction: column;
                gap: 1rem;
                padding: 1rem 0;
            }
            
            .bismillah-search {
                max-width: 100%;
                order: 2;
            }
            
            .bismillah-user-menu {
                order: 1;
                justify-content: center;
            }
            
            .footer-content {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }
            
            .bismillah-secondary-nav {
                flex-wrap: wrap;
                gap: 0.5rem;
                justify-content: center;
            }
            
            .nav-link {
                font-size: 0.9rem;
                padding: 0.4rem 0.8rem;
            }
        }
    </style>
    
    <!-- ZamZam.js for frontend interactivity -->
    <script defer src="/assets/js/zamzam.js"></script>
    
    {% block styles %}{% endblock %}
    
    {% block head %}{% endblock %}
    
    {% block body_class %}{% endblock %}
</head>
<body{% if block('body_class') %} class="{{ block('body_class') }}"{% endif %}>
    <!-- Top Bar with Islamic Info -->
    <div class="bismillah-top-bar">
        <div class="bismillah-top-bar-content">
            <div class="bismillah-islamic-info">
                <div class="bismillah-prayer-info">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
                    </svg>
                    Next Prayer: Asr - 3:45 PM
            </div>
                <div class="bismillah-date-info">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2Z"/>
                                </svg>
                    15 Rabi' al-Awwal 1446 | September 18, 2024
                </div>
            </div>
            <div class="bismillah-user-actions">
                    {% if user %}
                    <div class="user-dropdown">
                        <button class="bismillah-user-menu user-dropdown-toggle">
                            <span>👤 {{ user.name|default('User') }}</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M7,10L12,15L17,10H7Z"/>
                                </svg>
                            </button>
                        <div class="user-dropdown-menu">
                            <a href="/dashboard" class="dropdown-item">📊 Dashboard</a>
                            <a href="/profile" class="dropdown-item">👤 Profile</a>
                            <a href="/settings" class="dropdown-item">⚙️ Settings</a>
                            <a href="/auth/logout" class="dropdown-item">🚪 Logout</a>
                                </div>
                            </div>
                        {% else %}
                    <a href="/auth/login" class="bismillah-user-menu">🔑 Login</a>
                    <a href="/auth/register" class="bismillah-user-menu">📝 Join</a>
                        {% endif %}
                    </div>
        </div>
    </div>

    <!-- Main Bar with Logo and Search -->
    <div class="bismillah-main-bar">
        <div class="bismillah-main-bar-content">
            <a href="/" class="bismillah-site-logo">
                <div class="bismillah-logo-icon">☪</div>
                <div class="bismillah-logo-text">
                    <div class="bismillah-site-name">IslamWiki</div>
                    <div class="bismillah-site-tagline">Authentic Islamic Knowledge</div>
                </div>
            </a>

            <div class="bismillah-main-search">
                <form action="/iqra-search" method="GET" class="bismillah-search-form">
                    <input type="text" name="q" class="bismillah-search-input" placeholder="Search Quran, Hadith, Scholars, Articles..." value="{{ app.request.query.get('q', '') }}">
                    <button type="submit" class="bismillah-search-btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                        </svg>
                    </button>
                </form>
            </div>
            
            <div class="bismillah-header-actions">
                <button class="bismillah-lang-toggle" id="langToggle" data-lang="en" onclick="toggleLanguage()">
                    <span class="lang-icon">🌐</span>
                    <span class="lang-text">العربية</span>
                </button>
                <a href="/contribute" class="bismillah-contribute-btn">Contribute</a>
            </div>
        </div>
    </div>

    <!-- Main Navigation -->
    <nav class="bismillah-main-nav">
        <div class="bismillah-nav-content">
            <ul class="bismillah-nav-menu">
                <li class="bismillah-nav-item">
                    <a href="/" class="bismillah-nav-link">
                        <span class="bismillah-nav-icon">🏠</span>
                        Home
                    </a>
                </li>
                
                <li class="bismillah-nav-item has-dropdown">
                    <a href="/quran" class="bismillah-nav-link">
                        <span class="bismillah-nav-icon">📖</span>
                        Quran
                    </a>
                    <div class="nav-dropdown">
                        <a href="/quran" class="dropdown-item">
                            <span class="dropdown-icon">📖</span>
                            Browse Quran
                        </a>
                        <a href="/quran/search" class="dropdown-item">
                            <span class="dropdown-icon">🔍</span>
                            Search Quran
                        </a>
                        <a href="/quran/juz/1" class="dropdown-item">
                            <span class="dropdown-icon">📚</span>
                            Juz View
                        </a>
                        <a href="/quran/page/1" class="dropdown-item">
                            <span class="dropdown-icon">📄</span>
                            Page View
                        </a>
                    </div>
                </li>
                
                <li class="bismillah-nav-item has-dropdown">
                    <a href="/hadith" class="bismillah-nav-link">
                        <span class="bismillah-nav-icon">📜</span>
                        Hadith
                    </a>
                    <div class="nav-dropdown">
                        <a href="/hadith" class="dropdown-item">
                            <span class="dropdown-icon">📜</span>
                            Browse Hadith
                        </a>
                        <a href="/hadith/search" class="dropdown-item">
                            <span class="dropdown-icon">🔍</span>
                            Search Hadith
