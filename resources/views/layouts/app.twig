<!DOCTYPE html>
<html lang="{{ current_language|default('en') }}" dir="{{ current_language|default('en') in ['ar', 'ur', 'fa', 'he'] ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="">
    <title>{% block title %}{{ title|default('IslamWiki') }}{% endblock %}</title>
    
    <!-- Google Fonts for Islamic Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Global Bismillah Skin CSS -->
    <link rel="stylesheet" href="/skins/Bismillah/css/bismillah.css?v={{ 'now'|date('U') }}&v=0.0.2.6">
    
    <!-- Page-specific CSS files -->
    {% block page_css %}{% endblock %}
    
    <!-- Extra CSS from child templates -->
    {% block extra_css %}{% endblock %}
</head>
<body class="bismillah-body">
    <!-- Condensed Sidebar -->
    <div class="condensed-sidebar">
        <!-- Top Section: Logo, Search, Navigation -->
        <div class="sidebar-top">
            <!-- Logo -->
            <div class="sidebar-logo">
                <i class="fas fa-star-and-crescent"></i>
            </div>
            
            <!-- Search Button -->
            <div class="sidebar-icon search-icon" id="search-trigger" title="Search">
                <i class="fas fa-search"></i>
                <div class="search-dropdown">
                    <div class="search-input-container">
                        <input type="text" class="search-input" placeholder="Search Islamic knowledge...">
                        <button class="search-button">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    <div class="search-suggestions">
                        <div class="search-suggestion">
                            <i class="fas fa-book"></i>
                            <span>Quran</span>
                        </div>
                        <div class="search-suggestion">
                            <i class="fas fa-quote-left"></i>
                            <span>Hadith</span>
                        </div>
                        <div class="search-suggestion">
                            <i class="fas fa-mosque"></i>
                            <span>Islamic Practices</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Hamburger Menu -->
            <div class="sidebar-icon hamburger-icon" id="hamburger-trigger" title="Menu">
                <i class="fas fa-bars"></i>
                <div class="hamburger-dropdown">
                    <a href="/" class="dropdown-item">
                        <i class="fas fa-home"></i>
                        Home
                    </a>
                    <a href="/wiki" class="dropdown-item">
                        <i class="fas fa-book"></i>
                        Wiki
                    </a>
                    <a href="/search" class="dropdown-item">
                        <i class="fas fa-search"></i>
                        Search
                    </a>
                    <a href="/wiki/Recent_Changes" class="dropdown-item">
                        <i class="fas fa-history"></i>
                        Recent Changes
                    </a>
                    <div class="dropdown-divider"></div>
                    <a href="/wiki/How_to_Contribute" class="dropdown-item">
                        <i class="fas fa-hand-holding-heart"></i>
                        Contribute
                    </a>
                    <a href="/wiki/About_IslamWiki" class="dropdown-item">
                        <i class="fas fa-info-circle"></i>
                        About
                    </a>
                </div>
            </div>
        </div>
        
        <!-- Bottom Section: Settings, Notifications, Navigation, Profile -->
        <div class="sidebar-bottom">
            <!-- Settings (Cog Wheel) - Display Options - Always Visible -->
            <div class="sidebar-icon settings-icon" title="Display Options">
                <i class="fas fa-cog"></i>
                <div class="settings-dropdown">
                    <div class="dropdown-section">
                        <h4>Text Size</h4>
                        <div class="dropdown-options">
                            <a href="#" class="dropdown-option" data-text-size="small">Small</a>
                            <a href="#" class="dropdown-option active" data-text-size="standard">Standard</a>
                            <a href="#" class="dropdown-option" data-text-size="large">Large</a>
                            <a href="#" class="dropdown-option" data-text-size="extra-large">Extra Large</a>
                        </div>
                    </div>
                    <div class="dropdown-section">
                        <h4>Color Theme</h4>
                        <div class="dropdown-options">
                            <a href="#" class="dropdown-option active" data-color-theme="auto">Auto</a>
                            <a href="#" class="dropdown-option" data-color-theme="light">Light</a>
                            <a href="#" class="dropdown-option" data-color-theme="dark">Dark</a>
                        </div>
                    </div>
                    <div class="dropdown-section">
                        <h4>Width</h4>
                        <div class="dropdown-options">
                            <a href="#" class="dropdown-option" data-width="standard">Standard</a>
                            <a href="#" class="dropdown-option" data-width="wide">Wide</a>
                            <a href="#" class="dropdown-option active" data-width="full">Full</a>
                        </div>
                    </div>
                    {% if user %}
                        <div class="dropdown-section">
                            <p class="preferences-note">Preferences will be saved to your profile</p>
                        </div>
                    {% else %}
                        <div class="dropdown-section">
                            <p class="preferences-note">Preferences will be saved to your session</p>
                        </div>
                    {% endif %}
                </div>
            </div>
            
            {% if user %}
                <!-- User is logged in -->
                
                <!-- Notifications -->
                <div class="sidebar-icon notifications-icon" title="Notifications">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                    <div class="notifications-panel">
                        <div class="notifications-header">
                            <h3>Notifications</h3>
                            <button class="close-notifications" title="Close">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div class="notifications-list">
                            <div class="notification-item">
                                <i class="fas fa-info-circle"></i>
                                <span>New article published</span>
                            </div>
                            <div class="notification-item">
                                <i class="fas fa-bell"></i>
                                <span>Salah time reminder</span>
                            </div>
                            <div class="notification-item">
                                <i class="fas fa-user-plus"></i>
                                <span>New community member</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Profile - Logged In State -->
                <div class="sidebar-icon profile-icon" title="Profile">
                    <i class="fas fa-user"></i>
                    <div class="profile-dropdown">
                        <a href="/wiki/User/{{ user.username }}" class="user-info-header-link">
                            <div class="user-info-header">
                                <div class="user-avatar">{{ user.username|first|upper }}</div>
                                <div class="user-details">
                                    <span class="username-text">{{ user.username }}</span>
                                    <div class="user-role">{{ user.role|default('User') }}</div>
                                    <div class="user-stats">
                                        <span class="user-edits">Edits {{ user.edit_count|default('0') }}</span>
                                        <span class="user-joined">Joined {% if user.created_at and user.created_at != 'Unknown' %}{{ user.created_at|date('j F Y') }}{% else %}Recently{% endif %}</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                        <div class="dropdown-divider"></div>
                        <a href="/dashboard" class="dropdown-item">
                            <i class="fas fa-tachometer-alt"></i>
                            Dashboard
                        </a>
                        <a href="/wiki/Special:Preferences" class="dropdown-item">
                            <i class="fas fa-cog"></i>
                            Preferences
                        </a>
                        <div class="dropdown-divider"></div>
                        <a href="/logout" class="dropdown-item logout-button">
                            <i class="fas fa-sign-out-alt"></i>
                            Logout
                        </a>
                    </div>
                </div>
                
            {% else %}
                <!-- User is not logged in -->
                
                <!-- Profile - Logged Out State (contains auth elements) -->
                <div class="sidebar-icon profile-icon" title="Account">
                    <i class="fas fa-user"></i>
                    <div class="profile-dropdown">
                        <div class="user-info-header">
                            <div class="user-avatar">
                                <i class="fas fa-user-slash"></i>
                            </div>
                            <div class="user-details">
                                <div class="username">Not logged in</div>
                                <div class="user-role">Guest</div>
                            </div>
                        </div>
                        <div class="dropdown-divider"></div>
                        
                        <!-- Language Selection -->
                        <div class="dropdown-section">
                            <h4>Language</h4>
                            <a href="/wiki/Special:Preferences" class="dropdown-item">
                                <span class="language-flag">🇺🇸</span>
                                <span>English</span>
                            </a>
                        </div>
                        
                        <div class="dropdown-divider"></div>
                        
                        <!-- Authentication Buttons -->
                        <a href="/register" class="dropdown-item create-account">
                            <i class="fas fa-user-plus"></i>
                            Create Account
                        </a>
                        <a href="/login" class="dropdown-item login-button">
                            <i class="fas fa-sign-in-alt"></i>
                            Log In
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
    
    <!-- ===== MAIN CONTENT WRAPPER ===== -->
    <div class="main-content-wrapper">
        <!-- Simplified Header - Only Top Bar with Salah Time -->
        <header class="bismillah-header-simplified">
            <div class="bismillah-header-content">
                <div class="bismillah-salah-info">
                    <span class="salah-icon">🙏</span>
                    <span class="salah-text">
                        Next: Asr 3:45 PM
                    </span>
                    <span class="time-separator">•</span>
                    <span class="time-icon">🕐</span>
                    <span class="current-time">4:37 PM</span>
                    <span class="time-separator">•</span>
                    <span class="hijri-date">28 Safar 1447 AH</span>
                </div>
            </div>
        </header>
        
        <!-- Main Content Area -->
        <main class="main-content">
            {% block content %}{% endblock %}
        </main>
        
        <!-- Footer - Clean and Professional (INSIDE main-content-wrapper) -->
        <footer class="bismillah-footer">
            <div class="bismillah-footer-content">
                <div class="bismillah-footer-section">
                    <h3>About IslamWiki</h3>
                    <p>Your trusted source for authentic Islamic knowledge, verified by scholars and accessible to the global Muslim community.</p>
                </div>
                <div class="bismillah-footer-section">
                    <h3>Quick Links</h3>
                    <ul class="bismillah-footer-links">
                        <li><a href="/about">About Us</a></li>
                        <li><a href="/contact">Contact</a></li>
                        <li><a href="/privacy">Privacy Policy</a></li>
                        <li><a href="/terms">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="bismillah-footer-section">
                    <h3>Connect</h3>
                    <ul class="bismillah-footer-links">
                        <li><a href="/community">Community Forum</a></li>
                        <li><a href="/newsletter">Newsletter</a></li>
                        <li><a href="/social">Social Media</a></li>
                        <li><a href="/support">Support</a></li>
                    </ul>
                </div>
            </div>
            <div class="bismillah-footer-bottom">
                <div class="bismillah-footer-content">
                    <p>&copy; 2025 IslamWiki. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>
    
    <!-- Notifications Panel -->
    <div class="notifications-panel">
        <div class="notifications-header">
            <h3>
                <i class="fas fa-bell"></i>
                Notifications
            </h3>
            <button class="mark-all-read">Mark all as read</button>
        </div>
        
        <div class="notifications-list">
            <!-- Notifications will be loaded dynamically -->
        </div>
        
        <div class="notifications-footer">
            <a href="/wiki/Special:Notifications">
                <i class="fas fa-cog"></i>
                Notification preferences
            </a>
            <a href="/wiki/Special:Notifications">
                <i class="fas fa-list"></i>
                All notifications
            </a>
        </div>
    </div>
    
    <!-- Profile Menu -->
    <div class="profile-menu">
        <div class="user-info">
            <!-- User info will be loaded dynamically -->
        </div>
        
        <div class="profile-actions">
            <!-- Profile actions will be loaded dynamically -->
        </div>
        
        <div class="profile-footer">
            <button class="logout-btn">
                <i class="fas fa-sign-out-alt"></i>
                Log out
            </button>
        </div>
    </div>
    
    <!-- JavaScript -->
    <script src="/assets/js/marwa.js?v={{ 'now'|date('U') }}"></script>
    
    <!-- Smart Sidebar Navigation System -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Setup logo click handler
            const logo = document.querySelector('.sidebar-logo');
            if (logo) {
                logo.addEventListener('click', () => {
                    window.location.href = '/wiki/Main_Page';
                });
            }
            
            // Get all sidebar icons
            const sidebarIcons = document.querySelectorAll('.sidebar-icon');
            console.log('Found sidebar icons:', sidebarIcons.length);
            
            sidebarIcons.forEach((icon, index) => {
                const dropdown = icon.querySelector('[class*="-dropdown"], [class*="-panel"], [class*="-menu"]');
                const iconId = icon.id || icon.className.split(' ').find(cls => cls.includes('-icon'));
                
                console.log(`Icon ${index}: ${iconId}, Has dropdown: ${!!dropdown}`);
                
                // Smart dropdown positioning to prevent cutoff
                if (dropdown) {
                    icon.addEventListener('mouseenter', () => {
                        // Calculate available space above and below the icon
                        const iconRect = icon.getBoundingClientRect();
                        const dropdownHeight = dropdown.offsetHeight;
                        const viewportHeight = window.innerHeight;
                        
                        // Check if there's enough space below
                        const spaceBelow = viewportHeight - iconRect.bottom;
                        const spaceAbove = iconRect.top;
                        
                        // Position dropdown above if not enough space below
                        if (spaceBelow < dropdownHeight && spaceAbove > dropdownHeight) {
                            dropdown.classList.add('bottom-positioned');
                        } else {
                            dropdown.classList.remove('bottom-positioned');
                        }
                        
                        console.log('Smart positioning dropdown for', iconId, {
                            spaceBelow,
                            spaceAbove,
                            dropdownHeight,
                            positionedAbove: spaceBelow < dropdownHeight && spaceAbove > dropdownHeight
                        });
                    });
                }
                
                // Remove the complex hover logic and let CSS handle it
                // CSS :hover states will show/hide dropdowns automatically
                
                // Click to navigate to primary function - with multiple event types
                const handleIconClick = (e) => {
                    // Don't prevent default or stop propagation for profile icon and hamburger icon
                    // Let the dropdowns handle their own clicks
                    if (icon.classList.contains('profile-icon') || icon.classList.contains('hamburger-icon')) {
                        console.log('👤 Profile icon or 🍔 Hamburger icon clicked - allowing dropdown to handle');
                        return;
                    }
                    
                    e.preventDefault();
                    e.stopPropagation();
                    
                    console.log('🎯 CLICK DETECTED on icon:', iconId);
                    console.log('Icon classes:', icon.className);
                    console.log('Icon ID:', icon.id);
                    console.log('Event type:', e.type);
                    
                    // Determine navigation target based on class names or IDs
                    let targetUrl = null;
                    
                    if (icon.classList.contains('search-icon') || icon.id === 'search-trigger') {
                        targetUrl = '/search';
                        console.log('🔍 Search icon clicked');
                    } else if (icon.classList.contains('settings-icon')) {
                        targetUrl = '/settings';
                        console.log('⚙️ Settings icon clicked');
                    } else if (icon.classList.contains('notifications-icon')) {
                        targetUrl = '/notifications';
                        console.log('🔔 Notifications icon clicked');
                    } else if (icon.classList.contains('navigation-icon')) {
                        targetUrl = '/wiki';
                        console.log('🧭 Navigation icon clicked');
                    }
                    
                    if (targetUrl) {
                        console.log('🚀 Navigating to:', targetUrl);
                        // Add a small delay to ensure console logs are visible
                        setTimeout(() => {
                            window.location.href = targetUrl;
                        }, 100);
                    } else {
                        console.log('❌ No navigation target found for classes:', icon.className);
                    }
                };
                
                // Add click event listener
                icon.addEventListener('click', handleIconClick);
                
                // Handle dropdown button clicks for profile menu
                if (dropdown && icon.classList.contains('profile-icon')) {
                    const loginButton = dropdown.querySelector('.login-button');
                    const createAccountButton = dropdown.querySelector('.create-account');
                    const logoutButton = dropdown.querySelector('.logout-button');
                    const preferencesLink = dropdown.querySelector('a[href*="Special:Preferences"]');
                    const languageButton = dropdown.querySelector('.language-selector');
                    
                    if (loginButton) {
                        loginButton.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            console.log('🔐 Login button clicked, navigating to /login');
                            window.location.href = '/login';
                        });
                    }
                    
                    if (createAccountButton) {
                        createAccountButton.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            console.log('📝 Create Account button clicked, navigating to /register');
                            window.location.href = '/register';
                        });
                    }
                    
                    if (logoutButton) {
                        logoutButton.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            console.log('🚪 Logout button clicked, navigating to /auth/logout');
                            window.location.href = '/auth/logout';
                        });
                    }
                    
                    if (preferencesLink) {
                        preferencesLink.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            console.log('⚙️ Preferences link clicked, navigating to /wiki/Special:Preferences');
                            window.location.href = '/wiki/Special:Preferences';
                        });
                    }
                    
                    if (languageButton) {
                        languageButton.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            console.log('🌐 Language button clicked, navigating to /wiki/Special:Preferences');
                            window.location.href = '/wiki/Special:Preferences';
                        });
                    }
                }
                
                // Handle dropdown button clicks for settings menu
                if (dropdown && icon.classList.contains('settings-icon')) {
                    const textSizeOptions = dropdown.querySelectorAll('[data-text-size]');
                    const colorThemeOptions = dropdown.querySelectorAll('[data-color-theme]');
                    const widthOptions = dropdown.querySelectorAll('[data-width]');
                    
                    // Handle text size options
                    textSizeOptions.forEach(option => {
                        option.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            
                            // Remove active class from all options
                            textSizeOptions.forEach(opt => opt.classList.remove('active'));
                            // Add active class to clicked option
                            option.classList.add('active');
                            
                            const textSize = option.getAttribute('data-text-size');
                            console.log('📏 Text size changed to:', textSize);
                            
                            // Remove all text size classes from body
                            document.body.classList.remove('text-size-small', 'text-size-standard', 'text-size-large', 'text-size-extra-large');
                            // Add the selected text size class
                            document.body.classList.add(`text-size-${textSize}`);
                            
                            // Save preference if user is logged in
                            if (typeof saveUserPreference === 'function') {
                                saveUserPreference('display_text_size', textSize);
                            }
                        });
                    });
                    
                    // Handle color theme options
                    colorThemeOptions.forEach(option => {
                        option.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            
                            // Remove active class from all options
                            colorThemeOptions.forEach(opt => opt.classList.remove('active'));
                            // Add active class to clicked option
                            option.classList.add('active');
                            
                            const colorTheme = option.getAttribute('data-color-theme');
                            console.log('🎨 Color theme changed to:', colorTheme);
                            
                            // Apply color theme change using data attribute
                            if (colorTheme === 'auto') {
                                document.documentElement.removeAttribute('data-theme');
                            } else {
                                document.documentElement.setAttribute('data-theme', colorTheme);
                            }
                            
                            // Save preference if user is logged in
                            if (typeof saveUserPreference === 'function') {
                                saveUserPreference('display_color_theme', colorTheme);
                            }
                        });
                    });
                    
                    // Handle width options
                    widthOptions.forEach(option => {
                        option.addEventListener('click', (e) => {
                            e.preventDefault();
                            e.stopPropagation();
                            
                            // Remove active class from all options
                            widthOptions.forEach(opt => opt.classList.remove('active'));
                            // Add active class to clicked option
                            option.classList.add('active');
                            
                            const width = option.getAttribute('data-width');
                            console.log('📐 Width changed to:', width);
                            
                            // Remove all width classes from body
                            document.body.classList.remove('content-width-standard', 'content-width-wide', 'content-width-full');
                            // Add the selected width class
                            document.body.classList.add(`content-width-${width}`);
                            
                            // Save preference if user is logged in
                            if (typeof saveUserPreference === 'function') {
                                saveUserPreference('display_width', width);
                            }
                        });
                    });
                }
                
                // Keep dropdown open when hovering over it (for CSS hover to work properly)
                if (dropdown) {
                    dropdown.addEventListener('mouseenter', () => {
                        // Let CSS handle the hover state
                        console.log('Hovering over dropdown for', iconId);
                    });
                    
                    dropdown.addEventListener('mouseleave', () => {
                        // Let CSS handle the hover state
                        console.log('Leaving dropdown for', iconId);
                    });
                }
            });
            
            // Close dropdowns when clicking outside
            document.addEventListener('click', (e) => {
                // This logic is now handled by CSS :hover
                // if (hoveredDropdown) {
                //     console.log('Clicking outside, closing hovered dropdown');
                //     hoveredDropdown.style.display = 'none';
                //     hoveredDropdown.classList.remove('dropdown-open');
                //     hoveredDropdown = null;
                // }
            });
            
            // Close dropdowns with Escape key
            document.addEventListener('keydown', (e) => {
                // This logic is now handled by CSS :hover
                // if (e.key === 'Escape' && hoveredDropdown) {
                //     console.log('Escape key, closing hovered dropdown');
                //     hoveredDropdown.style.display = 'none';
                //     hoveredDropdown.classList.remove('dropdown-open');
                //     hoveredDropdown = null;
                // }
            });
            
            // Test: Log all found icons and their properties
            console.log('📋 SIDEBAR ICONS SUMMARY:');
            sidebarIcons.forEach((icon, i) => {
                console.log(`Icon ${i}:`, {
                    id: icon.id,
                    className: icon.className,
                    hasDropdown: !!icon.querySelector('[class*="-dropdown"], [class*="-panel"], [class*="-menu"]')
                });
            });
            
            console.log('✅ Smart sidebar navigation system initialized');
            
            // Load and apply user preferences on page load
            function loadUserPreferences() {
                // Load preferences from localStorage (temporary solution until backend is ready)
                const savedTextSize = localStorage.getItem('display_text_size') || 'standard';
                const savedColorTheme = localStorage.getItem('display_color_theme') || 'auto';
                const savedWidth = localStorage.getItem('display_width') || 'full';
                
                // Apply text size
                document.body.classList.remove('text-size-small', 'text-size-standard', 'text-size-large', 'text-size-extra-large');
                document.body.classList.add(`text-size-${savedTextSize}`);
                
                // Apply color theme
                if (savedColorTheme === 'auto') {
                    document.documentElement.removeAttribute('data-theme');
                } else {
                    document.documentElement.setAttribute('data-theme', savedColorTheme);
                }
                
                // Apply width
                document.body.classList.remove('content-width-standard', 'content-width-wide', 'content-width-full');
                document.body.classList.add(`content-width-${savedWidth}`);
                
                // Update active states in cog wheel menu
                const textSizeOption = document.querySelector(`[data-text-size="${savedTextSize}"]`);
                const colorThemeOption = document.querySelector(`[data-color-theme="${savedColorTheme}"]`);
                const widthOption = document.querySelector(`[data-width="${savedWidth}"]`);
                
                if (textSizeOption) textSizeOption.classList.add('active');
                if (colorThemeOption) colorThemeOption.classList.add('active');
                if (widthOption) widthOption.classList.add('active');
                
                console.log('📋 User preferences loaded:', { savedTextSize, savedColorTheme, savedWidth });
            }
            
            // Load preferences when page is ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadUserPreferences);
            } else {
                loadUserPreferences();
            }
            
            // Temporary saveUserPreference function for testing
            window.saveUserPreference = function(key, value) {
                localStorage.setItem(key, value);
                console.log(`💾 Preference saved: ${key} = ${value}`);
            };
            
            // Test: Add a visible alert to confirm JavaScript is working
            setTimeout(() => {
                console.log('🧪 Testing sidebar clicks - JavaScript is active!');
                // You can click on any sidebar icon now - check console for debug info
            }, 1000);
        });
    </script>
    
    {% block scripts %}{% endblock %}
</body>
</html> 