<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="">
    <title>{% block title %}{{ title|default('IslamWiki') }}{% endblock %}</title>
    
    <!-- Google Fonts for Islamic Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Safa CSS Framework -->
    <link rel="stylesheet" href="/css/safa.css?v={{ 'now'|date('U') }}">
    
    <!-- Skin CSS (must come after Safa to take precedence) -->
    {% if skin_css %}
        <style>{{ skin_css|raw }}</style>
    {% endif %}
    
    <!-- ZamZam.js for frontend interactivity -->
    <script defer src="/js/zamzam.js"></script>
    
    {% block styles %}{% endblock %}
    
    {% block head %}{% endblock %}
    
    {% block body_class %}{% endblock %}
</head>
<body{% if block('body_class') %} class="{{ block('body_class') }}"{% endif %}>
    {% if skin_layout_path is defined and skin_layout_path and active_skin == 'Muslim' %}
        {# Use Muslim skin layout structure #}
        <!-- Muslim Header Structure -->
        <header class="muslim-header">
            <!-- Top Bar -->
            <div class="muslim-header-top">
                <div class="muslim-header-container">
                    <div class="muslim-header-left">
                        <a href="/" class="muslim-logo">
                            <span class="logo-icon">🕌</span>
                            <span class="logo-text">IslamWiki</span>
                        </a>
                    </div>
                    
                    <div class="muslim-header-center">
                        <div class="muslim-search">
                            <form class="search-form" method="GET" action="/iqra-search">
                                <div class="search-input-wrapper">
                                    <input type="text" name="q" class="search-input" 
                                           placeholder="Search Islamic knowledge..." 
                                           value="{{ app.request.query.get('q', '') }}">
                                    <button type="submit" class="search-button">
                                        <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                        </svg>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                    
                    <div class="muslim-header-right">
                        <nav class="muslim-nav">
                            <a href="/" class="nav-link {{ is_current_page('/') ? 'active' : '' }}">Home</a>
                            <a href="/pages" class="nav-link {{ is_current_page('/pages') ? 'active' : '' }}">Browse</a>
                            <a href="/quran" class="nav-link {{ is_current_page('/quran') ? 'active' : '' }}">Quran</a>
                            <a href="/hadith" class="nav-link {{ is_current_page('/hadith') ? 'active' : '' }}">Hadith</a>
                        </nav>
                        
                        <div class="muslim-user-menu">
                            {% if user %}
                                <div class="user-dropdown" z-data='{"open": false}'>
                                    <button z-click="open = !open" class="user-button" aria-label="User menu for {{ user.username }}">
                                        <div class="user-avatar">
                                            <svg class="avatar-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                            </svg>
                                        </div>
                                        <span class="user-name">{{ user.username }}</span>
                                        <svg class="dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </button>
                                    
                                    <div z-show="open" 
                                         z-click-away="open = false"
                                         class="user-dropdown-menu">
                                        <a href="/dashboard" class="dropdown-item {{ is_current_page('/dashboard') ? 'active' : '' }}">
                                            <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"/>
                                            </svg>
                                            Dashboard
                                        </a>
                                        <a href="/profile" class="dropdown-item {{ is_current_page('/profile') ? 'active' : '' }}">
                                            <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                            </svg>
                                            Profile
                                        </a>
                                        <a href="/settings" class="dropdown-item {{ is_current_page('/settings') ? 'active' : '' }}">
                                            <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            </svg>
                                            Settings
                                        </a>
                                        <div class="dropdown-divider"></div>
                                        <form action="/logout" method="POST" class="dropdown-form">
                                            <button type="submit" class="dropdown-item logout-item">
                                                <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                                </svg>
                                                Logout
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            {% else %}
                                <div class="auth-buttons">
                                    <a href="/login" class="btn btn-outline">Sign In</a>
                                    <a href="/register" class="btn btn-primary">Join</a>
                                </div>
                            {% endif %}
                        </div>
                        
                        <!-- Mobile menu toggle -->
                        <button class="mobile-menu-toggle" aria-label="Toggle mobile menu">
                            <span></span>
                            <span></span>
                            <span></span>
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- Secondary Navigation -->
            <div class="muslim-header-secondary">
                <div class="muslim-header-container">
                    <nav class="muslim-secondary-nav">
                        <a href="/islamic-sciences" class="nav-link {{ is_current_page('/islamic-sciences') ? 'active' : '' }}">Islamic Sciences</a>
                        <a href="/prayer-times" class="nav-link {{ is_current_page('/prayer-times') ? 'active' : '' }}">Prayer Times</a>
                        <a href="/calendar" class="nav-link {{ is_current_page('/calendar') ? 'active' : '' }}">Islamic Calendar</a>
                        <a href="/community" class="nav-link {{ is_current_page('/community') ? 'active' : '' }}">Community</a>
                        <a href="/about" class="nav-link {{ is_current_page('/about') ? 'active' : '' }}">About</a>
                    </nav>
                </div>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="muslim-main">
            <div class="muslim-container">
                {% block content %}{% endblock %}
            </div>
        </main>

        <!-- Muslim Footer -->
        <footer class="muslim-footer">
            <div class="muslim-header-container">
                <div class="footer-content">
                    <div class="footer-section">
                        <h3>IslamWiki</h3>
                        <p>Your comprehensive source for Islamic knowledge and community.</p>
                    </div>
                    <div class="footer-section">
                        <h4>Quick Links</h4>
                        <ul>
                            <li><a href="/pages">Browse Pages</a></li>
                            <li><a href="/quran">Quran</a></li>
                            <li><a href="/hadith">Hadith</a></li>
                            <li><a href="/community">Community</a></li>
                        </ul>
                    </div>
                    <div class="footer-section">
                        <h4>Resources</h4>
                        <ul>
                            <li><a href="/prayer-times">Prayer Times</a></li>
                            <li><a href="/calendar">Islamic Calendar</a></li>
                            <li><a href="/islamic-sciences">Islamic Sciences</a></li>
                            <li><a href="/about">About</a></li>
                        </ul>
                    </div>
                    <div class="footer-section">
                        <h4>Support</h4>
                        <ul>
                            <li><a href="/help">Help Center</a></li>
                            <li><a href="/contact">Contact Us</a></li>
                            <li><a href="/privacy">Privacy Policy</a></li>
                            <li><a href="/terms">Terms of Service</a></li>
                        </ul>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>&copy; 2025 IslamWiki. All rights reserved.</p>
                </div>
            </div>
        </footer>
    {% else %}
        {# Use default layout structure #}
        <div class="header">
            <!-- Top Navigation Bar -->
            <div class="header-top-bar">
                <div class="header-top-content">
                    <a href="/" class="logo">
                        📚 IslamWiki
                    </a>
                    
                    <div class="search-container">
                        <form class="search-form" method="GET" action="/iqra-search">
                            <input type="text" name="q" class="search-input" placeholder="Search Islamic content..." 
                                   value="{{ app.request.query.get('q', '') }}">
                            <button type="submit" class="search-button">
                                <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                    
                    <div class="user-menu">
                        {% if user %}
                            <div class="user-dropdown" z-data='{"open": false}'>
                                <button z-click="open = !open" class="user-avatar-btn" aria-label="User menu for {{ user.username }}">
                                    <div class="user-avatar" title="{{ user.username }}">
                                        <svg class="avatar-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                    </div>
                                    <svg class="dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                    </svg>
                                </button>
                                
                                <div z-show="open" 
                                     z-click-away="open = false"
                                     class="user-dropdown-menu z-transition z-duration-200">
                                    <a href="/dashboard" class="dropdown-item {{ is_current_page('/dashboard') ? 'active' : '' }}">
                                        <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5a2 2 0 012-2h4a2 2 0 012 2v6H8V5z"/>
                                        </svg>
                                        Dashboard
                                    </a>
                                    <a href="/profile" class="dropdown-item {{ is_current_page('/profile') ? 'active' : '' }}">
                                        <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                        Profile
                                    </a>
                                    <a href="/settings" class="dropdown-item {{ is_current_page('/settings') ? 'active' : '' }}">
                                        <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 00-1.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        </svg>
                                        Settings
                                    </a>
                                    <div class="dropdown-divider"></div>
                                    <form action="/logout" method="POST" class="dropdown-form">
                                        <input type="hidden" name="_token" value="{{ csrf_token }}">
                                        <button type="submit" class="dropdown-item logout-item">
                                            <svg class="dropdown-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                            </svg>
                                            Logout
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% else %}
                            <a href="/login" class="btn btn-primary sign-in-btn">
                                <span class="btn-icon">🔐</span>
                                Sign In
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- Primary Navigation Bar -->
            <div class="header-primary-nav">
                <div class="nav-menu">
                    <a href="/" class="nav-link {{ is_current_page('/') ? 'active' : '' }}">Home</a>
                    <a href="/pages" class="nav-link {{ is_current_page('/pages') ? 'active' : '' }}">Browse</a>
                    <a href="/about" class="nav-link {{ is_current_page('/about') ? 'active' : '' }}">About</a>
                    <a href="/islamic-sciences" class="nav-link {{ is_current_page('/islamic-sciences') ? 'active' : '' }}">Sciences</a>
                </div>
            </div>
        </div>
        
        <div class="container">
            <!-- Content will be rendered here -->
        </div>
        
        <footer class="footer">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>IslamWiki</h3>
                    <p>Your comprehensive source for Islamic knowledge and community.</p>
                </div>
                <div class="footer-section">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="/pages">Browse Pages</a></li>
                        <li><a href="/quran">Quran</a></li>
                        <li><a href="/hadith">Hadith</a></li>
                        <li><a href="/community">Community</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Resources</h4>
                    <ul>
                        <li><a href="/prayer-times">Prayer Times</a></li>
                        <li><a href="/calendar">Islamic Calendar</a></li>
                        <li><a href="/islamic-sciences">Islamic Sciences</a></li>
                        <li><a href="/about">About</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="/help">Help Center</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                        <li><a href="/privacy">Privacy Policy</a></li>
                        <li><a href="/terms">Terms of Service</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 IslamWiki. All rights reserved.</p>
            </div>
        </footer>
    {% endif %}
    
    <!-- Skin JavaScript -->
    {% if skin_js %}
        <script>{{ skin_js|raw }}</script>
    {% endif %}
    
    {% block scripts %}{% endblock %}
</body>
</html> 