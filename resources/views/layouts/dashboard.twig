<!DOCTYPE html>
<html lang="{{ current_language|default('en') }}" dir="{{ current_language|default('en') in ['ar', 'ur', 'fa', 'he'] ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ __('dashboard.title') }}{% endblock %}</title>
    
    <!-- Safa CSS Framework -->
    <link rel="stylesheet" href="/assets/css/safa.css">
    
    <!-- Bismillah Skin CSS -->
    <link rel="stylesheet" href="/skins/Bismillah/css/bismillah.css">
    
    <!-- Dashboard CSS -->
    <style>
        :root {
            --islamic-green: #2d5016;
            --islamic-gold: #d4af37;
            --islamic-dark-green: #1a3009;
            --islamic-light-green: #4a8029;
            --islamic-cream: #f8f6f0;
            --islamic-white: #ffffff;
            --text-primary: #2c3e50;
            --text-secondary: #666;
            --text-light: #999;
            --border-light: #e9ecef;
            --shadow: 0 4px 6px rgba(0,0,0,0.07);
            --shadow-hover: 0 8px 25px rgba(0,0,0,0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Arial', sans-serif;
            background: var(--islamic-cream);
            color: var(--text-primary);
            line-height: 1.6;
        }

        .dashboard-container {
            display: flex;
            min-height: calc(100vh - 200px); /* Account for header and footer */
            margin-top: 0;
        }

        /* Islamic Pattern Background */
        .islamic-pattern {
            background-image: 
                radial-gradient(circle at 25% 25%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 75% 75%, rgba(45, 80, 22, 0.05) 0%, transparent 50%);
        }

        /* Sidebar */
        .sidebar {
            width: 300px;
            background: var(--islamic-green);
            border-right: 1px solid var(--islamic-dark-green);
            box-shadow: var(--shadow);
            overflow-y: auto;
            position: sticky;
            top: 200px; /* Position below the global header */
            height: calc(100vh - 200px);
            z-index: 1000;
        }

        .sidebar-header {
            padding: 1.5rem 1.5rem;
            border-bottom: 1px solid var(--islamic-dark-green);
            background: var(--islamic-green);
            color: var(--islamic-white);
        }

        .user-info {
            margin-top: 0;
            padding: 16px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .user-role {
            font-size: 11px;
            font-weight: 600;
            color: var(--islamic-gold);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .user-islamic-role {
            font-size: 10px;
            font-weight: 500;
            color: var(--islamic-gold);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            opacity: 0.8;
            margin-bottom: 0;
        }

        .user-name {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--islamic-white);
        }

        .user-current-role {
            font-size: 12px;
            font-weight: 500;
            color: var(--islamic-gold);
            opacity: 0.9;
        }

        .nav-menu {
            padding: 20px 0;
        }

        .nav-section {
            margin-bottom: 25px;
        }

        .nav-section-title {
            padding: 0 20px 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.9;
            font-weight: 600;
            color: var(--islamic-gold);
            margin-top: 20px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: var(--islamic-white);
            text-decoration: none;
            transition: all 0.3s ease;
            position: relative;
            font-weight: 500;
            border-radius: 8px;
            margin: 0 12px 4px 12px;
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(255, 255, 255, 0.1);
            padding-left: 24px;
            border-left: 3px solid var(--islamic-gold);
        }

        .nav-item.active {
            background: rgba(255, 255, 255, 0.15);
            font-weight: 600;
        }

        .nav-icon {
            width: 20px;
            height: 20px;
            margin-right: 14px;
            opacity: 0.9;
        }

        .nav-badge {
            background: var(--islamic-gold);
            color: var(--islamic-dark-green);
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 700;
            margin-left: auto;
        }

        /* Main Content */
        .main-content {
            margin-left: 300px;
            padding: 0;
            width: calc(100% - 300px);
            background: var(--islamic-cream);
            min-height: calc(100vh - 200px); /* Account for header and footer */
        }

        .header {
            background: var(--islamic-white);
            padding: 20px 30px;
            border-bottom: 3px solid var(--islamic-gold);
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow);
            position: sticky;
            top: 200px; /* Position below the global header */
            z-index: 100;
        }

        .header-left h1 {
            font-size: 32px;
            font-weight: 700;
            color: var(--islamic-green);
            margin-bottom: 5px;
        }

        .header-subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .islamic-date {
            text-align: right;
            font-size: 13px;
        }

        .hijri-date {
            color: var(--islamic-green);
            font-weight: 600;
        }

        .gregorian-date {
            color: var(--text-secondary);
            margin-top: 2px;
        }

        .search-box {
            position: relative;
        }

        .search-box input {
            padding: 12px 45px 12px 20px;
            border: 2px solid var(--border-light);
            border-radius: 25px;
            width: 350px;
            font-size: 14px;
            transition: all 0.3s ease;
            background: var(--islamic-white);
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--islamic-gold);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
        }

        .notifications {
            position: relative;
            cursor: pointer;
            padding: 12px;
            border-radius: 50%;
            background: var(--islamic-cream);
            transition: background 0.3s ease;
        }

        .notifications:hover {
            background: var(--islamic-gold);
            color: var(--islamic-white);
        }

        .notification-badge {
            position: absolute;
            top: 5px;
            right: 5px;
            background: #e74c3c;
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        /* Content Area */
        .content-area {
            padding: 40px;
        }

        /* Dashboard Content Styles */
        .islamic-greeting {
            text-align: center;
            padding: 50px 30px;
            margin-bottom: 40px;
            background: linear-gradient(135deg, var(--islamic-green), var(--islamic-dark-green));
            color: var(--islamic-white);
            border-radius: 15px;
            box-shadow: var(--shadow);
        }

        .greeting-arabic {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 15px;
            color: var(--islamic-gold);
        }

        .greeting-text {
            font-size: 18px;
            opacity: 0.9;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--islamic-white);
            padding: 30px;
            border-radius: 15px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
            border-color: var(--islamic-gold);
        }

        .stat-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 15px;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--islamic-green), var(--islamic-light-green));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--islamic-white);
        }

        .stat-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--islamic-green);
            margin-bottom: 8px;
        }

        .stat-change {
            font-size: 12px;
            font-weight: 600;
        }

        .stat-change.positive {
            color: #27ae60;
        }

        .stat-change.negative {
            color: #e74c3c;
        }

        .islamic-content-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 40px;
        }

        .content-category {
            background: var(--islamic-white);
            padding: 35px 25px;
            border-radius: 15px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            transition: all 0.3s ease;
            text-align: center;
        }

        .content-category:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-hover);
            border-color: var(--islamic-gold);
        }

        .category-icon {
            font-size: 48px;
            margin-bottom: 15px;
        }

        .category-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--islamic-green);
            margin-bottom: 10px;
        }

        .category-count {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 15px;
        }

        .category-progress {
            height: 6px;
            background: var(--border-light);
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--islamic-gold), var(--islamic-green));
            border-radius: 3px;
            transition: width 0.3s ease;
            }

        .activity-section {
            background: var(--islamic-white);
            border-radius: 15px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            overflow: hidden;
            margin-bottom: 40px;
        }

        .activity-header {
            padding: 20px 25px;
            background: linear-gradient(135deg, var(--islamic-green), var(--islamic-dark-green));
            color: var(--islamic-white);
            border-bottom: 1px solid var(--islamic-dark-green);
        }

        .activity-title {
            font-size: 18px;
            font-weight: 600;
            margin: 0;
        }

        .activity-list {
            padding: 0;
            margin: 0;
            list-style: none;
        }

        .activity-item {
            display: flex;
            align-items: center;
            padding: 20px 25px;
            border-bottom: 1px solid var(--border-light);
            transition: background 0.3s ease;
        }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-item:hover {
            background: rgba(45, 80, 22, 0.05);
            }

        .activity-avatar {
            width: 40px;
            height: 40px;
            background: var(--islamic-gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--islamic-dark-green);
            font-weight: 700;
            margin-right: 15px;
        }

        .activity-content {
            flex: 1;
        }

        .activity-action {
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        .activity-target {
            color: var(--islamic-green);
            text-decoration: none;
            font-weight: 500;
            }

        .activity-target:hover {
            text-decoration: underline;
        }

        .activity-description {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 5px;
        }

        .activity-time {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: var(--text-light);
        }

        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 12px;
                padding: 15px 20px;
            background: var(--islamic-white);
            border: 2px solid var(--border-light);
            border-radius: 10px;
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            }

        .action-btn:hover {
            border-color: var(--islamic-gold);
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .action-btn.secondary {
            background: var(--islamic-cream);
            border-color: var(--islamic-gold);
        }

        .action-btn.tertiary {
            background: linear-gradient(135deg, var(--islamic-green), var(--islamic-light-green));
            color: var(--islamic-white);
            border-color: var(--islamic-green);
        }

        .action-icon {
            width: 20px;
            height: 20px;
        }

        /* Dashboard Content Layout */
        .dashboard-content {
            padding: 0;
            width: 100%;
        }

        /* Welcome Header */
        .welcome-header {
            background: linear-gradient(135deg, var(--islamic-green), var(--islamic-dark-green));
            color: var(--islamic-white);
            padding: 40px 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow);
        }

        .welcome-content h1 {
            font-size: 32px;
            font-weight: 700;
            margin: 0 0 10px 0;
            color: var(--islamic-white);
        }

        .welcome-content p {
            font-size: 16px;
            opacity: 0.9;
            margin: 0;
        }

        .welcome-date {
            text-align: right;
        }

        .hijri-date {
            font-size: 18px;
            font-weight: 600;
            color: var(--islamic-gold);
            margin-bottom: 5px;
        }

        .gregorian-date {
            font-size: 14px;
            opacity: 0.8;
        }

        /* Statistics Row */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card.primary {
            background: var(--islamic-white);
            padding: 25px;
            border-radius: 15px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .stat-card.primary:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
            border-color: var(--islamic-gold);
        }

        .stat-card.primary .stat-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--islamic-green), var(--islamic-dark-green));
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--islamic-white);
            flex-shrink: 0;
        }

        .stat-card.primary .stat-content {
            flex: 1;
        }

        .stat-card.primary .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--islamic-green);
            margin-bottom: 5px;
        }

        .stat-card.primary .stat-label {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .stat-card.primary .stat-change {
            font-size: 12px;
            font-weight: 600;
        }

        .stat-change.positive {
            color: #27ae60;
        }

        /* Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 30px;
        }

        .content-column {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        /* Content Cards */
        .content-card {
            background: var(--islamic-white);
            border-radius: 15px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .content-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-hover);
            border-color: var(--islamic-gold);
        }

        .content-card .card-header {
            padding: 25px 25px 20px 25px;
            background: linear-gradient(135deg, var(--islamic-green), var(--islamic-dark-green));
            color: var(--islamic-white);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .content-card .card-header h3 {
            margin: 0;
            font-size: 18px;
            font-weight: 600;
        }

        .content-card .card-icon {
            font-size: 20px;
            opacity: 0.8;
        }

        /* Quick Actions */
        .quick-actions-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            padding: 25px;
        }

        .action-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px 15px;
            background: var(--islamic-cream);
            border-radius: 12px;
            text-decoration: none;
            color: var(--islamic-dark-green);
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }

        .action-btn:hover {
            background: var(--islamic-gold);
            color: var(--islamic-white);
            transform: translateY(-2px);
            border-color: var(--islamic-gold);
        }

        .action-icon {
                font-size: 24px;
            margin-bottom: 10px;
            }

        .action-text {
            font-size: 14px;
            font-weight: 600;
            text-align: center;
        }

        /* Recent Activity */
        .activity-list {
            padding: 0 25px 25px 25px;
        }

        .activity-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            padding: 15px 0;
            border-bottom: 1px solid var(--border-light);
        }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-avatar {
            width: 40px;
            height: 40px;
            background: var(--islamic-cream);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .activity-content {
            flex: 1;
        }

        .activity-text {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 5px;
            line-height: 1.4;
        }

        .activity-meta {
            font-size: 12px;
            color: var(--text-secondary);
        }

        /* Content Overview */
        .overview-grid {
            padding: 25px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .overview-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            background: var(--islamic-cream);
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .overview-item:hover {
            background: var(--islamic-gold);
            color: var(--islamic-white);
        }

        .overview-icon {
            font-size: 24px;
            width: 40px;
            text-align: center;
        }

        .overview-content {
            flex: 1;
        }

        .overview-title {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .overview-count {
            font-size: 12px;
            opacity: 0.8;
            margin-bottom: 8px;
        }

        .overview-progress {
            height: 6px;
            background: rgba(0, 0, 0, 0.1);
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--islamic-gold), var(--islamic-green));
            border-radius: 3px;
            transition: width 0.3s ease;
        }

        /* System Status */
        .status-list {
            padding: 0 25px 25px 25px;
        }

        .status-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px 0;
            border-bottom: 1px solid var(--border-light);
        }

        .status-item:last-child {
            border-bottom: none;
        }

        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .status-indicator.online {
            background: #27ae60;
            box-shadow: 0 0 0 3px rgba(39, 174, 96, 0.2);
        }

        .status-content {
            flex: 1;
        }

        .status-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 3px;
        }

        .status-detail {
            font-size: 12px;
            color: var(--text-secondary);
        }

        /* Responsive Design */
        @media (max-width: 1200px) {
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .content-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .welcome-header {
                flex-direction: column;
                text-align: center;
                gap: 20px;
            }
            
            .stats-row {
                grid-template-columns: 1fr;
            }
            
            .quick-actions-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

    {% block head %}{% endblock %}
</head>
<body class="islamic-pattern">
    <!-- Top Bar with Islamic Info -->
    <div class="bismillah-top-bar">
        <div class="bismillah-top-bar-content">
            <div class="bismillah-islamic-info">
                <div class="bismillah-prayer-info">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
                    </svg>
