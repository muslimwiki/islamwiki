{% extends "layouts/app.twig" %}

{% block title %}{% block dashboard_title %}{{ __('dashboard.title') }}{% endblock %}{% endblock %}

{% block content %}
<!-- Dashboard-specific content starts here -->
<div class="dashboard dashboard-container">
    <!-- Islamic Pattern Background -->
    <div class="islamic-pattern"></div>
    
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2>Dashboard</h2>
        </div>
        
        <div class="user-info">
            <div class="user-role">{{ user.is_admin ? 'Admin' : 'User' }}</div>
            <div class="user-islamic-role">{{ user.is_admin ? 'Administrator' : 'Regular User' }}</div>
            <div class="user-name">{{ user.username }}</div>
        </div>
        
        <nav class="sidebar-nav">
            <ul class="nav-list">
                <li class="nav-item">
                    <a href="/dashboard" class="nav-link">
                        <span class="nav-icon">📊</span>
                        Overview
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/profile" class="nav-link">
                        <span class="nav-icon">👤</span>
                        Profile
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/settings" class="nav-link">
                        <span class="nav-icon">⚙️</span>
                        Settings
                    </a>
                </li>
                {% if user.is_admin %}
                <li class="nav-item">
                    <a href="/admin" class="nav-link">
                        <span class="nav-icon">🔧</span>
                        Admin Panel
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/admin/users" class="nav-link">
                        <span class="nav-icon">👥</span>
                        User Management
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/admin/extensions" class="nav-link">
                        <span class="nav-icon">🔌</span>
                        Extensions
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/admin/system" class="nav-link">
                        <span class="nav-icon">⚙️</span>
                        System Settings
                    </a>
                </li>
                {% endif %}
            </ul>
        </nav>
    </aside>
    
    <!-- Main Content Area -->
    <main class="main-content">
        {% block dashboard_content %}
        <!-- Dashboard content will be inserted here by child templates -->
        {% endblock %}
    </main>
</div>
{% endblock %} 