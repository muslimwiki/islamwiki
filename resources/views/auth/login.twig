{% extends 'layouts/auth.twig' %}

{% block title %}Log in - IslamWiki{% endblock %}

{% block content %}
    <div class="login-page">
        <div class="login-container">
            <div class="login-header">
                <div class="login-icon">
                    <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                </div>
                <h2 class="login-title">
                    Welcome back
                </h2>
                <p class="login-subtitle">
                    Sign in to your IslamWiki account
                </p>
            </div>

            <div class="login-form-container">
                {% if error %}
                    <div class="alert alert-danger">
                        <div class="alert-content">
                            <svg class="alert-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                            </svg>
                            <p class="alert-text">{{ error }}</p>
                        </div>
                    </div>
                {% endif %}

                <form class="login-form" action="/login" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token }}">
                    
                    <div class="form-group">
                        <label for="username" class="form-label">
                            Username or email
                        </label>
                        <div class="input-wrapper">
                            <div class="input-icon">
                                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                            </div>
                            <input id="username" name="username" type="text" required
                                   class="form-control input-with-icon"
                                   placeholder="Enter your username or email">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">
                            Password
                        </label>
                        <div class="input-wrapper">
                            <div class="input-icon">
                                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                </svg>
                            </div>
                            <input id="password" name="password" type="password" autocomplete="current-password" required
                                   class="form-control input-with-icon"
                                   placeholder="Enter your password">
                        </div>
                    </div>

                    <div class="form-options">
                        <div class="checkbox-group">
                            <input id="remember" name="remember" type="checkbox" class="form-checkbox">
                            <label for="remember" class="checkbox-label">
                                Remember me
                            </label>
                        </div>

                        <div class="forgot-link">
                            <a href="/forgot-password" class="link">
                                Forgot your password?
                            </a>
                        </div>
                    </div>

                    <div class="form-submit">
                        <button type="submit" class="btn btn-primary btn-full">
                            Sign in to your account
                        </button>
                    </div>
                </form>

                <div class="social-login">
                    <div class="divider">
                        <span class="divider-text">Or continue with</span>
                    </div>

                    <div class="social-buttons">
                        <a href="#" class="social-btn">
                            <svg class="social-icon" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
                            </svg>
                            <span>Sign in with Google</span>
                        </a>
                        
                        <a href="#" class="social-btn">
                            <svg class="social-icon" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.699 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.14 18.25 20 14.45 20 10.017 20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
                            </svg>
                            <span>Sign in with GitHub</span>
                        </a>
                    </div>
                </div>
                
                <div class="login-footer">
                    <p class="footer-text">
                        Don't have an account? 
                        <a href="/register" class="link">
                            Create one now
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .login-page {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--primary-color, #667eea) 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        position: relative;
        overflow: hidden;
    }
    
    .login-page::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(45deg, #667eea, #764ba2, #f093fb, #f5576c);
        background-size: 400% 400%;
        animation: gradientShift 15s ease infinite;
        opacity: 0.1;
    }
    
    .login-container {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 400px;
    }
    
    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    
    .login-icon {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
    }
    
    .login-icon .icon {
        width: 32px;
        height: 32px;
        color: white;
    }
    
    .login-title {
        font-size: 2rem;
        font-weight: 700;
        color: white;
        margin: 0 0 0.5rem 0;
    }
    
    .login-subtitle {
        color: rgba(255, 255, 255, 0.8);
        margin: 0;
    }
    
    .login-form-container {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    
    .login-form {
        margin-bottom: 1.5rem;
    }
    
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-label {
        display: block;
        font-weight: 600;
        color: var(--text-primary, #1f2937);
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
    }
    
    .input-wrapper {
        position: relative;
    }
    
    .input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-secondary, #6b7280);
        pointer-events: none;
    }
    
    .input-icon .icon {
        width: 20px;
        height: 20px;
    }
    
    .input-with-icon {
        padding-left: 3rem;
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        transition: all 0.3s ease;
    }
    
    .input-with-icon:focus {
        border-color: var(--primary-color, #667eea);
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        background: rgba(255, 255, 255, 1);
    }
    
    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }
    
    .checkbox-group {
        display: flex;
        align-items: center;
    }
    
    .form-checkbox {
        width: 1rem;
        height: 1rem;
        margin-right: 0.5rem;
        accent-color: var(--primary-color, #667eea);
    }
    
    .checkbox-label {
        font-size: 0.875rem;
        color: var(--text-primary, #1f2937);
    }
    
    .forgot-link {
        font-size: 0.875rem;
    }
    
    .link {
        color: var(--primary-color, #667eea);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s ease;
    }
    
    .link:hover {
        color: var(--primary-hover, #4338ca);
    }
    
    .btn-full {
        width: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        transition: all 0.3s ease;
        border-radius: 12px;
        padding: 0.75rem 1rem;
    }
    
    .btn-full:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 35px rgba(102, 126, 234, 0.5);
    }
    
    .social-login {
        margin-top: 2rem;
    }
    
    .divider {
        position: relative;
        text-align: center;
        margin: 1.5rem 0;
    }
    
    .divider::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background: var(--border-color, #e5e7eb);
    }
    
    .divider-text {
        background: rgba(255, 255, 255, 0.8);
        padding: 0 1rem;
        color: var(--text-secondary, #6b7280);
        font-size: 0.875rem;
        font-weight: 500;
    }
    
    .social-buttons {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1rem;
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        color: var(--text-primary, #1f2937);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.3s ease;
        min-width: 220px;
    }
    
    .social-btn:hover {
        background: rgba(255, 255, 255, 1);
        border-color: var(--primary-color, #667eea);
        transform: translateY(-1px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        text-decoration: none;
        color: var(--text-primary, #1f2937);
    }
    
    .social-icon {
        width: 14px;
        height: 14px;
        margin-right: 0.5rem;
        flex-shrink: 0;
    }
    
    .login-footer {
        text-align: center;
        margin-top: 2rem;
    }
    
    .footer-text {
        font-size: 0.875rem;
        color: var(--text-secondary, #6b7280);
        margin: 0;
    }
    
    @keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    
    @media (max-width: 480px) {
        .login-form-container {
            padding: 1.5rem;
        }
        
        .login-title {
            font-size: 1.75rem;
        }
    }
</style>
{% endblock %}
