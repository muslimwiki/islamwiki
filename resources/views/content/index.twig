{% extends "layouts/app.twig" %}

{% block title %}Islamic Content - IslamWiki{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Islamic Content</h1>
        <p class="text-gray-600">Discover and explore Islamic knowledge and resources</p>
    </div>

    <!-- Search Bar -->
    <div class="mb-8">
        <form action="/content/search" method="GET" class="max-w-2xl">
            <div class="relative">
                <input type="text" name="q" placeholder="Search Islamic content..." 
                       class="w-full px-4 py-3 pl-12 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                       value="{{ search_query|default('') }}">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
                <button type="submit" class="absolute inset-y-0 right-0 px-4 py-2 bg-green-600 text-white rounded-r-lg hover:bg-green-700">
                    Search
                </button>
            </div>
        </form>
    </div>

    <!-- Categories Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
        <a href="/content/category/quran" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow duration-200 border-l-4 border-green-500">
            <div class="flex items-center">
                <div class="p-3 rounded-full bg-green-100 text-green-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <h3 class="text-lg font-semibold text-gray-900">Quran & Tafsir</h3>
                    <p class="text-gray-600">{{ categories.quran.count|default(0) }} articles</p>
                </div>
            </div>
        </a>

        <a href="/content/category/hadith" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow duration-200 border-l-4 border-blue-500">
            <div class="flex items-center">
                <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <h3 class="text-lg font-semibold text-gray-900">Hadith Collections</h3>
                    <p class="text-gray-600">{{ categories.hadith.count|default(0) }} articles</p>
                </div>
            </div>
        </a>

        <a href="/content/category/fiqh" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow duration-200 border-l-4 border-purple-500">
            <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <h3 class="text-lg font-semibold text-gray-900">Islamic Law (Fiqh)</h3>
                    <p class="text-gray-600">{{ categories.fiqh.count|default(0) }} articles</p>
                </div>
            </div>
        </a>

        <a href="/content/category/history" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow duration-200 border-l-4 border-orange-500">
            <div class="flex items-center">
                <div class="p-3 rounded-full bg-orange-100 text-orange-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <h3 class="text-lg font-semibold text-gray-900">Islamic History</h3>
                    <p class="text-gray-600">{{ categories.history.count|default(0) }} articles</p>
                </div>
            </div>
        </a>

        <a href="/content/category/spirituality" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow duration-200 border-l-4 border-indigo-500">
            <div class="flex items-center">
                <div class="p-3 rounded-full bg-indigo-100 text-indigo-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <h3 class="text-lg font-semibold text-gray-900">Spirituality</h3>
                    <p class="text-gray-600">{{ categories.spirituality.count|default(0) }} articles</p>
                </div>
            </div>
        </a>

        <a href="/content/category/contemporary" class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow duration-200 border-l-4 border-teal-500">
            <div class="flex items-center">
                <div class="p-3 rounded-full bg-teal-100 text-teal-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <h3 class="text-lg font-semibold text-gray-900">Contemporary Issues</h3>
                    <p class="text-gray-600">{{ categories.contemporary.count|default(0) }} articles</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Featured Content -->
    <div class="mb-8">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Featured Content</h2>
        
        {% if featured_content|length > 0 %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for content in featured_content %}
                <div class="bg-white rounded-lg shadow-md overflow-hidden">
                    {% if content.image %}
                        <img src="{{ content.image }}" alt="{{ content.title }}" class="w-full h-48 object-cover">
                    {% endif %}
                    <div class="p-6">
                        <div class="flex items-center mb-2">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                {{ content.category }}
                            </span>
                            <span class="ml-2 text-sm text-gray-500">{{ content.read_time }} min read</span>
                        </div>
                        <h3 class="text-lg font-semibold text-gray-900 mb-2">
                            <a href="/content/{{ content.id }}" class="hover:text-green-600">{{ content.title }}</a>
                        </h3>
                        <p class="text-gray-600 text-sm mb-4">{{ content.excerpt }}</p>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center">
                                <div class="w-6 h-6 bg-gray-200 rounded-full"></div>
                                <span class="ml-2 text-sm text-gray-600">{{ content.author }}</span>
                            </div>
                            <span class="text-sm text-gray-500">{{ content.published_date }}</span>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-8">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900">No featured content</h3>
                <p class="mt-1 text-sm text-gray-500">Check back later for featured Islamic content.</p>
            </div>
        {% endif %}
    </div>

    <!-- Recent Articles -->
    <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold text-gray-900">Recent Articles</h2>
            <a href="/content/search" class="text-green-600 hover:text-green-800 text-sm font-medium">View all</a>
        </div>
        
        {% if recent_articles|length > 0 %}
            <div class="space-y-4">
                {% for article in recent_articles %}
                <div class="bg-white rounded-lg shadow-md p-6">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <div class="flex items-center mb-2">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    {{ article.category }}
                                </span>
                                <span class="ml-2 text-sm text-gray-500">{{ article.published_date }}</span>
                            </div>
                            <h3 class="text-lg font-semibold text-gray-900 mb-2">
                                <a href="/content/{{ article.id }}" class="hover:text-green-600">{{ article.title }}</a>
                            </h3>
                            <p class="text-gray-600 text-sm mb-3">{{ article.excerpt }}</p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <div class="w-6 h-6 bg-gray-200 rounded-full"></div>
                                    <span class="ml-2 text-sm text-gray-600">{{ article.author }}</span>
                                </div>
                                <div class="flex items-center space-x-4 text-sm text-gray-500">
                                    <span>{{ article.views }} views</span>
                                    <span>{{ article.read_time }} min read</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-8">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900">No recent articles</h3>
                <p class="mt-1 text-sm text-gray-500">Check back later for new Islamic content.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %} 