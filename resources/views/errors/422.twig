<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>422 Unprocessable Entity - IslamWiki</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="error-header">
            <span class="error-icon">📝</span>
            <h1 class="error-code">422</h1>
            <h2 class="error-title">Unprocessable Entity</h2>
            <p class="error-message">The request was well-formed but contains invalid data that cannot be processed.</p>
        </div>

        <div class="error-content">
            {% if validation_errors is defined and validation_errors %}
                <div class="validation-errors">
                    <h3>Validation Errors</h3>
                    <ul>
                        {% for field, errors in validation_errors %}
                            {% for error in errors %}
                                <li><strong>{{ field }}:</strong> {{ error }}</li>
                            {% endfor %}
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
            
            <div class="info-grid">
                <div class="info-card">
                    <h3>Request Information</h3>
                    <div class="info-item">
                        <span class="info-label">URL:</span>
                        <span class="info-value" title="{{ request_uri|default('Unknown') }}">{{ request_uri|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Method:</span>
                        <span class="info-value">{{ request_method|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">IP Address:</span>
                        <span class="info-value">{{ request_ip|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">User Agent:</span>
                        <span class="info-value" title="{{ request_user_agent|default('Unknown') }}">{{ request_user_agent|default('Unknown')|length > 50 ? request_user_agent|default('Unknown')|slice(0, 50) ~ '...' : request_user_agent|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Timestamp:</span>
                        <span class="info-value">{{ timestamp|default('Unknown') }}</span>
                    </div>
                </div>
                
                <div class="info-card">
                    <h3>Form Data</h3>
                    <div class="info-item">
                        <span class="info-label">Content Type:</span>
                        <span class="info-value">{{ content_type|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Data Size:</span>
                        <span class="info-value">{{ data_size|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Validation Rules:</span>
                        <span class="info-value">{{ validation_rules|default('Not available') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Failed Fields:</span>
                        <span class="info-value">{{ failed_fields|default('None') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Error Count:</span>
                        <span class="info-value">{{ error_count|default('0') }}</span>
                    </div>
                </div>
            </div>
            
            <div class="suggestions">
                <h3>What you can do:</h3>
                <ul>
                    <li>Check the form data for any typos or invalid entries</li>
                    <li>Ensure all required fields are filled out</li>
                    <li>Verify the data format matches the expected requirements</li>
                    <li>Try submitting the form again with corrected data</li>
                    <li>Contact support if you continue to have issues</li>
                </ul>
            </div>
            
            <div class="actions">
                <a href="javascript:history.back()" class="btn btn-primary">⬅️ Go Back</a>
                <a href="javascript:location.reload()" class="btn">🔄 Try Again</a>
                <a href="{{ url('/help') }}" class="btn btn-secondary">❓ Help Center</a>
                <a href="{{ url('/contact') }}" class="btn btn-secondary">📧 Contact Support</a>
            </div>
            
            {% if debug %}
                <div class="debug-info">
                    <h3>🐛 Debug Information</h3>
                    
                    {% if exception is defined and exception %}
                        <h4>🚨 Exception Details</h4>
                        <p><strong>Type:</strong> {{ exception.class|default('Unknown') }}</p>
                        <p><strong>Message:</strong> {{ exception.message|default('Unknown') }}</p>
                        <p><strong>File:</strong> {{ exception.file|default('Unknown') }}</p>
                        <p><strong>Line:</strong> {{ exception.line|default('Unknown') }}</p>
                        <p><strong>Code:</strong> {{ exception.code|default('Unknown') }}</p>
                        
                        {% if exception.trace is defined and exception.trace %}
                            <h4>📚 Stack Trace</h4>
                            <pre>{{ exception.trace|default('No stack trace available') }}</pre>
                        {% endif %}
                    {% endif %}
                    
                    <h4>📝 Validation Context</h4>
                    <p><strong>Validation Method:</strong> {{ validation_method|default('Not specified') }}</p>
                    <p><strong>Custom Rules:</strong> {{ custom_rules|default('None') }}</p>
                    <p><strong>Sanitization Applied:</strong> {{ sanitization_applied|default('Unknown') }}</p>
                    <p><strong>Data Transformation:</strong> {{ data_transformation|default('None') }}</p>
                    
                    {% if form_data is defined and form_data %}
                        <h4>📋 Form Data (Sanitized)</h4>
                        <pre>{{ form_data|default('Form data not available') }}</pre>
                    {% endif %}
                    
                    <h4>⚙️ Server Environment</h4>
                    <p><strong>Error Time:</strong> {{ timestamp|default('Unknown') }}</p>
                    <p><strong>PHP Version:</strong> {{ php_version|default('Unknown') }}</p>
                    <p><strong>Server Software:</strong> {{ server_software|default('Unknown') }}</p>
                    <p><strong>Server Name:</strong> {{ server_name|default('Unknown') }}</p>
                    
                    {% if server_info is defined and server_info %}
                        <h4>🔧 Additional Server Info</h4>
                        <pre>{{ server_info|default('Server information not available') }}</pre>
                    {% endif %}
                </div>
            {% endif %}
        </div>
        
        <div class="footer">
            <p>IslamWiki - Islamic Knowledge Platform</p>
            <p>If you continue to experience issues, please contact our support team.</p>
        </div>
    </div>
</body>
</html> 