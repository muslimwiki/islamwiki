{% extends "layouts/app.twig" %}

{% block title %}500 - Internal Server Error - IslamWiki{% endblock %}

{% block content %}
<div class="error-500-container">
    <!-- Error Header -->
    <div class="error-500-header">
        <div class="error-500-icon">⚠️</div>
        <h1 class="error-500-title">500</h1>
        <h2 class="error-500-subtitle">Internal Server Error</h2>
        <p class="error-500-description">عذراً، حدث خطأ في الخادم<br>Sorry, a server error occurred</p>
    </div>

    <!-- Error Content -->
    <div class="error-500-content">
        <!-- Error Message -->
        <div class="error-500-message">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>📋 Error Information</h3>
                </div>
                <div class="error-500-card-content">
                    {% if error %}
                        <div class="error-detail">
                            <strong>Error:</strong>
                            <code class="error-code">{{ error }}</code>
                        </div>
                    {% endif %}
                    
                    <div class="error-detail">
                        <strong>Time:</strong>
                        <span>{{ "now"|date("Y-m-d H:i:s T") }}</span>
                    </div>
                    
                    <div class="error-detail">
                        <strong>Request ID:</strong>
                        <span>{{ request_id|default('Unknown') }}</span>
                    </div>
                    
                    <div class="error-detail">
                        <strong>Status Code:</strong>
                        <span class="status-badge">{{ status_code|default('500') }}</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Exception Details (if available) -->
        {% if exception %}
        <div class="error-500-exception">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>🐛 Debug Information</h3>
                </div>
                <div class="error-500-card-content">
                    <div class="exception-grid">
                        <div class="exception-item">
                            <strong>Exception Class:</strong>
                            <span>{{ exception.__class__ }}</span>
                        </div>
                        
                        <div class="exception-item">
                            <strong>File:</strong>
                            <span>{{ exception.file }}:{{ exception.line }}</span>
                        </div>
                        
                        <div class="exception-item">
                            <strong>Message:</strong>
                            <span>{{ exception.message }}</span>
                        </div>
                        
                        {% if exception.code %}
                        <div class="exception-item">
                            <strong>Error Code:</strong>
                            <span>{{ exception.code }}</span>
                        </div>
                        {% endif %}
                    </div>
                    
                    <!-- Stack Trace -->
                    <div class="stack-trace-section">
                        <details class="stack-trace-details">
                            <summary class="stack-trace-summary">
                                <span>📚 Stack Trace</span>
                                <span class="expand-icon">▼</span>
                            </summary>
                            <div class="stack-trace-content">
                                <pre class="stack-trace-code">{{ exception.traceAsString }}</pre>
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Shahid Logging Information -->
        <div class="error-500-logging">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>📊 Shahid Logging System</h3>
                </div>
                <div class="error-500-card-content">
                    <div class="logging-info">
                        <p>This error has been automatically logged through the Shahid logging system with comprehensive context.</p>
                        <p>Check the application logs for detailed debugging information.</p>
                        <div class="log-file-info">
                            <strong>Log File:</strong>
                            <code>storage/logs/application-{{ "now"|date("Y-m-d") }}.log</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Options -->
        <div class="error-500-navigation">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>🧭 Navigation Options</h3>
                </div>
                <div class="error-500-card-content">
                    <div class="navigation-grid">
                        <a href="/" class="nav-option home">
                            <i class="fas fa-home"></i>
                            <span>Home</span>
                        </a>
                        <a href="/wiki" class="nav-option wiki">
                            <i class="fas fa-book"></i>
                            <span>Wiki</span>
                        </a>
                        <a href="/search" class="nav-option search">
                            <i class="fas fa-search"></i>
                            <span>Search</span>
                        </a>
                        <a href="/dashboard" class="nav-option dashboard">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Dashboard</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Islamic Quote -->
        <div class="error-500-quote">
            <div class="islamic-quote-card">
                <div class="quote-icon">🕌</div>
                <div class="quote-content">
                    <p class="quote-text-arabic">"إِنَّ اللَّهَ مَعَ الصَّابِرِينَ"</p>
                    <p class="quote-text-english">"Indeed, Allah is with the patient."</p>
                    <p class="quote-reference">- Quran 2:153</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
