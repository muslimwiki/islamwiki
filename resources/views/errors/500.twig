{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-page">
                <h1 class="display-1 text-danger">500</h1>
                <h2 class="mb-4">خطأ في الخادم</h2>
                <h3 class="mb-4">Server Error</h3>
                
                <div class="error-message mb-4">
                    <p class="lead">عذراً، حدث خطأ في الخادم</p>
                    <p class="lead">Sorry, a server error occurred.</p>
                </div>
                
                {% if error %}
                <div class="error-details mb-4">
                    <h4>تفاصيل الخطأ:</h4>
                    <h4>Error Details:</h4>
                    <div class="alert alert-danger">
                        <code>{{ error }}</code>
                    </div>
                </div>
                {% endif %}
                
                <div class="suggestions mb-5">
                    <h4>اقتراحات:</h4>
                    <h4>Suggestions:</h4>
                    <ul class="list-unstyled">
                        <li><a href="/" class="btn btn-outline-primary m-2">🏠 الصفحة الرئيسية / Home</a></li>
                        <li><a href="/quran" class="btn btn-outline-success m-2">📖 القرآن الكريم / Quran</a></li>
                        <li><a href="/hadith" class="btn btn-outline-info m-2">📜 الحديث الشريف / Hadith</a></li>
                        <li><a href="/search" class="btn btn-outline-warning m-2">🔍 البحث / Search</a></li>
                    </ul>
                </div>
                
                <div class="arabic-text mb-4">
                    <p class="h5">"إِنَّ اللَّهَ مَعَ الصَّابِرِينَ"</p>
                    <p class="text-muted">"Indeed, Allah is with the patient."</p>
                </div>
                
                <div class="technical-info mb-4">
                    <h4>معلومات تقنية:</h4>
                    <h4>Technical Information:</h4>
                    <p class="text-muted">
                        <small>
                            Time: {{ "now"|date("Y-m-d H:i:s T") }}<br>
                            URL: {{ app.request.uri|default('Unknown') }}<br>
                            Method: {{ app.request.method|default('Unknown') }}
                        </small>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.error-page {
    padding: 3rem 0;
}

.error-page h1 {
    font-size: 8rem;
    font-weight: bold;
    color: #d32f2f;
    text-shadow: 2px 2px 4px rgba(211,47,47,0.1);
}

.error-page h2, .error-page h3 {
    color: #c62828;
}

.error-page .error-details {
    background: #fff3e0;
    padding: 1.5rem;
    border-radius: 10px;
    border: 1px solid #ffcc02;
}

.error-page .arabic-text {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    padding: 2rem;
    border-radius: 15px;
    border: 2px solid #dee2e6;
}

.error-page .arabic-text p {
    margin-bottom: 0.5rem;
}

.error-page .suggestions ul li {
    margin: 0.5rem 0;
}

.error-page .technical-info {
    background: #f8f9fa;
    padding: 1.5rem;
    border-radius: 10px;
    border: 1px solid #dee2e6;
}

.btn-outline-primary:hover, .btn-outline-success:hover, 
.btn-outline-info:hover, .btn-outline-warning:hover {
    transform: translateY(-2px);
    transition: transform 0.2s ease;
}

.alert-danger {
    background-color: #f8d7da;
    border-color: #f5c6cb;
    color: #721c24;
}
</style>
{% endblock %}
