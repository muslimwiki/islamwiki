{% extends "layouts/app.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-page">
                <h1 class="display-1 text-danger">500</h1>
                <h2 class="mb-4">خطأ في الخادم</h2>
                <h3 class="mb-4">Server Error</h3>
                
                <div class="error-message mb-4">
                    <p class="lead">عذراً، حدث خطأ في الخادم</p>
                    <p class="lead">Sorry, a server error occurred.</p>
                </div>
                
                {% if error %}
                <div class="error-details mb-4">
                    <h4>تفاصيل الخطأ:</h4>
                    <h4>Error Details:</h4>
                    <div class="alert alert-danger">
                        <code>{{ error }}</code>
                    </div>
                </div>
                {% endif %}
                
                <div class="suggestions mb-5">
                    <h4>اقتراحات:</h4>
                    <h4>Suggestions:</h4>
                    <ul class="list-unstyled">
                        <li><a href="/" class="btn btn-outline-primary m-2">🏠 الصفحة الرئيسية / Home</a></li>
                        <li><a href="/quran" class="btn btn-outline-success m-2">📖 القرآن الكريم / Quran</a></li>
                        <li><a href="/hadith" class="btn btn-outline-info m-2">📜 الحديث الشريف / Hadith</a></li>
                        <li><a href="/search" class="btn btn-outline-warning m-2">🔍 البحث / Search</a></li>
                    </ul>
                </div>
                
                <div class="arabic-text mb-4">
                    <p class="h5">"إِنَّ اللَّهَ مَعَ الصَّابِرِينَ"</p>
                    <p class="text-muted">"Indeed, Allah is with the patient."</p>
                </div>
                
                <div class="technical-info mb-4">
                    <h4>معلومات تقنية:</h4>
                    <h4>Technical Information:</h4>
                    <div class="alert alert-info">
                        <p class="text-muted mb-2">
                            <strong>Time:</strong> {{ "now"|date("Y-m-d H:i:s T") }}<br>
                            <strong>Request ID:</strong> {{ request_id|default('Unknown') }}<br>
                            <strong>Status Code:</strong> {{ status_code|default('500') }}<br>
                            <strong>URL:</strong> {{ app.request.uri|default('Unknown') }}<br>
                            <strong>Method:</strong> {{ app.request.method|default('Unknown') }}
                        </p>
                    </div>
                </div>

                {% if exception %}
                <div class="shahid-debug mb-4">
                    <h4>🐛 Shahid Debug Information:</h4>
                    <h4>معلومات التصحيح:</h4>
                    <div class="alert alert-warning">
                        <p><strong>Exception Class:</strong> {{ exception.__class__ }}</p>
                        <p><strong>File:</strong> {{ exception.file }}:{{ exception.line }}</p>
                        <p><strong>Message:</strong> {{ exception.message }}</p>
                        
                        {% if exception.code %}
                        <p><strong>Error Code:</strong> {{ exception.code }}</p>
                        {% endif %}
                        
                        <details class="mt-3">
                            <summary><strong>📚 Stack Trace (Click to expand)</strong></summary>
                            <div class="stack-trace mt-2">
                                <pre class="bg-light p-3 rounded"><code>{{ exception.traceAsString }}</code></pre>
                            </div>
                        </details>
                    </div>
                </div>
                {% endif %}

                <div class="shahid-logging mb-4">
                    <h4>📊 Shahid Logging System:</h4>
                    <h4>نظام التسجيل:</h4>
                    <div class="alert alert-success">
                        <p class="mb-2">This error has been automatically logged through the Shahid logging system with comprehensive context.</p>
                        <p class="mb-2">Check the application logs for detailed debugging information.</p>
                        <p class="mb-0"><strong>Log File:</strong> storage/logs/application-{{ "now"|date("Y-m-d") }}.log</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.error-page {
    padding: 3rem 0;
}

.error-page h1 {
    font-size: 8rem;
    font-weight: bold;
    color: #d32f2f;
    text-shadow: 2px 2px 4px rgba(211,47,47,0.1);
}

.error-page h2, .error-page h3 {
    color: #c62828;
}

.error-page .error-details {
    background: #fff3e0;
    padding: 1.5rem;
    border-radius: 10px;
    border: 1px solid #ffcc02;
}

.error-page .arabic-text {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    padding: 2rem;
    border-radius: 15px;
    border: 2px solid #dee2e6;
}

.error-page .arabic-text p {
    margin-bottom: 0.5rem;
}

.error-page .suggestions ul li {
    margin: 0.5rem 0;
}

.error-page .technical-info {
    background: #f8f9fa;
    padding: 1.5rem;
    border-radius: 10px;
    border: 1px solid #dee2e6;
}

.btn-outline-primary:hover, .btn-outline-success:hover, 
.btn-outline-info:hover, .btn-outline-warning:hover {
    transform: translateY(-2px);
    transition: transform 0.2s ease;
}

.alert-danger {
    background-color: #f8d7da;
    border-color: #f5c6cb;
    color: #721c24;
}
</style>
{% endblock %}
