<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>401 Unauthorized - IslamWiki</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="error-header">
            <span class="error-icon">🔒</span>
            <h1 class="error-code">401</h1>
            <h2 class="error-title">Authentication Required</h2>
            <p class="error-message">You need to be logged in to access this page. Please authenticate to continue.</p>
        </div>

        <div class="error-content">
            <div class="info-grid">
                <div class="info-card">
                    <h3>Request Information</h3>
                    <div class="info-item">
                        <span class="info-label">URL:</span>
                        <span class="info-value" title="{{ request_uri|default('Unknown') }}">{{ request_uri|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Method:</span>
                        <span class="info-value">{{ request_method|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">IP Address:</span>
                        <span class="info-value">{{ request_ip|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">User Agent:</span>
                        <span class="info-value" title="{{ request_user_agent|default('Unknown') }}">{{ request_user_agent|default('Unknown')|length > 50 ? request_user_agent|default('Unknown')|slice(0, 50) ~ '...' : request_user_agent|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Timestamp:</span>
                        <span class="info-value">{{ timestamp|default('Unknown') }}</span>
                    </div>
                </div>
                
                <div class="info-card">
                    <h3>Authentication Status</h3>
                    <div class="info-item">
                        <span class="info-label">Session Status:</span>
                        <span class="info-value">{{ session_status|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">User ID:</span>
                        <span class="info-value">{{ user_id|default('Not Logged In') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">User Role:</span>
                        <span class="info-value">{{ user_role|default('None') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Last Activity:</span>
                        <span class="info-value">{{ last_activity|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Required Role:</span>
                        <span class="info-value">{{ required_role|default('Any Authenticated User') }}</span>
                    </div>
                </div>
            </div>
            
            <div class="suggestions">
                <h3>What you can do:</h3>
                <ul>
                    <li>Log in to your account if you have one</li>
                    <li>Create a new account if you don't have one</li>
                    <li>Check if you have the required permissions</li>
                    <li>Contact support if you believe this is an error</li>
                    <li>Go back to the <a href="{{ url('/') }}">homepage</a></li>
                </ul>
            </div>
            
            <div class="actions">
                <a href="{{ url('/auth/login') }}" class="btn btn-success">🔑 Log In</a>
                <a href="{{ url('/auth/register') }}" class="btn">📝 Create Account</a>
                <a href="{{ url('/') }}" class="btn btn-secondary">🏠 Go to Homepage</a>
                <a href="javascript:history.back()" class="btn btn-secondary">⬅️ Go Back</a>
            </div>
            
            {% if debug %}
                <div class="debug-info">
                    <h3>🐛 Debug Information</h3>
                    
                    {% if exception is defined and exception %}
                        <h4>🚨 Exception Details</h4>
                        <p><strong>Type:</strong> {{ exception.class|default('Unknown') }}</p>
                        <p><strong>Message:</strong> {{ exception.message|default('Unknown') }}</p>
                        <p><strong>File:</strong> {{ exception.file|default('Unknown') }}</p>
                        <p><strong>Line:</strong> {{ exception.line|default('Unknown') }}</p>
                        <p><strong>Code:</strong> {{ exception.code|default('Unknown') }}</p>
                        
                        {% if exception.trace is defined and exception.trace %}
                            <h4>📚 Stack Trace</h4>
                            <pre>{{ exception.trace|default('No stack trace available') }}</pre>
                        {% endif %}
                    {% endif %}
                    
                    <h4>🔐 Authentication Context</h4>
                    <p><strong>Session ID:</strong> {{ session_id|default('Unknown') }}</p>
                    <p><strong>Session Data:</strong> {{ session_data|default('No session data') }}</p>
                    <p><strong>Authentication Guard:</strong> {{ auth_guard|default('Unknown') }}</p>
                    <p><strong>Required Permissions:</strong> {{ required_permissions|default('None specified') }}</p>
                    
                    <h4>⚙️ Server Environment</h4>
                    <p><strong>Error Time:</strong> {{ timestamp|default('Unknown') }}</p>
                    <p><strong>PHP Version:</strong> {{ php_version|default('Unknown') }}</p>
                    <p><strong>Server Software:</strong> {{ server_software|default('Unknown') }}</p>
                    <p><strong>Server Name:</strong> {{ server_name|default('Unknown') }}</p>
                    
                    {% if server_info is defined and server_info %}
                        <h4>🔧 Additional Server Info</h4>
                        <pre>{{ server_info|default('Server information not available') }}</pre>
                    {% endif %}
                </div>
            {% endif %}
        </div>
        
        <div class="footer">
            <p>IslamWiki - Islamic Knowledge Platform</p>
            <p>If you continue to experience issues, please contact our support team.</p>
        </div>
    </div>
</body>
</html>
