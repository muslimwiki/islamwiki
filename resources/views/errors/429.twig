<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>429 Too Many Requests - IslamWiki</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="error-header">
            <span class="error-icon">⏰</span>
            <h1 class="error-code">429</h1>
            <h2 class="error-title">Too Many Requests</h2>
            <p class="error-message">You've exceeded the rate limit for this resource. Please wait a moment before trying again.</p>
        </div>

        <div class="error-content">
            <div class="info-grid">
                <div class="info-card">
                    <h3>Request Information</h3>
                    <div class="info-item">
                        <span class="info-label">URL:</span>
                        <span class="info-value" title="{{ request_uri|default('Unknown') }}">{{ request_uri|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Method:</span>
                        <span class="info-value">{{ request_method|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">IP Address:</span>
                        <span class="info-value">{{ request_ip|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">User Agent:</span>
                        <span class="info-value" title="{{ request_user_agent|default('Unknown') }}">{{ request_user_agent|default('Unknown')|length > 50 ? request_user_agent|default('Unknown')|slice(0, 50) ~ '...' : request_user_agent|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Timestamp:</span>
                        <span class="info-value">{{ timestamp|default('Unknown') }}</span>
                    </div>
                </div>
                
                <div class="info-card">
                    <h3>Rate Limit Details</h3>
                    <div class="info-item">
                        <span class="info-label">Limit:</span>
                        <span class="info-value">{{ rate_limit|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Remaining:</span>
                        <span class="info-value">{{ rate_remaining|default('0') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Reset Time:</span>
                        <span class="info-value">{{ rate_reset|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Window:</span>
                        <span class="info-value">{{ rate_window|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Retry After:</span>
                        <span class="info-value">{{ retry_after|default('Unknown') }}</span>
                    </div>
                </div>
            </div>
            
            <div class="countdown">
                <h3>Time Until Reset</h3>
                <div class="countdown-timer" id="countdown-timer">
                    {{ retry_after|default('60') }}s
                </div>
                <p>Please wait until the rate limit resets before making another request.</p>
            </div>
            
            <div class="suggestions">
                <h3>What you can do:</h3>
                <ul>
                    <li>Wait for the rate limit to reset</li>
                    <li>Reduce the frequency of your requests</li>
                    <li>Use the API more efficiently</li>
                    <li>Contact support if you need higher limits</li>
                    <li>Go back to the <a href="{{ url('/') }}">homepage</a></li>
                </ul>
            </div>
            
            <div class="actions">
                <a href="{{ url('/') }}" class="btn btn-primary">🏠 Go to Homepage</a>
                <a href="javascript:location.reload()" class="btn">🔄 Try Again</a>
                <a href="javascript:history.back()" class="btn btn-secondary">⬅️ Go Back</a>
                <a href="{{ url('/help') }}" class="btn btn-secondary">❓ Help Center</a>
            </div>
            
            {% if debug %}
                <div class="debug-info">
                    <h3>🐛 Debug Information</h3>
                    
                    {% if exception is defined and exception %}
                        <h4>🚨 Exception Details</h4>
                        <p><strong>Type:</strong> {{ exception.class|default('Unknown') }}</p>
                        <p><strong>Message:</strong> {{ exception.message|default('Unknown') }}</p>
                        <p><strong>File:</strong> {{ exception.file|default('Unknown') }}</p>
                        <p><strong>Line:</strong> {{ exception.line|default('Unknown') }}</p>
                        <p><strong>Code:</strong> {{ exception.code|default('Unknown') }}</p>
                        
                        {% if exception.trace is defined and exception.trace %}
                            <h4>📚 Stack Trace</h4>
                            <pre>{{ exception.trace|default('No stack trace available') }}</pre>
                        {% endif %}
                    {% endif %}
                    
                    <h4>⏰ Rate Limiting Context</h4>
                    <p><strong>Current Requests:</strong> {{ current_requests|default('Unknown') }}</p>
                    <p><strong>Rate Limit Policy:</strong> {{ rate_limit_policy|default('Not available') }}</p>
                    <p><strong>User Tier:</strong> {{ user_tier|default('Standard') }}</p>
                    <p><strong>Throttle Key:</strong> {{ throttle_key|default('Not available') }}</p>
                    
                    <h4>⚙️ Server Environment</h4>
                    <p><strong>Error Time:</strong> {{ timestamp|default('Unknown') }}</p>
                    <p><strong>PHP Version:</strong> {{ php_version|default('Unknown') }}</p>
                    <p><strong>Server Software:</strong> {{ server_software|default('Unknown') }}</p>
                    <p><strong>Server Name:</strong> {{ server_name|default('Unknown') }}</p>
                    
                    {% if server_info is defined and server_info %}
                        <h4>🔧 Additional Server Info</h4>
                        <pre>{{ server_info|default('Server information not available') }}</pre>
                    {% endif %}
                </div>
            {% endif %}
        </div>
        
        <div class="footer">
            <p>IslamWiki - Islamic Knowledge Platform</p>
            <p>If you continue to experience issues, please contact our support team.</p>
        </div>
    </div>
    
    <script>
        // Simple countdown timer
        let timeLeft = {{ retry_after|default(60) }};
        const countdownElement = document.getElementById('countdown-timer');
        
        if (countdownElement && timeLeft > 0) {
            const timer = setInterval(() => {
                timeLeft--;
                if (timeLeft <= 0) {
                    countdownElement.textContent = 'Ready!';
                    clearInterval(timer);
                } else {
                    countdownElement.textContent = timeLeft + 's';
                }
            }, 1000);
        }
    </script>
</body>
</html> 