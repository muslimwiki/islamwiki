<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>503 Service Unavailable - IslamWiki</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="error-header">
            <span class="error-icon">🔧</span>
            <h1 class="error-code">503</h1>
            <h2 class="error-title">Service Unavailable</h2>
            <p class="error-message">We're currently performing maintenance to improve your experience. Please check back soon.</p>
        </div>

        <div class="error-content">
            <div class="maintenance-info">
                <h3>Maintenance Status</h3>
                <div class="maintenance-status">{{ maintenance_status|default('Scheduled maintenance in progress') }}</div>
                <div class="estimated-time">Estimated completion: {{ estimated_completion|default('2-3 hours') }}</div>
                <p>We apologize for the inconvenience. Our team is working hard to get everything back up and running.</p>
            </div>
            
            <div class="info-grid">
                <div class="info-card">
                    <h3>Request Information</h3>
                    <div class="info-item">
                        <span class="info-label">URL:</span>
                        <span class="info-value" title="{{ request_uri|default('Unknown') }}">{{ request_uri|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Method:</span>
                        <span class="info-value">{{ request_method|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">IP Address:</span>
                        <span class="info-value">{{ request_ip|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">User Agent:</span>
                        <span class="info-value" title="{{ request_user_agent|default('Unknown') }}">{{ request_user_agent|default('Unknown')|length > 50 ? request_user_agent|default('Unknown')|slice(0, 50) ~ '...' : request_user_agent|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Timestamp:</span>
                        <span class="info-value">{{ timestamp|default('Unknown') }}</span>
                    </div>
                </div>
                
                <div class="info-card">
                    <h3>Service Status</h3>
                    <div class="info-item">
                        <span class="info-label">Service:</span>
                        <span class="info-value">{{ service_name|default('IslamWiki') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Status:</span>
                        <span class="info-value">{{ service_status|default('Maintenance') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Start Time:</span>
                        <span class="info-value">{{ maintenance_start|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Duration:</span>
                        <span class="info-value">{{ maintenance_duration|default('Unknown') }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Reason:</span>
                        <span class="info-value">{{ maintenance_reason|default('System improvements') }}</span>
                    </div>
                </div>
            </div>
            
            <div class="suggestions">
                <h3>What you can do:</h3>
                <ul>
                    <li>Check our <a href="{{ url('/status') }}">status page</a> for updates</li>
                    <li>Follow us on social media for real-time updates</li>
                    <li>Try again in a few hours</li>
                    <li>Contact support if this is urgent</li>
                    <li>Check our <a href="{{ url('/help') }}">help center</a> for common questions</li>
                </ul>
            </div>
            
            <div class="actions">
                <a href="javascript:location.reload()" class="btn btn-success">🔄 Check Status</a>
                <a href="{{ url('/status') }}" class="btn btn-primary">📊 Status Page</a>
                <a href="{{ url('/contact') }}" class="btn">📧 Contact Support</a>
                <a href="{{ url('/help') }}" class="btn btn-secondary">❓ Help Center</a>
            </div>
            
            {% if debug %}
                <div class="debug-info">
                    <h3>🐛 Debug Information</h3>
                    
                    {% if exception is defined and exception %}
                        <h4>🚨 Exception Details</h4>
                        <p><strong>Type:</strong> {{ exception.class|default('Unknown') }}</p>
                        <p><strong>Message:</strong> {{ exception.message|default('Unknown') }}</p>
                        <p><strong>File:</strong> {{ exception.file|default('Unknown') }}</p>
                        <p><strong>Line:</strong> {{ exception.line|default('Unknown') }}</p>
                        <p><strong>Code:</strong> {{ exception.code|default('Unknown') }}</p>
                        
                        {% if exception.trace is defined and exception.trace %}
                            <h4>📚 Stack Trace</h4>
                            <pre>{{ exception.trace|default('No stack trace available') }}</pre>
                        {% endif %}
                    {% endif %}
                    
                    <h4>🔧 Maintenance Context</h4>
                    <p><strong>Maintenance Mode:</strong> {{ maintenance_mode|default('Enabled') }}</p>
                    <p><strong>Affected Services:</strong> {{ affected_services|default('All services') }}</p>
                    <p><strong>Maintenance Type:</strong> {{ maintenance_type|default('Scheduled') }}</p>
                    <p><strong>Priority:</strong> {{ maintenance_priority|default('Normal') }}</p>
                    
                    <h4>⚙️ Server Environment</h4>
                    <p><strong>Error Time:</strong> {{ timestamp|default('Unknown') }}</p>
                    <p><strong>PHP Version:</strong> {{ php_version|default('Unknown') }}</p>
                    <p><strong>Server Software:</strong> {{ server_software|default('Unknown') }}</p>
                    <p><strong>Server Name:</strong> {{ server_name|default('Unknown') }}</p>
                    
                    {% if server_info is defined and server_info %}
                        <h4>🔧 Additional Server Info</h4>
                        <pre>{{ server_info|default('Server information not available') }}</pre>
                    {% endif %}
                </div>
            {% endif %}
        </div>
        
        <div class="footer">
            <p>IslamWiki - Islamic Knowledge Platform</p>
            <p>We appreciate your patience during this maintenance period.</p>
        </div>
    </div>
</body>
</html> 