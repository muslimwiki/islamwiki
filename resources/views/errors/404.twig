{% extends "layouts/app.twig" %}

{% block title %}{{ title|default('Page Not Found') }}{% endblock %}

{% block content %}
<div class="error-500-container" data-error-type="404">
    <!-- Error Header -->
    <div class="error-500-header">
        <div class="error-500-icon">🔍</div>
        <h1 class="error-500-title">404</h1>
        <h2 class="error-500-subtitle">Page Not Found</h2>
        <p class="error-500-description">عذراً، الصفحة التي تبحث عنها غير موجودة<br>Sorry, the page you are looking for could not be found</p>
    </div>

                       <!-- Error Content -->
                   <div class="error-500-content">
                       <!-- Navigation Options - Moved below hero section -->
                       <div class="error-500-navigation">
                           <div class="error-500-card">
                               <div class="error-500-card-header">
                                   <h3>🧭 Navigation Options</h3>
                               </div>
                               <div class="error-500-card-content">
                                   <div class="navigation-grid">
                                       <a href="/wiki/Home" class="nav-option home">
                                           <i class="fas fa-home"></i>
                                           <span>Home</span>
                                       </a>
                                       <a href="/wiki" class="nav-option wiki">
                                           <i class="fas fa-book"></i>
                                           <span>Wiki</span>
                                       </a>
                                       <a href="/search" class="nav-option search">
                                           <i class="fas fa-search"></i>
                                           <span>Search</span>
                                       </a>
                                       <a href="/wiki/create" class="nav-option create">
                                           <i class="fas fa-plus"></i>
                                           <span>Create Page</span>
                                       </a>
                                   </div>
                               </div>
                           </div>
                       </div>

                       <!-- Error Message -->
                       <div class="error-500-message">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>📋 Error Information</h3>
                </div>
                <div class="error-500-card-content">
                    <div class="error-detail">
                        <strong>Time:</strong>
                        <span>{{ "now"|date("Y-m-d H:i:s T") }}</span>
                    </div>
                    
                    <div class="error-detail">
                        <strong>Request ID:</strong>
                        <span>{{ request_id|default('Unknown') }}</span>
                    </div>
                    
                    <div class="error-detail">
                        <strong>Status Code:</strong>
                        <span class="status-badge">{{ status_code|default('404') }}</span>
                    </div>
                    
                                                       <div class="error-detail">
                                       <strong>Requested URL:</strong>
                                       <span>{{ debug_info.request_info.uri|default('Unknown') }}</span>
                                   </div>
                                   
                                   <div class="error-detail">
                                       <strong>Method:</strong>
                                       <span>{{ debug_info.request_info.method|default('Unknown') }}</span>
                                   </div>
                </div>
            </div>
        </div>

        <!-- Exception Details (if available) -->
        <div class="error-500-exception">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>🐛 Debug Information</h3>
                </div>
                <div class="error-500-card-content">
                    <div class="exception-grid">
                        <div class="exception-item">
                            <strong>Exception Class:</strong>
                            <span>{{ debug_info.error_type|default('N/A') }}</span>
                        </div>
                        
                        <div class="exception-item">
                            <strong>File:</strong>
                            <span>{{ debug_info.file|default('N/A') }}:{{ debug_info.line|default('N/A') }}</span>
                        </div>
                        
                        <div class="exception-item">
                            <strong>Message:</strong>
                            <span>{{ debug_info.error_message|default('N/A') }}</span>
                        </div>
                        
                        <div class="exception-item">
                            <strong>Error Code:</strong>
                            <span>{{ debug_info.error_code|default('N/A') }}</span>
                        </div>
                    </div>
                    
                    <!-- Stack Trace -->
                    <div class="stack-trace-section">
                        <details class="stack-trace-details">
                            <summary class="stack-trace-summary">
                                <span>📚 Stack Trace</span>
                                <span class="expand-icon">▼</span>
                            </summary>
                            <div class="stack-trace-content">
                                <pre class="stack-trace-code">{{ debug_info.stack_trace|default('N/A') }}</pre>
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        </div>

        <!-- Enhanced Debug Information (if available) -->
        {% if debug_info %}
        <div class="error-500-enhanced-debug">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>🔍 Enhanced Debug Information</h3>
                </div>
                <div class="error-500-card-content">
                    <div class="enhanced-debug-section">
                        <div class="debug-header">
                            <h4>📋 Copy-Paste Debug Report</h4>
                            <button class="copy-debug-btn" onclick="copyDebugReport()">
                                <i class="fas fa-copy"></i> Copy Report
                            </button>
                        </div>
                        <p><strong>Copy the text below and paste it in your support request:</strong></p>
                        <textarea class="debug-report-textarea" id="debugReport" readonly>🐛 ENHANCED DEBUG REPORT
📅 Timestamp: {{ debug_info.timestamp|default('N/A') }}
🔍 Context: {{ debug_info.context|default('N/A') }}
❌ Error Type: {{ debug_info.error_type|default('N/A') }}
💬 Error Message: {{ debug_info.error_message|default('N/A') }}
🔢 Error Code: {{ debug_info.error_code|default('N/A') }}
📁 File: {{ debug_info.file|default('N/A') }}
📍 Line: {{ debug_info.line|default('N/A') }}

🌐 REQUEST INFORMATION
📡 Method: {{ debug_info.request_info.method|default('N/A') }}
🔗 URI: {{ debug_info.request_info.uri|default('N/A') }}
🌍 User Agent: {{ debug_info.request_info.user_agent|default('N/A') }}
🌐 Remote Address: {{ debug_info.request_info.remote_addr|default('N/A') }}
🏠 HTTP Host: {{ debug_info.request_info.http_host|default('N/A') }}

🔐 SESSION INFORMATION
🆔 Session ID: {{ debug_info.session_info.session_id|default('N/A') }}
📊 Session Status: {{ debug_info.session_info.session_status|default('N/A') }}
📝 Session Data: {{ debug_info.session_info.session_data|json_encode|default('N/A') }}
🏷️ Session Name: {{ debug_info.session_info.session_name|default('N/A') }}

🔑 AUTHENTICATION INFORMATION
✅ Auth Service Available: {{ debug_info.authentication_info.auth_service_available ? 'YES' : 'NO' }}
👤 User Data: {{ debug_info.authentication_info.user_data|json_encode|default('N/A') }}
📋 Session User Data: {{ debug_info.authentication_info.session_user_data|json_encode|default('N/A') }}
{% if debug_info.authentication_info.auth_error %}
❌ Auth Error: {{ debug_info.authentication_info.auth_error }}
{% endif %}

🗄️ DATABASE INFORMATION
✅ Database Available: {{ debug_info.database_info.database_available ? 'YES' : 'NO' }}
🔗 Connection Status: {{ debug_info.database_info.connection_status|default('N/A') }}
📊 Tables Exist: {{ debug_info.database_info.tables_exist|json_encode|default('N/A') }}
{% if debug_info.database_info.database_error %}
❌ Database Error: {{ debug_info.database_info.database_error }}
{% endif %}

📦 CONTAINER INFORMATION
✅ Container Available: {{ debug_info.container_info.container_available ? 'YES' : 'NO' }}
🔧 Services: {{ debug_info.container_info.services|json_encode|default('N/A') }}
{% if debug_info.container_info.container_error %}
❌ Container Error: {{ debug_info.container_info.container_error }}
{% endif %}

💾 MEMORY USAGE
📊 Memory Usage: {{ debug_info.memory_usage.memory_usage|default('N/A') }} bytes
📈 Memory Peak: {{ debug_info.memory_usage.memory_peak|default('N/A') }} bytes
🚫 Memory Limit: {{ debug_info.memory_usage.memory_limit|default('N/A') }}

🐘 PHP INFORMATION
📋 PHP Version: {{ debug_info.php_info.php_version|default('N/A') }}
🔧 Extensions: {{ debug_info.php_info.extensions|join(', ')|default('N/A') }}
📊 Error Reporting: {{ debug_info.php_info.error_reporting|default('N/A') }}
👁️ Display Errors: {{ debug_info.php_info.display_errors|default('N/A') }}
📝 Log Errors: {{ debug_info.php_info.log_errors|default('N/A') }}

📚 STACK TRACE
{{ debug_info.stack_trace|default('N/A') }}

🐛 END DEBUG REPORT</textarea>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}



        <!-- Logging Logging Information -->
        <div class="error-500-logging">
            <div class="error-500-card">
                <div class="error-500-card-header">
                    <h3>📊 Logging Logging System</h3>
                </div>
                <div class="error-500-card-content">
                    <div class="logging-info">
                        <p>This 404 error has been automatically logged through the Logging logging system with comprehensive context.</p>
                        <p>Check the application logs for detailed debugging information.</p>
                        <div class="log-file-info">
                            <strong>Log File:</strong>
                            <code>storage/logs/application-{{ "now"|date("Y-m-d") }}.log</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Islamic Quote -->
        <div class="error-500-quote">
            <div class="islamic-quote-card">
                <div class="quote-icon">🕌</div>
                <div class="quote-content">
                    <p class="quote-text-arabic">"إِنَّ اللَّهَ مَعَ الصَّابِرِينَ"</p>
                    <p class="quote-text-english">"Indeed, Allah is with the patient."</p>
                    <p class="quote-reference">- Quran 2:153</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function copyDebugReport() {
    const textarea = document.getElementById('debugReport');
    textarea.select();
    textarea.setSelectionRange(0, 99999); // For mobile devices
    
    try {
        document.execCommand('copy');
        
        // Show success feedback
        const btn = event.target.closest('.copy-debug-btn');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
        btn.classList.add('copied');
        
        setTimeout(() => {
            btn.innerHTML = originalText;
            btn.classList.remove('copied');
        }, 2000);
    } catch (err) {
        console.error('Failed to copy: ', err);
        
        // Fallback for modern browsers
        navigator.clipboard.writeText(textarea.value).then(() => {
            const btn = event.target.closest('.copy-debug-btn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
            btn.classList.add('copied');
            
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.remove('copied');
            }, 2000);
        });
    }
}
</script>
{% endblock %}
