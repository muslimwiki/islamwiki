{% extends "layouts/base.twig" %}

{% block title %}Deployment Dashboard - WikiExtension{% endblock %}

{% block content %}
<div class="wiki-deployment-dashboard">
    <!-- Header -->
    <div class="wiki-deployment-header">
        <h1>🚀 Deployment Dashboard</h1>
        <p class="wiki-deployment-subtitle">Phase 8: Production Deployment & Launch</p>
        <div class="wiki-deployment-status">
            <span class="status-badge status-success">Production Ready</span>
            <span class="version-badge">v0.0.2.1</span>
        </div>
    </div>

    <!-- Deployment Overview -->
    <div class="wiki-deployment-overview">
        <div class="overview-card">
            <h3>📊 Deployment Status</h3>
            <div class="status-grid">
                <div class="status-item">
                    <span class="status-label">Environment:</span>
                    <span class="status-value">{{ deployment_status.current_environment|title }}</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Version:</span>
                    <span class="status-value">{{ deployment_status.deployment_version }}</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Health:</span>
                    <span class="status-value status-{{ deployment_status.deployment_health }}">{{ deployment_status.deployment_health|title }}</span>
                </div>
                <div class="status-item">
                    <span class="status-label">Last Deploy:</span>
                    <span class="status-value">{{ deployment_status.last_deployment }}</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Performance Metrics -->
    <div class="wiki-performance-section">
        <h2>📈 Performance Metrics</h2>
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-header">
                    <h4>Page Load Time</h4>
                    <span class="metric-value">{{ "%.3f"|format(performance.current_request.execution_time) }}s</span>
                </div>
                <div class="metric-bar">
                    <div class="metric-progress" style="width: {{ (performance.current_request.execution_time / 2.0) * 100 }}%"></div>
                </div>
                <div class="metric-status {{ performance.benchmarks.page_load_time ? 'status-success' : 'status-warning' }}">
                    {{ performance.benchmarks.page_load_time ? '✅ Target Met' : '⚠️ Above Target' }}
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-header">
                    <h4>Database Queries</h4>
                    <span class="metric-value">{{ performance.current_request.database_queries }}</span>
                </div>
                <div class="metric-bar">
                    <div class="metric-progress" style="width: {{ (performance.current_request.database_queries / 20.0) * 100 }}%"></div>
                </div>
                <div class="metric-status {{ performance.benchmarks.database_queries ? 'status-success' : 'status-warning' }}">
                    {{ performance.benchmarks.database_queries ? '✅ Target Met' : '⚠️ Above Target' }}
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-header">
                    <h4>Memory Usage</h4>
                    <span class="metric-value">{{ (performance.current_request.memory_usage / 1024 / 1024)|round(1) }}MB</span>
                </div>
                <div class="metric-bar">
                    <div class="metric-progress" style="width: {{ (performance.current_request.memory_usage / (100 * 1024 * 1024)) * 100 }}%"></div>
                </div>
                <div class="metric-status {{ performance.benchmarks.memory_usage ? 'status-success' : 'status-warning' }}">
                    {{ performance.benchmarks.memory_usage ? '✅ Target Met' : '⚠️ Above Target' }}
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-header">
                    <h4>Cache Efficiency</h4>
                    <span class="metric-value">{{ (performance.current_request.cache_efficiency * 100)|round(1) }}%</span>
                </div>
                <div class="metric-bar">
                    <div class="metric-progress" style="width: {{ performance.current_request.cache_efficiency * 100 }}%"></div>
                </div>
                <div class="metric-status {{ performance.benchmarks.cache_efficiency ? 'status-success' : 'status-warning' }}">
                    {{ performance.benchmarks.cache_efficiency ? '✅ Target Met' : '⚠️ Below Target' }}
                </div>
            </div>
        </div>
    </div>

    <!-- Support System -->
    <div class="wiki-support-section">
        <h2>🆘 Support System</h2>
        <div class="support-grid">
            <div class="support-card">
                <h4>Support Tickets</h4>
                <div class="support-stats">
                    <div class="stat-item">
                        <span class="stat-label">Total:</span>
                        <span class="stat-value">{{ support.total_tickets }}</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Open:</span>
                        <span class="stat-value">{{ support.open_tickets }}</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Resolved:</span>
                        <span class="stat-value">{{ support.resolved_tickets }}</span>
                    </div>
                </div>
            </div>

            <div class="support-card">
                <h4>Priority Distribution</h4>
                <div class="support-stats">
                    <div class="stat-item">
                        <span class="stat-label">High:</span>
                        <span class="stat-value">{{ support.high_priority_tickets }}</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Critical:</span>
                        <span class="stat-value">{{ support.critical_priority_tickets }}</span>
                    </div>
                </div>
            </div>

            <div class="support-card">
                <h4>Response Time</h4>
                <div class="support-stats">
                    <div class="stat-item">
                        <span class="stat-label">Average:</span>
                        <span class="stat-value">{{ support.avg_resolution_time|round(1) }}h</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Success Metrics -->
    <div class="wiki-success-section">
        <h2>🎯 Success Metrics</h2>
        <div class="success-overview">
            <div class="success-score">
                <h3>Overall Success Score</h3>
                <div class="score-display">
                    <span class="score-value">{{ success.overall_success_score }}</span>
                    <span class="score-max">/ 100</span>
                </div>
                <div class="score-bar">
                    <div class="score-progress" style="width: {{ success.overall_success_score }}%"></div>
                </div>
                <div class="score-status">
                    {% if success.overall_success_score >= 90 %}
                        <span class="status-excellent">🌟 Excellent</span>
                    {% elseif success.overall_success_score >= 80 %}
                        <span class="status-good">✅ Good</span>
                    {% elseif success.overall_success_score >= 70 %}
                        <span class="status-fair">⚠️ Fair</span>
                    {% else %}
                        <span class="status-poor">❌ Needs Improvement</span>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if success.recommendations %}
        <div class="recommendations">
            <h4>📋 Recommendations</h4>
            <ul class="recommendation-list">
                {% for recommendation in success.recommendations %}
                <li class="recommendation-item">{{ recommendation }}</li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
    </div>

    <!-- Deployment Actions -->
    <div class="wiki-deployment-actions">
        <h2>🚀 Deployment Actions</h2>
        <div class="action-grid">
            <div class="action-card">
                <h4>Staging Deployment</h4>
                <p>Deploy to staging environment for testing</p>
                <button class="btn btn-primary" onclick="deployToStaging()">Deploy to Staging</button>
            </div>

            <div class="action-card">
                <h4>Production Deployment</h4>
                <p>Deploy to production environment</p>
                <button class="btn btn-success" onclick="deployToProduction()">Deploy to Production</button>
            </div>

            <div class="action-card">
                <h4>Rollback</h4>
                <p>Rollback to previous version if needed</p>
                <button class="btn btn-warning" onclick="rollbackDeployment()">Rollback</button>
            </div>

            <div class="action-card">
                <h4>Health Check</h4>
                <p>Check system health status</p>
                <button class="btn btn-info" onclick="checkHealth()">Health Check</button>
            </div>
        </div>
    </div>

    <!-- Real-time Monitoring -->
    <div class="wiki-monitoring-section">
        <h2>📡 Real-time Monitoring</h2>
        <div class="monitoring-grid">
            <div class="monitoring-card">
                <h4>System Health</h4>
                <div class="health-indicator">
                    <span class="health-dot health-green"></span>
                    <span class="health-text">All Systems Operational</span>
                </div>
            </div>

            <div class="monitoring-card">
                <h4>Performance</h4>
                <div class="performance-indicator">
                    <span class="performance-text">Within Benchmarks</span>
                </div>
            </div>

            <div class="monitoring-card">
                <h4>User Activity</h4>
                <div class="activity-indicator">
                    <span class="activity-text">Normal</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Deployment action functions
function deployToStaging() {
    if (confirm('Are you sure you want to deploy to staging?')) {
        fetch('/wiki/deployment/staging', { method: 'POST' })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Successfully deployed to staging!');
                    location.reload();
                } else {
                    alert('Staging deployment failed: ' + data.message);
                }
            })
            .catch(error => {
                alert('Deployment error: ' + error.message);
            });
    }
}

function deployToProduction() {
    if (confirm('Are you sure you want to deploy to production? This will affect live users.')) {
        fetch('/wiki/deployment/production', { method: 'POST' })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Successfully deployed to production!');
                    location.reload();
                } else {
                    alert('Production deployment failed: ' + data.message);
                }
            })
            .catch(error => {
                alert('Deployment error: ' + error.message);
            });
    }
}

function rollbackDeployment() {
    if (confirm('Are you sure you want to rollback the deployment? This will revert to the previous version.')) {
        fetch('/wiki/deployment/rollback', { method: 'POST' })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Successfully rolled back deployment!');
                    location.reload();
                } else {
                    alert('Rollback failed: ' + data.message);
                }
            })
            .catch(error => {
                alert('Rollback error: ' + error.message);
            });
    }
}

function checkHealth() {
    fetch('/wiki/deployment/health')
        .then(response => response.json())
        .then(data => {
            alert('System Health: ' + data.status + '\nVersion: ' + data.version + '\nTimestamp: ' + data.timestamp);
        })
        .catch(error => {
            alert('Health check error: ' + error.message);
        });
}

// Auto-refresh dashboard every 30 seconds
setInterval(() => {
    // Refresh performance metrics
    fetch('/wiki/deployment/status')
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update dashboard with new data
                console.log('Dashboard updated:', data);
            }
        })
        .catch(error => {
            console.error('Dashboard update error:', error);
        });
}, 30000);
</script>
{% endblock %} 