    }
}
</style>

<script>
function updateCompareButton() {
    const checkboxes = document.querySelectorAll('.wiki-revision-checkbox:checked');
    const compareButton = document.getElementById('compare-revisions');
    
    if (checkboxes.length === 2) {
        compareButton.disabled = false;
        compareButton.onclick = function() {
            const selectedRevisions = Array.from(checkboxes).map(cb => cb.value);
            if (selectedRevisions.length === 2) {
                const [rev1, rev2] = selectedRevisions.sort((a, b) => parseInt(a) - parseInt(b));
                window.location.href = `/wiki/{{ page.slug }}/compare/${rev1}/${rev2}`;
            }
        };
    } else {
        compareButton.disabled = true;
    }
}

// Initialize compare button state
document.addEventListener('DOMContentLoaded', function() {
    updateCompareButton();
    
    // Add click handlers for revision checkboxes
    const checkboxes = document.querySelectorAll('.wiki-revision-checkbox');
    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', updateCompareButton);
    });
});
</script>
{% endblock %}
