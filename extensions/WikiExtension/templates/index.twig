{% extends "layouts/app.twig" %}

{% block title %}Islamic Wiki - Discover Islamic Knowledge - IslamWiki{% endblock %}

{% block content %}
<!-- Wiki Hero Section -->
<section class="wiki-hero">
    <div class="wiki-hero__container">
        <div class="wiki-hero__content">
            <h1 class="wiki-hero__title">📚 Islamic Wiki</h1>
            <p class="wiki-hero__subtitle">Discover, learn, and contribute to the vast knowledge of Islamic scholarship, history, and contemporary understanding.</p>
            <p class="wiki-hero__description">Our comprehensive wiki system brings together authentic Islamic knowledge in an accessible, collaborative format.</p>
        </div>
    </div>
</section>

<!-- Search Section -->
<section class="wiki-search">
    <div class="wiki-search__container">
        <div class="wiki-search__form">
            <input type="text" class="wiki-search__input" placeholder="Search Islamic knowledge, topics, scholars, or concepts..." />
            <button class="wiki-search__button" type="button">🔍 Search</button>
        </div>
    </div>
</section>

<!-- Statistics Section -->
<section class="wiki-stats">
    <div class="wiki-stats__container">
        <div class="wiki-stats__grid">
            <div class="wiki-stats__card">
                <div class="wiki-stats__number">0</div>
                <div class="wiki-stats__label">Total Pages</div>
            </div>
            <div class="wiki-stats__card">
                <div class="wiki-stats__number">0</div>
                <div class="wiki-stats__label">Categories</div>
            </div>
            <div class="wiki-stats__card">
                <div class="wiki-stats__number">0</div>
                <div class="wiki-stats__label">Revisions</div>
            </div>
            <div class="wiki-stats__card">
                <div class="wiki-stats__number">0</div>
                <div class="wiki-stats__label">Contributors</div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Actions Section -->
<section class="wiki-actions">
    <div class="wiki-actions__container">
        <div class="wiki-actions__grid">
            <a href="/wiki/search" class="wiki-action__button wiki-action__button--primary">
                <span class="wiki-action__icon">🔍</span>
                <span class="wiki-action__text">Search Knowledge</span>
            </a>
            <a href="/wiki/create" class="wiki-action__button wiki-action__button--secondary">
                <span class="wiki-action__icon">✍️</span>
                <span class="wiki-action__text">Create New Page</span>
            </a>
            <a href="/wiki/categories" class="wiki-action__button wiki-action__button--outline">
                <span class="wiki-action__icon">📂</span>
                <span class="wiki-action__text">Browse Categories</span>
            </a>
        </div>
    </div>
</section>

<!-- Call to Action Section -->
<section class="wiki-cta">
    <div class="wiki-cta__container">
        <div class="wiki-cta__content">
            <h2 class="wiki-cta__title">🌟 Contribute to Islamic Knowledge</h2>
            <p class="wiki-cta__description">Share your knowledge, research, and insights with the global Islamic community.</p>
            <a href="/wiki/create" class="wiki-cta__button">Start Writing</a>
        </div>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script>
// Wiki-specific JavaScript
document.addEventListener('DOMContentLoaded', function() {
    // Search functionality
    const searchInput = document.querySelector('.wiki-search__input');
    const searchButton = document.querySelector('.wiki-search__button');
    
    if (searchInput && searchButton) {
        searchButton.addEventListener('click', function() {
            const query = searchInput.value.trim();
            if (query) {
                window.location.href = `/wiki/search?q=${encodeURIComponent(query)}`;
            }
        });
        
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchButton.click();
            }
        });
    }
});
</script>
{% endblock %} 