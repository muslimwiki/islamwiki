{
    "name": "WikiExtension",
    "version": "0.0.2.1",
    "description": "Unified wiki system for IslamWiki with page management, categories, and collaborative editing",
    "author": "IslamWiki Team",
    "url": "https://islamwiki.org/extensions/WikiExtension",
    "main": "WikiExtension.php",
    "class": "IslamWiki\\Extensions\\WikiExtension\\WikiExtension",
    "type": "content",
    "requires": {
        "IslamWiki": ">= 0.0.2.0"
    },
    "config": {
        "enableWikiPages": true,
        "enableCategories": true,
        "enableCollaborativeEditing": true,
        "enablePageHistory": true,
        "enablePageSearch": true,
        "enablePageTemplates": true,
        "enablePagePermissions": true,
        "enablePageVersioning": true,
        "enablePageComments": true,
        "enablePageWatchlist": true
    },
    "hooks": {
        "ContentParse": "onContentParse",
        "PageDisplay": "onPageDisplay",
        "SearchIndex": "onSearchIndex",
        "WidgetRender": "onWidgetRender",
        "TemplateLoad": "onTemplateLoad",
        "AdminMenu": "onAdminMenu",
        "UserProfile": "onUserProfile",
        "WikiPageCreate": "onWikiPageCreate",
        "WikiPageUpdate": "onWikiPageUpdate",
        "WikiPageDelete": "onWikiPageDelete"
    },
    "resources": {
        "css": [
            "assets/css/wiki.css",
            "assets/css/wiki-editor.css",
            "assets/css/wiki-categories.css"
        ],
        "js": [
            "assets/js/wiki.js",
            "assets/js/wiki-editor.js",
            "assets/js/wiki-categories.js"
        ]
    },
    "templates": {
        "wiki-index": "templates/index.twig",
        "wiki-show": "templates/show.twig",
        "wiki-edit": "templates/edit.twig",
        "wiki-category": "templates/category.twig",
        "wiki-search": "templates/search.twig",
        "wiki-history": "templates/history.twig"
    }
} 