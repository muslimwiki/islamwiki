{% extends "layouts/app.twig" %}

{% block title %}Search Islamic Knowledge - IslamWiki{% endblock %}

{% block content %}
<!-- Search Hero Section -->
<section class="search-hero">
    <div class="search-hero__container">
        <div class="search-hero__content">
            <h1 class="search-hero__title">🔍 Search Islamic Knowledge</h1>
            <p class="search-hero__subtitle">Discover authentic Islamic content across all knowledge areas</p>
        </div>
    </div>
</section>

<!-- Main Search Interface -->
<section class="search-interface">
    <div class="search-interface__container">
        <!-- Search Form -->
        <div class="search-form">
            <form class="search-form__form" action="/search" method="GET">
                <div class="search-form__input-group">
                    <input 
                        type="text" 
                        name="q" 
                        class="search-form__input" 
                        placeholder="Search for Islamic knowledge, topics, scholars, or concepts..."
                        value="{{ query }}"
                        autocomplete="off"
                        id="search-input"
                    />
                    <button type="submit" class="search-form__button">
                        <span class="search-form__button-icon">🔍</span>
                        <span class="search-form__button-text">Search</span>
                    </button>
                </div>
                
                <!-- Search Options -->
                <div class="search-form__options">
                    <div class="search-form__option-group">
                        <label for="search-type">Search in:</label>
                        <select name="type" id="search-type" class="search-form__select">
                            {% for value, label in searchTypes %}
                                <option value="{{ value }}" {% if type == value %}selected{% endif %}>
                                    {{ label }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div class="search-form__option-group">
                        <label for="search-sort">Sort by:</label>
                        <select name="sort" id="search-sort" class="search-form__select">
                            {% for value, label in sortOptions %}
                                <option value="{{ value }}" {% if sort == value %}selected{% endif %}>
                                    {{ label }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div class="search-form__option-group">
                        <label for="search-order">Order:</label>
                        <select name="order" id="search-order" class="search-form__select">
                            <option value="desc" {% if order == 'desc' %}selected{% endif %}>Descending</option>
                            <option value="asc" {% if order == 'asc' %}selected{% endif %}>Ascending</option>
                        </select>
                    </div>
                </div>
            </form>
        </div>

        <!-- Search Suggestions -->
        <div class="search-suggestions" id="search-suggestions" style="display: none;">
            <div class="search-suggestions__header">
                <h4>💡 Search Suggestions</h4>
            </div>
            <div class="search-suggestions__list" id="suggestions-list">
                <!-- Suggestions will be populated here -->
            </div>
        </div>

        <!-- Search Results -->
        {% if query %}
            <div class="search-results">
                <div class="search-results__header">
                    <div class="search-results__info">
                        <h2>Search Results for "{{ query }}"</h2>
                        <p>{{ totalResults }} results found in {{ searchTime }} seconds</p>
                    </div>
                    
                    <div class="search-results__filters">
                        <button class="search-results__filter-btn" data-filter="all">All</button>
                        <button class="search-results__filter-btn" data-filter="wiki">Wiki</button>
                        <button class="search-results__filter-btn" data-filter="quran">Quran</button>
                        <button class="search-results__filter-btn" data-filter="hadith">Hadith</button>
                        <button class="search-results__filter-btn" data-filter="articles">Articles</button>
                    </div>
                </div>

                {% if results|length > 0 %}
                    <div class="search-results__list">
                        {% for result in results %}
                            <div class="search-result" data-type="{{ result.type }}">
                                <div class="search-result__header">
                                    <h3 class="search-result__title">
                                        <a href="{{ result.url }}" class="search-result__link">
                                            {{ result.title }}
                                        </a>
                                    </h3>
                                    <span class="search-result__type search-result__type--{{ result.type }}">
                                        {{ result.type|title }}
                                    </span>
                                </div>
                                
                                <div class="search-result__content">
                                    <p class="search-result__snippet">{{ result.snippet }}</p>
                                </div>
                                
                                <div class="search-result__meta">
                                    <span class="search-result__relevance">
                                        Relevance: {{ result.relevance }}%
                                    </span>
                                    {% if result.last_updated %}
                                        <span class="search-result__date">
                                            Updated: {{ result.last_updated }}
                                        </span>
                                    {% endif %}
                                    {% if result.author %}
                                        <span class="search-result__author">
                                            By: {{ result.author }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    <!-- Pagination -->
                    {% if totalPages > 1 %}
                        <div class="search-pagination">
                            {% if currentPage > 1 %}
                                <a href="?q={{ query }}&type={{ type }}&sort={{ sort }}&order={{ order }}&page={{ currentPage - 1 }}" 
                                   class="search-pagination__link search-pagination__link--prev">
                                    ← Previous
                                </a>
                            {% endif %}
                            
                            <div class="search-pagination__pages">
                                {% for page in range(1, totalPages) %}
                                    {% if page == currentPage %}
                                        <span class="search-pagination__current">{{ page }}</span>
                                    {% else %}
                                        <a href="?q={{ query }}&type={{ type }}&sort={{ sort }}&order={{ order }}&page={{ page }}" 
                                           class="search-pagination__link">{{ page }}</a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                            
                            {% if currentPage < totalPages %}
                                <a href="?q={{ query }}&type={{ type }}&sort={{ sort }}&order={{ order }}&page={{ currentPage + 1 }}" 
                                   class="search-pagination__link search-pagination__link--next">
                                    Next →
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                {% else %}
                    <div class="search-no-results">
                        <div class="search-no-results__icon">🔍</div>
                        <h3>No results found</h3>
                        <p>Try adjusting your search terms or browse our content categories.</p>
                        <div class="search-no-results__suggestions">
                            <h4>Popular searches:</h4>
                            <div class="search-no-results__tags">
                                <a href="/search?q=islamic+principles" class="search-tag">Islamic Principles</a>
                                <a href="/search?q=quran+recitation" class="search-tag">Quran Recitation</a>
                                <a href="/search?q=hadith+authenticity" class="search-tag">Hadith Authenticity</a>
                                <a href="/search?q=salah+times" class="search-tag">Salah Times</a>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        {% else %}
            <!-- Search Tips -->
            <div class="search-tips">
                <h3>💡 Search Tips</h3>
                <div class="search-tips__grid">
                    <div class="search-tip">
                        <h4>Use Specific Terms</h4>
                        <p>Instead of "prayer", try "salah method" or "daily prayers"</p>
                    </div>
                    <div class="search-tip">
                        <h4>Search by Content Type</h4>
                        <p>Filter results by Wiki, Quran, Hadith, or Articles</p>
                    </div>
                    <div class="search-tip">
                        <h4>Use Arabic Terms</h4>
                        <p>Search in Arabic for more specific results</p>
                    </div>
                    <div class="search-tip">
                        <h4>Browse Categories</h4>
                        <p>Explore content by topic or category</p>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}

{% block scripts %}
<script src="/extensions/IqraSearchExtension/assets/js/iqra-search.js"></script>
{% endblock %} 