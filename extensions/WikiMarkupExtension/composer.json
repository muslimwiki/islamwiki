{
    "name": "islamwiki/wiki-markup-extension",
    "description": "MediaWiki-style markup support for IslamWiki",
    "type": "islamwiki-extension",
    "license": "AGPL-3.0",
    "authors": [
        {
            "name": "IslamWiki Development Team",
            "email": "dev@islam.wiki",
            "homepage": "https://islam.wiki"
        }
    ],
    "require": {
        "php": ">=8.1",
        "islamwiki/core": ">=0.0.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "IslamWiki\\Extensions\\WikiMarkupExtension\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IslamWiki\\Extensions\\WikiMarkupExtension\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "islamwiki": {
            "extension-type": "content-processing",
            "priority": 10,
            "hooks": [
                "ContentParse",
                "ContentPostRender"
            ]
        }
    }
}

