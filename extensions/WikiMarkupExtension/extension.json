{
    "name": "WikiMarkupExtension",
    "version": "0.0.1.0",
    "description": "MediaWiki-style markup support for IslamWiki",
    "author": "IslamWiki Development Team",
    "license": "AGPL-3.0",
    "requires": {
        "php": ">=8.1",
        "islamwiki/core": ">=0.0.1.0"
    },
    "autoload": {
        "psr-4": {
            "IslamWiki\\Extensions\\WikiMarkupExtension\\": "src/"
        }
    },
    "extensions": {
        "WikiMarkup": {
            "class": "WikiMarkupExtension",
            "priority": 10
        }
    },
    "hooks": [
        "ContentParse",
        "ContentPostRender"
    ],
    "config": {
        "enable_wiki_markup": true,
        "parse_internal_links": true,
        "parse_templates": true,
        "parse_headers": true,
        "parse_lists": true
    }
}

