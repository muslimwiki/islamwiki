{
    "name": "WikiMarkupExtension",
    "version": "0.0.1.3",
    "description": "Comprehensive MediaWiki-style markup and Markdown support for IslamWiki with edit functionality",
    "author": "IslamWiki Development Team",
    "license": "AGPL-3.0",
    "requires": {
        "php": ">=8.1",
        "islamwiki/core": ">=0.0.2.0"
    },
    "autoload": {
        "psr-4": {
            "IslamWiki\\Extensions\\WikiMarkupExtension\\": "src/"
        }
    },
    "extensions": {
        "WikiMarkup": {
            "class": "WikiMarkupExtension",
            "priority": 10
        }
    },
    "hooks": [
        "ContentParse",
        "ContentPostRender",
        "PageEdit",
        "PageSave",
        "EditorInit"
    ],
    "config": {
        "enable_wiki_markup": true,
        "enable_markdown": true,
        "default_format": "wikimarkup",
        "parse_internal_links": true,
        "parse_templates": true,
        "parse_headers": true,
        "parse_lists": true,
        "parse_tables": true,
        "parse_media": true,
        "parse_categories": true,
        "parse_signatures": true,
        "parse_comments": true,
        "parse_math": true,
        "parse_syntax_highlighting": true,
        "enable_edit_functionality": true,
        "auto_save_interval": 30000,
        "show_edit_button": true,
        "show_source_button": true,
        "enable_live_preview": true
    },
    "assets": {
        "css": [
            "assets/css/muslimwiki-editor.css"
        ],
        "js": [
            "assets/js/wiki-markup-editor.js"
        ]
    }
}

