<div class="translator-widget">
    <div class="translator-header">
        <h3>🌍 Translation</h3>
        <p>Translate this page to other languages</p>
    </div>

    <div class="translator-content">
        <div class="current-language">
            <span class="language-flag">{{ language_urls[current_language].flag }}</span>
            <span class="language-name">{{ language_urls[current_language].name }}</span>
            <span class="language-native">({{ language_urls[current_language].native }})</span>
        </div>

        <div class="translation-options">
            <h4>Available Languages</h4>
            
            {% for code, language in language_urls %}
                {% if code != current_language %}
                    <div class="language-option">
                        <a href="{{ language.url }}" class="language-link">
                            <span class="language-flag">{{ language.flag }}</span>
                            <span class="language-name">{{ language.name }}</span>
                            <span class="language-native">{{ language.native }}</span>
                        </a>
                        
                        {% if can_translate %}
                            <button class="translate-btn" 
                                    data-source="{{ current_language }}" 
                                    data-target="{{ code }}"
                                    data-page-path="{{ page_path }}">
                                Translate
                            </button>
                        {% endif %}
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        {% if can_translate %}
            <div class="translation-actions">
                <button class="btn btn-primary translate-page-btn" 
                        data-page-path="{{ page_path }}"
                        data-current-language="{{ current_language }}">
                    📝 Translate This Page
                </button>
                
                <div class="translation-tools">
                    <button class="btn btn-secondary suggest-translation-btn">
                        💡 Suggest Translation
                    </button>
                    <button class="btn btn-secondary review-translations-btn">
                        🔍 Review Translations
                    </button>
                </div>
            </div>
        {% else %}
            <div class="login-prompt">
                <p>💡 Want to help translate?</p>
                <a href="/login" class="btn btn-primary">Login to Translate</a>
            </div>
        {% endif %}
    </div>

    <div class="translation-status">
        <h4>Translation Status</h4>
        <div class="status-grid">
            {% for code, language in language_urls %}
                {% if code != current_language %}
                    <div class="status-item">
                        <span class="status-flag">{{ language.flag }}</span>
                        <span class="status-language">{{ language.name }}</span>
                        <span class="status-indicator incomplete">⏳</span>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>

