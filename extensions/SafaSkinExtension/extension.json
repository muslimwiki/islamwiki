{
  "name": "SafaSkinExtension",
  "version": "0.0.1",
  "description": "Unified skin management system that consolidates all visual elements into skins",
  "author": "IslamWiki Development Team",
  "license": "AGPL-3.0",
  "requires": {
    "islamwiki": ">=0.0.19",
    "php": ">=8.1"
  },
  "category": "system",
  "tags": ["skin", "theme", "unified", "visual"],
  "homepage": "https://github.com/islamwiki/SafaSkinExtension",
  "main_class": "SafaSkinExtension",
  "autoload": {
    "psr-4": {
      "IslamWiki\\Extensions\\SafaSkinExtension\\": ""
    }
  },
  "provides": [
    "skin.manager",
    "skin.template_engine", 
    "skin.asset_manager",
    "skin.registry"
  ],
  "hooks": [
    "init",
    "template_render",
    "asset_enqueue"
  ],
  "filters": [
    "template_path",
    "skin_assets"
  ]
} 