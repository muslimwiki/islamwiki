{% extends "layouts/admin.twig" %}

{% block title %}{{ page_title }} - IslamWiki{% endblock %}

{% block styles %}
<style>
.safa-settings-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    font-family: 'Amiri', serif;
}

.safa-settings-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 50%, #A855F7 100%);
    border-radius: 16px;
    color: white;
    box-shadow: 0 10px 30px rgba(79, 70, 229, 0.3);
}

.safa-settings-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
}

.safa-settings-header p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin: 0;
}

.safa-settings-tabs {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
    background: white;
    border-radius: 12px;
    padding: 0.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.safa-tab {
    padding: 1rem 2rem;
    margin: 0 0.25rem;
    border-radius: 8px;
    text-decoration: none;
    color: #6B7280;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 2px solid transparent;
}

.safa-tab:hover {
    color: #4F46E5;
    background: #F3F4F6;
}

.safa-tab.active {
    color: #4F46E5;
    background: #EEF2FF;
    border-color: #4F46E5;
}

.safa-settings-content {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.safa-current-skin {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);
    border-radius: 12px;
    border: 2px solid #E5E7EB;
}

.safa-current-skin h2 {
    color: #1F2937;
    font-size: 1.8rem;
    margin-bottom: 1rem;
}

.safa-skin-preview {
    display: inline-block;
    padding: 1rem;
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    margin: 1rem 0;
}

.safa-skin-preview img {
    max-width: 200px;
    height: auto;
    border-radius: 4px;
}

.safa-available-skins {
    margin-bottom: 3rem;
}

.safa-available-skins h3 {
    color: #1F2937;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    text-align: center;
}

.safa-skin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.safa-skin-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: 2px solid #E5E7EB;
    transition: all 0.3s ease;
    text-align: center;
}

.safa-skin-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    border-color: #4F46E5;
}

.safa-skin-card.active {
    border-color: #4F46E5;
    background: #EEF2FF;
}

.safa-skin-card h4 {
    color: #1F2937;
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
}

.safa-skin-card p {
    color: #6B7280;
    margin-bottom: 1rem;
    line-height: 1.6;
}

.safa-skin-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
}

.safa-btn {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
}

.safa-btn--primary {
    background: #4F46E5;
    color: white;
}

.safa-btn--primary:hover {
    background: #4338CA;
    transform: translateY(-1px);
}

.safa-btn--secondary {
    background: #F3F4F6;
    color: #374151;
    border: 1px solid #D1D5DB;
}

.safa-btn--secondary:hover {
    background: #E5E7EB;
}

.safa-btn--success {
    background: #059669;
    color: white;
}

.safa-btn--success:hover {
    background: #047857;
}

.safa-skin-stats {
    background: #F9FAFB;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
}

.safa-skin-stats h4 {
    color: #1F2937;
    font-size: 1.2rem;
    margin-bottom: 1rem;
    text-align: center;
}

.safa-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
}

.safa-stat-item {
    text-align: center;
    padding: 1rem;
    background: white;
    border-radius: 8px;
    border: 1px solid #E5E7EB;
}

.safa-stat-number {
    font-size: 1.5rem;
    font-weight: 600;
    color: #4F46E5;
    margin-bottom: 0.25rem;
}

.safa-stat-label {
    color: #6B7280;
    font-size: 0.9rem;
}

.safa-customization-preview {
    background: #F9FAFB;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
    text-align: center;
}

.safa-customization-preview h4 {
    color: #1F2937;
    font-size: 1.2rem;
    margin-bottom: 1rem;
}

.safa-customization-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
}

.safa-customization-option {
    background: white;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid #E5E7EB;
    text-align: center;
}

.safa-customization-option h5 {
    color: #1F2937;
    font-size: 1rem;
    margin-bottom: 0.5rem;
}

.safa-customization-option p {
    color: #6B7280;
    font-size: 0.9rem;
    margin: 0;
}

@media (max-width: 768px) {
    .safa-settings-container {
        padding: 1rem;
    }
    
    .safa-settings-header h1 {
        font-size: 2rem;
    }
    
    .safa-skin-grid {
        grid-template-columns: 1fr;
    }
    
    .safa-settings-tabs {
        flex-direction: column;
        align-items: center;
    }
    
    .safa-tab {
        margin: 0.25rem 0;
        width: 100%;
        text-align: center;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="safa-settings-container">
    <!-- Header -->
    <div class="safa-settings-header">
        <h1>🎨 Skin Settings</h1>
        <p>Customize your IslamWiki experience with beautiful, Islamic-themed skins</p>
    </div>

    <!-- Navigation Tabs -->
    <div class="safa-settings-tabs">
        <a href="{{ path('admin.skins.index') }}" class="safa-tab {{ active_tab == 'overview' ? 'active' : '' }}">
            📊 Overview
        </a>
        <a href="{{ path('admin.skins.gallery') }}" class="safa-tab {{ active_tab == 'gallery' ? 'active' : '' }}">
            🖼️ Gallery
        </a>
        <a href="{{ path('admin.skins.customize') }}" class="safa-tab {{ active_tab == 'customize' ? 'active' : '' }}">
            ⚙️ Customize
        </a>
    </div>

    <!-- Main Content -->
    <div class="safa-settings-content">
        <!-- Current Skin Display -->
        {% if current_skin %}
        <div class="safa-current-skin">
            <h2>Current Skin: {{ current_skin.display_name }}</h2>
            <div class="safa-skin-preview">
                {% if current_skin.thumbnail_url %}
                <img src="{{ current_skin.thumbnail_url }}" alt="{{ current_skin.display_name }} Preview">
                {% else %}
                <div style="width: 200px; height: 150px; background: #E5E7EB; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #6B7280;">
                    No Preview
                </div>
                {% endif %}
            </div>
            <p><strong>Version:</strong> {{ current_skin.version }} | <strong>Author:</strong> {{ current_skin.author }}</p>
            <p>{{ current_skin.description }}</p>
        </div>
        {% endif %}

        <!-- Available Skins -->
        {% if available_skins %}
        <div class="safa-available-skins">
            <h3>Available Skins</h3>
            <div class="safa-skin-grid">
                {% for skin in available_skins %}
                <div class="safa-skin-card {{ skin.is_active ? 'active' : '' }}">
                    <h4>{{ skin.display_name }}</h4>
                    <p>{{ skin.description }}</p>
                    <div class="safa-skin-actions">
                        {% if skin.is_active %}
                        <span class="safa-btn safa-btn--success">Active</span>
                        {% else %}
                        <button class="safa-btn safa-btn--primary" onclick="switchSkin('{{ skin.name }}')">
                            Activate
                        </button>
                        <button class="safa-btn safa-btn--secondary" onclick="previewSkin('{{ skin.name }}')">
                            Preview
                        </button>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Skin Statistics -->
        {% if skin_stats %}
        <div class="safa-skin-stats">
            <h4>Skin System Statistics</h4>
            <div class="safa-stats-grid">
                <div class="safa-stat-item">
                    <div class="safa-stat-number">{{ skin_stats.total_skins }}</div>
                    <div class="safa-stat-label">Total Skins</div>
                </div>
                <div class="safa-stat-item">
                    <div class="safa-stat-number">{{ skin_stats.enabled }}</div>
                    <div class="safa-stat-label">Enabled</div>
                </div>
                <div class="safa-stat-item">
                    <div class="safa-stat-number">{{ skin_stats.disabled }}</div>
                    <div class="safa-stat-label">Disabled</div>
                </div>
                <div class="safa-stat-item">
                    <div class="safa-stat-number">{{ skin_stats.active }}</div>
                    <div class="safa-stat-label">Active</div>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Customization Options -->
        {% if customization_options %}
        <div class="safa-customization-preview">
            <h4>Customization Options</h4>
            <div class="safa-customization-options">
                <div class="safa-customization-option">
                    <h5>🎨 Color Schemes</h5>
                    <p>{{ customization_options.color_schemes|length }} available</p>
                </div>
                <div class="safa-customization-option">
                    <h5>🔤 Typography</h5>
                    <p>{{ customization_options.typography_options.font_family|length }} font families</p>
                </div>
                <div class="safa-customization-option">
                    <h5>📐 Layouts</h5>
                    <p>{{ customization_options.layout_options.sidebar_position|length }} sidebar options</p>
                </div>
                <div class="safa-customization-option">
                    <h5>🧩 Components</h5>
                    <p>{{ customization_options.component_options|length }} customizable</p>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function switchSkin(skinName) {
    if (confirm(`Are you sure you want to switch to the ${skinName} skin?`)) {
        fetch('{{ path("admin.skins.switch") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': '{{ csrf_token() }}'
            },
            body: JSON.stringify({ skin_name: skinName })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred while switching skins');
        });
    }
}

function previewSkin(skinName) {
    // Open preview in new window
    window.open(`{{ path("admin.skins.preview") }}?skin=${skinName}`, '_blank', 'width=800,height=600');
}
</script>
{% endblock %} 