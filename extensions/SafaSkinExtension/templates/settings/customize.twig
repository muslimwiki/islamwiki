{% extends "layouts/admin.twig" %}

{% block title %}{{ page_title }} - IslamWiki{% endblock %}

{% block styles %}
<style>
.safa-customize-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    font-family: 'Amiri', serif;
}

.safa-customize-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #DC2626 0%, #EF4444 50%, #F87171 100%);
    border-radius: 16px;
    color: white;
    box-shadow: 0 10px 30px rgba(220, 38, 38, 0.3);
}

.safa-customize-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
}

.safa-customize-header p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin: 0;
}

.safa-customize-tabs {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
    background: white;
    border-radius: 12px;
    padding: 0.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.safa-tab {
    padding: 1rem 2rem;
    margin: 0 0.25rem;
    border-radius: 8px;
    text-decoration: none;
    color: #6B7280;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 2px solid transparent;
}

.safa-tab:hover {
    color: #DC2626;
    background: #FEF2F2;
}

.safa-tab.active {
    color: #DC2626;
    background: #FEF2F2;
    border-color: #DC2626;
}

.safa-customize-content {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.safa-customization-section {
    margin-bottom: 3rem;
    padding: 2rem;
    background: #F9FAFB;
    border-radius: 12px;
    border: 1px solid #E5E7EB;
}

.safa-section-header {
    text-align: center;
    margin-bottom: 2rem;
}

.safa-section-header h3 {
    color: #1F2937;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
}

.safa-section-header p {
    color: #6B7280;
    margin: 0;
}

.safa-color-schemes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.safa-color-scheme {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    border: 2px solid #E5E7EB;
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
}

.safa-color-scheme:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
}

.safa-color-scheme.selected {
    border-color: #DC2626;
    background: #FEF2F2;
}

.safa-color-scheme.selected::after {
    content: '✓';
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #DC2626;
    color: white;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.safa-color-scheme h4 {
    color: #1F2937;
    font-size: 1.2rem;
    margin-bottom: 1rem;
    text-align: center;
}

.safa-color-preview {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.safa-color-swatch {
    width: 100%;
    height: 40px;
    border-radius: 6px;
    border: 2px solid #E5E7EB;
    position: relative;
}

.safa-color-swatch::after {
    content: attr(data-color);
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    color: #6B7280;
    white-space: nowrap;
}

.safa-typography-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.safa-typography-option {
    background: white;
    border-radius: 8px;
    padding: 1.5rem;
    border: 1px solid #E5E7EB;
    text-align: center;
}

.safa-typography-option h5 {
    color: #1F2937;
    font-size: 1rem;
    margin-bottom: 1rem;
}

.safa-typography-preview {
    padding: 1rem;
    background: #F9FAFB;
    border-radius: 6px;
    margin-bottom: 1rem;
    border: 1px solid #E5E7EB;
}

.safa-font-family-selector {
    margin-bottom: 1rem;
}

.safa-font-family-selector label {
    display: block;
    margin-bottom: 0.5rem;
    color: #374151;
    font-weight: 500;
}

.safa-font-family-selector select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    background: white;
    color: #374151;
}

.safa-layout-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.safa-layout-option {
    background: white;
    border-radius: 8px;
    padding: 1.5rem;
    border: 1px solid #E5E7EB;
    text-align: center;
}

.safa-layout-option h5 {
    color: #1F2937;
    font-size: 1rem;
    margin-bottom: 1rem;
}

.safa-layout-preview {
    width: 100%;
    height: 120px;
    background: #F3F4F6;
    border-radius: 6px;
    margin-bottom: 1rem;
    position: relative;
    border: 1px solid #E5E7EB;
}

.safa-layout-preview.sidebar-left::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 30%;
    background: #E5E7EB;
    border-radius: 6px 0 0 6px;
}

.safa-layout-preview.sidebar-right::before {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 30%;
    background: #E5E7EB;
    border-radius: 0 6px 6px 0;
}

.safa-layout-preview.no-sidebar::after {
    content: 'Full Width';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #6B7280;
    font-size: 0.9rem;
}

.safa-component-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.safa-component-option {
    background: white;
    border-radius: 8px;
    padding: 1.5rem;
    border: 1px solid #E5E7EB;
    text-align: center;
}

.safa-component-option h5 {
    color: #1F2937;
    font-size: 1rem;
    margin-bottom: 1rem;
}

.safa-toggle-switch {
    position: relative;
    display: inline-block;
    width: 60px;
    height: 34px;
}

.safa-toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.safa-toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: .4s;
    border-radius: 34px;
}

.safa-toggle-slider:before {
    position: absolute;
    content: "";
    height: 26px;
    width: 26px;
    left: 4px;
    bottom: 4px;
    background-color: white;
    transition: .4s;
    border-radius: 50%;
}

input:checked + .safa-toggle-slider {
    background-color: #DC2626;
}

input:checked + .safa-toggle-slider:before {
    transform: translateX(26px);
}

.safa-customization-actions {
    text-align: center;
    margin-top: 3rem;
    padding: 2rem;
    background: #F9FAFB;
    border-radius: 12px;
    border: 1px solid #E5E7EB;
}

.safa-btn {
    padding: 1rem 2rem;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    margin: 0 0.5rem;
}

.safa-btn--primary {
    background: #DC2626;
    color: white;
}

.safa-btn--primary:hover {
    background: #B91C1C;
    transform: translateY(-1px);
}

.safa-btn--secondary {
    background: #F3F4F6;
    color: #374151;
    border: 1px solid #D1D5DB;
}

.safa-btn--secondary:hover {
    background: #E5E7EB;
}

.safa-btn--success {
    background: #059669;
    color: white;
}

.safa-btn--success:hover {
    background: #047857;
}

.safa-live-preview {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.9);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
}

.safa-preview-content {
    background: white;
    border-radius: 16px;
    max-width: 90vw;
    max-height: 90vh;
    overflow: hidden;
    position: relative;
}

.safa-preview-header {
    background: #F9FAFB;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #E5E7EB;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.safa-preview-title {
    font-weight: 600;
    color: #1F2937;
}

.safa-preview-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6B7280;
    padding: 0.5rem;
    border-radius: 4px;
    transition: background 0.3s ease;
}

.safa-preview-close:hover {
    background: #E5E7EB;
}

.safa-preview-body {
    padding: 1.5rem;
    max-height: 70vh;
    overflow-y: auto;
}

@media (max-width: 768px) {
    .safa-customize-container {
        padding: 1rem;
    }
    
    .safa-customize-header h1 {
        font-size: 2rem;
    }
    
    .safa-customize-tabs {
        flex-direction: column;
        align-items: center;
    }
    
    .safa-tab {
        margin: 0.25rem 0;
        width: 100%;
        text-align: center;
    }
    
    .safa-color-schemes,
    .safa-typography-options,
    .safa-layout-options,
    .safa-component-options {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="safa-customize-container">
    <!-- Header -->
    <div class="safa-customize-header">
        <h1>⚙️ Customize Skin</h1>
        <p>Personalize your {{ current_skin.display_name }} skin with colors, typography, and layout options</p>
    </div>

    <!-- Navigation Tabs -->
    <div class="safa-customize-tabs">
        <a href="{{ path('admin.skins.index') }}" class="safa-tab">
            📊 Overview
        </a>
        <a href="{{ path('admin.skins.gallery') }}" class="safa-tab">
            🖼️ Gallery
        </a>
        <a href="{{ path('admin.skins.customize') }}" class="safa-tab active">
            ⚙️ Customize
        </a>
    </div>

    <!-- Main Content -->
    <div class="safa-customize-content">
        <!-- Color Schemes -->
        <div class="safa-customization-section">
            <div class="safa-section-header">
                <h3>🎨 Color Schemes</h3>
                <p>Choose from beautiful Islamic-inspired color palettes</p>
            </div>
            
            <div class="safa-color-schemes">
                {% for scheme_key, scheme in color_schemes %}
                <div class="safa-color-scheme {{ current_skin.customization.color_scheme == scheme_key ? 'selected' : '' }}"
                     onclick="selectColorScheme('{{ scheme_key }}')">
                    <h4>{{ scheme.name }}</h4>
                    <div class="safa-color-preview">
                        <div class="safa-color-swatch" style="background: {{ scheme.primary }}" data-color="Primary"></div>
                        <div class="safa-color-swatch" style="background: {{ scheme.secondary }}" data-color="Secondary"></div>
                        <div class="safa-color-swatch" style="background: {{ scheme.accent }}" data-color="Accent"></div>
                        <div class="safa-color-swatch" style="background: {{ scheme.background }}" data-color="Background"></div>
                        <div class="safa-color-swatch" style="background: {{ scheme.text }}" data-color="Text"></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- Typography Options -->
        <div class="safa-customization-section">
            <div class="safa-section-header">
                <h3>🔤 Typography</h3>
                <p>Customize fonts and text styling for your content</p>
            </div>
            
            <div class="safa-typography-options">
                <div class="safa-typography-option">
                    <h5>Font Family</h5>
                    <div class="safa-font-family-selector">
                        <label for="font-family">Select Font:</label>
                        <select id="font-family" onchange="updateTypography()">
                            {% for font_key, font_value in typography_options.font_family %}
                            <option value="{{ font_key }}" {{ current_skin.customization.font_family == font_key ? 'selected' : '' }}>
                                {{ font_key|title }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="safa-typography-preview" id="font-preview">
                        <p style="font-family: {{ typography_options.font_family[current_skin.customization.font_family] }};">
                            Sample text in {{ current_skin.customization.font_family }} font
                        </p>
                    </div>
                </div>
                
                <div class="safa-typography-option">
                    <h5>Font Size</h5>
                    <div class="safa-font-family-selector">
                        <label for="font-size">Select Size:</label>
                        <select id="font-size" onchange="updateTypography()">
                            {% for size_key, size_value in typography_options.font_size %}
                            <option value="{{ size_key }}" {{ current_skin.customization.font_size == size_key ? 'selected' : '' }}>
                                {{ size_key|title }} ({{ size_value }})
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="safa-typography-preview" id="size-preview">
                        <p style="font-size: {{ typography_options.font_size[current_skin.customization.font_size] }};">
                            Sample text in {{ current_skin.customization.font_size }} size
                        </p>
                    </div>
                </div>
                
                <div class="safa-typography-option">
                    <h5>Line Height</h5>
                    <div class="safa-font-family-selector">
                        <label for="line-height">Select Height:</label>
                        <select id="line-height" onchange="updateTypography()">
                            {% for height_key, height_value in typography_options.line_height %}
                            <option value="{{ height_key }}" {{ current_skin.customization.line_height == height_key ? 'selected' : '' }}>
                                {{ height_key|title }} ({{ height_value }})
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="safa-typography-preview" id="height-preview">
                        <p style="line-height: {{ typography_options.line_height[current_skin.customization.line_height] }};">
                            Sample text with {{ current_skin.customization.line_height }} line height.<br>
                            This shows how the text spacing looks.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Layout Options -->
        <div class="safa-customization-section">
            <div class="safa-section-header">
                <h3>📐 Layout Options</h3>
                <p>Customize the structure and arrangement of your content</p>
            </div>
            
            <div class="safa-layout-options">
                <div class="safa-layout-option">
                    <h5>Sidebar Position</h5>
                    <div class="safa-font-family-selector">
                        <label for="sidebar-position">Select Position:</label>
                        <select id="sidebar-position" onchange="updateLayout()">
                            {% for position in layout_options.sidebar_position %}
                            <option value="{{ position }}" {{ current_skin.customization.sidebar_position == position ? 'selected' : '' }}>
                                {{ position|title }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="safa-layout-preview {{ current_skin.customization.sidebar_position }}" id="sidebar-preview"></div>
                </div>
                
                <div class="safa-layout-option">
                    <h5>Content Width</h5>
                    <div class="safa-font-family-selector">
                        <label for="content-width">Select Width:</label>
                        <select id="content-width" onchange="updateLayout()">
                            {% for width in layout_options.content_width %}
                            <option value="{{ width }}" {{ current_skin.customization.content_width == width ? 'selected' : '' }}>
                                {{ width|title }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="safa-typography-preview">
                        <p>Content will be displayed in <strong>{{ current_skin.customization.content_width }}</strong> width layout</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Component Options -->
        <div class="safa-customization-section">
            <div class="safa-section-header">
                <h3>🧩 Component Visibility</h3>
                <p>Choose which interface components to display</p>
            </div>
            
            <div class="safa-component-options">
                {% for component_key, component_value in component_options %}
                <div class="safa-component-option">
                    <h5>{{ component_key|replace('_', ' ')|title }}</h5>
                    <label class="safa-toggle-switch">
                        <input type="checkbox" id="{{ component_key }}" 
                               {{ component_value ? 'checked' : '' }}
                               onchange="updateComponent('{{ component_key }}')">
                        <span class="safa-toggle-slider"></span>
                    </label>
                    <p style="margin-top: 1rem; font-size: 0.9rem; color: #6B7280;">
                        {{ component_value ? 'Visible' : 'Hidden' }}
                    </p>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- Customization Actions -->
        <div class="safa-customization-actions">
            <h3>Save Your Customizations</h3>
            <p>Apply your changes and see them in real-time</p>
            
            <button class="safa-btn safa-btn--primary" onclick="saveCustomization()">
                💾 Save Changes
            </button>
            
            <button class="safa-btn safa-btn--secondary" onclick="resetCustomization()">
                🔄 Reset to Default
            </button>
            
            <button class="safa-btn safa-btn--success" onclick="previewCustomization()">
                👁️ Live Preview
            </button>
        </div>
    </div>
</div>

<!-- Live Preview Modal -->
<div class="safa-live-preview" id="live-preview">
    <div class="safa-preview-content">
        <div class="safa-preview-header">
            <div class="safa-preview-title">Live Preview</div>
            <button class="safa-preview-close" onclick="closeLivePreview()">&times;</button>
        </div>
        <div class="safa-preview-body" id="preview-content">
            <!-- Preview content will be loaded here -->
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
let customizationSettings = {
    color_scheme: '{{ current_skin.customization.color_scheme }}',
    font_family: '{{ current_skin.customization.font_family }}',
    font_size: '{{ current_skin.customization.font_size }}',
    line_height: '{{ current_skin.customization.line_height }}',
    sidebar_position: '{{ current_skin.customization.sidebar_position }}',
    content_width: '{{ current_skin.customization.content_width }}',
    components: {
        {% for component_key, component_value in component_options %}
        '{{ component_key }}': {{ component_value ? 'true' : 'false' }}{% if not loop.last %},{% endif %}
        {% endfor %}
    }
};

function selectColorScheme(schemeKey) {
    // Remove previous selection
    document.querySelectorAll('.safa-color-scheme').forEach(scheme => {
        scheme.classList.remove('selected');
    });
    
    // Add selection to clicked scheme
    event.currentTarget.classList.add('selected');
    
    // Update settings
    customizationSettings.color_scheme = schemeKey;
    
    // Apply preview
    applyCustomizationPreview();
}

function updateTypography() {
    const fontFamily = document.getElementById('font-family').value;
    const fontSize = document.getElementById('font-size').value;
    const lineHeight = document.getElementById('line-height').value;
    
    customizationSettings.font_family = fontFamily;
    customizationSettings.font_size = fontSize;
    customizationSettings.line_height = lineHeight;
    
    // Update previews
    updateTypographyPreviews();
    applyCustomizationPreview();
}

function updateTypographyPreviews() {
    const fontPreview = document.getElementById('font-preview');
    const sizePreview = document.getElementById('size-preview');
    const heightPreview = document.getElementById('height-preview');
    
    if (fontPreview) {
        fontPreview.innerHTML = `<p style="font-family: {{ typography_options.font_family[current_skin.customization.font_family] }};">
            Sample text in ${customizationSettings.font_family} font
        </p>`;
    }
    
    if (sizePreview) {
        sizePreview.innerHTML = `<p style="font-size: {{ typography_options.font_size[current_skin.customization.font_size] }};">
            Sample text in ${customizationSettings.font_size} size
        </p>`;
    }
    
    if (heightPreview) {
        heightPreview.innerHTML = `<p style="line-height: {{ typography_options.line_height[current_skin.customization.line_height] }};">
            Sample text with ${customizationSettings.line_height} line height.<br>
            This shows how the text spacing looks.
        </p>`;
    }
}

function updateLayout() {
    const sidebarPosition = document.getElementById('sidebar-position').value;
    const contentWidth = document.getElementById('content-width').value;
    
    customizationSettings.sidebar_position = sidebarPosition;
    customizationSettings.content_width = contentWidth;
    
    // Update previews
    updateLayoutPreviews();
    applyCustomizationPreview();
}

function updateLayoutPreviews() {
    const sidebarPreview = document.getElementById('sidebar-preview');
    
    if (sidebarPreview) {
        sidebarPreview.className = `safa-layout-preview ${customizationSettings.sidebar_position}`;
    }
}

function updateComponent(componentKey) {
    const checkbox = document.getElementById(componentKey);
    customizationSettings.components[componentKey] = checkbox.checked;
    
    // Update display
    const componentOption = checkbox.closest('.safa-component-option');
    const statusText = componentOption.querySelector('p');
    if (statusText) {
        statusText.textContent = checkbox.checked ? 'Visible' : 'Hidden';
    }
    
    applyCustomizationPreview();
}

function applyCustomizationPreview() {
    // Apply color scheme
    document.documentElement.style.setProperty('--primary-color', getColorScheme(customizationSettings.color_scheme).primary);
    document.documentElement.style.setProperty('--secondary-color', getColorScheme(customizationSettings.color_scheme).secondary);
    document.documentElement.style.setProperty('--accent-color', getColorScheme(customizationSettings.color_scheme).accent);
    
    // Apply typography
    document.documentElement.style.setProperty('--font-family', getFontFamily(customizationSettings.font_family));
    document.documentElement.style.setProperty('--font-size', getFontSize(customizationSettings.font_size));
    document.documentElement.style.setProperty('--line-height', getLineHeight(customizationSettings.line_height));
}

function getColorScheme(schemeKey) {
    const schemes = {{ color_schemes|json_encode|raw }};
    return schemes[schemeKey] || schemes['traditional'];
}

function getFontFamily(fontKey) {
    const fonts = {{ typography_options.font_family|json_encode|raw }};
    return fonts[fontKey] || fonts['islamic'];
}

function getFontSize(sizeKey) {
    const sizes = {{ typography_options.font_size|json_encode|raw }};
    return sizes[sizeKey] || sizes['medium'];
}

function getLineHeight(heightKey) {
    const heights = {{ typography_options.line_height|json_encode|raw }};
    return heights[heightKey] || heights['normal'];
}

function saveCustomization() {
    fetch('{{ path("admin.skins.save-customization") }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRF-TOKEN': '{{ csrf_token() }}'
        },
        body: JSON.stringify({ customization: customizationSettings })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Customization settings saved successfully!');
            // Apply settings immediately
            applyCustomizationPreview();
        } else {
            alert('Error: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('An error occurred while saving customization settings');
    });
}

function resetCustomization() {
    if (confirm('Are you sure you want to reset all customizations to default values?')) {
        // Reset to default values
        customizationSettings = {
            color_scheme: 'traditional',
            font_family: 'islamic',
            font_size: 'medium',
            line_height: 'normal',
            sidebar_position: 'right',
            content_width: 'standard',
            components: {
                show_search: true,
                show_navigation: true,
                show_breadcrumbs: true,
                show_sidebar: true,
                show_footer: true
            }
        };
        
        // Reset form elements
        resetFormElements();
        
        // Apply preview
        applyCustomizationPreview();
        
        alert('Customization settings have been reset to default values');
    }
}

function resetFormElements() {
    // Reset color scheme selection
    document.querySelectorAll('.safa-color-scheme').forEach(scheme => {
        scheme.classList.remove('selected');
    });
    document.querySelector('.safa-color-scheme[data-category="traditional"]').classList.add('selected');
    
    // Reset typography
    document.getElementById('font-family').value = 'islamic';
    document.getElementById('font-size').value = 'medium';
    document.getElementById('line-height').value = 'normal';
    
    // Reset layout
    document.getElementById('sidebar-position').value = 'right';
    document.getElementById('content-width').value = 'standard';
    
    // Reset components
    Object.keys(customizationSettings.components).forEach(componentKey => {
        const checkbox = document.getElementById(componentKey);
        if (checkbox) {
            checkbox.checked = customizationSettings.components[componentKey];
        }
    });
    
    // Update previews
    updateTypographyPreviews();
    updateLayoutPreviews();
}

function previewCustomization() {
    const previewModal = document.getElementById('live-preview');
    const previewContent = document.getElementById('preview-content');
    
    // Show loading
    previewContent.innerHTML = `
        <div style="text-align: center;">
            <div style="width: 40px; height: 40px; border: 4px solid #F3F4F6; border-top: 4px solid #DC2626; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 1rem;"></div>
            <p>Loading preview...</p>
        </div>
    `;
    
    previewModal.style.display = 'flex';
    
    // Generate preview content
    setTimeout(() => {
        previewContent.innerHTML = `
            <div style="text-align: center;">
                <h3>Customization Preview</h3>
                <div style="background: #F9FAFB; padding: 2rem; border-radius: 8px; margin: 1rem 0; text-align: left;">
                    <h4>Applied Settings:</h4>
                    <ul style="list-style: none; padding: 0;">
                        <li>🎨 Color Scheme: ${customizationSettings.color_scheme}</li>
                        <li>🔤 Font Family: ${customizationSettings.font_family}</li>
                        <li>📏 Font Size: ${customizationSettings.font_size}</li>
                        <li>📐 Line Height: ${customizationSettings.line_height}</li>
                        <li>📍 Sidebar: ${customizationSettings.sidebar_position}</li>
                        <li>📱 Content Width: ${customizationSettings.content_width}</li>
                    </ul>
                </div>
                <p>Your customizations will look like this when applied!</p>
            </div>
        `;
    }, 1000);
}

function closeLivePreview() {
    document.getElementById('live-preview').style.display = 'none';
}

// Close preview when clicking outside
document.getElementById('live-preview').addEventListener('click', function(e) {
    if (e.target === this) {
        closeLivePreview();
    }
});

// Initialize customization preview
document.addEventListener('DOMContentLoaded', function() {
    applyCustomizationPreview();
});
</script>
{% endblock %} 