{% extends "layouts/admin.twig" %}

{% block title %}{{ page_title }} - IslamWiki{% endblock %}

{% block styles %}
<style>
.safa-gallery-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
    font-family: 'Amiri', serif;
}

.safa-gallery-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #059669 0%, #10B981 50%, #34D399 100%);
    border-radius: 16px;
    color: white;
    box-shadow: 0 10px 30px rgba(5, 150, 105, 0.3);
}

.safa-gallery-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
}

.safa-gallery-header p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin: 0;
}

.safa-gallery-filters {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
}

.safa-filter-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.safa-filter-group label {
    font-weight: 500;
    color: #374151;
    min-width: 80px;
}

.safa-filter-group select,
.safa-filter-group input {
    padding: 0.5rem;
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    background: white;
    color: #374151;
    min-width: 120px;
}

.safa-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
}

.safa-skin-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    border: 2px solid #E5E7EB;
    transition: all 0.3s ease;
    position: relative;
}

.safa-skin-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    border-color: #059669;
}

.safa-skin-card.active {
    border-color: #059669;
    box-shadow: 0 8px 30px rgba(5, 150, 105, 0.2);
}

.safa-skin-card.active::before {
    content: '✓ Active';
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #059669;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 500;
    z-index: 10;
}

.safa-skin-preview {
    position: relative;
    height: 200px;
    background: #F9FAFB;
    overflow: hidden;
}

.safa-skin-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.safa-skin-card:hover .safa-skin-preview img {
    transform: scale(1.05);
}

.safa-skin-preview-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.safa-skin-card:hover .safa-skin-preview-overlay {
    opacity: 1;
}

.safa-preview-btn {
    background: #059669;
    color: white;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
}

.safa-preview-btn:hover {
    background: #047857;
    transform: scale(1.05);
}

.safa-skin-info {
    padding: 1.5rem;
}

.safa-skin-title {
    font-size: 1.4rem;
    font-weight: 600;
    color: #1F2937;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.safa-skin-version {
    background: #EEF2FF;
    color: #4F46E5;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 500;
}

.safa-skin-description {
    color: #6B7280;
    line-height: 1.6;
    margin-bottom: 1rem;
}

.safa-skin-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: #F9FAFB;
    border-radius: 8px;
}

.safa-skin-author {
    color: #374151;
    font-size: 0.9rem;
}

.safa-skin-date {
    color: #6B7280;
    font-size: 0.8rem;
}

.safa-skin-features {
    margin-bottom: 1.5rem;
}

.safa-feature-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.safa-feature-tag {
    background: #F3F4F6;
    color: #374151;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.8rem;
    border: 1px solid #E5E7EB;
}

.safa-skin-actions {
    display: flex;
    gap: 0.75rem;
}

.safa-btn {
    flex: 1;
    padding: 0.75rem 1rem;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    text-align: center;
}

.safa-btn--primary {
    background: #059669;
    color: white;
}

.safa-btn--primary:hover {
    background: #047857;
    transform: translateY(-1px);
}

.safa-btn--secondary {
    background: #F3F4F6;
    color: #374151;
    border: 1px solid #D1D5DB;
}

.safa-btn--secondary:hover {
    background: #E5E7EB;
}

.safa-btn--success {
    background: #059669;
    color: white;
}

.safa-btn--success:hover {
    background: #047857;
}

.safa-btn--disabled {
    background: #F3F4F6;
    color: #9CA3AF;
    cursor: not-allowed;
}

.safa-btn--disabled:hover {
    transform: none;
}

.safa-gallery-empty {
    text-align: center;
    padding: 4rem 2rem;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.safa-gallery-empty h3 {
    color: #6B7280;
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

.safa-gallery-empty p {
    color: #9CA3AF;
    margin-bottom: 2rem;
}

.safa-gallery-loading {
    text-align: center;
    padding: 4rem 2rem;
}

.safa-loading-spinner {
    display: inline-block;
    width: 40px;
    height: 40px;
    border: 4px solid #F3F4F6;
    border-top: 4px solid #059669;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.safa-live-preview {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.9);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
}

.safa-preview-content {
    background: white;
    border-radius: 16px;
    max-width: 90vw;
    max-height: 90vh;
    overflow: hidden;
    position: relative;
}

.safa-preview-header {
    background: #F9FAFB;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #E5E7EB;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.safa-preview-title {
    font-weight: 600;
    color: #1F2937;
}

.safa-preview-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6B7280;
    padding: 0.5rem;
    border-radius: 4px;
    transition: background 0.3s ease;
}

.safa-preview-close:hover {
    background: #E5E7EB;
}

.safa-preview-body {
    padding: 1.5rem;
    max-height: 70vh;
    overflow-y: auto;
}

@media (max-width: 768px) {
    .safa-gallery-container {
        padding: 1rem;
    }
    
    .safa-gallery-header h1 {
        font-size: 2rem;
    }
    
    .safa-gallery-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    
    .safa-gallery-filters {
        flex-direction: column;
        align-items: stretch;
    }
    
    .safa-filter-group {
        flex-direction: column;
        align-items: stretch;
    }
    
    .safa-filter-group label {
        min-width: auto;
    }
    
    .safa-skin-actions {
        flex-direction: column;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="safa-gallery-container">
    <!-- Header -->
    <div class="safa-gallery-header">
        <h1>🖼️ Skin Gallery</h1>
        <p>Explore and preview beautiful Islamic-themed skins for your IslamWiki</p>
    </div>

    <!-- Navigation Tabs -->
    <div class="safa-settings-tabs">
        <a href="{{ path('admin.skins.index') }}" class="safa-tab">
            📊 Overview
        </a>
        <a href="{{ path('admin.skins.gallery') }}" class="safa-tab active">
            🖼️ Gallery
        </a>
        <a href="{{ path('admin.skins.customize') }}" class="safa-tab">
            ⚙️ Customize
        </a>
    </div>

    <!-- Filters -->
    <div class="safa-gallery-filters">
        <div class="safa-filter-group">
            <label for="category-filter">Category:</label>
            <select id="category-filter" onchange="filterSkins()">
                <option value="">All Categories</option>
                <option value="traditional">Traditional Islamic</option>
                <option value="modern">Modern Islamic</option>
                <option value="elegant">Elegant Islamic</option>
                <option value="minimal">Minimal</option>
            </select>
        </div>
        
        <div class="safa-filter-group">
            <label for="compatibility-filter">Compatibility:</label>
            <select id="compatibility-filter" onchange="filterSkins()">
                <option value="">All Skins</option>
                <option value="compatible">Compatible Only</option>
                <option value="incompatible">Show Incompatible</option>
            </select>
        </div>
        
        <div class="safa-filter-group">
            <label for="search-filter">Search:</label>
            <input type="text" id="search-filter" placeholder="Search skins..." onkeyup="filterSkins()">
        </div>
    </div>

    <!-- Gallery Grid -->
    {% if skins %}
    <div class="safa-gallery-grid" id="skin-gallery">
        {% for skin in skins %}
        <div class="safa-skin-card {{ skin.name == current_skin ? 'active' : '' }}" 
             data-category="{{ skin.category|default('traditional') }}"
             data-compatible="{{ skin.is_compatible ? 'compatible' : 'incompatible' }}"
             data-name="{{ skin.name|lower }}">
            
            <!-- Skin Preview -->
            <div class="safa-skin-preview">
                {% if skin.thumbnail_url %}
                <img src="{{ skin.thumbnail_url }}" alt="{{ skin.display_name }} Preview">
                {% else %}
                <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%); display: flex; align-items: center; justify-content: center; color: #6B7280;">
                    <div style="text-align: center;">
                        <div style="font-size: 2rem; margin-bottom: 0.5rem;">🎨</div>
                        <div style="font-size: 0.9rem;">{{ skin.display_name }}</div>
                    </div>
                </div>
                {% endif %}
                
                <!-- Preview Overlay -->
                <div class="safa-skin-preview-overlay">
                    <button class="safa-preview-btn" onclick="openLivePreview('{{ skin.name }}')">
                        👁️ Live Preview
                    </button>
                </div>
            </div>
            
            <!-- Skin Information -->
            <div class="safa-skin-info">
                <div class="safa-skin-title">
                    {{ skin.display_name }}
                    <span class="safa-skin-version">v{{ skin.version }}</span>
                </div>
                
                <p class="safa-skin-description">{{ skin.description }}</p>
                
                <div class="safa-skin-meta">
                    <span class="safa-skin-author">By {{ skin.author }}</span>
                    <span class="safa-skin-date">{{ skin.registered_at|date('M j, Y') }}</span>
                </div>
                
                <!-- Skin Features -->
                <div class="safa-skin-features">
                    <div class="safa-feature-list">
                        {% if skin.assets.css %}
                        <span class="safa-feature-tag">🎨 {{ skin.assets.css|length }} CSS Files</span>
                        {% endif %}
                        {% if skin.assets.js %}
                        <span class="safa-feature-tag">⚡ {{ skin.assets.js|length }} JS Files</span>
                        {% endif %}
                        {% if skin.templates.layouts %}
                        <span class="safa-feature-tag">📐 {{ skin.templates.layouts|length }} Layouts</span>
                        {% endif %}
                        {% if skin.templates.components %}
                        <span class="safa-feature-tag">🧩 {{ skin.templates.components|length }} Components</span>
                        {% endif %}
                    </div>
                </div>
                
                <!-- Skin Actions -->
                <div class="safa-skin-actions">
                    {% if skin.name == current_skin %}
                    <span class="safa-btn safa-btn--success">✓ Active</span>
                    {% else %}
                        {% if skin.is_compatible %}
                        <button class="safa-btn safa-btn--primary" onclick="switchSkin('{{ skin.name }}')">
                            Activate
                        </button>
                        {% else %}
                        <button class="safa-btn safa-btn--disabled" disabled>
                            Incompatible
                        </button>
                        {% endif %}
                    {% endif %}
                    
                    <button class="safa-btn safa-btn--secondary" onclick="openLivePreview('{{ skin.name }}')">
                        Preview
                    </button>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="safa-gallery-empty">
        <h3>🎨 No Skins Available</h3>
        <p>No skins have been discovered yet. Check your skins directory or install some skins.</p>
        <button class="safa-btn safa-btn--primary" onclick="refreshGallery()">
            🔄 Refresh Gallery
        </button>
    </div>
    {% endif %}
</div>

<!-- Live Preview Modal -->
<div class="safa-live-preview" id="live-preview">
    <div class="safa-preview-content">
        <div class="safa-preview-header">
            <div class="safa-preview-title">Live Preview</div>
            <button class="safa-preview-close" onclick="closeLivePreview()">&times;</button>
        </div>
        <div class="safa-preview-body" id="preview-content">
            <!-- Preview content will be loaded here -->
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
let currentFilter = {
    category: '',
    compatibility: '',
    search: ''
};

function filterSkins() {
    const categoryFilter = document.getElementById('category-filter').value;
    const compatibilityFilter = document.getElementById('compatibility-filter').value;
    const searchFilter = document.getElementById('search-filter').value.toLowerCase();
    
    currentFilter = {
        category: categoryFilter,
        compatibility: compatibilityFilter,
        search: searchFilter
    };
    
    const skinCards = document.querySelectorAll('.safa-skin-card');
    
    skinCards.forEach(card => {
        const category = card.dataset.category;
        const compatible = card.dataset.compatible;
        const name = card.dataset.name;
        
        let show = true;
        
        // Category filter
        if (categoryFilter && category !== categoryFilter) {
            show = false;
        }
        
        // Compatibility filter
        if (compatibilityFilter && compatible !== compatibilityFilter) {
            show = false;
        }
        
        // Search filter
        if (searchFilter && !name.includes(searchFilter)) {
            show = false;
        }
        
        card.style.display = show ? 'block' : 'none';
    });
    
    updateGalleryVisibility();
}

function updateGalleryVisibility() {
    const visibleCards = document.querySelectorAll('.safa-skin-card[style*="block"], .safa-skin-card:not([style*="none"])');
    const gallery = document.getElementById('skin-gallery');
    
    if (visibleCards.length === 0) {
        if (gallery) {
            gallery.innerHTML = `
                <div class="safa-gallery-empty">
                    <h3>🔍 No Results Found</h3>
                    <p>No skins match your current filters. Try adjusting your search criteria.</p>
                    <button class="safa-btn safa-btn--secondary" onclick="clearFilters()">
                        Clear Filters
                    </button>
                </div>
            `;
        }
    }
}

function clearFilters() {
    document.getElementById('category-filter').value = '';
    document.getElementById('compatibility-filter').value = '';
    document.getElementById('search-filter').value = '';
    filterSkins();
}

function switchSkin(skinName) {
    if (confirm(`Are you sure you want to switch to the ${skinName} skin?`)) {
        fetch('{{ path("admin.skins.switch") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': '{{ csrf_token() }}'
            },
            body: JSON.stringify({ skin_name: skinName })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred while switching skins');
        });
    }
}

function openLivePreview(skinName) {
    const previewModal = document.getElementById('live-preview');
    const previewContent = document.getElementById('preview-content');
    
    // Show loading
    previewContent.innerHTML = `
        <div class="safa-gallery-loading">
            <div class="safa-loading-spinner"></div>
            <p>Loading preview...</p>
        </div>
    `;
    
    previewModal.style.display = 'flex';
    
    // Load preview data
    fetch(`{{ path("admin.skins.preview") }}?skin=${skinName}`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                previewContent.innerHTML = `
                    <div style="text-align: center;">
                        <h3>${data.preview_data.skin.display_name} Preview</h3>
                        <p>${data.preview_data.skin.description}</p>
                        <div style="background: #F9FAFB; padding: 2rem; border-radius: 8px; margin: 1rem 0;">
                            <h4>Skin Information</h4>
                            <p><strong>Version:</strong> ${data.preview_data.skin.version}</p>
                            <p><strong>Author:</strong> ${data.preview_data.skin.author}</p>
                            <p><strong>CSS Files:</strong> ${data.preview_data.assets.css.length}</p>
                            <p><strong>JS Files:</strong> ${data.preview_data.assets.js.length}</p>
                        </div>
                        <button class="safa-btn safa-btn--primary" onclick="switchSkin('${skinName}')">
                            Activate This Skin
                        </button>
                    </div>
                `;
            } else {
                previewContent.innerHTML = `
                    <div style="text-align: center; color: #DC2626;">
                        <h3>Preview Error</h3>
                        <p>${data.message}</p>
                    </div>
                `;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            previewContent.innerHTML = `
                <div style="text-align: center; color: #DC2626;">
                    <h3>Preview Error</h3>
                    <p>Failed to load preview. Please try again.</p>
                </div>
            `;
        });
}

function closeLivePreview() {
    document.getElementById('live-preview').style.display = 'none';
}

function refreshGallery() {
    location.reload();
}

// Close preview when clicking outside
document.getElementById('live-preview').addEventListener('click', function(e) {
    if (e.target === this) {
        closeLivePreview();
    }
});

// Initialize filters
document.addEventListener('DOMContentLoaded', function() {
    filterSkins();
});
</script>
{% endblock %} 