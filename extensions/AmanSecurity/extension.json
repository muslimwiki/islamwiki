{
    "name": "AmanSecurity",
    "version": "0.0.1.0",
    "description": "Comprehensive authentication and security system for IslamWiki",
    "author": "IslamWiki Development Team",
    "license": "AGPL-3.0-only",
    "type": "security",
    "namespace": "IslamWiki\\Extensions\\AmanSecurity",
    "autoload": {
        "psr-4": {
            "IslamWiki\\Extensions\\AmanSecurity\\": ""
        }
    },
    "providers": [
        "IslamWiki\\Extensions\\AmanSecurity\\Providers\\AmanSecurityServiceProvider"
    ],
    "dependencies": {
        "php": ">=8.1",
        "islamwiki/core": ">=0.0.2.6"
    },
    "features": [
        "user_authentication",
        "user_registration",
        "session_management",
        "password_reset",
        "two_factor_auth",
        "permission_system",
        "security_logging"
    ],
    "config": {
        "session_timeout": 3600,
        "max_login_attempts": 5,
        "password_min_length": 8,
        "require_email_verification": true,
        "enable_two_factor": false
    }
} 