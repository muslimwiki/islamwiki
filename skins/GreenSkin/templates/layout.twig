<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}IslamWiki - Green Theme{% endblock %}</title>
    
    <!-- Green Theme CSS -->
    <link rel="stylesheet" href="/skins/GreenSkin/css/style.css">
    
    <!-- Google Fonts for Islamic Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Custom Green Theme Styles -->
    <style>
        :root {
            --green-primary: #2E7D32;
            --green-secondary: #4CAF50;
            --green-accent: #81C784;
            --green-light: #F1F8E9;
            --green-dark: #1B5E20;
        }
        
        body {
            background-color: var(--green-light);
            font-family: 'Amiri', 'Noto Naskh Arabic', serif;
        }
        
        .green-header {
            background: linear-gradient(135deg, var(--green-primary), var(--green-secondary));
            color: white;
            padding: 2rem 0;
            border-bottom: 3px solid var(--green-accent);
        }
        
        .green-navbar {
            background-color: var(--green-dark);
            border-bottom: 2px solid var(--green-accent);
        }
        
        .green-navbar .navbar-brand {
            color: var(--green-accent) !important;
            font-weight: 700;
        }
        
        .green-navbar .nav-link {
            color: white !important;
            transition: color 0.3s ease;
        }
        
        .green-navbar .nav-link:hover {
            color: var(--green-accent) !important;
        }
        
        .green-content {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 4px 20px rgba(46, 125, 50, 0.1);
            margin: 2rem 0;
            padding: 2rem;
            border-left: 5px solid var(--green-primary);
        }
        
        .green-footer {
            background: linear-gradient(135deg, var(--green-dark), var(--green-primary));
            color: white;
            padding: 2rem 0;
            margin-top: 3rem;
            border-top: 3px solid var(--green-accent);
        }
        
        .green-card {
            background: linear-gradient(135deg, white, var(--green-light));
            border: 2px solid var(--green-secondary);
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(46, 125, 50, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .green-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(46, 125, 50, 0.2);
        }
        
        .green-card-header {
            background: linear-gradient(135deg, var(--green-primary), var(--green-secondary));
            color: white;
            border-bottom: 2px solid var(--green-accent);
            border-radius: 13px 13px 0 0;
            padding: 1rem 1.5rem;
        }
        
        .green-btn {
            background-color: var(--green-secondary);
            border-color: var(--green-secondary);
            color: white;
            font-weight: 500;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        
        .green-btn:hover {
            background-color: var(--green-primary);
            border-color: var(--green-primary);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(46, 125, 50, 0.3);
            color: white;
        }
        
        .green-link {
            color: var(--green-primary);
            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        .green-link:hover {
            color: var(--green-dark);
            text-decoration: underline;
        }
        
        .green-form-control {
            border: 2px solid var(--green-secondary);
            border-radius: 8px;
            padding: 0.75rem;
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
        }
        
        .green-form-control:focus {
            border-color: var(--green-primary);
            box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25);
        }
        
        .green-alert {
            background-color: var(--green-light);
            border-color: var(--green-secondary);
            color: var(--green-dark);
            border-radius: 10px;
        }
        
        .green-badge {
            background-color: var(--green-accent);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 500;
        }
        
        .green-icon {
            color: var(--green-primary);
            font-size: 1.2rem;
        }
        
        .green-text {
            color: var(--green-dark);
        }
        
        .green-bg {
            background-color: var(--green-light);
        }
        
        .green-border {
            border-color: var(--green-secondary);
        }
        
        /* Islamic Calligraphy Background */
        .islamic-bg {
            background-image: 
                radial-gradient(circle at 20% 80%, var(--green-accent) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, var(--green-secondary) 0%, transparent 50%),
                radial-gradient(circle at 40% 40%, var(--green-primary) 0%, transparent 50%);
            opacity: 0.05;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
            z-index: -1;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            .green-content {
                padding: 1rem;
                margin: 1rem 0;
            }
            
            .green-header {
                padding: 1rem 0;
            }
        }
    </style>
    
    {% block styles %}{% endblock %}
</head>
<body class="green-theme">
    <!-- Islamic Background Pattern -->
    <div class="islamic-bg"></div>
    
    <!-- Header -->
    <header class="green-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="mb-0">
                        <i class="fas fa-mosque green-icon me-2"></i>
                        IslamWiki
                    </h1>
                    <p class="mb-0 mt-2 opacity-75">
                        <i class="fas fa-leaf green-icon me-1"></i>
                        Green Theme - Islamic Knowledge Platform
                    </p>
                </div>
                <div class="col-md-4 text-end">
                    <div class="green-badge">
                        <i class="fas fa-palette me-1"></i>
                        GreenSkin v1.0.0
                    </div>
                </div>
            </div>
        </div>
    </header>
    
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg green-navbar">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-mosque me-2"></i>
                IslamWiki
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="fas fa-home me-1"></i>
                            Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/pages">
                            <i class="fas fa-book me-1"></i>
                            Pages
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/quran">
                            <i class="fas fa-quran me-1"></i>
                            Quran
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/hadith">
                            <i class="fas fa-scroll me-1"></i>
                            Hadith
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/community">
                            <i class="fas fa-users me-1"></i>
                            Community
                        </a>
                    </li>
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="fas fa-tachometer-alt me-1"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/settings">
                            <i class="fas fa-cog me-1"></i>
                            Settings
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/profile">
                            <i class="fas fa-user me-1"></i>
                            Profile
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    
    <!-- Main Content -->
    <main class="green-content">
        <div class="container">
            {% block content %}
                <!-- Default content -->
                <div class="text-center py-5">
                    <i class="fas fa-leaf green-icon" style="font-size: 4rem;"></i>
                    <h2 class="green-text mt-3">Welcome to IslamWiki Green Theme</h2>
                    <p class="green-text">A beautiful green-themed interface for Islamic knowledge.</p>
                </div>
            {% endblock %}
        </div>
    </main>
    
    <!-- Footer -->
    <footer class="green-footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5 class="green-icon">
                        <i class="fas fa-mosque me-2"></i>
                        IslamWiki
                    </h5>
                    <p class="mb-0">
                        A comprehensive platform for Islamic knowledge, 
                        featuring the beautiful GreenSkin theme.
                    </p>
                </div>
                <div class="col-md-4">
                    <h5 class="green-icon">
                        <i class="fas fa-leaf me-2"></i>
                        Green Theme
                    </h5>
                    <p class="mb-0">
                        Beautiful green color scheme inspired by nature 
                        and Islamic aesthetics.
                    </p>
                </div>
                <div class="col-md-4">
                    <h5 class="green-icon">
                        <i class="fas fa-info-circle me-2"></i>
                        Quick Links
                    </h5>
                    <ul class="list-unstyled mb-0">
                        <li><a href="/about" class="green-link">About</a></li>
                        <li><a href="/help" class="green-link">Help</a></li>
                        <li><a href="/contact" class="green-link">Contact</a></li>
                    </ul>
                </div>
            </div>
            <hr class="my-4" style="border-color: var(--green-accent);">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0">
                        <i class="fas fa-copyright green-icon me-1"></i>
                        2025 IslamWiki. All rights reserved.
                    </p>
                </div>
                <div class="col-md-6 text-end">
                    <span class="green-badge">
                        <i class="fas fa-palette me-1"></i>
                        GreenSkin v1.0.0
                    </span>
                </div>
            </div>
        </div>
    </footer>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Green Theme JavaScript -->
    <script src="/skins/GreenSkin/js/script.js"></script>
    
    {% block scripts %}{% endblock %}
</body>
</html> 