<!-- Muslim Skin Sidebar Component -->
<aside class="muslim-sidebar">
    <div class="sidebar-content">
        <!-- Secondary Navigation -->
        <div class="sidebar-section">
            <h3 class="sidebar-title">Quick Actions</h3>
            <nav class="sidebar-nav">
                {% for item in navigation %}
                    <a href="{{ item.url }}" class="sidebar-link {{ is_current_page(item.url) ? 'active' : '' }}">
                        <span class="sidebar-icon">{{ item.icon }}</span>
                        <span class="sidebar-text">{{ item.label }}</span>
                    </a>
                {% endfor %}
            </nav>
        </div>
        
        <!-- Quick Links -->
        <div class="sidebar-section">
            <h3 class="sidebar-title">Quick Links</h3>
            <nav class="sidebar-nav">
                {% for item in quick_links %}
                    <a href="{{ item.url }}" class="sidebar-link {{ is_current_page(item.url) ? 'active' : '' }}">
                        <span class="sidebar-icon">{{ item.icon }}</span>
                        <span class="sidebar-text">{{ item.label }}</span>
                    </a>
                {% endfor %}
            </nav>
        </div>
        
        <!-- User-specific content -->
        {% if user %}
            <div class="sidebar-section">
                <h3 class="sidebar-title">Your Account</h3>
                <div class="user-info">
                    <div class="user-avatar">
                        <svg class="avatar-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </div>
                    <div class="user-details">
                        <p class="user-name">{{ user.username }}</p>
                        <p class="user-role">{{ user.is_admin ? 'Administrator' : 'Member' }}</p>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</aside> 