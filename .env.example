# Application
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:generate_a_secure_random_key_here
APP_URL=http://localhost

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=islamwiki
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Cache
CACHE_DRIVER=file

# Queue
QUEUE_CONNECTION=sync

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# File Storage
FILESYSTEM_DISK=local

# Security
HASH_DRIVER=bcrypt
PASSWORD_BCRYPT_ROUNDS=10

# API
API_PREFIX=api
API_VERSION=v1

# Debug
DEBUG_BAR_ENABLED=true
