# IslamWiki .gitignore
# Version: 0.0.52
# Date: 2025-08-09

# =============================================================================
# PHP & Composer
# =============================================================================

# Composer
/vendor/
composer.phar
composer.lock

# PHP
*.php~
*.php.bak
*.php.swp
*.php.swo

# =============================================================================
# Environment & Configuration
# =============================================================================

# Environment files
.env
.env.local
.env.production
.env.staging
.env.test

# Configuration files with sensitive data
config/database.php
config/app.php
# LocalSettings.php - Keep for development, but should be ignored in production
# Uncomment the line below for production environments:
# LocalSettings.php

# =============================================================================
# Sessions & Temporary Files
# =============================================================================

# Session files
storage/sessions/
storage/sessions/*
*.sess
sess_*

# Temporary files
*.tmp
*.temp
*.cache
*.log

# =============================================================================
# Cache & Compiled Files
# =============================================================================

# Cache directories
storage/cache/
storage/framework/cache/
var/cache/
cache/

# Compiled templates
storage/framework/views/
storage/framework/compiledViews/
var/views/

# =============================================================================
# Logs
# =============================================================================

# Log files
storage/logs/
logs/
*.log
php_errors.log
error_log

# Debug log files (created during development)
debug.log
debug_*.log
storage/logs/debug.log.bak

# =============================================================================
# Database
# =============================================================================

# Database files
*.sql
*.sqlite
*.db
database.sql
backup/

# =============================================================================
# IDE & Editor Files
# =============================================================================

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Editor files
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# OS Generated Files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# =============================================================================
# Uploads & User Content
# =============================================================================

# Upload directories
public/uploads/
uploads/
storage/app/public/
public/storage/

# User uploaded files
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.ico
*.pdf
*.doc
*.docx
*.xls
*.xlsx

# =============================================================================
# Testing & Development
# =============================================================================

# Test files (keep test scripts but ignore test data)
tests/data/
tests/tmp/
test-results/
coverage/

# Development files
*.dev.php
*.test.php
debug_*.php
test_*.php

# =============================================================================
# Security & Sensitive Files
# =============================================================================

# Private keys and certificates
*.key
*.pem
*.crt
*.p12
*.pfx

# Backup files
*.bak
*.backup
*.old
*.orig

# =============================================================================
# Node.js (if using frontend build tools)
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# =============================================================================
# Build & Distribution
# =============================================================================

# Build directories
build/
dist/
out/

# Package files
*.tar.gz
*.zip
*.rar

# =============================================================================
# IslamWiki Specific
# =============================================================================

# Session files (already covered above, but explicit)
storage/sessions/sess_*

# Debug files (keep organized debug scripts but ignore runtime debug files)
# Note: debug/ directory scripts are kept, but runtime debug files are ignored
debug_*.log
debug_*.tmp

# Temporary test files
test_*.tmp
debug_*.tmp

# User settings cache
storage/framework/cache/data/
storage/framework/cache/views/

# =============================================================================
# Skin System
# =============================================================================

# Keep all skin directories and files
# Skins are part of the application and should be version controlled
# skins/*/ - This is intentionally NOT ignored to keep all skins

# Skin-specific temporary files (if any)
skins/*/tmp/
skins/*/cache/
skins/*/*.tmp
skins/*/*.log

# =============================================================================
# Exceptions (Files to keep)
# =============================================================================

# Keep these files even if they match patterns above
!tests/
!debug/
!scripts/tests/
!docs/tests/

# Keep test scripts but ignore their output
!*.test.php
!*Test.php
!*_test.php

# Keep documentation
!docs/
!README.md
!CHANGELOG.md
!LICENSE.md

# Keep configuration templates
!config/*.example.php
!LocalSettings.example.php

# Keep all skin files and directories
!skins/
!skins/*/
!skins/*/*

# Generated files
storage/sessions/
storage/logs/
storage/cache/
/tmp/
*.log
/vendor/
node_modules/
# Local dev overrides
LocalSettings.php
